@model IEnumerable<VendorIndexViewModel>
@{
    ViewData["Title"] = "Subcontractor Center";

    // Optional dynamic payloads (so you can keep IEnumerable<> as the model)
    var sel = ViewBag.SelectedVendor as VendorDetailViewModel;
    var txns = ViewBag.Transactions as IEnumerable<VendorTxnViewModel>;
    var cash = ViewBag.CashInvoices as IEnumerable<CashInvoiceListViewModel>;
    }
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    .vendor-wrap {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 14px;
    }

    .list-header {
        background: #f8f9fb;
        border: 1px solid #e9ecef;
        border-radius: .5rem .5rem 0 0;
    }

    .vendor-list {
        border: 1px solid #e9ecef;
        border-top: 0;
        height: calc(100vh - 220px);
        overflow: auto;
    }

    .vendor-item {
        cursor: pointer;
        padding: .5rem .75rem;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
        justify-content: space-between;
        gap: .5rem;
    }

        .vendor-item.active, .vendor-item:hover {
            background: #eef4ff;
        }

    .amount {
        min-width: 90px;
        text-align: right;
        color: #198754;
    }

    .table thead th {
        background: #f1f3f5;
        font-weight: 600;
    }

    .sticky-head {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .key {
        width: 170px;
        color: #6c757d;
    }

    .value {
        font-weight: 500;
    }
</style>

<div class="container-fluid mt-3">
    <!-- Top Menu -->
    <div class="d-flex justify-content-between align-items-center bg-light p-2 border rounded">
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                    Subcontractor Operations
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-action="Create" asp-controller="Subcontractors">New Subcontractor</a></li>
                    @* <li><a class="dropdown-item" asp-action="Index" asp-controller="Subcontractors">Edit Subcontractor</a></li> *@
                </ul>
            </div>

            <div class="dropdown">
                <button class="btn btn-sm btn-outline-success dropdown-toggle" data-bs-toggle="dropdown">
                    New Transactions
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Purchase" asp-action="CreateInvoice">Purchase Invoice</a></li>
                    <li><a class="dropdown-item" asp-controller="Cash" asp-action="ReceivePayment">Receive Payment</a></li>
                </ul>
            </div>

            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                    Print
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Subcontractor List</a></li>
                    <li><a class="dropdown-item" href="#">Transaction List – Credit & Payment</a></li>
                    <li><a class="dropdown-item" href="#">Transaction List – Cash</a></li>
                </ul>
            </div>
        </div>

        <div class="input-group input-group-sm" style="max-width:360px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input id="txtSearch" class="form-control" placeholder="Search by Name, Code">
            <button class="btn btn-outline-secondary" id="btnClear"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>

    <div class="vendor-wrap mt-3">
        <!-- Left Panel: Subcontractor List -->
        <div>
            <div class="list-header p-2 rounded-top">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Active Subcontractor</span>
                    <span class="text-muted small">(@(Model?.Count() ?? 0))</span>
                </div>
            </div>

            <!-- FIX: id="vendorList" -->
            <div class="vendor-list bg-white" id="vendorList">
                <div class="d-flex fw-semibold px-3 py-2 border-bottom">
                    <div class="flex-grow-1">Name</div>
                    <div class="amount">Amount</div>
                </div>

                @if (Model?.Any() == true)
                    {
                    foreach (var v in Model)
                        {
                        var isActive = (sel?.Id == v.Id) ? "active" : "";
                        <!-- FIX: data-id with vendor id -->
                        <div class="text-decoration-none text-body vendor-item @isActive" data-id="@v.Id">
                            <span class="text-truncate flex-grow-1" title="@($"{v.Code} - {v.Name}")">
                                @v.Code - @v.Name
                            </span>
                            <span class="amount">@v.Amount.ToString("N3")</span>
                        </div>
                        }
                    }
                else
                    {
                    <div class="p-3 text-muted">No vendors found.</div>
                    }
            </div>
        </div>

        <!-- Right Panel: Subcontractor Info -->
        <div class="card shadow-sm">
            @*  <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Subcontractor Information</h6>
                @if (sel != null)
                    {
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-controller="Vendor" asp-route-id="@sel.Id">
                        <i class="bi bi-pencil"></i>
                    </a>
                    }
            </div> *@

            <div class="card-body">
                @*    @if (sel == null)
                    {
                    <div class="text-muted">Choose a vendor from the left to view details.</div>
                    }
                else
                    { *@
                <div class="col-12">
                    <div id="vendorHeader" class="mb-3">
                        <!-- filled by JS -->
                        <div class="placeholder-glow">
                            <span class="placeholder col-3"></span>
                            <span class="placeholder col-2"></span>
                            <span class="placeholder col-4"></span>
                        </div>
                    </div>

                    <ul class="nav nav-tabs" id="vendorTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="transactions-tab" data-bs-toggle="tab"
                                    data-bs-target="#transactions-pane" type="button" role="tab">
                                Transactions
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="cash-tab" data-bs-toggle="tab"
                                    data-bs-target="#cash-pane" type="button" role="tab">
                                Cash invoice
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content border-start border-end border-bottom p-2">
                        <div class="tab-pane fade show active" id="transactions-pane" role="tabpanel">
                            <div id="transactionsTable"></div>
                        </div>
                        <div class="tab-pane fade" id="cash-pane" role="tabpanel">
                            <div id="cashTable"></div>
                        </div>
                    </div>
                </div>
                @* } *@
            </div>
        </div>
    </div>
</div>

    @section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
          const $header = $('#vendorHeader');
          const $trx = $('#transactionsTable');
          const $cash = $('#cashTable');
          let currentVendorId = null;
          let isLoading = false;

          // Search
          $('#txtSearch').on('input', function(){
            const q = this.value.toLowerCase();
            $('#vendorList .vendor-item').each(function(){
              const t = $(this).text().toLowerCase();
              $(this).toggle(t.includes(q));
            });
          });
          $('#btnClear').on('click', function(){ $('#txtSearch').val('').trigger('input'); });

          // Delegated click on left rows (works for current/future rows)
          $(document).on('click', '#vendorList .vendor-item', async function () {
            if (isLoading) return;

            const id = Number($(this).data('id'));
            if (!id || id === currentVendorId) return;

            currentVendorId = id;
            $('#vendorList .vendor-item.active').removeClass('active');
            $(this).addClass('active');
            showLoading();

            try {
              const [hRes, tRes, cRes] = await Promise.all([
                fetch(`/Subcontractors/Header?id=${encodeURIComponent(id)}`, { headers:{ 'Accept':'application/json' } }),
                fetch(`/Subcontractors/Transactions?vendorId=${encodeURIComponent(id)}`, { headers:{ 'Accept':'application/json' } }),
                fetch(`/Subcontractors/Cash?vendorId=${encodeURIComponent(id)}`, { headers:{ 'Accept':'application/json' } })
              ]);
              if (!hRes.ok || !tRes.ok || !cRes.ok) throw new Error('Load failed');

              const [header, rowsTrx, rowsCash] = await Promise.all([hRes.json(), tRes.json(), cRes.json()]);
              renderHeader(header);
              renderTransactions(rowsTrx || []);
              // supports either array or { rows: [...] }
              renderCash(Array.isArray(rowsCash) ? rowsCash : (rowsCash?.rows || []));
            } catch (e) {
              console.error(e);
              $header.html(`<div class="text-danger">Failed to load Subcontractors data.</div>`);
              $trx.empty(); $cash.empty();
            } finally {
              hideLoading();
            }
          });

          function showLoading(){
            isLoading = true;
            $header.html(`<div class="spinner-border spinner-border-sm me-2"></div> Loading vendor...`);
            $trx.html(`<div class="text-muted">Loading transactions...</div>`);
            $cash.html(`<div class="text-muted">Loading cash invoices...</div>`);
          }
          function hideLoading(){ isLoading = false; }

          function renderHeader(h){
            const safe = s => (s ?? '-');
            const num = n => (Number(n) || 0).toLocaleString(undefined, { minimumFractionDigits:3, maximumFractionDigits:3 });

            $header.html(`
              <div class="row g-2">
                <div class="col-3"><strong>Vendor Code</strong><div>${safe(h.code)}</div></div>
                <div class="col-5"><strong>Vendor Name</strong><div>${safe(h.name)}</div></div>
                <div class="col-2"><strong>TRN</strong><div>${safe(h.trn)}</div></div>
                <div class="col-2"><strong>Balance</strong><div>${num(h.balance)}</div></div>

                <div class="col-3"><strong>Work Phone</strong><div>${safe(h.workPhone)}</div></div>
                <div class="col-3"><strong>Main Phone</strong><div>${safe(h.mainPhone)}</div></div>
                <div class="col-3"><strong>Vendor Category</strong><div>${safe(h.category)}</div></div>
                <div class="col-3"><strong>Region</strong><div>${safe(h.region)}</div></div>

                <div class="col-6"><strong>Email</strong><div>${safe(h.email)}</div></div>
                <div class="col-6"><strong>Address</strong><div class="text-truncate">${safe(h.address)}</div></div>
              </div>
            `);
          }

          function renderTransactions(rows){
            if (!rows.length) { $trx.html(`<div class="text-muted">No transactions.</div>`); return; }
            let i = 0;
            const html = [
              `<div class="table-responsive"><table class="table table-sm table-striped align-middle">
                <thead><tr>
                  <th>SN#</th><th>Date</th><th>Voucher No</th><th>Voucher Type</th>
                  <th>Description</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th class="text-end">Balance</th>
                </tr></thead><tbody>`
            ];
            for (const r of rows){
              html.push(`<tr>
                <td>${++i}</td>
                <td>${fmtDate(r.date)}</td>
                <td>${safe(r.voucherNo)}</td>
                <td>${safe(r.voucherType)}</td>
                <td>${safe(r.description)}</td>
                <td class="text-end">${fmtAmt(r.debit)}</td>
                <td class="text-end">${fmtAmt(r.credit)}</td>
                <td class="text-end">${fmtAmt(r.balance)}</td>
              </tr>`);
            }
            html.push(`</tbody></table></div>`);
            $trx.html(html.join(''));
          }

          function renderCash(rows){
            if (!rows.length) { $cash.html(`<div class="text-muted">No cash invoices.</div>`); return; }
            let i = 0, total = 0;
            const body = rows.map(r => {
              const amt = Number(r.amount) || 0;
              total += amt;
              return `<tr>
                <td>${++i}</td>
                <td>${safe(r.voucherNo)}</td>
                <td>${fmtDate(r.date)}</td>
                <td>${safe(r.accountName)}</td>
                <td>${safe(r.voucherType)}</td>
                <td class="text-end">${fmtAmt(amt)}</td>
              </tr>`;
            }).join('');

            $cash.html(`
              <div class="table-responsive"><table class="table table-sm table-striped align-middle">
                <thead><tr>
                  <th>Sn</th><th>V - No</th><th>Date</th><th>Account Name</th><th>Type</th><th class="text-end">Amount</th>
                </tr></thead>
                <tbody>${body}</tbody>
                <tfoot><tr>
                  <th colspan="5" class="text-end">Total</th>
                  <th class="text-end">${fmtAmt(total)}</th>
                </tr></tfoot>
              </table></div>
            `);
          }

          // utils
          function safe(v){ return (v ?? ''); }
          function fmtAmt(n){ return (Number(n)||0).toLocaleString(undefined,{minimumFractionDigits:3,maximumFractionDigits:3}); }
          function fmtDate(d){
            if(!d) return '';
            const dt = (typeof d === 'string' || d instanceof String) ? new Date(d) : d;
            if(Number.isNaN(dt.getTime())) return '';
            return dt.toLocaleDateString();
          }

          // Auto-select first vendor on load
          $(function(){
            const $first = $('#vendorList .vendor-item:first');
            if($first.length) $first.trigger('click');
          });
        })();
    </script>
    }
