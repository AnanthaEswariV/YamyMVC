@model IEnumerable<VendorIndexViewModel>

@{
    ViewData["Title"] = "Subcontractor Center";
    }

<style>
    .vendor-wrap {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 14px;
    }

    .list-header {
        background: #f8f9fb;
        border: 1px solid #e9ecef;
        border-radius: .5rem .5rem 0 0;
    }

    .vendor-list {
        border: 1px solid #e9ecef;
        border-top: 0;
        height: calc(100vh - 220px);
        overflow: auto;
    }

    .vendor-item {
        cursor: pointer;
        padding: .5rem .75rem;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
        justify-content: space-between;
        gap: .5rem;
    }

        .vendor-item.active,
        .vendor-item:hover {
            background: #eef4ff;
        }

    .amount {
        min-width: 90px;
        text-align: right;
        color: #198754;
    }

    .table thead th {
        background: #f1f3f5;
        font-weight: 600;
    }

    .sticky-head {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .key {
        width: 170px;
        color: #6c757d;
    }

    .value {
        font-weight: 500;
    }
</style>

<div class="container-fluid mt-3">
    <!-- Top Menu -->
    <div class="d-flex justify-content-between align-items-center bg-light p-2 border rounded">
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button type="button"
                        class="btn btn-sm btn-outline-primary"
                        id="btnNewSubcontractor">
                    New Subcontractor
                </button>

                <!-- host for create/edit modal -->
                <div id="subContractModalHost"></div>
            </div>
        </div>

        <div class="input-group input-group-sm" style="max-width:360px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input id="txtSearch" class="form-control" placeholder="Search by Name, Code" />
            <button class="btn btn-outline-secondary" id="btnClear">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>

    <div class="vendor-wrap mt-3">
        <!-- Left Panel: Subcontractor List -->
        <div>
            <div class="list-header p-2 rounded-top">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Active Subcontractor</span>
                    <span class="text-muted small">(@(Model?.Count() ?? 0))</span>
                </div>
            </div>

            <div class="vendor-list bg-white" id="vendorList">
                <div class="d-flex fw-semibold px-3 py-2 border-bottom">
                    <div class="flex-grow-1">Name</div>
                    <div class="amount">Amount</div>
                </div>

                @if (Model?.Any() == true)
                    {
                    foreach (var v in Model)
                        {
                        <div class="text-decoration-none text-body vendor-item" data-id="@v.Id">
                            <span class="text-truncate flex-grow-1" title="@($"{v.Code} - {v.Name}")">
                                @v.Code - @v.Name
                            </span>
                            <span class="amount">@v.Amount.ToString("N3")</span>
                        </div>
                        }
                    }
                else
                    {
                    <div class="p-3 text-muted">No vendors found.</div>
                    }
            </div>
        </div>

        <!-- Right Panel: Subcontractor Info -->
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="col-12">
                    <div id="vendorHeader" class="mb-3">
                        <!-- placeholder until first vendor loads -->
                        <div class="placeholder-glow">
                            <span class="placeholder col-3"></span>
                            <span class="placeholder col-2"></span>
                            <span class="placeholder col-4"></span>
                        </div>
                    </div>

                    <ul class="nav nav-tabs" id="vendorTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="transactions-tab" data-bs-toggle="tab"
                                    data-bs-target="#transactions-pane" type="button" role="tab">
                                Transactions
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="cash-tab" data-bs-toggle="tab"
                                    data-bs-target="#cash-pane" type="button" role="tab">
                                Cash invoice
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content border-start border-end border-bottom p-2">
                        <div class="tab-pane fade show active" id="transactions-pane" role="tabpanel">
                            <div id="transactionsTable"></div>
                        </div>
                        <div class="tab-pane fade" id="cash-pane" role="tabpanel">
                            <div id="cashTable"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    @section Scripts {
    <script>
        (function () {
            const $header = $('#vendorHeader');
            const $trx = $('#transactionsTable');
            const $cash = $('#cashTable');

            // MVC URLs (no hard-coded paths)
            const headerUrl = '@Url.Action("Header", "Subcontractors")';
            const trxUrl = '@Url.Action("Transactions", "Subcontractors")';
            const cashUrl = '@Url.Action("Cash", "Subcontractors")';

            let currentVendorId = null;
            let isLoading = false;

            // Search
            $('#txtSearch').on('input', function () {
                const q = this.value.toLowerCase();
                $('#vendorList .vendor-item').each(function () {
                    const t = $(this).text().toLowerCase();
                    $(this).toggle(t.includes(q));
                });
            });

            $('#btnClear').on('click', function () {
                $('#txtSearch').val('').trigger('input');
            });

            // Click on left vendor rows
            $(document).on('click', '#vendorList .vendor-item', async function () {
                if (isLoading) return;

                const id = Number($(this).data('id'));
                if (!id || id === currentVendorId) return;

                currentVendorId = id;
                $('#vendorList .vendor-item.active').removeClass('active');
                $(this).addClass('active');
                showLoading();

                try {
                    const [hRes, tRes, cRes] = await Promise.all([
                        fetch(`${headerUrl}?id=${encodeURIComponent(id)}`, { headers: { 'Accept': 'application/json' } }),
                        fetch(`${trxUrl}?vendorId=${encodeURIComponent(id)}`, { headers: { 'Accept': 'application/json' } }),
                        fetch(`${cashUrl}?vendorId=${encodeURIComponent(id)}`, { headers: { 'Accept': 'application/json' } })
                    ]);

                    if (!hRes.ok || !tRes.ok || !cRes.ok) throw new Error('Load failed');

                    const [header, rowsTrx, rowsCash] = await Promise.all([
                        hRes.json(),
                        tRes.json(),
                        cRes.json()
                    ]);

                    renderHeader(header);
                    renderTransactions(rowsTrx || []);
                    renderCash(Array.isArray(rowsCash) ? rowsCash : (rowsCash?.rows || []));
                } catch (e) {
                    console.error(e);
                    $header.html(`<div class="text-danger">Failed to load subcontractor data.</div>`);
                    $trx.empty();
                    $cash.empty();
                } finally {
                    hideLoading();
                }
            });

            function showLoading() {
                isLoading = true;
                $header.html(`<div class="spinner-border spinner-border-sm me-2"></div> Loading subcontractor...`);
                $trx.html(`<div class="text-muted">Loading transactions...</div>`);
                $cash.html(`<div class="text-muted">Loading cash invoices...</div>`);
            }

            function hideLoading() {
                isLoading = false;
            }

            function renderHeader(h) {
                const safe = s => (s ?? '-');

                $header.html(`
                    <!-- Title + Edit button -->
                    <div class="d-flex justify-content-between align-items-center mb-2 pb-1 border-bottom">
                        <h5 class="mb-0 fw-semibold">Subcontractor Information</h5>

                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                id="btnEditSubcontractor"
                                data-id="${h.id}"
                                title="Edit subcontractor">
                            <i class="bi bi-pencil"></i>
                        </button>
                    </div>

                    <!-- Details -->
                    <div class="row small">
                        <!-- Left column -->
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted pe-3">Subcontractor Code</td>
                                        <td class="fw-semibold">${safe(h.code)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Subcontractor Name</td>
                                        <td class="fw-semibold">${safe(h.name)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">TRN</td>
                                        <td>${safe(h.trn)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Email</td>
                                        <td>${safe(h.email)}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Right column -->
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted pe-3">Work Phone</td>
                                        <td>${safe(h.workPhone)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Main Phone</td>
                                        <td>${safe(h.mainPhone)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Subcontractor Category</td>
                                        <td>${safe(h.category)}</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Address</td>
                                        <td class="text-truncate">${safe(h.address)}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                `);
            }

            function renderTransactions(rows) {
                if (!rows || !rows.length) {
                    $trx.html(`<div class="text-muted">No transactions.</div>`);
                    return;
                }

                let i = 0;
                const html = [
                    `<div class="table-responsive"><table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>SN#</th>
                                <th>Date</th>
                                <th>Voucher No</th>
                                <th>Voucher Type</th>
                                <th>Description</th>
                                <th class="text-end">Debit</th>
                                <th class="text-end">Credit</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>`
                ];

               for (const r of rows) {
                    const rawDate = r.date
                        ? (typeof r.date === 'string'
                            ? r.date.split('T')[0]
                            : r.date.toISOString().split('T')[0])
                        : '';

                    html.push(`<tr class="txn-row"
                    data-type="${safe(r.voucherType)}"
                    data-form="${safe(r.voucherType)}"
                    data-invoice-id="${r.invoiceId}"
                    data-vendor-id="${r.id}"
                    data-date="${rawDate}">
                        <td>${++i}</td>
                        <td>${fmtDate(r.date)}</td>
                        <td>${safe(r.voucherNo)}</td>
                        <td>${safe(r.voucherType)}</td>
                        <td>${safe(r.description)}</td>
                        <td class="text-end">${fmtAmt(r.debit)}</td>
                        <td class="text-end">${fmtAmt(r.credit)}</td>
                        <td class="text-end">${fmtAmt(r.balance)}</td>
                    </tr>`);
                }

                html.push(`</tbody></table></div>`);
                $trx.html(html.join(''));
            }

            function renderCash(rows) {
                if (!rows || !rows.length) {
                    $cash.html(`<div class="text-muted">No cash invoices.</div>`);
                    return;
                }

                let i = 0, total = 0;
                const body = rows.map(r => {
                    const amt = Number(r.amount) || 0;
                    total += amt;
                    return `<tr>
                        <td>${++i}</td>
                        <td>${safe(r.voucherNo)}</td>
                        <td>${fmtDate(r.date)}</td>
                        <td>${safe(r.accountName)}</td>
                        <td>${safe(r.voucherType)}</td>
                        <td class="text-end">${fmtAmt(amt)}</td>
                    </tr>`;
                }).join('');

                $cash.html(`
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Sn</th>
                                    <th>V - No</th>
                                    <th>Date</th>
                                    <th>Account Name</th>
                                    <th>Type</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>${body}</tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="5" class="text-end">Total</th>
                                    <th class="text-end">${fmtAmt(total)}</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                `);
            }

            // shared helpers
            function safe(v) { return (v ?? ''); }

            function fmtAmt(n) {
                return (Number(n) || 0)
                    .toLocaleString(undefined, { minimumFractionDigits: 3, maximumFractionDigits: 3 });
            }

            function fmtDate(d) {
                if (!d) return '';
                const dt = (typeof d === 'string' || d instanceof String) ? new Date(d) : d;
                if (Number.isNaN(dt.getTime())) return '';
                return dt.toLocaleDateString();
            }

            // Auto-select first vendor on load
            $(function () {
                const $first = $('#vendorList .vendor-item:first');
                if ($first.length) $first.trigger('click');
            });
        })();
    </script>
    <script>
        $(function () {
            // NEW SUBCONTRACTOR
            $('#btnNewSubcontractor').on('click', function (e) {
                e.preventDefault();

                $.get('@Url.Action("Create", "Subcontractors")')
                    .done(function (html) {
                        // Put the partial view (your modal) into a host div
                        $('#subContractModalHost').html(html);

                        // Find the modal element
                        var modalEl = document.getElementById('subContractModal');

                        if (!modalEl) {
                            console.error('#subContractModal not found in returned HTML');
                            return;
                        }

                        // Works with Bootstrap 5 (any minor version)
                        // Try to get instance, otherwise create a new one
                        var modal = bootstrap.Modal.getInstance(modalEl);
                        if (!modal) {
                            modal = new bootstrap.Modal(modalEl);
                        }

                        modal.show();
                    })
                    .fail(function (xhr, status, error) {
                        console.error('Error loading Create Subcontractor modal:', status, error);
                        console.error(xhr.responseText);
                    });
            });

            // EDIT SUBCONTRACTOR
            $(document).on('click', '#btnEditSubcontractor', function (e) {
                e.preventDefault();

                var id = $(this).data('id');
                if (!id) return;

                $.get('@Url.Action("Edit", "Subcontractors")', { id: id })
                    .done(function (html) {
                        $('#subContractModalHost').html(html);

                        var modalEl = document.getElementById('subContractModal');
                        if (!modalEl) {
                            console.error('#subContractModal not found in Edit HTML');
                            return;
                        }

                        var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                        modal.show();
                    })
                    .fail(function (xhr, status, error) {
                        console.error('Error loading Edit Subcontractor modal:', status, error);
                        console.error(xhr.responseText);
                    });
            });
        });
    </script>
    <script>
        $(document).on('dblclick', '#transactionsTable .txn-row', function () {
                const formNameRaw = $(this).data('form');
                const type        = $(this).data('type');
                const invoiceId   = $(this).data('invoiceId');
