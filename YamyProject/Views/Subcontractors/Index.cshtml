                        '@Url.Action("Edit", "PurchasesCenter")' + '?id=' + invoiceId;
                }
                else if (formName.includes('purchase return')) {
                    window.location.href =
                        '@Url.Action("Edit", "PurchasesReturn")' + '?id=' + invoiceId;
                }
                else if (formName.includes('Subcontractor payment')) {
                    window.location.href =
                        '@Url.Action("GetVendorInvoiceRowsAsync", "ReceiveVoucher")'
                        + '?vendorId=' + vendorId;
                }
                else if (formName.includes('advance payment')) {
                    window.location.href =
                        '@Url.Action("Details", "AdvancePayments")'
                        + '?id=' + invoiceId + '&vendorId=' + vendorId;
                }
                else if (formName.includes('Subcontractor opening balance')) {                   
