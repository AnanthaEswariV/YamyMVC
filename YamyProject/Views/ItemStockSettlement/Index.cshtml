@model IEnumerable<ItemStockSettlementListVm>

@{
    ViewData["Title"] = "Inventory - Stock Management";
}

<div class="container-fluid bg-light p-3 rounded shadow-sm">

    <a  class="btn btn-sm btn-primary js-render-modal"  asp-action="Create">
        <i class="bi bi-plus-circle-dotted"></i>
        New Settlement
    </a>

@*     <a href="javascript:;" class="btn btn-sm btn-primary js-render-modal"
       data-title="Add Company" data-url="/CompanyCenter/Create">
        <i class="bi bi-plus-square-dotted"></i>
        Add
    </a> *@
