@model IEnumerable<ItemStockSettlementListVm>

@{
    ViewData["Title"] = "Inventory - Stock Management";
    }

<div class="container-fluid bg-light p-3 rounded shadow-sm">

    <a class="btn btn-sm btn-primary js-render-modal" asp-action="Create">
        <i class="fa fa-plus"></i>
        New Settlement
    </a>

    <!-- Filter Section -->
    <div class="mt-4"></div><div class="mt-4"></div><div class="mt-4"></div>

    <form class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="FromDate" class="form-label">Start Date</label>
            <input type="date" id="FromDate" name="FromDate" class="form-control" />
        </div>

        <div class="col-md-3">
            <label for="ToDate" class="form-label">End Date</label>
            <input type="date" id="ToDate" name="ToDate" class="form-control" />
        </div>

        <div class="col-md-2 d-flex align-items-center">
            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" id="All" name="All" checked />
                <label class="form-check-label" for="All">All</label>
            </div>
        </div>

        <div class="col-md-3">
            <label for="SelectionMethod" class="form-label">Selection Method</label>
            <select id="SelectionMethod" name="SelectionMethod" class="form-select">
                <option value="Default">Default</option>
                <option value="ItemWise">Item Wise</option>
            </select>
        </div>

        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100" asp-action="List">Filter</button>
        </div>
    </form>

    <!-- First table: Settlements -->
    <div class="table-responsive mt-4">
        @if (Model != null)
            {
            <table id="settlementTable"
                   class="table table-bordered table-striped table-hover text-center align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>Sn</th>
                        <th>Date</th>
                        <th>JV No</th>
                        <th>INV NO</th>
                        <th>Edit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                        {
                        <tr class="settlement-row" data-id="@item.Id">
                            <td>@item.Id</td>
                            <td>@item.Date?.ToString("d")</td>
                            <td>@item.JvNo</td>
                            <td>@item.Code</td>
                            <td>
                                <a class="menu-link px-3 js-render-modal"
                                   asp-controller="ItemStockSettlement"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id">
                                    Edit
                                </a>
                            </td>
                        </tr>
                        }
                </tbody>
            </table>
            }
    </div>

    <!-- Second table: Items of selected settlement -->
    <div class="mt-4">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-semibold small">Item Name</span>
            <span id="selectedItemName" class="small text-primary"></span>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-sm table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Item</th>
                        <th class="text-end">QTY</th>
                        <th class="text-end">Cost Price</th>
                        <th class="text-end">New on hand</th>
                    </tr>
                </thead>
                <tbody id="itemsTableBody">
                    <tr>
                        <td colspan="4" class="text-muted text-center">
                            Select a settlement from the list above to see its items.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

    @section Scripts {
    <script>
        $(function () {
            // Template URL for Details action (adjust controller name if needed)
            // This will produce something like "/Stock/Details/__id__"
            
            var detailsUrlTemplate = '@Url.Action("Details", "ItemStockSettlement")';

            // click on settlement row
            $(document).on('click', '.settlement-row', function () {
                var id = $(this).data('id');
                if (!id) return;

                // highlight selected row
                $('.settlement-row').removeClass('table-active');
                $(this).addClass('table-active');

                loadSettlementDetails(id);
            });

            function getProp(obj) {
                for (var i = 1; i < arguments.length; i++) {
                    var name = arguments[i];
                    if (obj[name] !== undefined && obj[name] !== null)
                        return obj[name];
                }
                return null;
            }

            function formatNumber(value) {
                if (value === null || value === undefined || value === '') return '';
                return Number(value).toLocaleString(undefined, {
                    minimumFractionDigits: 3,
                    maximumFractionDigits: 3
                });
            }

            function loadSettlementDetails(id) {
                var url = detailsUrlTemplate.replace("id", id);

                $.ajax({
                    url: url,
                    type: 'GET',
                     data: { id: id },
                    success: function (result) {
                        var items = result.items || result.Items || [];
                        var $tbody = $('#itemsTableBody');
                        $tbody.empty();

                        if (!items.length) {
                            $tbody.append(
                                '<tr><td colspan="4" class="text-muted text-center">No items found.</td></tr>');
                            $('#selectedItemName').text('');
                            return;
                        }

                        // show name of first item in header line
                        var first = items[0];
                        var firstCode = getProp(first, 'itemCode', 'ItemCode') || '';
                        var firstName = getProp(first, 'itemName', 'ItemName') || '';
                        $('#selectedItemName').text(firstCode + ' - ' + firstName);

                        $.each(items, function (i, it) {
                            var itemCode = getProp(it, 'itemCode', 'ItemCode') || '';
                            var itemName = getProp(it, 'itemName', 'ItemName') || '';
                            var onHand = getProp(it, 'onHand', 'OnHand');     // used as Qty
                            var price = getProp(it, 'price', 'Price');
                            var newOnHand = getProp(it, 'newOnHand', 'NewOnHand');

                            var rowHtml =
                                '<tr>' +
                                    '<td>' + (itemCode ? itemCode + ' - ' : '') + itemName + '</td>' +
                                    '<td class="text-end">' + formatNumber(onHand) + '</td>' +
                                    '<td class="text-end">' + formatNumber(price) + '</td>' +
                                    '<td class="text-end">' + formatNumber(newOnHand) + '</td>' +
                                '</tr>';

                            $tbody.append(rowHtml);
                        });
                    },
                    error: function () {
                        alert('Failed to load settlement items.');
                    }
                });
            }
        });
    </script>
    }
