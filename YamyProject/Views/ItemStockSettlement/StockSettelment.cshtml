
@model CreateUpdateSettlementVm

@{    
    var isEdit = Model?.Id > 0;  // example logic
    ViewData["Title"] = $" Stock Settlement - {(Model?.Id > 0 ? "Edit" : "Create")}";
}
<div class="container-fluid ">
    <div class="card shadow">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5>@ViewData["Title"]</h5>
        </div>
        <div class="card-body">
            <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Date" class="form-label">Date</label>
                            <input asp-for="Date" type="date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                        <label asp-for="WarehouseId"></label>
                                <div class="form-floating mb-2">
                                    <select class="form-select form-select-solid js-select2"
                                            data-placeholder="Select an author"
                                            asp-for="WarehouseId"
                                            asp-items="@(new SelectList(Model.WarehousesVm, "Id", "Name"))">
                                <option value="">Select an Warehouse</option>
                                    </select>
                                </div>
                                <span asp-validation-for="WarehouseId" class="text-danger d-block"></span>
                            </div>
                        <div class="col mb-3 ">
                            @* <div class="text-center mt-2"></div> *@
                            <div class="col-md-4 d-flex">
                                <div>Previous </div>
                                <div>Next</div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end justify-content-end">
                                  @* <label>Previous</label> *@
                                  <div class="btn-group"> 
                                      <button type="button" class="btn btn-outline-primary">&lt;&lt;</button>
                                      <input type="text" value="@Model.Code" readonly class="form-control text-center" style="max-width:120px" />
                                      <button type="button" class="btn btn-outline-primary">&gt;&gt;</button>
                                  </div>
                                  @* <label>Next</label> *@
                            </div>
                        </div>
                </div>
                <div class="table-responsive mt-4">

                <table class="table table-bordered table-sm align-middle" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Item Code</th>
                            <th>Item Name</th>
                            <th>SYS QTY</th>
                            <th>Price</th>
                            <th>SYS Amount</th>
                            <th>New QTY</th>
                            <th>QTY DIF</th>
                            <th>Amount (-)</th>
                            <th>Amount (+)</th>
                            <th>DEL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                                int index = 1;
                                foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td><input type="text" asp-for="@item.ItemId"></td>
                                        <td><input type="text" asp-for="@item.ItemName"></td>
                                        @* Example for item name if needed:
                                        <td><input type="text" value="@item.Name" class="form-control" /></td> *@
                                        <td>@item.OnHand</td>
                                        <td>@item.Price</td>
                                        <td>@(item.OnHand* item.Price)</td>
                                        <td><input type="text" asp-for="@item.NewOnHand"></td>
                                        <td>@(item.NewOnHand - item.OnHand)</td>
                                        <td>@item.MinusAmount</td>
                                        <td>@item.PlusAmount</td>
                                        <td class="text-center">
                                        <a calss=" btn btn-danger">REMOVE</a>
                                        </td>
                                       
                                    </tr>
                                    index++;
                                }
                        }
                        else
                        {
                            <tr>
                                <td>1</td>
                                <td>
                                        <input list="itemOptions0" id="itemInput0" placeholder="Type or select..." class="form-control itemCode"
                                        oninput="updateNameFromInput(this, 0)">
                                        <datalist id="itemOptions0"></datalist>
                                    </td>
                            @*     <td>
                                        <input list="itemOptions1" id="itemInput1" placeholder="Type or select..." class="form-control itemName"
                                        oninput="updateNameFromInput(this, 0)">
                                        <datalist id="itemOptions1"></datalist>
                                    </td> *@
                                    @* <td><input type="text" name="Items[0].NewOnHand" class="form-control itemSearchCode" /></td> *@
                                    <td><input type="text" name="Items[0].NewOnHand" class="form-control itemSearchName" /></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td><input type="text" name="Items[0].NewOnHand" class="form-control" /> </td>
                                <td></td>
                                <td></td>
                                <td></td>
                                    <td class="text-center"><a calss=" btn btn-danger">REMOVE</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                <div class="row justify-content-end">
                    <div class="col-md-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Amount (-)</span>
                            <input type="text" class="form-control" value="@Model.Items.Sum(x => x.MinusAmount)" readonly />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Amount (+)</span>
                            <input type="text" class="form-control" value="@Model.Items.Sum(x => x.PlusAmount)" readonly />
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="submit" class="btn btn-primary" formaction="@(Url.Action(isEdit ? "Edit" : "Create"))">Save &amp; New</button>
                    <a asp-action="Index" class="btn btn-secondary">Close</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script src="~/assets/js/stocksettelment.js"></script>
    <script>
        $(function () {
            $('#itemsTable').on('click', '.remove-row', function () {
                $(this).closest('tr').remove();
            });

            // Auto calculate QTY DIF and amounts
            $('#itemsTable').on('input', '.number-input', function () {
                var $row = $(this).closest('tr');
                var onHand = parseFloat($row.find('input[name$=".OnHand"]').val()) || 0;
                var price = parseFloat($row.find('input[name$=".Price"]').val()) || 0;
                var newQty = parseFloat($row.find('input[name$=".NewOnHand"]').val()) || 0;

                var sysAmt = onHand * price;
                var diff = newQty - onHand;
                var minusAmt = diff < 0 ? Math.abs(diff) * price : 0;
                var plusAmt = diff > 0 ? diff * price : 0;

                $row.find('input[name$=".SysAmount"]').val(sysAmt.toFixed(2));
                $row.find('input[name$=".QtyDiff"]').val(diff.toFixed(2));
                $row.find('input[name$=".MinusAmount"]').val(minusAmt.toFixed(2));
                $row.find('input[name$=".PlusAmount"]').val(plusAmt.toFixed(2));
            });
        });
    </script>
}
