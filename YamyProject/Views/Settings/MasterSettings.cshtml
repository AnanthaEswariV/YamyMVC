@{
    ViewData["Title"] = "Setting - Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<div class="bg-primary text-white p-3 mb-3" style="font-size:small;">
    <i class="bi bi-gear-fill me-2"></i> Settings - Master
</div>

<div class="container">

    <!-- MAIN BUTTON -->
    <button class="btn btn-dark btn-sm mb-3" onclick="showSubButtons()">Default Account Config</button>

    <!-- SUB BUTTONS -->
    <div id="subButtons" class="mb-3" style="display:none;">
        <button class="btn btn-primary btn-sm me-1 mb-1" onclick="showSection('commonSection', this)">Common</button>
        <button class="btn btn-outline-primary btn-sm me-1 mb-1" onclick="showSection('vendorSection', this)">Vendor - Purchase</button>
        <button class="btn btn-outline-primary btn-sm me-1 mb-1" onclick="showSection('inventorySection', this)">Inventory</button>
        <button class="btn btn-outline-primary btn-sm me-1 mb-1" onclick="showSection('customerSection', this)">Customer - Sales</button>
        <button class="btn btn-outline-primary btn-sm me-1 mb-1" onclick="showSection('employeeSection', this)">Employee</button>
        <button class="btn btn-outline-primary btn-sm me-1 mb-1" onclick="showSection('bankSection', this)">Bank</button>
    </div>

    <!-- COMMON SECTION -->
    <div id="commonSection" class="card section mb-3" style="display:none;">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <label class="form-label">PDC Receivable</label>
                    <select id="PDCReceivable" class="form-select mb-3"></select>

                    <label class="form-label">PDC Receivable Return</label>
                    <select id="PDCReceivableReturn" class="form-select mb-3"></select>

                    <label class="form-label">PDC Receivable Hold</label>
                    <select id="PDCReceivableHold" class="form-select mb-3"></select>

                    <label class="form-label">PDC Payable</label>
                    <select id="PDCPayable" class="form-select mb-3"></select>

                    <label class="form-label">PDC Payable Return</label>
                    <select id="PDCPayableReturn" class="form-select mb-3"></select>

                    <label class="form-label">PDC Payable Hold</label>
                    <select id="PDCPayableHold" class="form-select mb-3"></select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Default Account For Cash</label>
                    <select id="DefaultAccountCash" class="form-select mb-3"></select>

                    <label class="form-label">Opening Balance</label>
                    <select id="OpeningBalance" class="form-select mb-3"></select>

                    <label class="form-label">Opening Balance Equity</label>
                    <select id="OpeningBalanceEquity" class="form-select mb-3"></select>

                    <label class="form-label">Prepaid Expense Debit Account</label>
                    <select id="PrepaidExpenseDebit" class="form-select mb-3"></select>

                    <label class="form-label">Prepaid Expense Credit Account</label>
                    <select id="PrepaidExpenseCredit" class="form-select mb-3"></select>

                    <label class="form-label">Fixed Asset Debit Account</label>
                    <select id="FixedAssetDebit" class="form-select mb-3"></select>

                    <label class="form-label">Fixed Asset Credit Account</label>
                    <select id="FixedAssetCredit" class="form-select mb-3"></select>
                </div>
            </div>
        </div>
    </div>

    <!-- VENDOR SECTION -->
    <div id="vendorSection" class="card section mb-3" style="display:none;">
        <div class="card-body row">
            <div class="col-md-6">
                <label class="form-label">Vendor</label>
                <select id="Vendor" class="form-select mb-3"></select>

                <label class="form-label">VAT Input</label>
                <select id="VATInput" class="form-select mb-3"></select>

                <label class="form-label">Purchase Payment Cash Method</label>
                <select id="PurchasePaymentCashMethod" class="form-select mb-3"></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Purchase Invoice</label>
                <select id="PurchaseInvoice" class="form-select mb-3"></select>

                <label class="form-label">Purchase Return Invoice</label>
                <select id="PurchaseReturnInvoice" class="form-select mb-3"></select>
            </div>
        </div>
    </div>

    <!-- INVENTORY SECTION -->
    <div id="inventorySection" class="card section mb-3" style="display:none;">
        <div class="card-body row">
            <div class="col-md-6">
                <label class="form-label">Inventory</label>
                <select id="Inventory" class="form-select mb-3"></select>

                <label class="form-label">Item COGS</label>
                <select id="ItemCOGS" class="form-select mb-3"></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Inventory Damage Account</label>
                <select id="InventoryDamage" class="form-select mb-3"></select>

                <label class="form-label">Stock Settlement</label>
                <select id="StockSettlement" class="form-select mb-3"></select>
            </div>
        </div>
    </div>

    <!-- CUSTOMER SECTION -->
    <div id="customerSection" class="card section mb-3" style="display:none;">
        <div class="card-body row">
            <div class="col-md-6">
                <label class="form-label">Customer</label>
                <select id="Customer" class="form-select mb-3"></select>

                <label class="form-label">Invoice Payment Cash Method</label>
                <select id="InvoicePaymentCashMethod" class="form-select mb-3"></select>

                <label class="form-label">VAT Output</label>
                <select id="VATOutput" class="form-select mb-3"></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Sales Invoice</label>
                <select id="SalesInvoice" class="form-select mb-3"></select>

                <label class="form-label">Sales Return Invoice</label>
                <select id="SalesReturnInvoice" class="form-select mb-3"></select>
            </div>
        </div>
    </div>

    <!-- EMPLOYEE SECTION -->
    <div id="employeeSection" class="card section mb-3" style="display:none;">
        <div class="card-body row">
            <div class="col-md-6">
                <label class="form-label">Accrued Salaries</label>
                <select id="AccruedSalaries" class="form-select mb-3"></select>

                <label class="form-label">Salaries</label>
                <select id="Salaries" class="form-select mb-3"></select>

                <label class="form-label">Accrual Leave Salary</label>
                <select id="AccrualLeaveSalary" class="form-select mb-3"></select>

                <label class="form-label">Employee Receivable</label>
                <select id="EmployeeReceivable" class="form-select mb-3"></select>

                <label class="form-label">Gratuity</label>
                <select id="Gratuity" class="form-select mb-3"></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">End Of Service Debit Account</label>
                <select id="EndOfServiceDebit" class="form-select mb-3"></select>

                <label class="form-label">End Of Service Credit Account</label>
                <select id="EndOfServiceCredit" class="form-select mb-3"></select>

                <label class="form-label">Leave Salary Debit</label>
                <select id="LeaveSalaryDebit" class="form-select mb-3"></select>

                <label class="form-label">Leave Salary Credit</label>
                <select id="LeaveSalaryCredit" class="form-select mb-3"></select>
            </div>
        </div>
    </div>

    <!-- BANK SECTION -->
    <div id="bankSection" class="card section mb-3" style="display:none;">
        <div class="card-body">
            <label class="form-label">Default Account For Bank</label>
            <select id="DefaultAccountBank" class="form-select mb-3"></select>
        </div>
    </div>

    <div class="text-end mb-5">
        <button id="saveDefaultAccountsBtn" class="btn btn-primary">Save</button>
    </div>


</div>

<script>
    $(".section").hide();

    function showSubButtons() {
        $("#subButtons").show();
        showSection('commonSection', $("#subButtons button:first"));
    }

    function showSection(id, btn) {
        $(".section").hide();
        $("#" + id).show();

        // Highlight active sub-button
        $("#subButtons button").removeClass("btn-primary").addClass("btn-outline-primary");
        if (btn) $(btn).removeClass("btn-outline-primary").addClass("btn-primary");

        // Load dropdowns
        switch (id) {
            case 'commonSection': loadCommon(); break;
            case 'vendorSection': loadVendor(); break;
            case 'inventorySection': loadInventory(); break;
            case 'customerSection': loadCustomer(); break;
            case 'employeeSection': loadEmployee(); break;
            case 'bankSection': loadBank(); break;
        }
    }

    function loadDropdown(id, category) {
        $.get('@Url.Action("GetAccounts", "Settings")', { category }, function (res) {
            const ddl = $("#" + id);
            ddl.empty().append('<option value="">-- Select --</option>');
            if(res.accounts){
                res.accounts.forEach(a => {
                    ddl.append($('<option>', {
                        value: a.id,
                        text: a.name,
                        selected: a.id === res.selectedAccountId
                    }));
                });
            }
        });
    }

    function loadCommon() {
        loadDropdown("PDCReceivable", "PDC Receivable");
        loadDropdown("PDCReceivableReturn", "PDC Receivable Return");
        loadDropdown("PDCReceivableHold", "PDC Receivable Hold");
        loadDropdown("PDCPayable", "PDC Payable");
        loadDropdown("PDCPayableReturn", "PDC Payable Return");
        loadDropdown("PDCPayableHold", "PDC Payable Hold");
        loadDropdown("DefaultAccountCash", "Default Account For Cash");
        loadDropdown("OpeningBalance", "Opening Balance");
        loadDropdown("OpeningBalanceEquity", "Opening Balance Equity");
        loadDropdown("PrepaidExpenseDebit", "Prepaid Expense Debit Account");
        loadDropdown("PrepaidExpenseCredit", "Prepaid Expense Credit Account");
        loadDropdown("FixedAssetDebit", "Fixed Asset Debit Account");
        loadDropdown("FixedAssetCredit", "Fixed Asset Credit Account");
    }

    function loadVendor() {
        loadDropdown("Vendor", "Vendor");
        loadDropdown("VATInput", "Vat Input");
        loadDropdown("PurchasePaymentCashMethod", "Purchase Payment Cash Method");
        loadDropdown("PurchaseInvoice", "Purchase");
        loadDropdown("PurchaseReturnInvoice", "PurchaseReturn");
    }

    function loadInventory() {
        loadDropdown("Inventory", "Inventory");
        loadDropdown("ItemCOGS", "COGS");
        loadDropdown("InventoryDamage", "Item Damage");
        loadDropdown("StockSettlement", "Stock Settlement");
    }

    function loadCustomer() {
        loadDropdown("Customer", "Customer");
        loadDropdown("InvoicePaymentCashMethod", "Invoice Payment Cash Method");
        loadDropdown("VATOutput", "Vat Output");
        loadDropdown("SalesInvoice", "Sales");
        loadDropdown("SalesReturnInvoice", "SalesReturn");
    }

    function loadEmployee() {
        loadDropdown("AccruedSalaries", "Accrued Salaries");
        loadDropdown("Salaries", "Salaries");
        loadDropdown("AccrualLeaveSalary", "Accrual Leave Salary");
        loadDropdown("EmployeeReceivable", "Employee Receivable");
        loadDropdown("Gratuity", "Gratuity");
        loadDropdown("EndOfServiceDebit", "End of Service Debit");
        loadDropdown("EndOfServiceCredit", "End of Service Credit");
        loadDropdown("LeaveSalaryDebit", "Leave Salary Debit");
        loadDropdown("LeaveSalaryCredit", "Leave Salary Credit");
    }

    function loadBank() {
        loadDropdown("DefaultAccountBank", "Default Account For Bank");
    }

     $('#saveDefaultAccountsBtn').on('click', function (e) {
        e.preventDefault();

        // Collect all dropdowns
        const settings = [];

        $(".section select").each(function () {
            const category = $(this).prev("label").text().trim();
            const accountId = parseInt($(this).val()) || 0;

            // Only include if a value is selected
            if (accountId > 0) {
                settings.push({ category, accountId });
            }
        });

        if (settings.length === 0) {
            toastr.warning("Please select at least one account before saving.");
            return;
        }

        // AJAX POST
        $.ajax({
            url: '@Url.Action("SaveDefaultAccounts", "Settings")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(settings),
            success: function (res) {
                if (res.status) {
                    toastr.success(res.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error(res.message);
                }
            },
            error: function (xhr) {
                console.error("❌ AJAX ERROR", xhr);
                toastr.error(xhr.responseJSON?.message || xhr.statusText);
            }
        });
    });
</script>
