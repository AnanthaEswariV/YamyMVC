
@{
    ViewData["Title"] = "AttendanceList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="col-12">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="card-title">Attendance List</h4>
            <span id="todayDate" class="text-muted fw-bold"></span>
        </div>
        <div class="card-content">
            <div class="card-body">

                <!-- Search -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <input type="text" id="searchInput" class="form-control"
                               placeholder="Search by name...">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary" onclick="loadAttendance()">
                            🔄 Refresh
                        </button>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-striped table-bordered" id="attendanceTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>User ID</th>
                                <th>User Name</th>
                                <th>Work Date</th>
                                <th>Day</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="attendanceBody">
                            <tr>
                                <td colspan="8" class="text-center">Loading...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Summary -->
                <div class="row mt-3">
                    <div class="col-md-12">
                        <span class="badge bg-success me-2" id="presentCount">Present: 0</span>
                        <span class="badge bg-danger" id="absentCount">Absent: 0</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <script>

        var allData = [];

        // Show today's date in header
        $(document).ready(function () {
            var now = new Date();
            $("#todayDate").text(now.toLocaleDateString([], {
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            }));

            loadAttendance();

            // Search filter
            $("#searchInput").on("keyup", function () {
                var keyword = $(this).val().toLowerCase();
                var filtered = allData.filter(function (row) {
                    return row.userName.toLowerCase().includes(keyword);
                });
                renderTable(filtered);
            });
        });

        // Load attendance data
        function loadAttendance() {
            $("#attendanceBody").html('<tr><td colspan="8" class="text-center">Loading...</td></tr>');

            $.ajax({
                url: '@Url.Action("GetAttendanceList", "Settings")',
                type: "GET",
                success: function (res) {
                    if (res.status) {
                        allData = res.data;
                        renderTable(allData);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    var err = JSON.parse(xhr.responseText);
                    toastr.error(err.message || "Failed to load attendance.");
                }
            });
        }

        // Render table rows
        function renderTable(data) {
            var tbody = "";
            var presentCount = 0;
            var absentCount  = 0;

            if (data.length === 0) {
                tbody = '<tr><td colspan="8" class="text-center">No records found.</td></tr>';
            } else {
                $.each(data, function (i, row) {
                    var statusBadge = row.status === "P"
                        ? '<span class="badge bg-success">P</span>'
                        : '<span class="badge bg-danger">A</span>';

                    if (row.status === "P") presentCount++;
                    else absentCount++;

                    tbody += '<tr>' +
                        '<td>' + (i + 1) + '</td>' +
                        '<td>' + row.userId + '</td>' +
                        '<td>' + row.userName + '</td>' +
                        '<td>' + row.workDate + '</td>' +
                        '<td>' + row.dayOfWeek + '</td>' +
                        '<td>' + row.checkIn + '</td>' +
                        '<td>' + row.checkOut + '</td>' +
                        '<td>' + statusBadge + '</td>' +
                        '</tr>';
                });
            }

            $("#attendanceBody").html(tbody);
            $("#presentCount").text("Present: " + presentCount);
            $("#absentCount").text("Absent: " + absentCount);
        }

    </script>
}
