@model ReceiptVoucherViewModel
@{
    ViewData["Title"] = "Receipt Voucher";
    }

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    .ribbon .btn {
        min-width: 110px
    }

    .section-title {
        font-weight: 600;
        background: var(--bs-tertiary-bg);
        padding: .5rem .75rem;
        border-bottom: 1px solid var(--bs-border-color);
    }

    .fieldset {
        border: 1px solid var(--bs-border-color);
        border-radius: .5rem;
    }

    .toolbar-icon {
        width: 34px;
        height: 34px;
        border-radius: .5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--bs-border-color);
    }

    .tiny {
        font-size: .85rem
    }
</style>

<div class="container-fluid py-3">
    <!-- Top Tabs -->
    <ul class="nav nav-tabs mb-2">
        <li class="nav-item"><a class="nav-link active" href="#">Main</a></li>
        <li class="nav-item"><a class="nav-link disabled" tabindex="-1">Reports</a></li>
    </ul>

    <!-- Ribbon -->
    <div class="ribbon card shadow-sm border-0 mb-3">
        <div class="card-body d-flex flex-wrap align-items-center gap-3">
            <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-light border"><i class="bi bi-arrow-left-short"></i></button>
                <div class="toolbar-icon">RV</div>
                <button type="button" class="btn btn-light border"><i class="bi bi-arrow-right-short"></i></button>
            </div>
            <div class="vr"></div>

            <button type="submit" form="rvForm" class="btn btn-primary" id="btnSave"><i class="bi bi-save"></i> Save</button>

            <div class="vr"></div>
            <button type="button" class="btn btn-outline-secondary" id="btnPrint"><i class="bi bi-printer"></i> Print</button>
            <div class="form-check tiny">
                <input class="form-check-input" type="checkbox" id="PrintAfterSave" checked>
                <label class="form-check-label" for="PrintAfterSave">Print After Save</label>
            </div>
            <button type="button" class="btn btn-outline-secondary" id="btnEmail"><i class="bi bi-envelope"></i> Email</button>

            <div class="ms-auto badge text-bg-secondary px-3 py-2">
                @(Model?.VoucherNo ?? "RV-0000")
            </div>
        </div>
    </div>

    <form asp-action="Create" asp-controller="ReceiptVouchers" method="post" id="rvForm" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()

        <!-- Header -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Date</label>
                        <input asp-for="Date" class="form-control" type="date" />
                        <span class="text-danger small" asp-validation-for="Date"></span>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Payment Method</label>
                        <!-- values: 1=Cash, 2=Cheque, 3=Transfer -->
                        <select class="form-select" asp-for="PaymentMethod" asp-items="Model.PaymentMethods" id="PaymentMethod"></select>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Amount</label>
                        <input asp-for="Amount" id="Amount" class="form-control text-end" placeholder="0.000" readonly />
                        <span class="text-danger small" asp-validation-for="Amount"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Amount In Word</label>
                        <input asp-for="AmountInWords" class="form-control" id="AmountInWords" readonly />
                    </div>
                </div>
            </div>
        </div>

        <!-- hidden keys -->
        <input type="hidden" asp-for="CreditAccountId" id="CreditAccountId" />
        <input type="hidden" asp-for="CreditCostCenterId" id="CreditCostCenterId" />
        <input type="hidden" asp-for="DebitAccountId" id="DebitAccountId" />
        <input type="hidden" asp-for="DebitCostCenterId" id="DebitCostCenterId" />
        <input type="hidden" asp-for="CustomerId" id="customidId" />

        <!-- Received From - Credit -->
        <div class="fieldset mb-3">
            <div class="section-title">Received From - Credit</div>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Account Code</label>
                        <input asp-for="Credit.AccountCode" class="form-control" id="CreditAccountCode" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Account Name</label>
                        <select class="form-select" asp-for="CreditAccountId"
                                asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                id="filterCreditAccount">
                        </select>
                        <span class="text-danger" asp-validation-for="CreditAccountId"></span>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Cost Center</label>
                        <select class="form-select" asp-for="CreditCostCenterId"
                                asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                id="filterCreditCostCenter">
                        </select>
                    </div>
                    <div class="col-md-3"></div>

                    <div class="col-12 col-md-2">
                        <label class="form-label">Customer Code</label>
                        <input asp-for="Credit.CustomerCode" class="form-control" id="customerCode" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Customer Name</label>
                        <select class="form-select" asp-for="CustomerId"
                                asp-items="@(new SelectList(Model.Customers, "Id", "Name"))"
                                id="filterCustomer">
                        </select>
                        <span class="text-danger" asp-validation-for="CustomerId"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Note</label>
                        <textarea asp-for="Credit.Note" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Received To - Debit -->
        <div class="fieldset mb-3">
            <div class="section-title">Received To - Debit</div>
            <div class="p-3">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Account Code</label>
                        <input asp-for="Debit.AccountCode" class="form-control" id="DebitAccountCode" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Account Name</label>
                        <select class="form-select" asp-for="DebitAccountId"
                                asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                id="filterDebitAccount">
                        </select>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Cost Center</label>
                        <select class="form-select" asp-for="DebitCostCenterId"
                                asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                id="filterDebitCostCenter">
                        </select>
                    </div>

                    <div class="w-100"></div>

                    <!-- Cheque (hidden by default) -->
                    <div class="col-12 col-md-3 cheque-only d-none">
                        <label class="form-label">Cheque Name</label>
                        <input asp-for="Debit.ChequeName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-2 cheque-only d-none">
                        <label class="form-label d-block">Cheque</label>
                        <div class="form-check mt-1">
                            <input class="form-check-input" type="checkbox" asp-for="Debit.IsCheque" />
                            <label class="form-check-label tiny">Is Cheque</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-3 cheque-only d-none">
                        <label class="form-label">Cheque No</label>
                        <input asp-for="Debit.ChequeNo" class="form-control" />
                    </div>
                    <div class="col-12 col-md-3 cheque-only d-none">
                        <label class="form-label">Cheque Date</label>
                        <input asp-for="Debit.ChequeDate" type="date" class="form-control" />
                    </div>

                    <!-- Transfer (hidden by default) -->
                    <div class="col-12 col-md-3 transfer-only d-none">
                        <label class="form-label">Transfer Date</label>
                        <input asp-for="Debit.transferDate" type="date" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4 transfer-only d-none">
                        <label class="form-label">TRNS / Name</label>
                        <input class="form-control" asp-for="Debit.TRNSNAme" />
                    </div>
                    <div class="col-12 col-md-4 transfer-only d-none">
                        <label class="form-label">TRNS / REF</label>
                        <input class="form-control" asp-for="Debit.TRNSRef" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Details Grid (target for JS rendering) -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" id="invoiceTable">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px">SN#</th>
                                <th style="width:140px">ID</th>
                                <th style="width:140px">Date</th>
                                <th style="width:140px">INV NO</th>
                                <th style="width:140px" class="text-end">Total</th>
                                <th style="width:70px" class="text-center">Pay</th>
                                <th style="width:160px" class="text-end">Payment</th>
                                <th style="width:140px" class="text-end">Description</th>
                            
                            </tr>
                        </thead>
                        <tbody><!-- filled by JS --></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bottom Buttons -->
        <div class="d-flex justify-content-end gap-2">
            <button type="submit" name="close" value="1" class="btn btn-primary">Save &amp; Close</button>
            <button type="submit" class="btn btn-secondary">Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Close</a>
        </div>
    </form>
</div>

