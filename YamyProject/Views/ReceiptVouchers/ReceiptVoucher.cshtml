@model ReceiptVoucherViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Receipt Voucher";
    }

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    .rv-wrap {
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f3f4f8;
        padding: 10px;
    }

    .rv-window {
        background: #fff;
        border: 1px solid #cfd3e1;
        border-radius: 4px;
    }

    .rv-header-bar {
        background: #122a4c;
        color: #fff;
        padding: .4rem .75rem;
        font-weight: 600;
        text-align: center;
        border-radius: 4px 4px 0 0;
    }

    .rv-tabs {
        background: #f8f9fc;
        border-bottom: 1px solid #e0e4f0;
        padding: 0 .6rem;
    }

    .rv-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: .5rem .75rem;
        border-bottom: 1px solid #e0e4f0;
        background: #fafbff;
    }

    .rv-toolbar-nav {
        display: flex;
        align-items: center;
        gap: 4px;
        padding-right: 12px;
        border-right: 1px solid #e0e4f0;
        margin-right: 8px;
    }

        .rv-toolbar-nav .voucher-box {
            min-width: 100px;
            text-align: center;
            padding: .2rem .5rem;
            background: #4b5563;
            color: #fff;
            border-radius: 3px;
            font-size: .9rem;
            font-weight: 600;
        }

    .rv-toolbar-icon-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 70px;
        padding: .2rem 0;
        border-radius: 4px;
        border: 1px solid #d1d5e5;
        background: #ffffff;
        font-size: .75rem;
        gap: 2px;
    }

        .rv-toolbar-icon-btn i {
            font-size: 1.25rem;
        }

    .rv-toolbar-spacer {
        flex: 1 1 auto;
    }

    .rv-toolbar-print-after {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: .8rem;
    }

    .section-card {
        border-radius: 8px;
        border: 1px solid #e0e4f0;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        margin-bottom: .75rem;
        background: #f9fafb;
    }

    .section-card-header {
        padding: .5rem .75rem;
        font-weight: 600;
        border-bottom: 1px solid #e0e4f0;
        color: #4b5563;
    }

    .section-card-body {
        padding: .75rem;
        background: #ffffff;
        border-radius: 0 0 8px 8px;
    }

    .rv-readonly {
        background: #e5e7eb !important;
        pointer-events: none;
    }

    .tiny {
        font-size: .8rem;
    }

    #invoiceTable thead th {
        background: #f3f4f8;
    }

    .rv-footer-buttons {
        padding: .75rem;
        border-top: 1px solid #e0e4f0;
        background: #f9fafb;
    }
</style>

<div class="rv-wrap">
    <div class="rv-window">

        <!-- Top blue title bar -->
        <div class="rv-header-bar">
            Receipt Voucher
        </div>
@* 
        <!-- Tabs (Main / Reports) -->
        <div class="rv-tabs">
            <ul class="nav nav-tabs border-0">
                <li class="nav-item">
                    <a class="nav-link active" href="#">Main</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link disabled" tabindex="-1">Reports</a>
                </li>
            </ul>
        </div> *@

        <!-- Ribbon -->
        <div class="rv-toolbar">
            <!-- Navigation + Voucher No -->
            <div class="rv-toolbar-nav">
                <button type="button" class="btn btn-light btn-sm border"><i class="bi bi-arrow-left-short"></i></button>
                <div class="voucher-box">
                    @(Model?.VoucherNo ?? "RV-0000")
                </div>
                <button type="button" class="btn btn-light btn-sm border"><i class="bi bi-arrow-right-short"></i></button>
            </div>

            <!-- Ribbon buttons -->
            <button type="button" class="rv-toolbar-icon-btn" id="btnNew">
                <i class="bi bi-file-earmark-plus"></i>
                <span>New</span>
            </button>

            <button type="submit" form="rvForm" class="rv-toolbar-icon-btn" id="btnSave">
                <i class="bi bi-save2"></i>
                <span>Save</span>
            </button>

            <button type="button" class="rv-toolbar-icon-btn" id="btnDelete">
                <i class="bi bi-trash3"></i>
                <span>Delete</span>
            </button>
@* 
            <button type="button" class="rv-toolbar-icon-btn" id="btnMemorize">
                <i class="bi bi-bookmark"></i>
                <span>Memorize</span>
            </button> *@

            <button type="button" class="rv-toolbar-icon-btn" id="btnCopy">
                <i class="bi bi-files"></i>
                <span>Create a Copy</span>
            </button>

            <button type="button" class="rv-toolbar-icon-btn" id="btnPrint">
                <i class="bi bi-printer"></i>
                <span>Print</span>
            </button>

            <button type="button" class="rv-toolbar-icon-btn" id="btnEmail">
                <i class="bi bi-envelope"></i>
                <span>Email</span>
            </button>

            <div class="rv-toolbar-spacer"></div>

            <div class="rv-toolbar-print-after">
                <input class="form-check-input" type="checkbox" id="PrintAfterSave" checked />
                <label class="form-check-label" for="PrintAfterSave">Print After Save</label>
            </div>
        </div>

        <!-- BODY -->
        <form asp-action="Create" asp-controller="ReceiptVouchers" method="post" id="rvForm" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()

            <!-- hidden keys -->
            <input type="hidden" asp-for="CreditAccountId" id="CreditAccountId" />
            <input type="hidden" asp-for="CreditCostCenterId" id="CreditCostCenterId" />
            <input type="hidden" asp-for="DebitAccountId" id="DebitAccountId" />
            <input type="hidden" asp-for="DebitCostCenterId" id="DebitCostCenterId" />
            <input type="hidden" asp-for="CustomerId" id="customidId" />

            <!-- Header (Date / Payment type / Amount) -->
            <div class="section-card">
                <div class="section-card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Date</label>
                            <input asp-for="Date" class="form-control form-control-sm" type="date" />
                            <span class="text-danger small" asp-validation-for="Date"></span>
                        </div>

                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Payment Type</label>
                            <select class="form-select form-select-sm" asp-for="PaymentType" asp-items="Model.PaymentTypes"></select>
                        </div>

                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Payment Method</label>
                            <select class="form-select form-select-sm" asp-for="PaymentMethod" asp-items="Model.PaymentMethods" id="PaymentMethod"></select>
                        </div>

                        <div class="w-100"></div>

                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Amount</label>
                            <input asp-for="Amount" id="Amount" class="form-control form-control-sm text-end rv-readonly" placeholder="0.000" />
                            <span class="text-danger small" asp-validation-for="Amount"></span>
                        </div>
                        <div class="col-12 col-md-5">
                            <label class="form-label tiny">Amount In Word</label>
                            <input asp-for="AmountInWords" class="form-control form-control-sm rv-readonly" id="AmountInWords" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Received From - Credit -->
            <div class="section-card">
                <div class="section-card-header">Received From - Credit</div>
                <div class="section-card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Account Code</label>
                            <input asp-for="Credit.AccountCode" class="form-control form-control-sm" id="CreditAccountCode" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label tiny">Account Name</label>
                            <select class="form-select form-select-sm"
                                    asp-for="CreditAccountId"
                                    asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                    id="filterCreditAccount">
                            </select>
                            <span class="text-danger tiny" asp-validation-for="CreditAccountId"></span>
                        </div>
                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Cost Center</label>
                            <select class="form-select form-select-sm"
                                    asp-for="CreditCostCenterId"
                                    asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                    id="filterCreditCostCenter">
                            </select>
                        </div>

                        <div class="w-100"></div>

                        <div class="col-12 col-md-2">
                            <label class="form-label tiny">Customer Code</label>
                            <input asp-for="Credit.CustomerCode" class="form-control form-control-sm" id="customerCode" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label tiny">Customer Name</label>
                            <select class="form-select form-select-sm"
                                    asp-for="CustomerId"
                                    asp-items="@(new SelectList(Model.Customers, "Id", "Name"))"
                                    id="filterCustomer">
                            </select>
                            <span class="text-danger tiny" asp-validation-for="CustomerId"></span>
                        </div>

                        <div class="w-100"></div>

                        <div class="col-12">
                            <label class="form-label tiny">Note</label>
                            <textarea asp-for="Credit.Note" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Received To - Debit -->
            <div class="section-card">
                <div class="section-card-header">Received To - Debit</div>
                <div class="section-card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Account Code</label>
                            <input asp-for="Debit.AccountCode" class="form-control form-control-sm" id="DebitAccountCode" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label tiny">Account Name</label>
                            <select class="form-select form-select-sm"
                                    asp-for="DebitAccountId"
                                    asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                    id="filterDebitAccount">
                            </select>
                        </div>
                        <div class="col-12 col-md-3">
                            <label class="form-label tiny">Cost Center</label>
                            <select class="form-select form-select-sm"
                                    asp-for="DebitCostCenterId"
                                    asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                    id="filterDebitCostCenter">
                            </select>
                        </div>

                        <div class="w-100"></div>

                        <!-- Cheque fields -->
                        <div class="col-12 col-md-3 cheque-only d-none">
                            <label class="form-label tiny">Cheque Name</label>
                            <input asp-for="Debit.ChequeName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12 col-md-2 cheque-only d-none">
                            <label class="form-label tiny d-block">Cheque</label>
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" asp-for="Debit.IsCheque" />
                                <label class="form-check-label tiny">Is Cheque</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-3 cheque-only d-none">
                            <label class="form-label tiny">Cheque No</label>
                            <input asp-for="Debit.ChequeNo" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12 col-md-3 cheque-only d-none">
                            <label class="form-label tiny">Cheque Date</label>
                            <input asp-for="Debit.ChequeDate" type="date" class="form-control form-control-sm" />
                        </div>

                        <!-- Transfer fields -->
                        <div class="col-12 col-md-3 transfer-only d-none">
                            <label class="form-label tiny">Transfer Date</label>
                            <input asp-for="Debit.transferDate" type="date" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12 col-md-4 transfer-only d-none">
                            <label class="form-label tiny">TRNS / Name</label>
                            <input class="form-control form-control-sm" asp-for="Debit.TRNSNAme" />
                        </div>
                        <div class="col-12 col-md-4 transfer-only d-none">
                            <label class="form-label tiny">TRNS / REF</label>
                            <input class="form-control form-control-sm" asp-for="Debit.TRNSRef" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Invoice list -->
            <div class="section-card mb-0">
                <div class="section-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle mb-0" id="invoiceTable">
                            <thead>
                                <tr>
                                    <th style="width:60px">SN#</th>
                                    <th style="width:120px">ID</th>
                                    <th style="width:120px">Date</th>
                                    <th style="width:150px">INV NO</th>
                                    <th style="width:120px" class="text-end">Amount</th>
                                    <th style="width:60px" class="text-center">Pay</th>
                                    <th style="width:150px" class="text-end">Payment</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody><!-- filled by JS --></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Footer buttons -->
            <div class="rv-footer-buttons d-flex justify-content-end gap-2">
                <button type="submit" name="close" value="1" class="btn btn-primary btn-sm">Save &amp; Close</button>
                <button type="submit" class="btn btn-secondary btn-sm">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Close</a>
            </div>
        </form>
    </div>
</div>

    @section Scripts {
    <script>
        (function () {
            // ---------- Amount in words ----------
            function toWords(n) {
                n = Math.trunc(+String(n).replace(/,/g, '')) || 0;
                if (n < 0) return 'minus ' + toWords(-n);
                if (n === 0) return 'zero only';
                const A = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine',
                    'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen',
                    'seventeen', 'eighteen', 'nineteen'];
                const B = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];
                function h(x) {
                    return x < 20 ? A[x]
                        : x < 100 ? B[(x / 10 | 0)] + (x % 10 ? '-' + A[x % 10] : '')
                            : A[(x / 100 | 0)] + ' hundred' + (x % 100 ? ' ' + h(x % 100) : '');
                }
                function c(x, s) { return x ? h(x) + ' ' + s : ''; }
                return (c((n / 1e12 | 0), 'trillion') + ' ' +
                    c((n % 1e12 / 1e9 | 0), 'billion') + ' ' +
                    c((n % 1e9 / 1e6 | 0), 'million') + ' ' +
                    c((n % 1e6 / 1e3 | 0), 'thousand') + ' ' +
                    (n % 1e3 ? h(n % 1e3) : '')).trim() + ' only';
            }

            const $amount = $('#Amount');
            const $amountWords = $('#AmountInWords');

            function syncAmountWords() {
                const n = parseFloat($amount.val() || '0') || 0;
                $amountWords.val(toWords(n));
            }
            $amount.on('input', syncAmountWords);
            syncAmountWords();

            // ---------- Print ----------
            $('#btnPrint').on('click', () => {
                const id = '@Model?.Id';
                if (!id) return;
                window.open('@Url.Action("PrintPreview", "ReceiptVouchers")' + '?id=' + id, '_blank');
            });

            // ---------- Payment Method toggle  ----------
            (function () {
                const $method = $('#PaymentMethod');
                const $cheque = $('.cheque-only');
                const $transfer = $('.transfer-only');

                function setGroup($el, show) {
                    $el.toggleClass('d-none', !show);
                    $el.find('input,select,textarea').prop('disabled', !show);
                    if (!show) {
                        $el.find('input[type="text"], input[type="date"], input[type="number"], textarea').val('');
                        $el.find('input[type="checkbox"]').prop('checked', false);
                        $el.find('select').each(function () { this.selectedIndex = 0; });
                    }
                }
                function onChange(val) {
                    setGroup($cheque, val === '2');    // Cheque
                    setGroup($transfer, val === '3');  // Transfer
                }
                onChange(String($method.val()));
                $method.on('change', function () { onChange(this.value); });
            })();

            // ---------- Customer mirror & invoice loader ----------
            (function () {
                const customers = @Html.Raw(JsonSerializer.Serialize(
                                    Model.Customers.Select(c => new { id = c.Id, code = c.Code, name = c.Name })
                            ));
            const byId = Object.fromEntries(customers.map(x => [String(x.id), x]));

                const $sel = $('#filterCustomer');
                const $hiddenId = $('#customidId');
                const $codeInput = $('#customerCode');

                function syncFromSelect() {
                    const m = byId[String($sel.val())];
                    if (!m) {
                        $codeInput.val('');
                        $hiddenId.val('');
                        return;
                    }
                    $hiddenId.val(String(m.id));
                    $codeInput.val(m.code ?? '');
                }

                function getCurrentCustomerId() {
                    return Number($sel.val() || $hiddenId.val() || 0) || 0;
                }

                async function loadInvoicesForCustomer(customerId) {
                    if (!customerId) return;
                    const url = '/ReceiptVouchers/GetInvoiceRowsAsync?customerId=' + encodeURIComponent(customerId);
                    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
                    if (!res.ok) {
                        alert('Failed to load invoices. HTTP ' + res.status);
                        return;
                    }
                    const rows = await res.json();
                    renderInvoiceRows(rows || []);
                }

                (function init() {
                    const pre = $hiddenId.val();
                    if (pre && byId[pre]) $sel.val(pre);
                    syncFromSelect();

                    const initialId = getCurrentCustomerId();
                    if (initialId) loadInvoicesForCustomer(initialId);

                    $sel.on('change', function () {
                        syncFromSelect();
                        loadInvoicesForCustomer(getCurrentCustomerId());
                    });

                    $codeInput.on('blur', function () {
                        const val = $(this).val()?.toString() ?? '';
                        if (!val) return;
                        const m = customers.find(c => String(c.code) === val);
                        if (m) {
                            $sel.val(String(m.id));
                            syncFromSelect();
                            loadInvoicesForCustomer(m.id);
                        }
                    });
                })();
            })();

            // ---------- Invoice table render & totals ----------
            function renderInvoiceRows(rows) {
                const $tbody = $('#invoiceTable tbody');
                $tbody.empty();

                if (!rows.length) {
                    $tbody.append('<tr class="text-center text-muted"><td colspan="8">No invoices found for this customer.</td></tr>');
                    return;
                }

                rows.forEach((r, i) => {
                    const dateStr = r.date ? new Date(r.date).toISOString().slice(0, 10) : '';
                    const amount = Number(r.amount ?? 0);
                    const idCol = r.humId ?? '';

                    $tbody.append(`
                        <tr data-original-amount="${amount}">
                            <td class="text-center">${i + 1}</td>
                            <td><input type="text" class="form-control form-control-sm" name="Items[${i}].HumId" value="${idCol}" readonly></td>
                            <td><input type="date" class="form-control form-control-sm" name="Items[${i}].InvDate" value="${dateStr}" readonly></td>
                            <td><input type="text" class="form-control form-control-sm" name="Items[${i}].InvoiceNo" value="${r.invoiceNo ?? ''}" readonly></td>
                            <td><input type="number" step="0.01" class="form-control form-control-sm text-end item-total" name="Items[${i}].Total" value="${amount.toFixed(2)}" readonly></td>
                            <td class="text-center">
                                <input type="checkbox" class="form-check-input row-select" name="Items[${i}].Selected">
                            </td>
                            <td>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm text-end item-payment" name="Items[${i}].Payment" value="0.00" data-max="${amount}" disabled>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm" name="Items[${i}].Description">
                            </td>
                        </tr>
                    `);
                });
            }

            // single-select logic
            $('#invoiceTable').on('change', '.row-select', function () {
                if (this.checked) {
                    $('.row-select').not(this).prop('checked', false);
                    const $tr = $(this).closest('tr');
                    $('.item-payment').prop('disabled', true).val('0.00');

                    const max = Number($tr.data('original-amount') || 0);
                    $tr.find('.item-payment').prop('disabled', false).val(max.toFixed(2));
                } else {
                    const $tr = $(this).closest('tr');
                    $tr.find('.item-payment').prop('disabled', true).val('0.00');
                }
                recalcHeaderTotals();
            });

            // limit payment to total
            $('#invoiceTable').on('input', '.item-payment', function () {
                const $tr = $(this).closest('tr');
                const max = Number($tr.data('original-amount') || 0);
                let val = Number(this.value || 0);
                if (val < 0) val = 0;
                if (val > max) val = max;
                this.value = val.toFixed(2);
                recalcHeaderTotals();
            });

            // header totals
            window.recalcHeaderTotals = function () {
                const sum = $('.row-select:checked').closest('tr').find('.item-payment').toArray()
                    .reduce((t, el) => t + (parseFloat(el.value || '0') || 0), 0);
                $('#Amount').val(sum.toFixed(3));
                syncAmountWords();
            };

            // ---------- Account & CostCenter code mirrors ----------
            // Credit account
            (function () {
                const accounts = @Html.Raw(JsonSerializer.Serialize(
                                Model.Accounts.Select(a => new { id = a.Id, code = a.Code, name = a.Name })
                        ));
            const byId = Object.fromEntries(accounts.map(x => [String(x.id), x]));

                const sel = document.getElementById('filterCreditAccount');
                const hidden = document.getElementById('CreditAccountId');
                const code = document.getElementById('CreditAccountCode');

                function sync() {
                    const m = byId[sel.value];
                    if (!m) { code.value = ''; return; }
                    if (hidden) hidden.value = String(m.id);
                    code.value = m.code ?? '';
                }

                (function init() {
                    const pre = hidden?.value;
                    if (pre && byId[pre]) sel.value = pre;
                    sync();
                    sel.addEventListener('change', sync);
                })();
            })();

            // Debit account
            (function () {
                const accounts = @Html.Raw(JsonSerializer.Serialize(
                                Model.Accounts.Select(a => new { id = a.Id, code = a.Code, name = a.Name })
                        ));
            const byId = Object.fromEntries(accounts.map(x => [String(x.id), x]));

                const sel = document.getElementById('filterDebitAccount');
                const hidden = document.getElementById('DebitAccountId');
                const code = document.getElementById('DebitAccountCode');

                function sync() {
                    const m = byId[sel.value];
                    if (!m) { code.value = ''; return; }
                    if (hidden) hidden.value = String(m.id);
                    code.value = m.code ?? '';
                }

                (function init() {
                    const pre = hidden?.value;
                    if (pre && byId[pre]) sel.value = pre;
                    sync();
                    sel.addEventListener('change', sync);
                })();
            })();

            // Debit cost center
            (function () {
                const centers = @Html.Raw(JsonSerializer.Serialize(
                                Model.CostCenters.Select(c => new { id = c.Id, code = c.Code, name = c.Name })
                        ));
            const byId = Object.fromEntries(centers.map(x => [String(x.id), x]));

                const sel = document.getElementById('filterDebitCostCenter');
                const hidden = document.getElementById('DebitCostCenterId');

                function sync() {
                    const m = byId[sel.value];
                    if (!m) return;
                    if (hidden) hidden.value = String(m.id);
                }

                (function init() {
                    const pre = hidden?.value;
                    if (pre && byId[pre]) sel.value = pre;
                    sync();
                    sel.addEventListener('change', sync);
                })();
            })();

            // Credit cost center (simple mirror)
            (function () {
                const sel = document.getElementById('filterCreditCostCenter');
                const hidden = document.getElementById('CreditCostCenterId');

                function sync() {
                    if (hidden) hidden.value = sel.value;
                }
                (function init() {
                    if (hidden?.value) sel.value = hidden.value;
                    sync();
                    sel.addEventListener('change', sync);
                })();
            })();

        })();
    </script>
}
