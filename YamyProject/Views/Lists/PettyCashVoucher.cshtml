@{
    ViewData["Title"] = "PettyCashVoucher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center"><strong>Petty Cash</strong></div>
    <div class="card-body">

        <div class="d-flex align-items-center justify-content-between mb-4 gap-2">

            <!-- Left - Filter / Bank -->
            <div style="min-width: 150px;">
                <select class="form-select form-select-sm" id="bankSelect">
                    <option>Petty Cash</option>
                    <option>Deleted Petty Cash</option>
                </select>
            </div>

            <!-- Middle - Petty Cash Dropdown -->
            <div class="input-group input-group-sm" style="width: 44%;">
                <span class="input-group-text"><i class="fas fa-angle-double-left"></i></span>
                <select class="form-select form-select-sm mt-1" id="pettyCashDropdown">
                    <option value="">Select Petty Cash</option>
                </select>
                <span class="input-group-text"><i class="fas fa-angle-double-right"></i></span>
            </div>

            <!-- Right - Buttons -->
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addPettyCashModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Petty Cash
                </button>
                <button type="button" class="btn btn-success btn-sm recycleCardBtn" data-bs-toggle="modal" data-bs-target="#pettyCashSubmissionModal" style="display: none;>
                    <i class="fas fa-paper-plane me-1"></i>Submit
                </button>
            </div>

        </div>

        <!-- Main Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>REF</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Project</th>
                    <th>Vendor</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Note</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Dynamic rows will be appended here -->
            </tbody>
        </table>
    </div>
</div>

<!-- Add Petty Cash Modal -->
<div class="modal fade" id="addPettyCashModal" tabindex="-1" aria-labelledby="addPettyCashModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="addPettyCashModalLabel">Add Petty Cash</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Top Fields -->
                <div class="row mb-3 g-3">
                    <div class="col-md-3">
                        <label class="form-label">PettyCash Code</label>
                        <input type="text" class="form-control" id="pettyCashCode" disabled>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">PettyCash Name</label>
                        <select class="form-select" id="pettyCashNameDropdown">
                            <option value="">Select Petty Cash</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" id="pettyCashDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">No</label>
                        <input type="text" class="form-control" id="pettyCashNo" disabled>
                    </div>
                </div>

                <!-- Hidden Employee ID -->
                <input type="hidden" id="pettyCashEmployeeId" />

                <!-- Petty Cash Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Date</th>
                                <th>REF</th>
                                <th>Category</th>
                                <th>Type</th>
                                <th>Project</th>
                                <th>Vendor</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Note</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="pettyCashTableBody">
                            <tr>
                                <td>1</td>
                                <td><input type="date" class="form-control form-control-sm"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><select class="form-select form-select-sm pettyCashCategorySelect"></select></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><select class="form-select form-select-sm projectName"></select></td>
                                <td><select class="form-select form-select-sm vendorName"></select></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="number" class="form-control form-control-sm" step="0.01"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- Modal Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="savePettyCashBtn">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

<!-- Edit Petty Cash Modal -->
<div class="modal fade" id="editPettyCashModal" tabindex="-1" aria-labelledby="editPettyCashModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold" id="editPettyCashModalLabel">Edit Petty Cash</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- Top Fields -->
                <div class="row mb-3 g-3">
                    <input type="hidden" id="editPettyCashId">
                    <input type="hidden" id="editPettyCashEmployeeId">
                    <div class="col-md-3">
                        <label class="form-label">PettyCash Code</label>
                        <input type="text" class="form-control" id="editPettyCashCode" disabled>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">PettyCash Name</label>
                        <select class="form-select" id="editPettyCashNameDropdown"></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date</label>  
                        <input type="date" class="form-control" id="editPettyCashDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Employee</label>
                        <input type="text" class="form-control" id="editPettyCashEmployeeName" disabled>
                    </div>
                </div>

                <!-- Petty Cash Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Date</th>
                                <th>REF</th>
                                <th>Category</th>
                                <th>Type</th>
                                <th>Project</th>
                                <th>Vendor</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Note</th>
                            </tr>
                        </thead>
                        <tbody id="editPettyCashTableBody"></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-warning" id="updatePettyCashBtn">Update</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="pettyCashSubmissionModal" tabindex="-1" aria-labelledby="pettyCashSubmissionLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content rounded-4 shadow-lg border-0">

            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="pettyCashSubmissionLabel">Petty Cash Submission Journal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="pettyCashSubmissionForm" class="needs-validation" novalidate>

                    <!-- Top Form Fields -->
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Petty Cash Code</label>
                            <input type="text" id="pettyCashCode" class="form-control" disabled>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Petty Cash Name</label>
                            <select id="pettyCashNameJ" class="form-select" disabled>
                            </select>
                            <div class="invalid-feedback">Please select a petty cash name.</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date</label>
                            <input type="date" id="submissionDate" class="form-control" disabled>
                            <div class="invalid-feedback">Please select a date.</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">No</label>
                            <input type="text" id="submissionNo" class="form-control" disabled>
                        </div>
                    </div>

                    <!-- Table Section -->
                    <div class="table-responsive mb-3">
                        <table class="table table-bordered align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px;">No</th>
                                    <th>A/C Name</th>
                                    <th style="width: 150px;">C. Center</th>
                                    <th>Description</th>
                                    <th style="width: 120px;">Debit</th>
                                    <th style="width: 120px;">Credit</th>
                                    <th style="width: 80px;">View</th>
                                </tr>
                            </thead>
                            <tbody id="submissionTableBody">
                                <tr>
                                    <td>1</td>
                                    <td>
                                        <select class="form-select bankAccountSelect">
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-select costCenterSelect">
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control" placeholder="Description"></td>
                                    <td><input type="number" class="form-control text-end" /></td>
                                    <td><input type="number" class="form-control text-end" readonly /></td>
                                    <td><a href="#" class="text-primary text-decoration-none">View</a></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer Fields -->
                    <div class="row align-items-center">
                        <div class="col-md-2">
                            <input type="text" class="form-control text-end fw-bold" readonly>
                        </div>
                        <div class="col-md-10">
                            <input type="text" class="form-control" value="Four hundred and fifty-three Dirham" readonly>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer bg-light rounded-bottom-4">
                <button type="button" id="saveCloseBtn" class="btn btn-primary">
                    <i class="bi bi-save me-2"></i>Save & Close
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-2"></i>Close
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalTitle">Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="detailModalBody">
                <!-- Detail content will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="transactionDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Transaction Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Account Name</th>
                            <th>Debit</th>
                            <th>Credit</th>
                        </tr>
                    </thead>
                    <tbody id="transactionDetailBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
   
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>
        let pettyCashCategories = [];

        function loadPettyCashCards() {
            $.ajax({
                   url: '@Url.Action("GetPettyCashCards", "Lists")',
                type: 'GET',
                success: function(res) {
                    if (res.status && res.data?.length > 0) {
                        const $dropdown1 = $('#pettyCashNameDropdown');
                       // const $dropdown2 = $('#pettyCashDropdown');
                        $dropdown1.empty().append('<option value="">Select Petty Cash</option>');
                       // $dropdown2.empty().append('<option value="">Select Petty Cash</option>');


                        res.data.forEach(pc => {
                            const optionText = `${pc.code} - ${pc.employeeName}`;
                            $dropdown1.append(`<option value="${pc.id}" data-code="${pc.code}" data-empid="${pc.employeeId}">${optionText}</option>`);
                           //  $dropdown2.append(`<option value="${pc.id}" data-code="${pc.code}" data-empid="${pc.employeeId}">${optionText}</option>`);
                        });
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Failed to load petty cash cards");
                }
            });
        }

        function loadPettyCashForEmployee() {
            $.ajax({
              url: '@Url.Action("GetPettyCashCardsByEmployee", "Lists")',
                type: 'GET',
                success: function (res) {
                    const $dropdown = $('#pettyCashDropdown');
                    $dropdown.empty().append('<option value="">Select Petty Cash</option>');

                    if (res.status && res.data?.length > 0) {
                        res.data.forEach(pc => {
                            $dropdown.append(`<option value="${pc.id}">${pc.id}</option>`);
                        });
                    } else {
                        $dropdown.html('<option value="">No petty cash found</option>');
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Failed to load petty cash');
                }
            });
        }

        function loadPettyCashCategories() {
            $.ajax({
                   url: '@Url.Action("GetPettyCashCategories", "Lists")',
                type: 'GET',
                success: function(res) {
                    if (res.status && res.data?.length > 0) {
                        pettyCashCategories = res.data;
                        fillCategoryDropdown($('#pettyCashTableBody tr:first select.pettyCashCategorySelect'));
                    }
                }
            });
        }

        function fillCategoryDropdown($dropdown) {
            $dropdown.empty().append('<option value="">Select Category</option>');
            pettyCashCategories.forEach(cat => {
                $dropdown.append(`<option value="${cat.id}">${cat.name}</option>`);
            });
        }

        function addNewRow() {
            const rowCount = $('#pettyCashTableBody tr').length + 1;
            const newRow = `<tr>
                <td>${rowCount}</td>
                <td><input type="date" class="form-control form-control-sm"></td>
                <td><input type="text" class="form-control form-control-sm"></td>
                <td><select class="form-select form-select-sm pettyCashCategorySelect"></select></td>
                <td><input type="text" class="form-control form-control-sm"></td>
                    <td><select class="form-select form-select-sm projectName"></select></td>
                    <td><select class="form-select form-select-sm vendorName"></select></td>
                <td><input type="text" class="form-control form-control-sm"></td>
                <td><input type="number" class="form-control form-control-sm" step="0.01"></td>
                <td><input type="text" class="form-control form-control-sm"></td>
            </tr>`;
            $('#pettyCashTableBody').append(newRow);
            fillCategoryDropdown($('#pettyCashTableBody tr:last select.pettyCashCategorySelect'));
        }

        $(document).on('change', '.pettyCashCategorySelect', function() {
            if ($(this).val() && $(this).closest('tr').is(':last-child')) addNewRow();
        });

        $('#addPettyCashModal').on('shown.bs.modal', function() {
                    loadPettyCashCards();
                    loadPettyCashCategories();
                    $('#pettyCashDate').val(new Date().toISOString().split('T')[0]);
                    $('#pettyCashCode').val('');
                    $('#pettyCashNo').val('');
                    $('#pettyCashEmployeeId').val('');
                    $('#pettyCashTableBody').empty();
                    addNewRow();
                });

        $(document).on('change', '#pettyCashDropdown', function() {
            const selected = $(this).find(':selected');
            $('#pettyCashCode').val(selected.data('code') || '');
            $('#pettyCashNo').val(selected.data('code') || '');
            $('#pettyCashEmployeeId').val(selected.data('empid') || '');
        })

         $(document).on('change', '#pettyCashDropdown', function() {
            const selectedId = $(this).val();
            if (!selectedId) return;

            $.ajax({
                url: '@Url.Action("GetPettyCashVoucher", "Lists")' + '?id=' + selectedId,
                type: "GET",
                success: function(res) {
                    const tbody = $("#table1 tbody");
                    tbody.empty();

                    if (res.status && res.data && res.data.details.length > 0) {
                        const voucher = res.data;

                        // Get the roleId from the API response
                        const roleId = voucher.roleId; // roleId is passed in the API response


                        // Iterate over voucher details and append rows
                        $.each(voucher.details, function(i, row) {

                            // Conditionally render the "Approve" and "Decline" buttons
                            const approveDeclineButtons = (roleId === 1 || roleId === 2) ? `
                                <button class="btn btn-sm btn-success approvePettyCashBtn"
                                        title="Approve Petty Cash"
                                        data-pettyCashId="${row.pettyCashId}">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="btn btn-sm btn-warning declinePettyCashBtn"
                                        title="Decline Petty Cash"
                                        data-pettyCashId="${row.pettyCashId}">
                                    <i class="fas fa-times"></i>
                                </button>
                            ` : ''; // If roleId is 1 or 2, show buttons, else don't show them

                            // Create the table row
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${row.entryDate ?? ''}</td>
                                    <td>${row.refId ?? ''}</td>
                                    <td>${row.category ?? ''}</td>
                                    <td>${row.humName ?? ''}</td>
                                    <td>${row.projectName ?? ''}</td>
                                    <td>${row.vendorName ?? ''}</td>
                                    <td>${row.description ?? ''}</td>
                                    <td>${row.amount ?? 0}</td>
                                    <td>${row.note ?? ''}</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-primary editPettyCashBtn"
                                                data-voucher='${JSON.stringify(voucher).replace(/'/g, "&apos;")}'>
                                            <i class="fas fa-pen"></i>
                                        </button>

                                        <button class="btn btn-sm btn-danger deletePettyCashBtn" data-id='${voucher.voucher.id}'>
                                            <i class="fas fa-trash-alt"></i>
                                        </button>

                                        ${approveDeclineButtons} <!-- Conditionally render the buttons -->
                                    </td>
                                </tr>
                            `;
                            tbody.append(tr);
                        });
                    } else {
                        tbody.append(`<tr><td colspan="10" class="text-center" style="padding:40px; color:#6c757d; font-style:italic;">No records found</td></tr>`);
                    }

                            // ✅ Check voucher state after loading table data
                            $.ajax({
                                url: '@Url.Action("GetPettyCashRequestState", "Lists")' + '?id=' + selectedId,
                                type: 'GET',
                                success: function (statusRes) {
                                    if (statusRes.status && statusRes.data) {
                                        const voucherState = statusRes.data.state;
                                        if (voucherState === 'Approved') {
                                            $('.recycleCardBtn').show();
                                        } else {
                                            $('.recycleCardBtn').hide();
                                        }
                                    } else {
                                        $('.recycleCardBtn').hide();
                                    }
                                },
                                error: function () {
                                    $('.recycleCardBtn').hide();
                                }
                            });
                },
                error: function() {
                    $("#table1 tbody").html(`<tr><td colspan="10" class="text-center" style="color:red; padding:40px;">Error loading data</td></tr>`);
                }
            });
        });

         // When "Approve" button is clicked
        $(document).on('click', '.approvePettyCashBtn', function() {
                         const requestId = $(this).data('pettycashid');
            if (!requestId) return;

            $.ajax({
                url: '@Url.Action("UpdatePettyCashStatus", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    RequestId: requestId,
                    NewStatus: 'Approved'
                }),
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message);
                        $('#pettyCashDropdown').trigger('change');
                        $(this).prop('disabled', true);
                        $('.declinePettyCashBtn').prop('disabled', true);
                    } else {
                        toastr.error(res.message); 
                    }
                },
                error: function(xhr, status, error) {
                    toastr.error('Error updating status: ' + error);
                }
            });
        });

        // When "Decline" button is clicked
        $(document).on('click', '.declinePettyCashBtn', function() {
                    const requestId = $(this).data('pettycashid');  
            if (!requestId) return;
            $.ajax({
                url: '@Url.Action("UpdatePettyCashStatus", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    RequestId: requestId,
                    NewStatus: 'Declined'
                }),
                success: function(res) {
                    if (res.status) {
                        toastr.warning(res.message);
                        $('#pettyCashDropdown').trigger('change');
                        $(this).prop('disabled', true);
                        $('.approvePettyCashBtn').prop('disabled', false);
                    } else {
                        toastr.error(res.message);  
                    }
                },
                error: function(xhr, status, error) {
                    toastr.error('Error updating status: ' + error);
                }
            });
        });

        $(document).on('change', '#pettyCashNameDropdown', function() {
            const selected = $(this).find(':selected');
            $('#pettyCashCode').val(selected.data('code') || '');
            $('#pettyCashNo').val(selected.data('code') || '');
            $('#pettyCashEmployeeId').val(selected.data('empid') || '');
        });

        function calculateTotalAmount() {
            let total = 0;
            $('#pettyCashTableBody tr').each(function() {
                const val = parseFloat($(this).find('td:eq(8) input').val());
                if (!isNaN(val)) total += val;
            });
            return total;
        }

        $('#savePettyCashBtn').on('click', function() {
            const pettyCashName = $('#pettyCashNameDropdown').val();
            const pettyCashDate = $('#pettyCashDate').val();
            const empId = parseInt($('#pettyCashEmployeeId').val()) || 0;
                    const vendorId = parseInt($('.vendorName').val()) || 0;
            if (!pettyCashName) return toastr.warning('Select Petty Cash Name');

            const totalAmount = calculateTotalAmount();
            if (!totalAmount) return toastr.warning('Enter at least one valid amount');
            
            const details = [];
            $('#pettyCashTableBody tr').each(function() {
                const row = $(this);
                const amount = parseFloat(row.find('td:eq(8) input').val()) || 0;

                if (amount > 0) {
