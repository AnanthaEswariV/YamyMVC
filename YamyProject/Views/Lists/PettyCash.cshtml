
@{
    ViewData["Title"] = "PettyCash";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<!-- Basic Tables start -->
<section class="section">
    <div class="row" id="basic-table">
        <div class="col-12 col-md-4">
            <div class="card" style="height: 150%;">
                <div class="card-header d-flex justify-content-end">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-primary dropdown-toggle"
                                type="button"
                                id="configMenuButton"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                title="Configure">
                            <i class="fas fa-cog"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="configMenuButton">
                            <li>
                                <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#pettyCashModal">
                                    <i class="fas fa-plus-circle me-2 text-success"></i> New P.C A/C
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Lists/PettyCashCategory">
                                    <i class="fas fa-list-alt me-2 text-primary"></i> P.C Categories
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Lists/PettyCashVoucher">
                                    <i class="fas fa-wallet me-2 text-warning"></i> New Petty Cash
                                </a>
                            </li>
                          @*   <li>
                                <a class="dropdown-item" href="#">
                                    <i class="fas fa-edit me-2 text-info"></i> Edit Petty Cash
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="fas fa-trash me-2 text-danger"></i> Delete Petty Cash
                                </a>
                            </li> *@
                        </ul>
                    </div>
                </div>

                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                      
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="pettyCashTable">
                                <thead class="table-ligh">
                                    <tr>
                                        <th>Code</th>
                                        <th>Employee Name</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows will be loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-8">
                <div class="card" style="height: 150%;">
                    <div class="card-header">
                        <h5 class="card-title">Petty cash Log</h5>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs" id="myTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="home-tab" data-bs-toggle="tab" href="#home"
                                   role="tab" aria-controls="home" aria-selected="true">Petty Cash Voucher</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="profile-tab" data-bs-toggle="tab" href="#profile"
                                   role="tab" aria-controls="profile" aria-selected="false">Transactions</a>
                            </li>
                        </ul>
                        <div class="tab-content" id="myTabContent">
                            <div class="tab-pane fade show active" id="home" role="tabpanel"
                                 aria-labelledby="home-tab">
                            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                                <table class="table table-striped custom-table mb-0" id="pettyCashVoucherTable">
                                    <thead class="table-ligh">
                                        <tr>
                                            <th>S.No</th>
                                            <th>Code</th>
                                            <th>Date</th>
                                            <th>Total</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Rows will be loaded dynamically -->
                                    </tbody>
                                </table>
                            </div>
                            </div>
                            <div class="tab-pane fade" id="profile" role="tabpanel"
                                 aria-labelledby="profile-tab">
                            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                                <table class="table table-striped custom-table mb-0" id="pettyCashTransactionsTable">
                                    <thead class="table-ligh">
                                        <tr>
                                            <th>S.No</th>
                                            <th>Date</th>
                                            <th>Voucher No</th>
                                            <th>Type</th>
                                            <th>Inv Id</th>
                                            <th>Description</th>
                                            <th>Debit</th>
                                            <th>Credit</th>
                                            <th>Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Rows will be loaded dynamically -->
                                    </tbody>
                                </table>
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
   
</section>
<!-- Basic Tables end -->


<div class="modal fade" id="pettyCashModal" tabindex="-1" aria-labelledby="pettyCashModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="pettyCashForm" class="needs-validation" novalidate>
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="pettyCashModalLabel">Petty Cash Card - New</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <!-- Hidden ID -->
                    <input type="hidden" id="pettyCashId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Code</label>
                            <input type="text" id="code" class="form-control" placeholder="Code" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Employee Name</label>
                            <select id="employeeSelect" class="form-select" required>
                                <option value="">-- Select Employee --</option>
                                <!-- Options will be loaded dynamically -->
                            </select>
                            <div class="invalid-feedback">Please select an employee.</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Account Code</label>
                            <input type="text" id="accountCode" class="form-control" placeholder="Account Code" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Account Name</label>
                            <select id="accountSelect" class="form-select" required>
                                <option value="">-- Select Account --</option>
                            </select>
                            <div class="invalid-feedback">Please select an account.</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Mobile</label>
                            <input type="text" id="mobile" class="form-control" placeholder="0543991167">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">WhatsApp No</label>
                            <input type="text" id="whatsapp" class="form-control">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" id="email" class="form-control">
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>

            </div>
        </form>
    </div>
</div>




                                                                        
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>


<script>

        $(document).ready(function () {

            // 1️⃣ Load Petty Cash Cards
            function loadPettyCashCards() {
                $.ajax({
                    url: '@Url.Action("GetPettyCashCards", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        let tbody = $("#pettyCashTable tbody");
                        tbody.empty();
                        console.log(res);
                        if (res.status && res.data.length > 0) {
                            res.data.forEach(card => {
                                tbody.append(`
                                    <tr class="employee-row" data-empcode="${card.empCode}">
                                        <td>${card.code ?? ""}</td>
                                        <td>${card.employeeName ?? ""}</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary edit-card"
                                                    data-id="${card.id}"
                                                    data-code="${card.empCode}"
                                                    data-empname="${card.employeeId}"
                                                    data-accountid="${card.accountId}"
                                                    data-mobile="${card.mobile}"
                                                    data-whatsapp="${card.whatsapp_no}"
                                                    data-email="${card.email}">
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger delete-card" data-id="${card.id}">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append(`<tr><td colspan="3" class="text-center text-muted">No petty cash cards found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error("Failed to load petty cash cards");
                    }
                });
            }

            $(document).on('click', '.employee-row', function () {
                let empCode = $(this).data('empcode');
                if (!empCode) {
                    console.error("❌ empCode not found");
                    return;
                }

                // Highlight selected row
                $('.employee-row').removeClass('table-primary');
                $(this).addClass('table-primary');

                loadVouchers(empCode);
                loadTransactions(empCode);
            });

            // 3️⃣ Load Petty Cash Vouchers
            function loadVouchers(empCode) {
                $.ajax({
                   url: '@Url.Action("GetEmployeePettyCash", "Lists")',
                    type: 'GET',
                    data: { empCode: empCode },
                    success: function (res) {
                        let tbody = $("#pettyCashVoucherTable tbody");
                        tbody.empty();

                        if (res.status && res.data.length > 0) {
                            res.data.forEach((voucher, index) => {
                                tbody.append(`
                                    <tr>
                                        <td>${index + 1}</td>
                                        <td>${voucher.code ?? ""}</td>
                                        <td>${voucher.date ?? ""}</td>
                                        <td class="text-end">${voucher.total ?? voucher.totalWithVAT ?? 0}</td>
                                        <td>${voucher.status ?? ""}</td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append(`<tr><td colspan="5" class="text-center text-muted">No vouchers found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error("Failed to load vouchers");
                    }
                });
            }

            // 4️⃣ Load Petty Cash Transactions
            function loadTransactions(empCode) {
                $.ajax({
                url: '@Url.Action("GetEmployeePettyCashTransactions", "Lists")',
                    type: 'GET',
                    data: { empCode: empCode }, 
                    success: function (res) {
                        let tbody = $("#pettyCashTransactionsTable tbody");
                        tbody.empty();

                        if (res.status && res.data.length > 0) {
                            res.data.forEach((trx, index) => {
                                tbody.append(`
                                    <tr>
                                        <td>${index + 1}</td>
                                        <td>${trx.date ?? ""}</td>
                                        <td>${trx.no ?? ""}</td>
                                        <td>${trx.type ?? ""}</td>
                                        <td>${trx.invoiceId ?? ""}</td>
                                        <td>${trx.description ?? ""}</td>
                                        <td class="text-end">${trx.debit ?? 0}</td>
                                        <td class="text-end">${trx.credit ?? 0}</td>
                                        <td class="text-end">${trx.balance ?? 0}</td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append(`<tr><td colspan="9" class="text-center text-muted">No transactions found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error("Failed to load transactions");
                    }
                });
            }

            loadPettyCashCards();

            $(document).on("click", ".edit-card", function () {
            const card = $(this).data();
            if (!card) return;
           

            $("#pettyCashId").val(card.id || 0);
            $("#code").val(card.code || "");

            // Employee
            const $empSelect = $("#employeeSelect");
            if (card.empname) {   
                $empSelect.val(card.empname);
            } else {
                $empSelect.prop("disabled", false);
            }

            // Account
            const $accSelect = $("#accountSelect");
            if (card.accountid) {   // your backend sends accountid
                $accSelect.val(card.accountid);
            }
            $("#accountCode").val($accSelect.find(':selected').data('code') || "");

            // Other fields
            $("#mobile").val(card.mobile || "");
            $("#whatsapp").val(card.whatsapp || "");   // not whatsapp_no
            $("#email").val(card.email || "");

            $("#pettyCashModalLabel").text("Edit Petty Cash Card");
            $("#pettyCashModal").modal("show");
        });

            // Submit form (unchanged, works for both create and update)
            $('#pettyCashForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const idVal = $('#pettyCashId').val();
            const isEdit = idVal && parseInt(idVal) > 0;

            const pettyCashData = {
                Id: isEdit ? parseInt(idVal) : 0,
                Code: $('#code').val() || '',
                EmployeeId: parseInt($('#employeeSelect').val()) || 0,
                Mobile: $('#mobile').val() || '',
                WhatsappNo: $('#whatsapp').val() || '',
                Email: $('#email').val() || '',
                AccountId: parseInt($('#accountSelect').val()) || 0
            };

            $.ajax({
              url: '@Url.Action("SavePettyCashCard", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(pettyCashData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? 'Petty Cash Card updated' : 'Petty Cash Card created');
                        $('#pettyCashModal').modal('hide');
                        $('#pettyCashForm')[0].reset();
                        loadPettyCashCards(); // reload table
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

           function loadAccounts() {
                    $.ajax({
                        url: '/HR/GetAccruedSalaries',
                        type: 'GET',
                        success: function (data) {
                            const dropdowns = [
                                        { ddl: '#accountSelect', codeBox: '#accountCode' },
                            ];

                            dropdowns.forEach(set => {
                                const $ddl = $(set.ddl);
                                $ddl.empty().append('<option value="">-- Select --</option>');

                                data.forEach(item => {
                                    $ddl.append(
                                        $('<option>', {
                                            value: item.id,
                                            text: item.code + ' - ' + item.name,
                                            'data-code': item.code
                                        })
                                    );
                                });

                                // 🔹 Update account code textbox on change
                                $ddl.off('change').on('change', function () {
                                    const selected = $(this).find(':selected');
                                    $(set.codeBox).val(selected.data('code') || "");
                                });
                            });
                        },
                        error: function (xhr, status, error) {
                            console.error("❌ Error loading accounts:", status, error);
                            toastr.error("Server error while loading accounts");
                        }
                    });
                }

           loadAccounts();

            function loademployee() {
            $.ajax({
              url: '@Url.Action("GetEmployees", "HR")',
                type: 'GET',
                success: function (res) {

                    const employees = res.data;

                    const $ddl = $('#employeeSelect');
                    if ($ddl.length === 0) {
                        console.error("❌ #employeeSelect not found in DOM");
                        return;
                    }

                    $ddl.empty().append('<option value="">-- Select Employee --</option>');

                    if (!Array.isArray(employees)) {
                        console.error("❌ res.data is not an array:", employees);
                        return;
                    }

                    employees.forEach((item, index) => {

                        const empId = item.id ?? "";
                        const empCode = item.code ?? "";
                        const empName = item.name ?? "";

                        if (!empId || !empName) return;

                        $ddl.append(
                            $('<option>', {
                                value: empId,
                                text: `${empCode} - ${empName}`,
                                'data-code': empCode
                            })
                        );
                    });

                    // 🔄 Update code field when selected
                    $ddl.off('change').on('change', function () {
                        const selected = $(this).find(':selected');
                        const selectedCode = selected.data('code') || "";
                        $('#code').val(selectedCode);
                    });
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading employees:", status, error);
                    toastr.error("Server error while loading employees");
                }
            });
        }

             loademployee();

            // Reset form when modal is fully hidden
            $('#pettyCashModal').on('hidden.bs.modal', function () {
            // Reset form fields
            $('#pettyCashForm')[0].reset();

            // Clear hidden ID and dropdowns
            $('#pettyCashId').val(0);
            $('#employeeSelect').prop('disabled', false).val('');
            $('#accountSelect').val('');
            $('#accountCode').val('');

            // Reset modal title
            $("#pettyCashModalLabel").text("New Petty Cash Card");

            // Remove validation styles
            $('#pettyCashForm').removeClass('was-validated');
        });

            $(document).on("click", ".delete-card", function () {
            const id = $(this).data("id");
            if (!confirm("Are you sure you want to delete this Petty Cash Card?")) return;

            $.ajax({
              url: '@Url.Action("DeletePettyCashCard", "Lists")' + '/' + id,
                type: 'DELETE',
                success: function (res) {
                    if (res.status) {
                        toastr.success("Petty Cash Card deleted successfully!");
                        loadPettyCashCards(); // refresh your table
                    } else {
                        toastr.error(res.message || "Error deleting Petty Cash Card");
                    }
                },
                error: function (err) {
                    console.error("AJAX error:", err);
                    toastr.error("Server error occurred while deleting Petty Cash Card");
                }
            });
        });


        });


    </script>



}