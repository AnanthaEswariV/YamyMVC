@{
    ViewData["Title"] = "ChartOfAccount";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="container py-3">
    <div class="content">

        <!-- Search + Button Row -->
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <!-- Search box -->
            <div class="search-box position-relative flex-grow-1" style="max-width: 400px;">
                <input type="text" class="form-control ps-5" placeholder="Search accounts..." id="searchInput">
                <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary">🔍</span>
            </div>

            <!-- Add button -->
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#coaModal">
                <i class="bi bi-plus-lg"></i> Add Account
            </button>
        </div>

        <!-- COA Tree -->
        <div class="tree border rounded-3 p-3 bg-light" id="coaTree" style="min-height: 300px;">
            <div class="loading text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <div>Loading accounts...</div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="editAccountModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Edit Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editAccountId" />
                <div class="mb-3">
                    <label class="form-label">Account Name</label>
                    <input type="text" id="editAccountName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Debit</label>
                    <input type="number" id="editDebit" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Credit</label>
                    <input type="number" id="editCredit" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Due Date</label>
                    <input type="date" id="editDate" class="form-control" />
                </div>
                <div class="col-3">
                    <label class="form-label fw-semibold">Cost Center</label>
                    <select class="form-select form-select-sm editcostCenterSelect" data-selected-id="5">
                        <option value="">-- Select --</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="saveEditAccount" class="btn btn-primary">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- COA - New Account Modal -->
<div class="modal fade" id="coaModal" tabindex="-1" aria-labelledby="coaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content rounded-4 shadow-lg border-0">
            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="coaModalLabel">COA - New Account</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <form id="coaForm" class="needs-validation" novalidate>
                <div class="modal-body px-4 py-3">
                    <input type="hidden" id="level4Id" value="0">

                    <!-- LEVEL 1 -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">LEVEL 1</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm flex-grow-1" id="ddlLevel1" required></select>
                            <a href="/Lists/ChartOfAccountL1" class="text-primary" title="Chart of Account L1">
                                <i class="fas fa-plus-circle fs-6"></i>
                            </a>
                        </div>
                    </div>

                    <!-- LEVEL 2 -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">LEVEL 2</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm flex-grow-1" id="ddlLevel2" required></select>
                            <a href="/Lists/ChartOfAccountL2" class="text-primary">
                                <i class="fas fa-plus-circle fs-6"></i>
                            </a>
                        </div>
                    </div>

                    <!-- LEVEL 3 -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">LEVEL 3</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm flex-grow-1" id="ddlLevel3" required></select>
                            <a href="/Lists/ChartOfAccountL3" class="text-primary">
                                <i class="fas fa-plus-circle fs-6"></i>
                            </a>
                        </div>
                    </div>

                    <!-- LEVEL 4 -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">LEVEL 4</label>
                        <input type="text" id="txtLevel4" class="form-control form-control-sm" placeholder="Enter Level 4" required>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-3">
                            <label class="form-label fw-semibold">Debit</label>
                            <input type="number" id="txtDebit" class="form-control form-control-sm" placeholder="Debit" value="0">
                        </div>

                        <div class="col-3">
                            <label class="form-label fw-semibold">Credit</label>
                            <input type="number" id="txtCredit" class="form-control form-control-sm" placeholder="Credit" value="0">
                        </div>

                        <div class="col-3">
                            <label class="form-label fw-semibold">Due Date</label>
                            <input type="date" id="txtDate" class="form-control form-control-sm">
                        </div>

                        <div class="col-3">
                            <label class="form-label fw-semibold">Cost Center</label>
                            <select class="form-select form-select-sm costCenterSelect" data-selected-id="5">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer justify-content-between">
                    <button type="submit" class="btn btn-primary px-4 rounded-3">Save</button>
                    <button type="button" class="btn btn-outline-secondary px-4 rounded-3" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        .container {
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: white;
            padding: 30px 40px;
            position: relative;
            overflow: hidden;
        }

            .header::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -20%;
                width: 200px;
                height: 200px;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 50%;
                animation: float 6s ease-in-out infinite;
            }

        keyframes float {
            0%, 100%

        {
            transform: translateY(0px) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(180deg);
        }

        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
        }

        .header p {
            opacity: 0.9;
            font-size: 1.1rem;
            position: relative;
            z-index: 1;
        }

        .content {
            padding: 40px;
        }

        .search-box {
            position: relative;
            margin-bottom: 30px;
        }

        .search-input {
            width: 100%;
            padding: 15px 50px 15px 20px;
            font-size: 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            background: #f9fafb;
            transition: all 0.3s ease;
        }

            .search-input:focus {
                outline: none;
                border-color: #4f46e5;
                background: white;
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
            }

        .search-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 20px;
        }

        .tree {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

            .tree ul {
                list-style: none;
                margin: 0;
                padding: 0;
                display: none;
            }

            .tree > ul {
                display: block;
            }

            .tree li {
                position: relative;
                transition: all 0.3s ease;
            }

        .tree-node {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            border-bottom: 1px solid #f3f4f6;
            position: relative;
        }

            .tree-node:hover {
                background: linear-gradient(90deg, #f8fafc 0%, #f1f5f9 100%);
                transform: translateX(5px);
            }

            .tree-node.level-0 {
                color: #2563eb;
                background: lightgray;
                font-weight: bold;
                font-size: 16px;
                border-radius: 6px;
                padding: 10px 14px;
                margin-bottom: 6px;
                font-color: blue;
            }

                .tree-node.level-0:hover {
                    background: gray;
                    transform: translateX(0);
                }

            .tree-node.level-1 {
                background: linear-gradient(90deg, #f0f9ff 0%, #e0f2fe 100%);
                font-weight: 600;
                color: #0369a1;
                border-left: 4px solid #0ea5e9;
            }

                .tree-node.level-1:hover {
                    background: linear-gradient(90deg, #e0f2fe 0%, #bae6fd 100%);
                }

        .toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.2);
            margin-right: 15px;
            font-size: 12px;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .tree-node.level-0 .toggle {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .tree-node:not(.level-0) .toggle {
            background: #e5e7eb;
            color: #6b7280;
        }

        .toggle:hover {
            transform: scale(1.1);
            background: rgba(255, 255, 255, 0.3);
        }

        .toggle.expanded {
            transform: rotate(90deg);
        }

        .account-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 16px;
            flex-shrink: 0;
        }

        .level-0 .account-icon {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .level-1 .account-icon {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .level-2 .account-icon, .level-3 .account-icon {
            background: #f3f4f6;
            color: #6b7280;
        }

        .account-info {
            flex: 1;
            min-width: 0;
        }

        .account-code {
            font-family: 'Courier New', monospace;
            font-weight: 600;
            font-size: 0.9rem;
            opacity: 0.8;
        }

        .account-name {
            font-weight: 500;
            margin-top: 2px;
        }

        .tree-node.level-0 .account-code,
        .tree-node.level-0 .account-name {
            color: blue;
        }


        .tree li ul {
            margin-left: 0;
            border-left: 2px solid #e5e7eb;
            margin-left: 50px;
        }

        .tree li.level-0 > ul {
            border-left: none;
            margin-left: 0;
        }

        .loading {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
            color: #6b7280;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid #e5e7eb;
            border-top: 3px solid #4f46e5;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 15px;
        }

        keyframes spin {
            0%

        {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }

        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6b7280;
        }

            .empty-state svg {
                width: 80px;
                height: 80px;
                margin: 0 auto 20px;
                opacity: 0.5;
            }

        .dot-indicator {
            color: #9ca3af;
            margin-right: 10px;
            font-size: 1.2rem;
        }

        media (max-width: 768px) {
            .container

        {
            margin: 10px;
            border-radius: 15px;
        }

        .header {
            padding: 20px 25px;
        }

            .header h1 {
                font-size: 2rem;
            }

        .content {
            padding: 25px;
        }

        .tree-node {
            padding: 12px 15px;
        }

        }
    </style>

    <script>
        $(function () {

            // ✅ Single declaration at the TOP — shared by all functions
            let isEditMode = false;

            // ─── Build Tree ───────────────────────────────────────────────
            function buildTree(nodes, container) {
                container.empty();
                const ul = $("<ul></ul>");
                nodes.forEach(node => ul.append(createNodeLi(node, 0)));
                container.append(ul);
                ul.show();
            }

            function createNodeLi(node, level) {
                const li = $("<li>").addClass(`level-${level}`);
                const nodeDiv = $("<div>").addClass(`tree-node level-${level}`);

                const id = node.id ?? '';
                const code = node.code ?? '';
                const name = node.name ?? '';
                const debit = (node.debit === 0 || node.debit) ? node.debit : '';
                const credit = (node.credit === 0 || node.credit) ? node.credit : '';
                const date = formatDateForInput(node.date ?? node.due ?? '');
                const costCenter = node.costCenter ?? '';

                nodeDiv.attr({
                    'data-id': id,
                    'data-code': code,
                    'data-name': name,
                    'data-debit': debit,
                    'data-credit': credit,
                    'data-date': date,
                    'data-costCenter': costCenter
                });

                if (node.children && Array.isArray(node.children) && node.children.length) {
                    const toggle = $("<div class='toggle'>▶</div>");
                    toggle.on("click", function (e) {
                        e.stopPropagation();
                        const $childUl = $(this).closest('.tree-node').next("ul");
                        if ($childUl.is(":visible")) {
                            $childUl.slideUp(250);
                            $(this).removeClass('expanded').text("▶");
                        } else {
                            $childUl.slideDown(250);
                            $(this).addClass('expanded').text("▼");
                        }
                    });
                    nodeDiv.append(toggle);
                } else {
                    nodeDiv.append("<div class='dot-indicator'>•</div>");
                }

                const infoDiv = $("<div class='account-info'></div>");
                infoDiv.append(`<div class='account-code'>${code}</div>`);
                infoDiv.append(`<div class='account-name'>${name}</div>`);
                nodeDiv.append(infoDiv);

                if (level === 3) {
                    const actionContainer = $("<div class='action-container'></div>");
                    const editBtn = $(`<button class="btn btn-sm btn-outline-primary ms-2" title="Edit"><i class="fas fa-pen"></i></button>`);
                    editBtn.on("click", e => {
                        e.stopPropagation();
                        const nid = $(e.currentTarget).closest('.tree-node').attr('data-id');
                        openCoaEditModal(nid);
                    });

                    const deleteBtn = $(`<button class="btn btn-sm btn-outline-danger ms-2" title="Delete"><i class="fas fa-trash-alt"></i></button>`);
                    deleteBtn.on("click", e => {
                        e.stopPropagation();
                        const $node = $(e.currentTarget).closest('.tree-node');
                        deleteLevel4Account($node.attr('data-id'), $node.attr('data-name'));
                    });

                    actionContainer.append(editBtn, deleteBtn);
                    nodeDiv.append(actionContainer);
                    nodeDiv.css('cursor', 'default');
                } else {
                    nodeDiv.on('click', function (e) {
                        e.stopPropagation();
                        const $toggle = $(this).find('> .toggle');
                        if ($toggle.length) $toggle.trigger('click');
                    });
                }

                li.append(nodeDiv);

                if (node.children && Array.isArray(node.children) && node.children.length) {
                    const childUl = $("<ul></ul>").hide();
                    node.children.forEach(child => childUl.append(createNodeLi(child, level + 1)));
                    li.append(childUl);
                }

                return li;
            }

            // ─── Search ───────────────────────────────────────────────────
            function setupSearch() {
                $('#searchInput').on('input', function () {
                    const searchTerm = $(this).val().toLowerCase().trim();
                    if (!searchTerm) {
                        $('.tree li').show();
                        $('.tree ul').hide();
                        $('.tree > ul').show();
                        $('.toggle').text('▶').removeClass('expanded');
                        return;
                    }
                    $('.tree li').each(function () {
                        const $li = $(this);
                        const code = $li.find('.account-code').first().text().toLowerCase();
                        const name = $li.find('.account-name').first().text().toLowerCase();
                        if (code.includes(searchTerm) || name.includes(searchTerm)) {
                            $li.show();
                            $li.parents('li').show();
                            $li.parents('ul').show();
                            $li.parents('li').find('> .tree-node .toggle').text('▼').addClass('expanded');
                        } else {
                            $li.hide();
                        }
                    });
                });
            }

            // ─── Load COA ─────────────────────────────────────────────────
            function loadChartOfAccounts() {
                $("#coaTree").html('<div class="loading"><div class="spinner"></div>Loading accounts...</div>');
                $.getJSON('@Url.Action("GetCOA", "Lists")')
                    .done(function (data) {
                        if (data && data.status === false) {
                            $("#coaTree").html(renderEmpty("Unable to Load Accounts", data.message));
                            return;
                        }
                        let nodes = (data && data.data && Array.isArray(data.data)) ? data.data : data;
                        if (!Array.isArray(nodes)) {
                            $("#coaTree").html(renderEmpty("Data Format Error", "Unexpected data format received from server."));
                            return;
                        }
                        buildTree(nodes, $("#coaTree"));
                        setupSearch();
                    })
                    .fail(function () {
                        $("#coaTree").html(renderEmpty("Connection Error", "Unable to load Chart of Accounts. Please try again."));
                    });
            }

            function renderEmpty(title, message) {
                return `
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <h3>${title}</h3>
                    <p>${message || ''}</p>
                </div>`;
            }

            // ─── Open Edit Modal ──────────────────────────────────────────
            function openCoaEditModal(id) {
                if (!id) { toastr.error("Invalid account id"); return; }

                const toInt = v => { const n = parseInt(v); return isNaN(n) ? 0 : n; };

                const $modal  = $('#coaModal');
                const $ddl1   = $modal.find('#ddlLevel1');
                const $ddl2   = $modal.find('#ddlLevel2');
                const $ddl3   = $modal.find('#ddlLevel3');

                $.ajax({
                    url: '@Url.Action("GetLevel4AccountById", "Lists")',
                    type: 'GET',
                    data: { id: id },
                    success: function (res) {
                        if (!res || !res.status) {
                            toastr.error(res?.message || "Failed to load account details");
                            return;
                        }
                        const d = res.data || {};
                        d.level1Id = toInt(d.level1Id);
                        d.level2Id = toInt(d.level2Id);
                        d.level3Id = toInt(d.level3Id);
                        loadLevel1Options(d);
                    },
                    error: function () { toastr.error('Failed to fetch account details'); }
                });

                // ── inner helpers (use $ddl1/2/3 from closure above) ──────

                function loadLevel1Options(d) {
                    $.ajax({
                        url: '@Url.Action("GetLevel1Accounts", "Lists")',
                        type: 'GET',
                        success: function (r1) {
                            $ddl1.empty().append('<option value="">Select Level 1</option>');
                            if (r1.status && Array.isArray(r1.data)) {
                                r1.data.forEach(row => $ddl1.append(`<option value="${row.id}">${row.name}</option>`));
                            }
                            if (d.level1Id && $ddl1.find(`option[value="${d.level1Id}"]`).length === 0) {
                                $ddl1.append(`<option value="${d.level1Id}">${d.level1Name || 'Level 1'}</option>`);
                            }
                            if (d.level1Id) {
                                $ddl1.val(String(d.level1Id));
                                loadLevel2Options(d.level1Id, d);
                            } else {
                                populateFieldsAndShow(d);
                            }
                        },
                        error: function () {
                            toastr.error('Failed to load Level 1 accounts.');
                            populateFieldsAndShow(d);
                        }
                    });
                }

                function loadLevel2Options(level1Id, d) {
                    if (!level1Id) return populateFieldsAndShow(d);
                    $.ajax({
                        url: '@Url.Action("GetLevel2AccountsByLevel1", "Lists")' + '?level1Id=' + level1Id,
                        type: 'GET',
                        success: function (r2) {
                            $ddl2.empty().append('<option value="">Select Level 2</option>');
                            if (r2.status && Array.isArray(r2.data)) {
                                r2.data.forEach(row => $ddl2.append(`<option value="${row.id}">${row.name}</option>`));
                            }
                            if (d.level2Id && $ddl2.find(`option[value="${d.level2Id}"]`).length === 0) {
                                $ddl2.append(`<option value="${d.level2Id}">${d.level2Name || 'Level 2'}</option>`);
                            }
                            if (d.level2Id) {
                                $ddl2.val(String(d.level2Id));
                                loadLevel3Options(d.level2Id, d);
                            } else if (d.level3Id) {
                                $.ajax({
                                    url: '@Url.Action("GetLevel3ById", "Lists")',
                                    type: 'GET',
                                    data: { id: d.level3Id },
                                    success: function (rL3) {
                                        const toInt2 = v => { const n = parseInt(v); return isNaN(n) ? 0 : n; };
                                        const resolvedLevel2Id = toInt2(rL3?.data?.lvl2Id || rL3?.data?.level2Id || 0);
                                        const resolvedLevel2Name = rL3?.data?.level2Name || d.level2Name || '';
                                        if (resolvedLevel2Id > 0) {
                                            if ($ddl2.find(`option[value="${resolvedLevel2Id}"]`).length === 0) {
                                                $ddl2.append(`<option value="${resolvedLevel2Id}">${resolvedLevel2Name || 'Level 2'}</option>`);
                                            }
                                            $ddl2.val(String(resolvedLevel2Id));
                                            loadLevel3Options(resolvedLevel2Id, d);
                                        } else {
                                            loadLevel3Options(0, d);
                                        }
                                    },
                                    error: function () { loadLevel3Options(0, d); }
                                });
                            } else {
                                populateFieldsAndShow(d);
                            }
                        },
                        error: function () {
                            toastr.error('Failed to load Level 2 accounts.');
                            populateFieldsAndShow(d);
                        }
                    });
                }

                function loadLevel3Options(level2Id, d) {
                    $ddl3.empty().append('<option value="">Select Level 3</option>');
                    if (!level2Id || level2Id <= 0) {
                        if (d.level3Id) {
                            $ddl3.append(`<option value="${d.level3Id}">${d.level3Name || 'Level 3'}</option>`);
                            $ddl3.val(String(d.level3Id));
                        }
                        return populateFieldsAndShow(d);
                    }
                    $.ajax({
                        url: '@Url.Action("GetLevel3AccountsByLevel2", "Lists")' + '?id=' + level2Id,
                        type: 'GET',
                        success: function (r3) {
                            if (r3.status && Array.isArray(r3.data)) {
                                r3.data.forEach(row => $ddl3.append(`<option value="${row.id}">${row.name}</option>`));
                            }
                            if (d.level3Id && $ddl3.find(`option[value="${d.level3Id}"]`).length === 0) {
                                $ddl3.append(`<option value="${d.level3Id}">${d.level3Name || 'Level 3'}</option>`);
                            }
                            if (d.level3Id) $ddl3.val(String(d.level3Id));
                            populateFieldsAndShow(d);
                        },
                        error: function () {
                            toastr.error('Failed to load Level 3 accounts.');
                            populateFieldsAndShow(d);
                        }
                    });
                }

                // ✅ populateFieldsAndShow is INSIDE openCoaEditModal
                //    so it can access $ddl1/2/3 AND the outer isEditMode
                function populateFieldsAndShow(d) {
                    const id       = d.level4Id || d.Id || 0;
                    const name     = d.level4Name || d.level4 || d.name || "";
                    const debit    = (d.debit  !== undefined && d.debit  !== null) ? d.debit  : 0;
                    const credit   = (d.credit !== undefined && d.credit !== null) ? d.credit : 0;
                    const dateVal  = d.date ? d.date.toString().slice(0, 10) : '';
                    const costCenter = (d.costCenter !== undefined && d.costCenter !== null) ? String(d.costCenter) : '';

                    $modal.find('#level4Id').val(id);
                    $modal.find('#txtLevel4').val(name);
                    $modal.find('#txtDebit').val(debit);
                    $modal.find('#txtCredit').val(credit);
                    $modal.find('#txtDate').val(dateVal);
                    $modal.find('#coaModalLabel').text('Edit Level 4 Account');

                    // ✅ Set BEFORE showing so shown.bs.modal knows to skip reset
                    isEditMode = true;

                    populateAndSelectCostCenter(function () {
                        $modal.find('.costCenterSelect').val(costCenter);
                    });

                    const modalEl = document.getElementById('coaModal');
                    if (modalEl && window.bootstrap) {
                        new bootstrap.Modal(modalEl).show();
                    } else {
                        $modal.modal('show');
                    }
                }
            } // ─── end openCoaEditModal ────────────────────────────────────

            // ─── Delete Level4 ────────────────────────────────────────────
            function deleteLevel4Account(id, name) {
                if (!id) { toastr.error("Invalid account selected."); return; }
                if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

                $.ajax({
                    url: `@Url.Action("DeleteCoaLevel4", "Lists")?id=${id}`,
                    type: 'DELETE',
                    success: function (res) {
                        if (res.status) {
                            toastr.success(res.message || "Account deleted successfully");
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            toastr.error(res.message || "Failed to delete account");
                        }
                    },
                    error: function (xhr) {
                        toastr.error(xhr.responseJSON?.message || xhr.statusText || "Error deleting account");
                    }
                });
            }

            // ─── Date Helper ──────────────────────────────────────────────
            function formatDateForInput(d) {
                if (!d) return '';
                const dt = new Date(d);
                if (isNaN(dt.getTime())) return '';
                const month = (dt.getMonth() + 1).toString().padStart(2, '0');
                const day   = dt.getDate().toString().padStart(2, '0');
                return `${dt.getFullYear()}-${month}-${day}`;
            }

            // ─── Add-Mode Dropdown Loaders ────────────────────────────────
            function loadLevel2(level1Id) {
                const $ddl2 = $('#ddlLevel2');
                const $ddl3 = $('#ddlLevel3');
                $ddl2.empty().append('<option value="">Select Level 2</option>');
                $ddl3.empty().append('<option value="">Select Level 3</option>');
                if (!level1Id) return;
                $.ajax({
                    url: '@Url.Action("GetLevel2AccountsByLevel1", "Lists")' + '?level1Id=' + level1Id,
                    type: 'GET',
                    success: function (res) {
                        if (res.status && res.data?.length > 0) {
                            res.data.forEach(row => $ddl2.append(`<option value="${row.id}">${row.name}</option>`));
                        }
                    },
                    error: function () { toastr.error('Failed to load Level 2 accounts.'); }
                });
            }

            function loadLevel3(level2Id) {
                const $ddl3 = $('#ddlLevel3');
                $ddl3.empty().append('<option value="">Select Level 3</option>');
                if (!level2Id) return;
                $.ajax({
                    url: '@Url.Action("GetLevel3AccountsByLevel2", "Lists")' + '?id=' + level2Id,
                    type: 'GET',
                    success: function (res) {
                        if (res.status && res.data?.length > 0) {
                            res.data.forEach(row => $ddl3.append(`<option value="${row.id}">${row.name}</option>`));
                        }
                    },
                    error: function () { toastr.error('Failed to load Level 3 accounts.'); }
                });
            }

            // ─── Cost Centers ─────────────────────────────────────────────
            function populateAndSelectCostCenter(callback) {
                $.ajax({
                    url: '@Url.Action("GetCostCenters", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        const data = Array.isArray(res) ? res : (res.data || []);
                        $('.costCenterSelect, .editcostCenterSelect').each(function () {
                            const $select    = $(this);
                            const selectedId = $select.data('selected-id');
                            $select.empty().append('<option value="">-- Select --</option>');
                            $.each(data, function (i, item) {
                                const isSelected = String(item.id) === String(selectedId);
                                $select.append(`<option value="${item.id}" ${isSelected ? 'selected' : ''}>${item.code} - ${item.name}</option>`);
                            });
                        });
                        if (typeof callback === 'function') callback();
                    }
                });
            }

            // ─── Modal Events ─────────────────────────────────────────────
            // Fires BEFORE animation starts
            $('#coaModal').on('show.bs.modal', function () {
                if (!isEditMode) {
                    // ADD mode: reset title & id immediately
                    $('#coaModalLabel').text('COA - New Account');
                    $('#level4Id').val(0);
                }
            });

            // Fires AFTER modal is fully visible
            $('#coaModal').on('shown.bs.modal', function () {
                if (isEditMode) {
                    // ✅ Edit mode: dropdowns already populated — just reset flag
                    isEditMode = false;
                    return;
                }

                // ─── ADD MODE: Reset & load Level 1 ───────────────────────
                $('#coaForm')[0].reset();
                $('#level4Id').val(0);
                $('#txtDebit').val(0);
                $('#txtCredit').val(0);
                $('#ddlLevel2').empty().append('<option value="">Select Level 2</option>');
                $('#ddlLevel3').empty().append('<option value="">Select Level 3</option>');

                $.ajax({
                    url: '@Url.Action("GetLevel1Accounts", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        const $ddl1 = $('#ddlLevel1');
                        $ddl1.empty().append('<option value="">Select Level 1</option>');
                        if (res.status && Array.isArray(res.data) && res.data.length > 0) {
                            res.data.forEach(row => $ddl1.append(`<option value="${row.id}">${row.name}</option>`));
                        } else {
                            toastr.warning('No Level 1 accounts found.');
                        }
                    },
                    error: function (xhr) {
                        toastr.error('Failed to load Level 1 accounts. Status: ' + xhr.status);
                    }
                });
            });

            // Reset hidden id and title when modal fully closes
            $('#coaModal').on('hidden.bs.modal', function () {
                $('#level4Id').val(0);
                $('#coaModalLabel').text('COA - New Account');
                isEditMode = false;
            });

            // ─── Cascade Dropdowns (Add mode) ─────────────────────────────
            $('#ddlLevel1').on('change', function () { loadLevel2($(this).val()); });
            $('#ddlLevel2').on('change', function () { loadLevel3($(this).val()); });

            // ─── Form Submit ──────────────────────────────────────────────
            $('#coaForm').on('submit', function (e) {
                e.preventDefault();
                const form = this;
                if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

                const idVal     = $('#level4Id').val();
                const isEdit    = idVal && parseInt(idVal) > 0;
                const payload   = {
                    Id:         isEdit ? parseInt(idVal) : 0,
                    Name:       $('#txtLevel4').val().trim(),
                    Level3Id:   parseInt($('#ddlLevel3').val() || 0),
                    Debit:      parseFloat($('#txtDebit').val())  || 0,
                    Credit:     parseFloat($('#txtCredit').val()) || 0,
                    Date:       $('#txtDate').val() || null,
                    CostCenter: $('.costCenterSelect').val() || null
                };

                const url  = isEdit
                    ? '@Url.Action("EditCoaLevel4", "Lists")'
                    : '@Url.Action("AddLevel4Account", "Lists")';
                const type = isEdit ? 'PUT' : 'POST';

                $.ajax({
                    url: url,
                    type: type,
                    contentType: 'application/json; charset=utf-8',
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.status) {
                            toastr.success(res.message || (isEdit ? 'Account updated' : 'Account added'));
                            $('#coaModal').modal('hide');
                            $('#coaForm')[0].reset();
                            $('#level4Id').val(0);
                            $('#coaModalLabel').text('COA - New Account');
                            form.classList.remove('was-validated');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            toastr.error(res.message || 'Operation failed');
                        }
                    },
                    error: function (xhr) {
                        toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Error');
                    }
                });
            });

            // ─── Init ─────────────────────────────────────────────────────
            loadChartOfAccounts();
            populateAndSelectCostCenter();
            window.openCoaEditModal = openCoaEditModal;

        }); // end $(function)
    </script>
}