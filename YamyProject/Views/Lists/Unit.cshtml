@{
    ViewData["Title"] = "Unit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />


<div class="card">
    <div class="card-header text-center">
        <strong>Unit List</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUnitModal">
                <i class="bi bi-plus-lg"></i> Add Unit
            </button>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="unitTable">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Unit Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

</div>

@Html.Partial("_Unit")

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>

         $(document).ready(function () {
                loadUnits
         });

          function loadUnits() {
            $.ajax({
        url: '@Url.Action("GetUnit", "Lists")',
                type: 'GET',

                beforeSend: function () {
                    $('#unitTable tbody').html(`
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading Units...
                            </td>
                        </tr>
                    `);
                },

                success: function (res) {
                    console.log(res);
                    if (!res || res.length === 0) {
                        const tbody = $('#unitTable tbody');
                        tbody.html(`
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    No units found
                                </td>
                            </tr>
                        `);
                        return;
                    }

                    // Destroy existing DataTable if initialized
                    if ($.fn.DataTable.isDataTable('#unitTable')) {
                        $('#unitTable').DataTable().clear().destroy();
                    }

                    const tbody = $('#unitTable tbody');
                    tbody.empty();

                          $.each(res.data, function (i, u) {
            const tr = `
                <tr data-id="${u.id}">
                    <td>${i + 1}</td>
                    <td>${u.unitName}</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-primary editUnitBtn"
                                data-unit='${JSON.stringify(u)}'>
                            <i class="fas fa-pen"></i>
                        </button>
                        <button class="btn btn-sm btn-danger deleteUnitBtn"
                                onclick="deleteUnit(${u.id})">
                            <i class="fas fa-prescription-bottle-alt"></i>
                        </button>
                    </td>
                </tr>
            `;
            tbody.append(tr);
        });


                    $('#unitTable').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                className: 'btn btn-primary btn-sm',
                                  exportOptions: {
                columns: ':not(:last-child)'
            }
                            },
                            {
                                extend: 'pdfHtml5',
                                text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                className: 'btn btn-primary btn-sm',
                                orientation: 'landscape',
                                pageSize: 'A4',
                                  exportOptions: {
                columns: ':not(:last-child)'
            }
                            }
                        ],
                        order: [[0, 'asc']],
                        pageLength: 15
                    });
                },

                error: function () {
                    toastr.error('Error loading units data');
                }
            });
        }

          function saveUnit() {
            const name = $("#addUnitName").val();

            if (!name.trim()) {
                toastr.warning("Please enter a unit name.");
                return;
            }

            $.ajax({
            url: '@Url.Action("AddUnit", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Name: name }),
                success: function (res) {
                    if (res.status) {
                        const modalEl = document.getElementById("addUnitModal");
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        modal.hide();
                        $("#addUnitForm")[0].reset();
                        toastr.success('Unit Added Successfully!');
                        // Optional reload after short delay
                        setTimeout(function () {
                            location.reload();
                        }, 1500);
                    } else {
                        toastr.error(res.message || 'Failed to add unit');
                    }
                },
                error: function (xhr) {
                    toastr.error("Error: " + xhr.responseText);
                }
            });
        }

          $(document).on('click', '.editUnitBtn', function () {
            const unit = $(this).data('unit'); // parses the data-unit JSON automatically
            openEditModal(unit.id, unit.unitName);
        });

          function openEditModal(id, name) {
            $("#editUnitId").val(id);
            $("#editUnitName").val(name);
            const modal = new bootstrap.Modal(document.getElementById("editUnitModal"));
            modal.show();
        }

           function updateUnit() {
            const id = $("#editUnitId").val();
            const name = $("#editUnitName").val();

            if (!name.trim()) {
                alert("Please enter a unit name.");
                return;
            }

            $.ajax({
               url: '@Url.Action("EditUnit", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id, name: name }),
                success: function(res) {
                    if (res.status) {
                        const modalEl = document.getElementById("editUnitModal");
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        modal.hide();
                        toastr.success('Unit Edited Successfully!');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    if (xhr.status === 409) {
                        toastr.warning('Unit name already exists.');
                    } else {
                        toastr.error('Error updating unit.');
                    }
                }
            });
        }

          function deleteUnit(id) {
            if (!confirm("Are you sure you want to delete this unit?")) return;

            $.ajax({
                url: '@Url.Action("DeleteUnit", "Lists")' + '?id=' + id,
                type: 'POST',
                success: function(res) {
                    if (res.status) {
                        toastr.success('Unit Deleted Successfully!');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error('Error deleting unit.');
                }
            });
        }

           document.addEventListener("DOMContentLoaded", loadUnits);
    </script>
}
