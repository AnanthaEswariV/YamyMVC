@{
    ViewData["Title"] = "FixedAssetsCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />


<div class="card">
    <div class="card-header text-center">
        <strong>Fixed Assets Category List</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addFixedAssetsCategoryModal">
                <i class="bi bi-plus-lg"></i>Fixed Assets Category
            </button>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="fixedAssetCategoryTable">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

</div>



@Html.Partial("_FixedAssetsCategory")




@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>


    <script>

                       function loadFixedAssetCategories() {
            $.ajax({
               url: '@Url.Action("GetFixedAssetsCategory", "Lists")',
                type: "GET",

                beforeSend: function () {
                    $('#fixedAssetCategoryTable tbody').html(`
                        <tr>
                            <td colspan="2" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading Asset Categories...
                            </td>
                        </tr>
                    `);
                },

                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load asset categories');
                        return;
                    }

                    // Destroy the existing DataTable if already initialized
                    if ($.fn.DataTable.isDataTable("#fixedAssetCategoryTable")) {
                        $("#fixedAssetCategoryTable").DataTable().clear().destroy();
                    }

                    const tbody = $("#fixedAssetCategoryTable tbody");
                    tbody.empty();

                    // Check if the data is available and has records
                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, cat) {
                            const tr = `
                                <tr data-id="${cat.id}">
                                    <td>${cat.category_name ?? ''}</td>
                                    <td class="text-center">
                                                <button class="btn btn-sm btn-primary edit-btn" data-id="${cat.id}"
                data-name="${cat.category_name}" data-assets="${cat.assets_account_id}"
                data-assets-code="${cat.assets_account_id}" data-depreciation="${cat.depreciation_account_id}"
                data-depreciation-code="${cat.depreciation_account_id}" data-expence="${cat.expence_account_id}"
                data-expence-code="${cat.expence_account_id}">
            <i class="fas fa-pen"></i>
        </button>

                                        <button class="btn btn-sm btn-danger delete-btn"
                                                data-id="${cat.id}">
                                            <i class="fas fa-prescription-bottle-alt"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        $('#fixedAssetCategoryTable').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {
                                        columns: ':not(:last-child)'
                                    }
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4',
                                    exportOptions: {
                                        columns: ':not(:last-child)'
                                    }
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 10
                        });

                    } else {
                        tbody.append(`
                            <tr><td colspan="2" class="text-center text-muted py-4">
                                No asset categories found
                            </td></tr>
                        `);
                    }
                },

                error: function () {
                    toastr.error('Error loading asset categories data');
                }
            });
        }



           function addFixedAssetsCategory() {
                    let model = {
                        CategoryName: $("#categoryName").val(),
                        AssetsAccountId: $("#fixedAssetsAccount").val(),
                        DepreciationAccountId: $("#accumulatedDepreciation").val(),
                        ExpenceAccountId: $("#depreciationExpense").val()
                    };

                    if (!model.CategoryName) {
                        alert("Please enter Category Name");
                        return;
                    }

                    $.ajax({
                url: '@Url.Action("AddFixedAssetsCategory", "Lists")',
                        method: "POST",
                        contentType: "application/json",
                        data: JSON.stringify(model),
                        success: function (res) {
                            if (res.status) {
                                $("#addFixedAssetsCategoryModal").modal("hide");
                                $("#addFixedAssetsCategoryForm")[0].reset();
                                       // Show success message
                                toastr.success("Category Added Successfully!");

                                // Optional: reload page after short delay
                                setTimeout(() => location.reload(), 1500); loadFixedAssetCategories();

                            } else {
                                    toastr.error(res.message || "Error saving category");
                            }
                        },
                        error: function (xhr) {
                               console.error(err);
                            toastr.error("Server error occurred while saving category");
                        }
                    });
                }

           $(document).ready(function () {
            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function (data) {

                    // List of dropdowns with their matching code textbox
                    const dropdowns = [
                            { ddl: '#fixedAssetsAccount', codeBox: '#code2' },
                            { ddl: '#accumulatedDepreciation', codeBox: '#code3' },
                            { ddl: '#depreciationExpense', codeBox: '#code4' }
                    ];

                    dropdowns.forEach(set => {
                        let $ddl = $(set.ddl);


                        $ddl.empty().append('<option value="">-- Select --</option>');

                        $.each(data, function (i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name,
                                    'data-code': item.code
                                })
                            );
                        });



                        // On change, update the code textbox
                        $ddl.on('change', function () {
                            let selected = $(this).find(':selected');
                            let code = selected.data('code');
                            console.log("Selected in", set.ddl, ":", selected.text(), "Code:", code);
                            $(set.codeBox).val(code || "");
                        });
                    });
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                }
            });

             loadFixedAssetCategories();
        });

           $(document).ready(function() {
                       function loadEditDropdowns(selectedAssets, selectedDepreciation, selectedExpence, codes = {}) {
            $.ajax({
               url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function (data) {
                    const dropdowns = [
                        { ddl: '#editFixedAssetsAccount', codeBox: '#editCode2', selected: selectedAssets, code: codes.assetsCode },
                        { ddl: '#editAccumulatedDepreciation', codeBox: '#editCode3', selected: selectedDepreciation, code: codes.depreciationCode },
                        { ddl: '#editDepreciationExpence', codeBox: '#editCode4', selected: selectedExpence, code: codes.expenceCode }
                    ];

                    dropdowns.forEach(set => {
                        let $ddl = $(set.ddl);
                        $ddl.empty().append('<option value="">-- Select --</option>');

                        $.each(data, function (i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name,
                                    'data-code': item.code
                                })
                            );
                        });

                        // Set the selected value AFTER the options are added
                        $ddl.val(set.selected);

                        // Set the code textbox value
                        $(set.codeBox).val(set.code || '');

                        // On change, update the code box
                        $ddl.off("change").on('change', function () {
                            let selectedOption = $(this).find(':selected');
                            $(set.codeBox).val(selectedOption.data('code') || '');
                        });
                    });
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                }
            });
        }

                       $(document).on("click", ".edit-btn", function () {
            const id = $(this).data("id");
            const name = $(this).data("name");
            const assets = $(this).data("assets");
            const assetsCode = $(this).data("assets-code");
            const depreciation = $(this).data("depreciation");
            const depreciationCode = $(this).data("depreciation-code");
            const expence = $(this).data("expence");
            const expenceCode = $(this).data("expence-code");

            // Log the values to verify what is being passed (you can remove this later)
            console.log("Depreciation:", depreciation, "Code:", depreciationCode);
            console.log("Expense:", expence, "Code:", expenceCode);

            // Set the values in the modal
            $("#editCategoryId").val(id);
            $("#editCategoryName").val(name);  // This should populate the Category Name input field

            // Load the dropdowns and set selected values based on passed data
            loadEditDropdowns(assets, depreciation, expence, {
                assetsCode: assetsCode,
                depreciationCode: depreciationCode,
                expenceCode: expenceCode
            });

            // Show the modal
            $("#editFixedAssetsCategoryModal").modal("show");
        });


                 $("#updateBtn").on("click", function () {
                const model = {
                    Id: parseInt($("#editCategoryId").val()),
                    CategoryName: $("#editCategoryName").val().trim(),
                    AssetsAccountId: parseInt($("#editFixedAssetsAccount").val()) || 0,
                    DepreciationAccountId: parseInt($("#editAccumulatedDepreciation").val()) || 0,
                    ExpenceAccountId: parseInt($("#editDepreciationExpence").val()) || 0

                };

                $.ajax({
            url: '@Url.Action("EditFixedAssetsCategory", "Lists")',
                    type: "PUT",
                    contentType: "application/json",
                    data: JSON.stringify(model),
                    success: function (res) {
                        if (res.status) {
                            $("#editFixedAssetsCategoryModal").modal("hide");
                            toastr.success(res.message);
                            loadFixedAssetCategories();
                        } else {
                            toastr.error(res.message);
                        }
                    },
                    error: function (err) {
                        console.error(err);
                        toastr.error("Server error occurred while updating category");
                    }
                });
            });


            });


                    // Delete Fixed Asset Category
        $(document).on("click", ".delete-btn", function () {
            const categoryId = $(this).data("id");

            if (!categoryId) return;

            // Confirmation
            if (!confirm("Are you sure you want to delete this category?")) return;

            $.ajax({
           url: '@Url.Action("DeleteFixedAssetCategory", "Lists")' + '?id=' + categoryId,
                type: 'DELETE',
                success: function (res) {
                    if (res.status) {
                        toastr.success("Category deleted Successfully!");
                        setTimeout(() => location.reload(), 1500); loadFixedAssetCategories();
                    } else {
                        toastr.error(res.message || "Cannot delete this category.");
                    }
                },
                error: function (err) {
                    if (err.responseJSON && err.responseJSON.message) {
                toastr.error(err.responseJSON.message);
            } else {
                toastr.error("An error occurred while deleting the category.");
            }
                }
            });
        });

    </script>
}