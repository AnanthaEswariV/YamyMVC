@{
    ViewData["Title"] = "Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />


<div class="card">
    <div class="card-header text-center">
        <i class="bi bi-building text-success fs-1 mb-3"></i>
        <h5 class="card-title fw-bold">Department</h5>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDepartmentModal">
                <i class="bi bi-plus-lg"></i> Department
            </button>


        </div>
        <!-- Table -->
        <table class="table table-striped" id="departmentTable">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Department</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>



<!-- Add Department Modal -->
<div class="modal fade" id="addDepartmentModal" tabindex="-1" aria-labelledby="addDepartmentLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addDepartmentLabel">Add New Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addDepartmentForm">
                    <div class="mb-3">
                        <label for="addDepartmentName" class="col-form-label">Department Name</label>
                        <input type="text" class="form-control" id="addDepartmentName" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveDepartment()">Save</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="editDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editDepartmentId">
                <div class="mb-3">
                    <label for="editDepartmentName" class="col-form-label">Department Name</label>
                    <input type="text" class="form-control" id="editDepartmentName">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="updateDepartment()">Update</button>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        let taxDataTable; // global reference
                  // Configure Toastr options
             toastr.options = {
                 "closeButton": true,
                 "debug": false,
                 "newestOnTop": false,
                 "progressBar": true,
                 "positionClass": "toast-top-right",
                 "preventDuplicates": false,
                 "onclick": null,
                 "showDuration": "300",
                 "hideDuration": "1000",
                 "timeOut": "5000", // Adjust to desired display duration
                 "extendedTimeOut": "1000",
                 "showEasing": "swing",
                 "hideEasing": "linear",
                 "showMethod": "fadeIn",
                 "hideMethod": "fadeOut"
             };


        function saveDepartment() {
            const name = $("#addDepartmentName").val().trim();

            if (!name) {
                toastr.warning("Please enter Department Name");
                return;
            }

            $.ajax({
              url: '@Url.Action("AddDepartment", "Lists")',
                type: 'POST',
                contentType: 'application/json', // important
                data: JSON.stringify({ name: name }), // send JSON body
                success: function(res) {
                    if (res.status) {
                        // Hide modal
                        const modalEl = document.getElementById("addDepartmentModal");
                        bootstrap.Modal.getInstance(modalEl)?.hide();

                        // Reset form
                        $("#addDepartmentForm")[0].reset();

                        // Show success message
                        toastr.success("Department Added Successfully!");

                        // Optional: reload page after short delay
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message || "Error saving department");
                    }
                },
                error: function(err) {
                    console.error(err);
                    toastr.error("Server error occurred while saving department");
                }
            });
        }


              function loadDepartments() {
            $.ajax({
             url: '@Url.Action("GetDepartments", "Lists")',
                type: "GET",
                success: function (res) {
                    if (res.status) {
                        if ($.fn.DataTable.isDataTable("#departmentTable")) {
                            $("#departmentTable").DataTable().destroy();
                        }

                        let tbody = $("#departmentTable tbody");
                        tbody.empty();
                        console.log(res);

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, dept) {
                                let tr = `
                                    <tr>
                                        <td>${i + 1}</td>
                                        <td>${dept.name ?? "-"}</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary edit-btn me-2"
                                                data-id="${dept.id}" title="Edit Department">
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger delete-btn"
                                                data-id="${dept.id}" title="Delete Department">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                `;
                                tbody.append(tr);
                            });

                            $("#departmentTable").DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                      extend: 'print',
                                      text: '<i class="fas fa-print me-1"></i> Print',
                                      className: 'btn btn-primary btn-sm',
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15
                            });
                        } else {
                            tbody.append(`<tr><td colspan="3" class="text-center" style="padding:40px; color:#6c757d; font-style:italic;">No records found</td></tr>`);
                            $('.dt-buttons').hide();
                        }
                    } else {
                        $("#departmentTable tbody").html(`<tr><td colspan="3" class="text-center" style="color:red; padding:40px;">Error: ${res.message || 'Failed to load data'}</td></tr>`);
                        $('.dt-buttons').hide();
                    }
                },
                error: function (xhr, status, error) {
                    if ($.fn.DataTable.isDataTable("#departmentTable")) {
                        $("#departmentTable").DataTable().destroy();
                    }
                    $("#departmentTable tbody").html(`<tr><td colspan="3" class="text-center" style="color:red; padding:40px;">Error loading data: ${error}</td></tr>`);
                    $('.dt-buttons').hide();
                }
            });
        }


        $(document).ready(function() {
            loadDepartments();
        });


                // Open modal for editing
        $(document).on("click", ".edit-btn", function() {
            const id = $(this).data("id");
            const row = $(this).closest("tr");
            const name = row.find("td:first").text();

            $("#editDepartmentId").val(id);
            $("#editDepartmentName").val(name);
            $("#editDepartmentModal").modal("show");
        });


         function updateDepartment() {
            const id = parseInt($("#editDepartmentId").val());
            const name = $("#editDepartmentName").val().trim();
                    console.log("Id:", $("#editDepartmentId").val());
        console.log("Name:", $("#editDepartmentName").val());

            if (!name) {
                toastr.warning("Please enter department name");
                return;
            }

            $.ajax({
               url: '@Url.Action("EditDepartment", "Lists")',
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({ Id: id, Name: name }),
                success: function(res) {
                    if (res.status) {
                        $("#editDepartmentModal").modal("hide");
                        toastr.success(res.message);
                        // Optional: reload page after short delay
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(err) {
                    console.error(err);
                    toastr.error("Server error occurred while updating department");
                }
            });
        }



        $(document).on("click", ".delete-btn", function() {
            const id = $(this).data("id");
            if (!confirm("Are you sure you want to delete this department?")) return;

            $.ajax({
           url: `@Url.Action("DeleteDepartment", "Lists")/${id}`,
                type: 'DELETE',
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message);
                        loadDepartments(); // Refresh table
                    } else {
                        toastr.error(res.message || "Error deleting department");
                    }
                },
                error: function(err) {
                    console.error(err);
                    toastr.error("Server error occurred while deleting department");
                }
            });
        });



    </script>
}