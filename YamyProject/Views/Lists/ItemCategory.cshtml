@{
    ViewData["Title"] = "ItemCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Item Category</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                <i class="bi bi-plus-lg"></i> Add Category
            </button>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Category Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

</div>


@Html.Partial("_ItemCategory.cshtml")

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
       

         $(document).ready(function () {
             if (document.getElementById("table1")) {
                 loadCategories();
             }
         });

        function loadCategories() {
            $.ajax({
              url: '@Url.Action("GetItemCategory", "Lists")',
                type: 'GET',

                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading Categories...
                            </td>
                        </tr>
                    `);
                },

                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load categories');
                        return;
                    }

                    // Destroy the existing DataTable if already initialized
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    // Check if the data is available and has records
                    if (res.data && res.data.length > 0) {
                        console.log(res);
                        $.each(res.data, function (i, cat) {
                            const tr = `
                                <tr data-id="${cat.id}">
                                    <td>${i + 1}</td>
                                   <td>${cat.code} - ${cat.name}</td>
                                    <td class="text-center">
                                                <button class="btn btn-sm btn-primary editCategoryBtn"
                data-category='${JSON.stringify(cat)}'>
            <i class="fas fa-pen"></i>
        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteCategory(${cat.id})">
                                            <i class="fas fa-prescription-bottle-alt"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        $('#table1').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {
                                     columns: ':not(:last-child)'
                                    }
                                },
                               {
                                  extend: 'print',
                                  text: '<i class="fas fa-print me-1"></i> Print',
                                  className: 'btn btn-primary btn-sm',
                                  exportOptions: {  columns: ':not(:last-child)'}
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });

                    } else {
                        tbody.append(`
                            <tr><td colspan="3" class="text-center text-muted py-4">
                                No categories found
                            </td></tr>
                        `);
                    }
                },

                error: function () {
                    toastr.error('Error loading categories data');
                }
            });
        }

        $(document).on("click", ".editCategoryBtn", function () {

            const cat = $(this).data("category");

            $("#categoryId").val(cat.id);
           $("#categoryName").val(cat.name); 


            $("#addCategoryModalLabel").text("Edit Category");
            $("#addCategoryModal").modal("show");
        });

        $("#categoryForm").on("submit", function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add("was-validated");
                return;
            }

            const idVal = $("#categoryId").val();
            const isEdit = idVal && parseInt(idVal) > 0;

            const categoryData = {
                Id: isEdit ? parseInt(idVal) : 0,
                CategoryName: $("#categoryName").val().trim()
            };

            $.ajax({
                url: isEdit
        ? '@Url.Action("EditCategory", "Lists")'
        : '@Url.Action("AddCategory", "Lists")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(categoryData),

                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? "Category updated successfully" : "Category added successfully");
                        $("#addCategoryModal").modal("hide");

                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },

                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Request error");
                }
            });
        });

        $("#addCategoryBtn").on("click", function () {
            $("#categoryModalLabel").text("Add Category");
            $("#categoryForm")[0].reset();
            $("#categoryId").val(0);
            $("#categoryModal").modal("show");
        });

        function deleteCategory(id) {
             if (!confirm("Are you sure you want to delete category ID " + id + "?")) {
                 return;
             }

             $.ajax({
               url: '@Url.Action("DeleteCategory", "Lists")',
                 type: 'POST', 
                 data: { id: id },
                 success: function (result) {
                        if (result.status) {
                                toastr.success('Category Deleted Successfully!');
                                setTimeout(function () {
                                   location.reload();
                                }, 1500); // Optional delay before redirect
                            } else {
                                 toastr.error(result.message);
                            }
                 },
                 error: function (xhr, status, error) {
                     alert("Error: " + error);
                 }
             });
         }

    </script>
}

