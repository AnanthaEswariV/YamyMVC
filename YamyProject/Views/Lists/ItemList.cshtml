@{
    ViewData["Title"] = "ItemList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<style>

    .inventory-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
        text-align: center;
    }

    .employee-toolbar {
        background: #e7e6e6;
        margin: 0 -15px;
        padding: 5px 15px;
        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .employee-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .dataTables_wrapper {
        padding: 50px;
    }
    .go-to-link {
        color: #0066cc;
        text-decoration: none;
        font-size: 11px;
        float: right;
    }

  

</style>

<div class="inventory-header">
    Inventory Center
</div>

<div class="employee-toolbar">
    <div class="container">

        <!-- Top Controls -->
        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <ul class="nav nav-pills">
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                            <i class="bi bi-gear-fill me-1"></i> Item Operation
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newItemModal">
                                    <i class="bi bi-plus-circle me-2"></i> New Item
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
            <div class="col-md-4">
                <button type="button" class="btn btn-primary go-to-link">
                    <i class="fas fa-cart-plus"></i> Go To Item
                </button>
            </div>
        </div>

        <div class="row">
            <!-- Warehouse Table -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="itemsTable">
                                <thead>
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Type</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Items Table -->
            <div class="col-md-8">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="dataTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Barcode</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>INV NO</th>
                                        <th>Type</th>
                                        <th>Qty In</th>
                                        <th>Qty Out</th>
                                        <th>Cost Price</th>
                                        <th>Sales Price</th>
                                        <th>Qty Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</div>

<!-- New Item Modal -->
<div class="modal fade" id="newItemModal" tabindex="-1" aria-labelledby="newItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #5865f2;">
                <h5 class="modal-title"><i class="fas fa-box"></i> Inventory - New Item</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="newItemForm">
                    <input type="hidden" id="itemId" value="0" />

                    <!-- Warehouse & Type -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted">Warehouse</label>
                            <select class="form-select" id="warehouseDropdown"><option value="">Select Warehouse</option></select>
                            <button class="btn btn-outline-secondary" type="button" id="btnNew" data-bs-toggle="modal" data-bs-target="#newWarehouseModal">New</button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Item Type</label>
                            <select class="form-select" id="typeSelect" onchange="changeFormLayout()">
                                <option value="11 - Inventory Part">11 - Inventory Part</option>
                                <option value="12 - Service">12 - Service</option>
                                <option value="13 - Inventory Assembly">13 - Inventory Assembly</option>
                            </select>
                        </div>
                    </div>

                    <!-- Category & Inventory Type -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted">Category</label>
                            <select id="categoryDropdowns" class="form-select"><option value="">Loading...</option></select>
                            <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#addCategoryModal">New</button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Inventory Type</label>
                            <select class="form-select" id="inventoryType">
                                <option value="Inventory" selected>Inventory</option>
                                <option value="Service">Service</option>
                                <option value="Non-Inventory">Non-Inventory</option>
                            </select>
                        </div>
                    </div>

                    <!-- Item Code & Name -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Item Code</label>
                            <input type="text" disabled class="form-control bg-light" id="itemCodeInput" placeholder="Item Code">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Item Name</label>
                            <input type="text" class="form-control" id="itemNameInput" placeholder="Item Name" required>
                        </div>
                    </div>

                    <!-- Inventory Section -->
                    <div id="inventorySection">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Opening Qty</label>
                                <input type="number" class="form-control" id="onHandInput" placeholder="On Hand" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Cost Price</label>
                                <input type="number" class="form-control" id="costPriceInput" placeholder="Cost Price" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Total</label>
                                <input type="number" class="form-control bg-light" id="totalValueInput" placeholder="Total Value" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">As Of</label>
                                <input type="date" class="form-control" id="asOfDateInput" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted">Cost Center</label>
                                <select id="costCenterSelect" class="form-select"><option value="">Loading...</option></select>
                            </div>
                        </div>
                    </div>

                    <!-- Sales & Active -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Sales Price</label>
                            <input type="number" class="form-control" id="salesPriceInput" placeholder="Sales Price">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="itemActive" checked>
                                <label class="form-check-label" for="itemActive">Item Active</label>
                            </div>
                        </div>
                    </div>

                    <!-- Barcode Section -->
                    <div id="barcodeSection" class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Barcode</label>
                            <input type="text" class="form-control" id="barcodeInput" placeholder="Barcode">
                        </div>
                    </div>

                    <!-- Unit & Costing -->
                    <div id="unitCostingSection" class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted">Main Unit</label>
                            <select class="form-select" id="mainUnit"></select>
                            <button type="button" class="btn btn-outline-primary mt-4" data-bs-toggle="modal" data-bs-target="#addUnitModal">Add More Unit</button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Costing Method</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="avg" checked>
                                    <label class="form-check-label" for="avg">AVG</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="fifo">
                                    <label class="form-check-label" for="fifo">FIFO</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="lifo">
                                    <label class="form-check-label" for="lifo">LIFO</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Min/Max Section -->
                    <div id="minMaxSection" class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Min Amount</label>
                            <input type="number" class="form-control" id="minAmountInput" placeholder="Min Amount">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Max Amount</label>
                            <input type="number" class="form-control" id="maxAmountInput" placeholder="Max Amount">
                        </div>
                    </div>

                    <!-- Accounts -->
                    <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted">COGS Account</label>
                                    <select id="cogsAccount" class="form-select form-select-sm"></select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted">Asset Account</label>
                                    <select id="assetAccount" class="form-select form-select-sm"></select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted">Income Account</label>
                                    <select id="incomeAccount" class="form-select form-select-sm"></select>
                                </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold text-muted">Preferred Vendor</label>
                                <select id="preferredVendor" class="form-select form-select-sm"></select>
                            </div>
                        </div>
                    </div>
                    <div id="assemblyTable" class="mb-3" style="display:none;">
                        <h6>Assembly Items</h6>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Item Name</th>
                                    <th>Cost</th>
                                    <th>Qty</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                        <button type="button" onclick="addAssemblyRow()">Add Assembly Item</button>
                    </div>
                </form>
         
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times"></i> CLOSE</button>
                <button type="button" class="btn btn-primary" onclick="saveItem()"><i class="fas fa-save"></i> Save</button>
            </div>



        
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="itemCardModal" tabindex="-1" aria-labelledby="itemCardModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="itemCardModalLabel">Item Card Transactions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Item Info -->
                <div class="mb-3">
                    <strong>Item ID:</strong> <span id="modalItemCode"></span> |
                    <strong>Method:</strong> <span id="modalItemMethod"></span> |
                    <strong>On Hand:</strong> <span id="modalItemOnHand"></span> |
                    <strong>Cost:</strong> <span id="modalItemCost"></span>
                </div>

                <!-- Transactions Table -->
                
                            
                            <div class="table-responsive">
                                <table id="modalTransactionTable" class="table table-striped">
                                    <thead>
                            <tr>
                                <th>Date</th>
                                <th>Warehouse</th>
                                <th>INV NO</th>
                                <th>Trans No</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Price</th>
                                <th>Qty In</th>
                                <th>Qty Out</th>
                                <th>Qty Balance</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th>Balance</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.Partial("~/Views/Inventory/_WareHouse.cshtml")
@Html.Partial("~/Views/Lists/_ItemCategory.cshtml")
@Html.Partial("~/Views/Lists/_Unit.cshtml")
@Html.Partial("~/Views/HR/_Employee.cshtml")

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>
        let selectedItem = null;
        let assemblyItems = [];
         loadAccountsAndDefaults();
          loadPreferredVendors();
        function loadAssemblyItems() {
            $.ajax({
              url: '@Url.Action("GetItems", "Lists")',
                type: 'GET',
                success: function (res) {
                    if (res.status && res.data.length > 0) {
                        assemblyItems = res.data; 
                       
                    } else {
                        assemblyItems = [];
                    }
                },
                error: function (err) {
                    console.error("Failed to load items:", err);
                    assemblyItems = [];
                }
            });
        }

        function addAssemblyRow() {
            if (assemblyItems.length === 0) return;

            const tableBody = $("#assemblyTable tbody");
            const row = $("<tr></tr>");

            // Item Name (Dropdown)
            const nameTd = $('<td></td>');
            const select = $('<select class="form-control item-select"><option value="">Select Item</option></select>');
            assemblyItems.forEach(item => {
                select.append(`<option value="${item.id}" data-cost="${item.cost_price}">${item.itemName}</option>`);
            });
            nameTd.append(select);

            // Cost
            const costTd = $('<td><input type="number" class="form-control item-cost" readonly /></td>');

            // Qty
            const qtyTd = $('<td><input type="number" class="form-control item-qty" value="1" min="1" /></td>');

            // Action
            const actionTd = $('<td><button type="button" class="btn btn-danger btn-sm remove-row">Remove</button></td>');

            row.append(nameTd, costTd, qtyTd, actionTd);
            tableBody.append(row);

            $("#assemblyTable").show();

            // On change, update cost
            select.on("change", function () {
                const selectedOption = $(this).find("option:selected");
                const cost = selectedOption.data("cost") || 0;
                row.find(".item-cost").val(cost);
            });

            // Remove row
            actionTd.find(".remove-row").on("click", function () {
                row.remove();
                if ($("#assemblyTable tbody tr").length === 0) {
                    $("#assemblyTable").hide();
                }
            });
        }


                function getTodayDate() {
                const today = new Date();
                const year = today.getFullYear();
                const month = String(today.getMonth() + 1).padStart(2, '0');
                const day = String(today.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

         document.getElementById('newItemModal').addEventListener('shown.bs.modal', function () {
                const todayDate = getTodayDate();

                // Fill all date fields
                const dateFields = [
                     'asOfDateInput'
                ];

                dateFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (field && !field.value) {
                        field.value = todayDate;
                    }
                });
            });

        function validateForm() {
            let itemName = $("#itemNameInput").val().trim();
            let warehouse = $("#warehouseDropdown").val();
            let category = $("#categoryDropdowns").val();
            let mainUnit = $("#mainUnit").val();
            let onHand = $("#onHandInput").val();
            let costPrice = $("#costPriceInput").val();

            if (!itemName) {
                alert("Item Name is required");
                $("#itemNameInput").focus();
                return false;
            }
            if (!warehouse) {
                alert("Please select a Warehouse");
                $("#warehouseDropdown").focus();
                return false;
            }
            if (!category) {
                alert("Please select a Category");
                $("#categoryDropdowns").focus();
                return false;
            }
        
            // if (onHand === "" || parseFloat(onHand) < 0) {
            //     alert("Opening Qty must be 0 or more");
            //     $("#onHandInput").focus();
            //     return false;
            // }
            // if (costPrice === "" || parseFloat(costPrice) < 0) {
            //     alert("Cost Price must be 0 or more");
            //     $("#costPriceInput").focus();
            //     return false;
            // }
                if (!$("#asOfDateInput").val()) {
            toastr.error("As Of Date is required");
            return false;
        }
            return true; // All checks passed
        }

        // ===== Load Items =====
        function loadItems() {
            const state = $('#stateFilter').val();
            const categoryId = $("#allCat").is(":checked") ? "" : $("#categoryDropdown").val();
            const type = $("#allType").is(":checked") ? "" : $("#typeDropdown").val();

            $.ajax({
          url: '@Url.Action("GetItems", "Lists")',
                type: 'GET',
                data: { state, categoryId, type },
                success: function (result) {
                    const tbody = $('#itemsTable tbody');
                    tbody.empty();
                    if (result.status && result.data.length > 0) {
                        $.each(result.data, function (i, item) {
                            const editBtn = `
                                <button class="btn btn-sm btn-outline-primary edit-item"
                                    data-id="${item.id}"
                                    data-name="${item.itemName ?? ''}"
                                    data-type="${item.type ?? ''}"
                                    data-barcode="${item.barcode ?? ''}"
                                    data-costprice="${item.cost_price ?? 0}"
                                    data-warehouseid="${item.warehouse_id ?? 0}"
                                    data-unitid="${item.unit_id ?? 0}"
                                    data-cogsaccountid="${item.cogs_account_id ?? 0}"
                                    data-vendorid="${item.vendor_id ?? 0}"
                                    data-salesprice="${item.sales_price ?? 0}"
                                    data-taxcodeid="${item.tax_code_id ?? 0}"
                                    data-incomeaccountid="${item.income_account_id ?? 0}"
                                    data-assetaccountid="${item.asset_account_id ?? 0}"
                                    data-minamount="${item.min_amount ?? 0}"
                                    data-maxamount="${item.max_amount ?? 0}"
                                    data-onhand="${item.on_hand ?? 0}"
                                    data-totalvalue="${item.total_value ?? 0}"
                                    data-date="${item.date ?? ''}"
                                    data-active="${item.active ?? 0}"
                                    data-method="${item.method ?? ''}"
                                    data-categoryid="${item.category_id ?? 0}"
                                    data-positem="${item.posItem ?? 0}"
                                    data-itemtype="${item.item_type ?? ''}"
                                     data-costcenter="${item.costcenter ?? 0}">
                                    <i class="fas fa-pen"></i>
                                </button>`;

                            const deleteBtn = `
                                <button class="btn btn-sm btn-outline-danger delete-item" data-id="${item.id}">
                                    <i class="fas fa-trash"></i>
                                </button>`;

                            tbody.append(`
                                <tr data-id="${item.id}" data-name="${item.itemName ?? ''}" data-barcode="${item.barcode ?? ''}" data-type="${item.type ?? ''}">
                                    <td>${item.itemName ?? ''}</td>
                                    <td>${item.type ?? ''}</td>
                                    <td class="text-center">${editBtn} ${deleteBtn}</td>
                                </tr>
                            `);
                        });
                    } else {
                        tbody.append('<tr><td colspan="3" class="text-center text-muted">No items found</td></tr>');
                    }
                },
                error: function (err) {
                    console.error('Error loading items:', err);
                    toastr.error('Failed to load items');
                }
            });
        }

        // ===== Load Categories =====
        function loadCategories(selector = "#categoryDropdown, #categoryDropdowns") {
            $.ajax({
               url: '@Url.Action("GetItemCategory", "Lists")',
                type: 'GET',
                success: function (result) {
                    var dropdowns = $(selector);
                    dropdowns.empty();

                    if (result.status && result.data.length > 0) {
                        dropdowns.append('<option value="">-- Select Category --</option>');
                        $.each(result.data, function (i, category) {
                            dropdowns.append(`<option value="${category.id}">${category.categoryName}</option>`);
                        });
                    } else {
                        dropdowns.append('<option value="">No categories found</option>');
                    }
                },
                error: function (err) {
                    console.error('Error loading categories:', err);
                    toastr.error('Failed to load categories');
                }
            });
        }

       $('#allCat').on('change', function () {
                $('#categoryDropdown').prop('disabled', $(this).is(':checked')).val('');
            });
       if ($('#allCat').is(':checked')) $('#categoryDropdown').prop('disabled', true);


                      function loadWarehouses(selectedId = null) {
            $.ajax({
                url: '@Url.Action("GetWarehouses", "Inventory")',
                type: 'GET',
                success: function(res) {
                    const $warehouse = $('#warehouse');
                    const $warehouseDropdown = $('#warehouseDropdown');

                    $warehouse.empty().append('<option value="">-- Select Warehouse --</option>');
                    $warehouseDropdown.empty().append('<option value="">-- Select Warehouse --</option>');

                    if (res.status && res.data.length > 0) {
                        res.data.forEach(w => {
                            const option1 = new Option(w.name, w.id, selectedId == w.id, selectedId == w.id);
                            const option2 = new Option(w.name, w.id, selectedId == w.id, selectedId == w.id);

                            $warehouse.append(option1);
                            $warehouseDropdown.append(option2);
                        });
                    }
                },
                error: function(xhr) {
                    console.error('❌ Error loading warehouses:', xhr.responseJSON?.message || xhr.statusText);
                }
            });
        }


           function loadPreferredVendors() {
            $.ajax({
                url: '@Url.Action("GetVendorAndSub", "Vendor")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const $ddl = $('#preferredVendor');
                        $ddl.empty().append('<option value="">-- Select Vendor --</option>');

                        $.each(res.data, function (i, v) {
                            $ddl.append(
                                $('<option>', {
                                    value: v.id,
                                    text: v.code + ' - ' + v.name
                                })
                            );
                        });
                    } else {
                        toastr.error(res.message || 'Failed to load vendors');
                    }
                },
                error: function (xhr) {
                    console.error('Error loading vendors:', xhr);
                    toastr.error('Failed to load vendors');
                }
            });
        }

                $("#newWarehouseForm").submit(function(e) {
            e.preventDefault();

            let model = {
                Id: parseInt($("#warehouseId").val()) || 0,
                Name: $("#warehouseName").val(),
                City: $("#city").val(),
                BuildingName: $("#buildingName").val(),
                EmpId: parseInt($("#manager").val()) || null,
                AccountId: parseInt($("#accruedSalaries").val()) || null,
            };
            $.ajax({
                url: '/Inventory/SaveWarehouse',
                type: 'POST',
                contentType: 'application/json',
