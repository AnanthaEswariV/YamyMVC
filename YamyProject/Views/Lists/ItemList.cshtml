        // 🔹 Save function (your base, with insert/update logic)
        function saveItem() {
            if (!validateForm()) return;

            let item = {
                Id: parseInt($("#itemId").val()) || 0,   // 👈 determines Add vs Update
                Name: $("#itemNameInput").val(),
                WarehouseId: parseInt($("#warehouseDropdown").val()) || 0,
                Type: $("#typeSelect").val(),
                CategoryId: parseInt($("#categoryDropdowns").val()) || 0,
                UnitId: parseInt($("#mainUnit").val()) || 0,
                Barcode: $("#barcodeInput").val() || "",
                CostPrice: parseFloat($("#costPriceInput").val()) || 0,
                SalesPrice: parseFloat($("#salesPriceInput").val()) || 0,
                CogsAccountId: parseInt($("#cogsAccount").val()) || 0,
                IncomeAccountId: parseInt($("#incomeAccount").val()) || 0,
                AssetAccountId: parseInt($("#assetAccount").val()) || 0,
                VendorId: $("#preferredVendor").val() ? parseInt($("#preferredVendor").val()) : null,
                MinAmount: parseFloat($("#minAmountInput").val()) || 0,
                MaxAmount: parseFloat($("#maxAmountInput").val()) || 0,
                OnHand: parseFloat($("#onHandInput").val()) || 0,
                Method: $("input[name='costingMethod']:checked").attr("id") || "avg",
                TotalValue: parseFloat($("#totalValueInput").val()) || 0,
                Date: $("#asOfDateInput").val(),
                Active: $("#itemActive").is(":checked"),
                ItemType: $("#inventoryType").val(),
                Units: [{ UnitId: parseInt($("#mainUnit").val()), Factor: 1 }],
                Assemblies: []
            };

            if (item.Type && item.Type.includes("Assembly")) {
                $("#assemblyTable tbody tr").each(function () {
                    const itemId = $(this).find(".item-select").val();
                    const qty = $(this).find(".item-qty").val();
                    if (itemId && qty) {
                        item.Assemblies.push({
                            ItemId: parseInt(itemId),
                            Qty: parseFloat(qty)
                        });
                    }
                });
            }

         

            $.ajax({
                url: '/Lists/SaveItem',
                type: 'POST',
                data: JSON.stringify(item),
                contentType: "application/json",
                success: function (res) {
                    if (res.status) {
                        $("#newItemModal").modal("hide");
                        toastr.success(item.Id > 0 ? "Item Updated Successfully!" : "Item Added Successfully!");
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message || "Something went wrong!");
                    }
                },
                error: function (xhr) {
                    let msg = "An unexpected error occurred.";
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        msg = xhr.responseJSON.message;
                    }
                    toastr.error(msg);
                }
            });
        }


        // ==================
