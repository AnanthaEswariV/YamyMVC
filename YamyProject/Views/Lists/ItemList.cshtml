@{
    ViewData["Title"] = "ItemList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<style>



    .inventory-header {
        background: #4472c4;
        color: white;
        padding: 8px 15px;
        font-weight: bold;
        text-align: center;
        font-size: 14px;
    }

    .mt-4 {
        margin-top: 2.0rem !important;
    }

    .toolbar {
        background: #e7e6e6;
        padding: 5px 15px;
        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
            text-decoration: none;
            border: 1px solid transparent;
        }

            .toolbar .nav-link:hover {
                background-color: rgba(0,0,0,0.1);
                border-radius: 3px;
            }

    .main-container {
        display: flex;
        height: calc(100vh - 80px);
        background: white;
    }
    /* Left Panel Styling */
    .left-panel {
        width: 330px;
        background: #f8f9fa;
        border-right: 2px solid #ddd;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .filter-section {
        padding: 12px;
        border-bottom: 1px solid #ddd;
    }

    .filter-row {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
        font-size: 11px;
    }

    .filter-label {
        width: 60px;
        font-weight: 600;
        color: #333;
        text-align: right;
        margin-right: 10px;
    }

    .filter-control {
        flex: 1;
        display: flex;
        align-items: center;
    }

        .filter-control select {
            flex: 1;
            font-size: 11px;
            padding: 2px 4px;
            border: 1px solid #ccc;
            background: white;
        }

        .filter-control input[type="text"] {
            flex: 1;
            font-size: 11px;
            padding: 3px 6px;
            border: 1px solid #ccc;
        }

    .checkbox-container {
        display: flex;
        align-items: center;
        margin-left: 8px;
        font-size: 11px;
    }

        .checkbox-container input {
            margin-right: 4px;
            transform: scale(0.8);
        }

    /* Items List */
    .items-list {
        flex: 1;
        margin: 8px;
        overflow: hidden;
    }

        .items-list .card {
            height: 100%;
        }

        .items-list .table-responsive {
            max-height: 400px;
            overflow-y: auto;
        }

    .custom-table {
        font-size: 11px;
    }

        .custom-table th {
            font-size: 11px;
            font-weight: 600;
            padding: 6px 8px;
        }

        .custom-table td {
            padding: 4px 8px;
            font-size: 11px;
            cursor: pointer;
        }

        .custom-table tbody tr:hover {
            background-color: #e3f2fd;
        }

        .custom-table tbody tr.selected {
            background-color: #b3d9ff !important;
        }

    .item-code {
        font-weight: 600;
        color: #000;
    }

    .item-type {
        color: #666;
    }

    /* Right Panel */
    .right-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: white;
    }

    .right-header {
        background: #f8f9fa;
        padding: 8px 12px;
        border-bottom: 1px solid #ddd;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .header-info span {
            font-size: 11px;
            color: #555;
        }

    .go-to-link {
        color: #0066cc;
        text-decoration: none;
        font-size: 11px;
    }

    /* Right Panel Data Grid */
    .right-panel .card {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .right-panel .card-body {
        flex: 1;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .data-grid {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

        .data-grid .table-responsive {
            flex: 1;
            overflow-y: auto;
        }

        .data-grid .custom-table {
            font-size: 11px;
            margin: 0;
        }

            .data-grid .custom-table th {
                font-size: 10px;
                font-weight: 600;
                padding: 6px 8px;
                white-space: nowrap;
            }

            .data-grid .custom-table td {
                padding: 6px 8px;
                font-size: 11px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .data-grid .custom-table tbody tr:hover {
                background-color: #e3f2fd;
            }

    .modal-body {
        max-height: calc(90vh - 120px); /* Subtract header and footer height */
        overflow-y: auto;
        overflow-x: hidden;
    }

</style>


<div class="inventory-header">
    Inventory Center
</div>

<div class="toolbar">
    <div class="container-fluid p-0">
        <ul class="nav nav-pills">
            <li class="nav-item dropdown me-2">
                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                    <i class="bi bi-gear-fill me-1"></i> Item Operations
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#newItemModal">
                            <i class="bi bi-plus-circle me-2"></i> New Item
                        </a>
                    </li>

                </ul>
            </li>
            <li class="nav-item me-2">
                <a class="nav-link" href="#" id="btnPrint">
                    <i class="bi bi-printer me-1"></i> Print
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" id="btnExcel">
                    <i class="bi bi-file-earmark-excel me-1"></i> Excel
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="main-container">
    <!-- Left Panel -->
    <div class="left-panel">
        <div class="filter-section">
            <div class="filter-row">
                <div class="filter-label">State</div>
                <div class="filter-control">
                    <select id="stateFilter">
                        <option value="All">All</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>




            <div class="filter-row">
                <div class="filter-label">Category</div>
                <div class="filter-control">
                    <select id="categoryDropdown" class="form-select">
                        <option value="">Loading...</option>
                    </select>
                    <div class="checkbox-container">
                        <input type="checkbox" id="allCat" checked>
                        <label for="allCat">All</label>
                    </div>
                </div>

            </div>

            <div class="filter-row">
                <div class="filter-label">Type</div>
                <div class="filter-control">
                    <select>
                        <option>11 - Inventory</option>
                        <option>12 - Service</option>
                    </select>
                    <div class="checkbox-container">
                        <input type="checkbox" id="allType" checked>
                        <label for="allType">All</label>
                    </div>
                </div>
            </div>

            <div class="filter-row">
                <div class="filter-label">Search By Item</div>
                <div class="filter-control">
                    <input type="text" placeholder="">
                </div>
            </div>
        </div>

        <div class="items-list">
            <div class="card shadow-sm h-100">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <!-- Items Table -->
                        <table id="itemsTable" class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Item Name</th>
                                    <th>Barcode</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
        <div class="right-header">
            <div class="header-info">
                <span>Item Code ↕</span>
                <span>Item Name ↕</span>
                <span>Cost Price ↕</span>
                <span>Sale Price ↕</span>
                <span>Balance Qty ↕</span>
            </div>
            <a href="#" class="go-to-link">Go To Item </a>
        </div>

        <div class="card shadow-sm h-100">
            <div class="card-body p-0">
                <div class="data-grid">
                    <div class="table-responsive">
                        <table class="table table-striped custom-table mb-0" id="dataTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Item Name</th>
                                    <th>Barcode</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>INV NO</th>
                                    <th>Type</th>
                                    <th>Qty In</th>
                                    <th>Qty Out</th>
                                    <th>Cost Price</th>
                                    <th>Sales Price</th>
                                    <th>Qty Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- New Item Modal -->
<div class="modal fade" id="newItemModal" tabindex="-1" aria-labelledby="newItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: #5865f2;">
                <h5 class="modal-title">
                    <i class="fas fa-box"></i> Inventory - New Item
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="warehouseDropdown" class="form-label fw-semibold text-muted">Warehouse</label>
                            <select class="form-select" id="warehouseDropdown">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Type</label>
                            <select class="form-select" id="typeSelect" onchange="changeFormLayout()">
                                <option value="inventory">11 - Inventory Part</option>
                                <option value="service">12 - Service</option>
                                <option value="assembly">13 - Inventory Assembly</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="categoryDropdowns" class="form-label fw-semibold text-muted">Category</label>
                            <select id="categoryDropdowns" class="form-select">
                                <option value="">Loading...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Type</label>
                            <select class="form-select" id="inventoryType">
                                <option value="Inventory" selected>Inventory</option>
                                <option value="Service">Service</option>
                                <option value="Non-Inventory">Non-Inventory</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Item Code</label>
                            <input type="text" disabled class="form-control bg-light" id="itemCodeInput" placeholder="Item Code">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Item Name</label>
                            <input type="text" class="form-control" id="itemNameInput" placeholder="Item Name">
                        </div>
                    </div>
                    <div id="inventorySection" class="inventory-section">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Opening Qty</label>
                                <input type="text" class="form-control" id="onHandInput" placeholder="On Hand">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Cost Price</label>
                                <input type="text" class="form-control" id="costPriceInput" placeholder="Cost Price">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Total</label>
                                <input type="text" class="form-control bg-light" id="totalValueInput" placeholder="Total Value" readonly>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <label class="form-label">As Of</label>
                                <input type="date" class="form-control" id="asOfDateInput">
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Sales Price</label>
                            <input type="text" class="form-control" id="salesPriceInput" placeholder="Sales Price">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="itemActive" checked>
                                <label class="form-check-label" for="itemActive">
                                    Item Active
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="barcodeSection" class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Barcode</label>
                            <input type="text" class="form-control" id="barcodeInput" placeholder="Barcode">
                        </div>
                    </div>
                    <div id="unitCostingSection" class="row mb-3">
                        <div class="col-md-6">
                            <label for="mainUnit" class="form-label fw-semibold text-muted">Main Unit</label>
                            <select class="form-select" id="mainUnit"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Costing Method</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="avg" checked>
                                    <label class="form-check-label" for="avg">AVG</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="fifo">
                                    <label class="form-check-label" for="fifo">FIFO</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="costingMethod" id="lifo">
                                    <label class="form-check-label" for="lifo">LIFO</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="minMaxSection" class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Min Amount</label>
                            <input type="text" class="form-control" id="minAmountInput" placeholder="Min Amount">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Max</label>
                            <input type="text" class="form-control" id="maxAmountInput" placeholder="Max Amount">
                        </div>
                    </div>
                    <!-- Accounts -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="cogsAccount" class="form-label fw-semibold text-muted">COGS Account</label>
                                <select id="cogsAccount" class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="assetAccount" class="form-label fw-semibold text-muted">Asset Account</label>
                                <select id="assetAccount" class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="incomeAccount" class="form-label fw-semibold text-muted">Income Account</label>
                                <select id="incomeAccount" class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="preferredVendor" class="form-label fw-semibold text-muted">Preferred Vendor</label>
                                <select id="preferredVendor" class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> CLOSE
                </button>
                <button type="button" class="btn btn-primary" onclick="saveItem()">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>


@Html.Partial("~/Views/Inventory/_WareHouse.cshtml")
@Html.Partial("~/Views/Lists/_ItemCategory.cshtml")
@Html.Partial("~/Views/Lists/_Unit.cshtml")

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>


        function saveItem() {
            let item = {
                Id: 0,
                Name: $("#itemNameInput").val(),
                WarehouseId: parseInt($("#warehouseDropdown").val()) || 0,
                Type: $("#typeSelect").val(),        // Use the value, not text
                CategoryId: parseInt($("#categoryDropdowns").val()) || 0,
                UnitId: parseInt($("#mainUnit").val()) || 0,
                Barcode: $("#barcodeInput").val() || "",
                CostPrice: parseFloat($("#costPriceInput").val()) || 0,
                SalesPrice: parseFloat($("#salesPriceInput").val()) || 0,
                CogsAccountId: parseInt($("#cogsAccount").val()) || 0,
                IncomeAccountId: parseInt($("#incomeAccount").val()) || 0,
                AssetAccountId: parseInt($("#assetAccount").val()) || 0,
                VendorId: $("#preferredVendor").val() ? parseInt($("#preferredVendor").val()) : null,
                MinAmount: parseFloat($("#minAmountInput").val()) || 0,
                MaxAmount: parseFloat($("#maxAmountInput").val()) || 0,
                OnHand: parseFloat($("#onHandInput").val()) || 0,
                Method: $("input[name='costingMethod']:checked").attr("id"),
                TotalValue: parseFloat($("#totalValueInput").val()) || 0,
                Date: $("#asOfDateInput").val(),     // format: yyyy-MM-dd
                Active: $("#itemActive").is(":checked"),
                ItemType: $("#inventoryType").val(),
                Units: [],
                Assemblies: []
            };

            // If assembly, collect assembly rows
            if (item.Type === "assembly") {
                $("#assemblyTable tbody tr").each(function() {
                    let asm = {
                        ItemId: parseInt($(this).find("select.itemIdSelect").val()) || 0,
                        Qty: parseFloat($(this).find("input.qtyInput").val()) || 0
                    };
                    if (asm.ItemId > 0) item.Assemblies.push(asm);
                });
            }

            // Send AJAX
            $.ajax({
                url: '/Lists/SaveItem',
                type: 'POST',
                data: JSON.stringify(item),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (res) {
                    if (res.status) {
                        $("#newItemModal").modal("hide");
                        toastr.success("Item Added Successfully!");
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                    toastr.error("Error: " + xhr.responseText);
                }
            });
        }



        $(document).ready(function () {

            // ===== Load Items Table =====
            function loadItems() {
                var state = $('#stateFilter').val(); // get selected state
                $.ajax({
                    url: '/Lists/GetItems',
                    type: 'GET',
                    data: { state: state },
                    success: function (result) {
                        var tbody = $('#itemsTable tbody');
                        tbody.empty();

                        if (result.status && result.data.length > 0) {
                            $.each(result.data, function (i, item) {
                                tbody.append(`
                                    <tr>
                                        <td>${item.itemName}</td>
                                        <td>${item.barcode ?? ''}</td>
                                        <td>${item.type}</td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append('<tr><td colspan="3" class="text-center">No items found</td></tr>');
                        }
                    },
                    error: function (err) {
                        console.error('Error loading items:', err);
                        toastr.error('Failed to load items');
                    }
                });
            }
            loadItems(); // initial load
            $('#stateFilter').on('change', loadItems);

            // ===== Load Categories =====
            function loadCategories(selector = "#categoryDropdown, #categoryDropdowns") {
                $.ajax({
                    url: '/Lists/GetItemCategory',
                    type: 'GET',
                    success: function (result) {
                        var dropdowns = $(selector);
                        dropdowns.empty();

                        if (result.status && result.data.length > 0) {
                            dropdowns.append('<option value="">-- Select Category --</option>');
                            $.each(result.data, function (i, category) {
                                dropdowns.append(`<option value="${category.id}">${category.categoryName}</option>`);
                            });
                        } else {
                            dropdowns.append('<option value="">No categories found</option>');
                        }
                    },
                    error: function (err) {
                        console.error('Error loading categories:', err);
                        toastr.error('Failed to load categories');
                    }
                });
            }
            loadCategories();

            // Toggle category dropdown based on checkbox
            $('#allCat').on('change', function () {
                $('#categoryDropdown').prop('disabled', $(this).is(':checked')).val('');
            });
            if ($('#allCat').is(':checked')) $('#categoryDropdown').prop('disabled', true);

            // ===== Load Warehouses =====
            function loadWarehouses(selector = "#warehouse, #warehouseDropdown") {
                $.ajax({
                    url: '/Inventory/GetWarehouses',
                    type: 'GET',
                    success: function (res) {
                        if (res.status) {
                            const dropdowns = $(selector);
                            dropdowns.empty().append('<option value="">Select Warehouse</option>');
                            res.data.forEach(w => {
                                dropdowns.append(`<option value="${w.id}">${w.display}</option>`);
                            });
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function (err) {
                        console.error("Error fetching warehouses:", err);
                    }
                });
            }
            loadWarehouses();

            // ===== Load Units =====
            function loadUnitsDropdown(selector = "#mainUnit") {
                $.get('/Lists/GetUnit', function (res) {
                    const dropdown = $(selector);
                    dropdown.empty().append('<option value="">-- Select Unit --</option>');
                    if (res && res.length > 0) {
                        res.forEach(u => dropdown.append(`<option value="${u.id}">${u.unitName}</option>`));
                    } else {
                        dropdown.append('<option value="">No units found</option>');
                    }
                }).fail(function (err) {
                    console.error("Error loading units:", err);
                    toastr.error("Failed to load units");
                });
            }
            loadUnitsDropdown("#mainUnit");

            // Reload units dropdown when modal opens
            $(document).on('shown.bs.modal', '#newWarehouseModal', function () {
                loadUnitsDropdown("#mainUnit");
            });

            // ===== Load Accounts =====
            $.ajax({
                url: '/HR/GetAccruedSalaries',
                type: 'GET',
                success: function (data) {
                    const dropdowns = [
                        { ddl: '#cogsAccount', codeBox: '#code1' },
                        { ddl: '#assetAccount', codeBox: '#code2' },
                        { ddl: '#incomeAccount', codeBox: '#code3' },
                        { ddl: '#preferredVendor', codeBox: '#code4' }
                    ];

                    dropdowns.forEach(set => {
                        let $ddl = $(set.ddl);
                        $ddl.empty().append('<option value="">-- Select --</option>');

                        $.each(data, function (i, item) {
                            $ddl.append($('<option>', {
                                value: item.id,
                                text: item.code + ' - ' + item.name,
                                'data-code': item.code
                            }));
                        });

                        $ddl.on('change', function () {
                            let code = $(this).find(':selected').data('code');
                            $(set.codeBox).val(code || "");
                        });
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Error loading accounts:", status, error);
                }
            });





        });


        toastr.options = {
                         "closeButton": true,
                         "debug": false,
                         "newestOnTop": false,
                         "progressBar": true,
                         "positionClass": "toast-top-right",
                         "preventDuplicates": false,
                         "onclick": null,
                         "showDuration": "300",
                         "hideDuration": "1000",
                         "timeOut": "5000",
                         "extendedTimeOut": "1000",
                         "showEasing": "swing",
                         "hideEasing": "linear",
                         "showMethod": "fadeIn",
                         "hideMethod": "fadeOut"
                     };

        function changeFormLayout() {
            const type = $("#typeSelect").val(); // inventory, service, assembly

            if (type === "inventory") {
                $("#inventorySection").show();
                $("#barcodeSection").show();
                $("#unitCostingSection").show();
                $("#minMaxSection").show();
                $("#assemblyTable").hide();
            } else if (type === "service") {
                $("#inventorySection").hide();
                $("#barcodeSection").hide();
                $("#unitCostingSection").hide();
                $("#minMaxSection").hide();
                $("#assemblyTable").hide();
            } else if (type === "assembly") {
                $("#inventorySection").show();       // keep inventory fields if needed
                $("#barcodeSection").show();
                $("#unitCostingSection").show();
                $("#minMaxSection").show();
                $("#assemblyTable").show();         // show assembly table
            }
        }

         $(document).ready(function() {
            changeFormLayout();
        });


    </script>

}
