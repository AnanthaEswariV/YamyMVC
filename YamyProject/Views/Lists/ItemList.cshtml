        function updateUnit() {
            const id = parseInt($("#editUnitId").val());
            const name = $("#editUnitName").val();

            if (!id || !name.trim()) {
                toastr.warning("Please enter a unit name.");
                return;
            }


            $.ajax({
                url: '@Url.Action("EditUnit", "Lists")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ Id: id, Name: name }),
                success: function(res) {
     

                    if (res && res.status) {
                        toastr.success(res.message || 'Unit Updated Successfully!');

                        // ✅ Close the modal
                        const modalEl = document.getElementById("editUnitModal");
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if (modal) {
                            modal.hide();
                        }

                        // ✅ Reset form
                        $("#editUnitForm")[0].reset();
                        $("#editUnitId").val('');

                        // ✅ Update dropdown option
                        if (res.id && res.name) {

                            // Remove old option
                            $('#mainUnit option[value="' + res.id + '"]').remove();

                            // Add updated option and select it
                            const newOption = new Option(res.name, res.id, true, true);
                            $('#mainUnit').append(newOption);

                        }
                    } else {
                        toastr.error(res?.message || 'Failed to update unit');
                    }
                },
                error: function(xhr) {
                    console.error('❌ Update error:', xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Server error');
                }
            });
        }

