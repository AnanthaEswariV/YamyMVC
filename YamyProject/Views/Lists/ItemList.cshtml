                         $.each(data, function (i, country) {
                             $ddl.append('<option value="' + country.id + '">' + country.name + '</option>');
                         });
                     },
                     error: function () {
                         alert("Error loading countries");
                     }
                 });

                function saveCategory() {
            const id = parseInt($("#categoryId").val()) || 0;
            const name = $("#categoryName").val().trim();

            if (!name) {
                toastr.warning("Please enter a category name.");
                return;
            }

            const isEdit = id > 0;
            const data = { Id: id, CategoryName: name };

            $.ajax({
                url: isEdit
                    ? '@Url.Action("EditCategory", "Lists")'
                    : '@Url.Action("AddCategory", "Lists")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function(res) {
                    if (res && res.status) {
                        toastr.success(res.message || (isEdit ? "Category updated" : "Category added"));

                        // ✅ Close modal
                        const modalEl = document.getElementById("addCategoryModal");
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if (modal) modal.hide();

                        // ✅ Reset form
                        $("#categoryForm")[0].reset();
                        $("#categoryId").val(0);

                        // ✅ Prepare display text with code
                        const displayText = res.code ? `${res.code} - ${res.categoryName}` : res.categoryName;

                        // ✅ Update dropdowns
                        if (res.id && res.categoryName) {
                            if (isEdit) {
                                $(`#categoryDropdown option[value="${res.id}"]`).text(displayText);
                                $(`#categoryDropdowns option[value="${res.id}"]`).text(displayText);
                            } else {
                                const option1 = new Option(displayText, res.id, true, true);
                                const option2 = new Option(displayText, res.id, true, true);
                                $("#categoryDropdown").append(option1);
                                $("#categoryDropdowns").append(option2);
                            }
                        }
                    } else {
                        toastr.error(res?.message || "Failed to save category");
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Server error");
                }
            });
        }


        // Optional: attach form submit
        $("#categoryForm").on("submit", function(e) {
            e.preventDefault();
            saveCategory();
        });



