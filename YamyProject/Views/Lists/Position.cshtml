@{
    ViewData["Title"] = "Position";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<div class="card">
    <div class="card-header text-center">
        <strong>Position List</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPositionModal">
                <i class="bi bi-plus-lg"></i> Add Position
            </button>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="positionTable">
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Position Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

</div>


<!-- Add/Edit Position Modal -->
<div class="modal fade" id="addPositionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add/Edit Position</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="positionId">
                <div class="mb-3">
                    <label for="departmentSelect" class="form-label">Department</label>
                    <select id="departmentSelect" class="form-select"></select>
                </div>
                <div class="mb-3">
                    <label for="positionName" class="form-label">Position Name</label>
                    <input type="text" id="positionName" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-primary" onclick="savePosition()">Save</button>
            </div>
        </div>
    </div>
</div>




@section Scripts {

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>


    <script>

                $(document).ready(function() {
            loadDepartments();
            loadPositions();

             toastr.options = {
                 "closeButton": true,
                 "debug": false,
                 "newestOnTop": false,
                 "progressBar": true,
                 "positionClass": "toast-top-right",
                 "preventDuplicates": false,
                 "onclick": null,
                 "showDuration": "300",
                 "hideDuration": "1000",
                 "timeOut": "5000", // Adjust to desired display duration
                 "extendedTimeOut": "1000",
                 "showEasing": "swing",
                 "hideEasing": "linear",
                 "showMethod": "fadeIn",
                 "hideMethod": "fadeOut"
             };
        });




        // Load departments for dropdown
        function loadDepartments() {
            $.get('/Lists/GetDepartments', function(res) {
                if (res.status) {
                    const select = $("#departmentSelect");
                    select.empty().append('<option value="">--Select Department--</option>');
                    res.data.forEach(d => select.append(`<option value="${d.id}">${d.name}</option>`));
                }
            });
        }
        // Load positions table
        function loadPositions() {
            $.ajax({
            url: '@Url.Action("GetPositions", "Lists")',
                type: 'GET',

                beforeSend: function () {
                    $('#positionTable tbody').html(`
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading Positions...
                            </td>
                        </tr>
                    `);
                },

                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load positions');
                        return;
                    }

                    // Destroy the existing DataTable if already initialized
                    if ($.fn.DataTable.isDataTable("#positionTable")) {
                        $("#positionTable").DataTable().clear().destroy();
                    }

                    const tbody = $("#positionTable tbody");
                    tbody.empty();

                    // Check if the data is available and has records
                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, pos) {
                            const row = `
                                <tr data-id="${pos.id}">
                                    <td>${pos.departmentName}</td>
                                    <td>${pos.name}</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-primary edit-btn" data-id="${pos.id}" data-dept="${pos.departmentId}" data-name="${pos.name}">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger delete-btn" data-id="${pos.id}">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(row);
                        });

                        // Initialize DataTable with Excel & PDF export buttons
                        $("#positionTable").DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    title: 'Positions',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {
                                        columns: ':not(:last-child)'  
                                    }
                                },
                                {
                                  extend: 'print',
                                  text: '<i class="fas fa-print me-1"></i> Print',
                                  className: 'btn btn-primary btn-sm',
                                  exportOptions: {  columns: ':not(:last-child)'}
                                }
                                
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });

                    } else {
                        tbody.append(`
                            <tr><td colspan="3" class="text-center text-muted py-4">
                                No positions found
                            </td></tr>
                        `);
                    }
                },

                error: function () {
                    toastr.error('Error loading positions data');
                }
            });
        }



        function savePosition() {
            // Get values from modal
            const idVal = $("#positionId").val();
            const name = $("#positionName").val().trim();
            const deptVal = $("#departmentSelect").val();

            if (!name || !deptVal) {
                toastr.warning("Please fill all fields");
                return;
            }

            // Convert to integers
            const data = {
                Id: idVal ? parseInt(idVal) : 0,
                Name: name,
                DepartmentId: parseInt(deptVal)
            };


            // Determine URL and method
            const isUpdate = data.Id > 0;
        const url = isUpdate
         ? '@Url.Action("EditPosition", "Lists")'
         : '@Url.Action("AddPosition", "Lists")';

            const type = isUpdate ? 'PUT' : 'POST';

            // Send AJAX request
            $.ajax({
                url: url,
                type: type,
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function(res) {
                    if (res.status) {
                        $("#addPositionModal").modal('hide');
                        $("#positionId").val('');
                        $("#positionName").val('');
                        loadPositions();

                        // Show Toastr message based on action
                        if (isUpdate) {
                            toastr.success("Position updated successfully!");
                              // Optional: reload page after short delay
                        setTimeout(() => location.reload(), 1500);
                        } else {
                            toastr.success("Position added successfully!");
                              // Optional: reload page after short delay
                        setTimeout(() => location.reload(), 1500);
                        }

                    } else {
                        toastr.error(res.message || "Error saving position");
                    }
                },
                error: function(err) {
                    console.error("AJAX error:", err);
                    toastr.error("Server error occurred while saving position");
                }
            });
        }


        // Open Edit modal
        $(document).on("click", ".edit-btn", function() {
            $("#positionId").val($(this).data("id"));
            $("#departmentSelect").val($(this).data("dept"));
            $("#positionName").val($(this).data("name"));
            $("#addPositionModal").modal('show');
        });

        // Delete position
        $(document).on("click", ".delete-btn", function() {
            const id = $(this).data("id");
            if (!confirm("Are you sure you want to delete this position?")) return;

            $.ajax({
                // url: `/Lists/DeletePosition/${id}`,
                url : '@Url.Action("DeletePosition", "Lists")' + '/' + id,
                type: 'DELETE',
                success: function(res) {
                    if (res.status) {
                        loadPositions();
                        toastr.success("Position deleted successfully!");
                          // Optional: reload page after short delay
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message || "Error deleting position");
                    }
                },
                error: function(err) {
                    console.error("AJAX error:", err);
                    toastr.error("Server error occurred while deleting position");
                }
            });
        });



    </script>



}

