@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor


@{
    ViewData["Title"] = "General Journal Transaction";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId") ?? 0;

}



<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<form id="journalForm" novalidate>
    <div class="container-fluid mt-3">
        <div class="card shadow-sm">
            <div class="card-header text-center">
                <strong style="color: #254acd; font-weight: 700; font-family: 'Georgia', serif; font-size: 1.25rem;">
                    General Journal Voucher
                </strong>
            </div>
            <div class="card-body">
                @*       <!-- Date, Voucher No, Name -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label for="date" class="form-label">Date</label>
                        <input type="date" id="date" class="form-control" readonly required />
                    </div>
                    <div class="col-md-3">
                        <label for="voucherNo" class="form-label">Voucher No</label>
                        <input type="text" id="voucherNo" class="form-control" readonly required />
                    </div>
                    <div class="col-md-6">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" id="name" class="form-control" placeholder="Name" readonly required />
                    </div>
                </div> *@

                <div class="card-header d-flex justify-content-between align-items-center" style="padding: 1rem 1.5rem;">
                    <!-- Left side: QR + Title -->
                    <div class="d-flex align-items-center">
                        <div style="width:70px; margin-right:1rem;">
                            <img id="qrCodeImg" src="" style="width:100%; height:auto;" />
                        </div>

                    </div>

                    <div id="headerRight" style="text-align: left; line-height: 1.5; font-weight: 600; color: #555;">
                        <div>
                            <span style="font-weight: 700; font-size:small">Date:</span> <span id="dateDisplay" style="font-size: small;"></span>
                        </div>
                        <div><span style="font-weight: 700; font-size:small">J.V No:</span> <span id="voucherNoDisplay" style="font-size: small;"></span></div>
                        <div><span style="font-weight: 700; font-size:small">User Id:</span> <span style="font:small;">@userId</span></div>
                    </div>


                </div>


                <!-- Journal Table -->
                <div class="table-responsive">
                    <table class="table" id="journalTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>AC Code</th>
                                <th>Account Name</th>
                                <th>Description</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th>Cost Center</th>

                            </tr>
                        </thead>
                        <tbody></tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">Total</th>
                                <th id="totalDebitCell" class="text-end">0.00</th>
                                <th id="totalCreditCell" class="text-end">0.00</th>
                            </tr>
                        </tfoot>

                    </table>
                </div>



                <div class="table-responsive" id="journalTableContainer" style="display:none;">
                    <table class="table" id="journalTable">
                        <thead>
                            <tr>
                                <th width="10px">S.No</th>
                                <th>AC Code</th>
                                <th>Account Name</th>
                                <th>Description</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th>Cost Center</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">Total</th>
                                <th id="totalDebitCell" class="text-end">0.00</th>
                                <th id="totalCreditCell" class="text-end">0.00</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary me-2" id="saveBtn">Save</button>
                    <button type="button" class="btn btn-primary me-2" id="editBtn">Edit</button>
                    <button type="button" class="btn btn-secondary" onclick="window.history.back()">Close</button>
                </div>

            </div>
        </div>
    </div>
</form>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
             $(document).ready(function () {
            const urlParams = new URLSearchParams(window.location.search);
            const refId = urlParams.get('refId');
            const vType = urlParams.get('vType');
            const date = urlParams.get('date');

            if (refId && vType && date) {
                $('#voucherNo').val(refId);
                $('#date').val(formatDateForInput(date));

          $('#dateDisplay').text(formatDateForInput(date));
        $('#voucherNoDisplay').text(refId);
                // 🔹 Load account list first, then journal details
                loadAccountList(() => loadJournalDetails(refId, vType, date));
            } else {
                toastr.warning('Missing parameters.');
            }


               function parseDateForISO(dateStr) {
            if (!dateStr) return new Date().toISOString(); // fallback to today
            const parts = dateStr.split('/');
            if (parts.length === 3) {
                const day = parts[0].padStart(2, '0');
                const month = parts[1].padStart(2, '0');
                const year = parts[2];
                return `${year}-${month}-${day}T00:00:00`; // string format for C# DateTime
            }
            return new Date(dateStr).toISOString();
        }


                $('#journalForm').on('submit', function(e) {
            e.preventDefault();
            handleFormSubmit('save');
        });

        $('#editBtn').on('click', function() {
            handleFormSubmit('edit');
        });

        function handleFormSubmit(actionType) {
            // Validate form
            const form = $('#journalForm')[0];
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            // Get form data
            const refId = $('#voucherNo').val();
            const voucherDate = $('#voucherDate').val(); // YYYY-MM-DD format
            const vType = 'General Journal';
            const modifiedBy = $('#userId').val() || "1";

            // Get the transaction ID from hidden field or first row
            const transactionId = parseInt($('#transactionId').val()) ||
                                  parseInt($('#journalTable tbody tr:first').data('transactionid')) || 0;

            // Build entries array
            const entries = [];
            let valid = true;
            let totalDebit = 0;
            let totalCredit = 0;

            $('#journalTable tbody tr').each(function(index) {
                const row = $(this);
                const accountId = parseInt(row.find('.account-name').val()) || 0;
                const debit = parseFloat(row.find('.debit').val()) || 0;
                const credit = parseFloat(row.find('.credit').val()) || 0;
                const description = row.find('.description').val() || '';
                const humId = row.data('humid') || "0";
                const rowId = parseInt(row.data('id')) || 0;
                const rowTransactionId = parseInt(row.data('transactionid')) || transactionId;

                // Validate row
                if (!accountId) {
                    toastr.warning('Row ' + (index + 1) + ' must have a valid account selected');
                    valid = false;
                    return false; // break loop
                }

                if (debit === 0 && credit === 0) {
                    toastr.warning('Row ' + (index + 1) + ' must have Debit or Credit greater than 0');
                    valid = false;
                    return false; // break loop
                }

                totalDebit += debit;
                totalCredit += credit;

                     entries.push({
            AccountId: accountId,           // int
            AccountName: row.find('.account-name').val() || '',
            Debit: debit,                   // decimal
            Credit: credit,                 // decimal
            Description: description,       // string
            HumId: humId,                   // string
            TId: rowId.toString()           // string
        });

            });

            if (!valid) return;

            if (!entries.length) {
                toastr.warning('No journal entries found to save.');
                return;
            }

            if (totalDebit.toFixed(2) !== totalCredit.toFixed(2)) {
                toastr.error('Debit Total (' + totalDebit.toFixed(2) + ') and Credit Total (' + totalCredit.toFixed(2) + ') are not equal.');
                return;
            }

                 const payload = {
            Id: transactionId,
            Date: parseDateForISO(voucherDate),
            VType: vType,
            CurrentVoucherName: '',
            CurrentVoucherId: refId,
            UserId: modifiedBy.toString(),
            JournalEntries: entries
        };



            // Send AJAX request
            $.ajax({
                url: '/Lists/UpdateJournal',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                beforeSend: function() {
                    if(actionType === 'save') {
                        $('#saveBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');
                    } else {
                        $('#editBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Updating...');
                    }
                },
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message || (actionType === 'save' ? 'Journal saved successfully!' : 'Journal updated successfully!'));
                        $('#totalDebitCell').text(totalDebit.toFixed(2));
                        $('#totalCreditCell').text(totalCredit.toFixed(2));
                        if (transactionId === 0 && res.journalId) {
                            $('#transactionId').val(res.journalId);
                        }
                    } else {
                        toastr.error(res.message || 'Failed to process journal.');
                    }
                },
                error: function(xhr) {
                    let errorMessage = 'An error occurred while processing the journal.';
                    if (xhr.responseJSON && xhr.responseJSON.message) errorMessage = xhr.responseJSON.message;
                    toastr.error(errorMessage);
                    console.error('Error:', xhr.responseText);
                },
                complete: function() {
                    $('#saveBtn').prop('disabled', false).html('<i class="fas fa-save"></i> Save');
                    $('#editBtn').prop('disabled', false).html('<i class="fas fa-edit"></i> Edit');
                }
            });
        }





        generateQrCode(refId, vType, date);


        const isScan = urlParams.get('scan');

        // Hide QR-Table by default
        $("#journalTableContainer").hide();

        // Show only when scanned
        if (isScan === "true") {
            $("#journalTableContainer").show();
        }



        });

                function generateQrCode(refId, vType, date) {
            if (!refId || !vType || !date) return;

            const url = `${window.location.origin}/Lists/GeneralJournalTransaction?refId=${encodeURIComponent(refId)}&vType=${encodeURIComponent(vType)}&date=${encodeURIComponent(date)}&scan=true`;

            $("#qrCodeImg").attr("src",
                `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(url)}`
            );
        }





                function formatNumber(num) {
            return Number(num).toLocaleString('en-US', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }


        function loadAccountList(callback) {
            $.ajax({
                url: '/HR/GetAccruedSalaries',
                type: 'GET',
                success: function (data) {
                    accountList = data || [];

                    if (typeof callback === 'function') callback();
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                    toastr.error("Failed to load account list", "Error");
                }
            });
        }

        function formatDateForInput(dateStr) {
            const [day, month, year] = dateStr.split('/');
            if (year) return `${year}-${month}-${day}`;
            return dateStr;
        }

        function loadJournalDetails(refId, vType, date) {

            const data = {
                refId: refId,
                vType: vType,
                date: date
            };
            $.ajax({
                url: '/Lists/GetJournalDetails',
                type: 'GET',
                data: data,
                beforeSend: function () {
                    // Destroy existing DataTable before showing loading message
                    if ($.fn.DataTable.isDataTable("#journalTable")) {
                        $("#journalTable").DataTable().clear().destroy();
                    }
                    $('#journalTable tbody').html('<tr><td colspan="6" class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Loading...</td></tr>');
                     
                },
                success: function (res) {
                    const tbody = $('#journalTable tbody').empty();
                    let totalDebit = 0, totalCredit = 0;
                    console.log(res);
                    if (res.status && res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            // Format numbers
                            const debit = row.debit != null ? parseFloat(row.debit).toFixed(2) : '0.00';
                            const credit = row.credit != null ? parseFloat(row.credit).toFixed(2) : '0.00';

                            // Increment totals
                            totalDebit += parseFloat(row.debit || 0);
                            totalCredit += parseFloat(row.credit || 0);

                            tbody.append(`
         <tr data-id="${row.id ?? ''}" data-transactionid="${row.transactionId ?? ''}">
                <td>${row.sn ?? i + 1}</td>
                <td>
                    <select class="form-select form-select-sm account-code">
                        <option value="">-- Select --</option>
                        ${accountList.map(acc =>
                            `<option value="${acc.id}" data-code="${acc.code}" ${acc.code == row.accountCode ? 'selected' : ''}>${acc.code}</option>`
                        ).join('')}
                    </select>
                </td>
                <td>
                    <select class="form-select form-select-sm account-name">
                        <option value="">-- Select --</option>
                        ${accountList.map(acc =>
                            `<option value="${acc.id}" data-code="${acc.code}" ${acc.id == row.accountId ? 'selected' : ''}>${acc.name}</option>`
                        ).join('')}
                    </select>
                </td>
                 <td>
            <input type="text" class="form-control form-control-sm description" value="${row.description ?? ''}" />
        </td>
                      <td class="text-end">
            <input type="text" class="form-control form-control-sm debit text-end format-number"
        value="${formatNumber(row.debit)}" />
        </td>
        <td class="text-end">
            <input type="text" class="form-control form-control-sm credit text-end format-number"
        value="${formatNumber(row.credit)}" />
        </td>
        <td class="text-end">-</td>
            </tr>
        `);

                        });

                        $('#totalDebitCell').text(formatNumber(totalDebit));
                        $('#totalCreditCell').text(formatNumber(totalCredit));
                        $('#name').val(res.data[0].humName || '');

                                $('#journalTable').DataTable({
            dom: 'Brtip', // Removed search bar
            buttons: [
                {
                    extend: 'print',
                    className: 'btn btn-primary btn-sm',
                    text: '<i class="fas fa-print"></i> Print',
                    title: 'General Journal Details',
                    exportOptions: { columns: ':visible' ,
                    format: {
                    body: function (data, row, column, node) {
                        // If cell contains an <input>, return its value
                        if ($(node).find('input').length) {
                            return $(node).find('input').val();
                        }
                        // If cell contains a <select>, return selected text
                        if ($(node).find('select').length) {
                            return $(node).find('select option:selected').text();
                        }
                        return data;
                    }
                    }
                    }
                },
                {
                    extend: 'pdfHtml5',
                    className: 'btn btn-primary btn-sm',
                    orientation: 'landscape',
                    pageSize: 'A4',
                    text: '<i class="fas fa-file-pdf"></i> PDF',
                    title: 'General Journal Details',
                    exportOptions: { columns: ':visible',
                    format: {
                    body: function (data, row, column, node) {
                        if ($(node).find('input').length) {
                            return $(node).find('input').val();
                        }
                        if ($(node).find('select').length) {
                            return $(node).find('select option:selected').text();
                        }
                        return data;
                    }
                }
            }
                }
            ],
            order: [[0, 'asc']],
            pageLength: 15,
            paging: false,
            info: false,
        });



                    } else {
                        tbody.append('<tr><td colspan="6" class="text-center py-4 text-muted"><i class="fas fa-info-circle"></i> No records found</td></tr>');
                        toastr.info('No records found', 'Info');
                    }
                },
                error: function (xhr, status, error) {
                    console.error('API Error:', xhr.responseText);
                    $('#journalTable tbody').html('<tr><td colspan="6" class="text-center py-4 text-danger"><i class="fas fa-exclamation-triangle"></i> Error loading data</td></tr>');
                    toastr.error('Failed to load journal details: ' + error, 'Error');
                }
            });
        }


        $('#journalTable').off('change', '.account-name').on('change', '.account-name', function () {
            const selectedId = $(this).val();
            const row = $(this).closest('tr');
            const acc = accountList.find(a => a.id == selectedId);
            row.find('.account-code').val(acc?.id || '');
        });

        $('#journalTable').off('change', '.account-code').on('change', '.account-code', function () {
            const selectedId = $(this).val();
            const row = $(this).closest('tr');
            const acc = accountList.find(a => a.id == selectedId);
            row.find('.account-name').val(acc?.id || '');
        });


    </script>
}
