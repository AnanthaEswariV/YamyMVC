@{
    ViewData["Title"] = " CostCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<style>
    .tree-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .tree-node {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        margin: 2px 0;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }

        .tree-node:hover {
            background-color: #f5f7fa;
        }

        .tree-node.selected {
            background-color: #e3f2fd;
            border: 1px solid #2196f3;
        }

    .expand-toggle {
        width: 20px;
        height: 20px;
        margin-right: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
        color: #666;
        transition: transform 0.2s ease;
    }

        .expand-toggle.expanded {
            transform: rotate(90deg);
        }

        .expand-toggle.no-children {
            visibility: hidden;
        }

    .node-icon {
        margin-right: 10px;
        font-size: 16px;
        width: 20px;
        text-align: center;
    }

    .main-node .node-icon {
        color: #2196f3;
    }

    .sub-node .node-icon {
        color: #ff9800;
    }

    .node-content {
        flex: 1;
        display: flex;
        align-items: center;
    }

    .node-label {
        font-weight: 500;
        color: #333;
    }

    .node-code {
        margin-left: 10px;
        padding: 2px 6px;
        background: #f0f0f0;
        border-radius: 3px;
        font-size: 11px;
        color: #666;
    }

    .main-node .node-label {
        font-weight: 600;
        color: #1976d2;
    }

    .sub-node {
        margin-left: 30px;
        background: #fafafa;
    }

        .sub-node .node-label {
            color: #555;
        }

    .children-container {
        margin-left: 30px;
        border-left: 2px solid #e0e0e0;
        padding-left: 10px;
        display: none;
    }

        .children-container.expanded {
            display: block;
        }

    .node-actions {
        opacity: 0;
        transition: opacity 0.2s ease;
        margin-left: 10px;
    }

    .tree-node:hover .node-actions {
        opacity: 1;
    }

    .action-btn {
        background: none;
        border: none;
        padding: 4px 8px;
        margin: 0 2px;
        border-radius: 3px;
        cursor: pointer;
        font-size: 12px;
        color: #666;
        transition: all 0.2s ease;
    }

        .action-btn:hover {
            background: #e0e0e0;
            color: #333;
        }

    .loading {
        text-align: center;
        padding: 40px;
        color: #666;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #999;
    }

 /*    .page-heading {
        margin: -61px 0 2rem;
    } */
</style>
<div class="page-heading">
<div class="row">
    <div class="col-6">
        <h3>Cost Center</h3>
    </div>
    <div class="col-6 text-end">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCostCenterModal">
            <i class="bi bi-plus-lg"></i> Add Cost Center
        </button>
    </div>
</div>
</div>


<section class="section">
    <div class="card">
        <div class="card-body">
            <div class="tree-container">
                <div id="costCenterTree">
                    <div class="loading">
                        <i class="bi bi-arrow-clockwise spin"></i> Loading cost centers...
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal -->
<div class="modal fade" id="addCostCenterModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Cost Center</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="costCenterForm">
                    <!-- Type Selection -->
                    <div class="mb-3">
                        <label class="form-label">Type</label><br />
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="type" id="radioMain" value="main" />
                            <label class="form-check-label" for="radioMain">Main Cost Center</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="type" id="radioSub" value="sub" />
                            <label class="form-check-label" for="radioSub">Sub Cost Center</label>
                        </div>
                    </div>

                    <!-- Dropdown for Main Cost Centers (for Sub type only) -->
                    <div class="mb-3" id="mainSelectDiv" style="display:none;">
                        <label for="mainId" class="form-label">Select Main Cost Center</label>
                        <select id="mainId" name="mainId" class="form-select">
                            <option value="">Choose main cost center...</option>
                        </select>
                    </div>

                    <!-- Common Textbox for Cost Center Name -->
                    <div class="mb-3">
                        <label for="name" class="form-label">Cost Center Name</label>
                        <input type="text" class="form-control" id="name" name="name" required />
                    </div>

                    <input type="hidden" id="editId" name="editId" value="" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveCostCenterBtn">
                    <span id="saveButtonText">Save</span>
                    <span id="saveButtonSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        let costCenterData = [];

        // Load cost centers from server
        function loadCostCenters() {
            const treeContainer = $('#costCenterTree');
            treeContainer.html('<div class="loading"><i class="bi bi-arrow-clockwise"></i> Loading cost centers...</div>');

          
            $.ajax({
                url: '/Lists/GetCostCenters', 
                type: 'GET',
                success: function(response) {
                    console.log('Loaded cost centers:', response);
                    if (response && Array.isArray(response)) {
                        costCenterData = response;
                        renderTree();
                    } else {
                        showError('Invalid data format received');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error loading cost centers:', xhr.responseText);
                    showError('Failed to load cost centers: ' + error);
                }
            });
        }

               function renderTree() {
            const container = $('#costCenterTree');
            container.empty();

            if (!costCenterData || costCenterData.length === 0) {
                container.html('<div class="empty-state">No cost centers found</div>');
                return;
            }

            const mainNodes = costCenterData.filter(x => x.isMain);
            const subNodes = costCenterData.filter(x => x.isSub);

            mainNodes.forEach(main => {
                const children = subNodes.filter(sub => sub.mainId === main.id);
                container.append(createNode(main, children, true));
            });
        }

                               function createNode(node, children = [], isMain = false) {
            const hasChildren = children && children.length > 0;
            const childrenId = `children-${node.id}`;

            let html = `
            <div class="tree-item" data-id="${node.id}">
                <div class="tree-node ${isMain ? 'main-node' : 'sub-node'}" data-id="${node.id}">
                    <div class="expand-toggle ${hasChildren ? '' : 'no-children'}" onclick="toggleChildren('${childrenId}', this)">
                        ${hasChildren ? '<i class="bi bi-chevron-right"></i>' : ''}
                    </div>
                    <div class="node-icon">${isMain ? '<i class="bi bi-folder"></i>' : '<i class="bi bi-file-text"></i>'}</div>
                    <div class="node-content d-flex align-items-center justify-content-between">
                        <span class="node-label">${node.code || ''} - ${node.name}</span>
                        ${!isMain ? `
                        <span class="node-actions" style="margin-left: 10px; display: flex; gap: 5px;">
                            <button class="btn btn-sm btn-outline-primary editCostCenterBtn"
                                    data-costcenter='${JSON.stringify(node).replace(/'/g, "&apos;")}'
                                    title="Edit">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger deleteCostCenterBtn"
                                    data-costcenter='${JSON.stringify(node).replace(/'/g, "&apos;")}'
                                    title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </span>` : ''}
                    </div>
                </div>
            </div>
            `;

            if (hasChildren) {
                html += `<div class="children-container" id="${childrenId}">`;
                children.forEach(child => {
                    html += createNode(child, [], false);
                });
                html += `</div>`;
            }

            return html;
        }





        // Toggle children visibility
        function toggleChildren(childrenId, toggleElement) {
            const childrenDiv = $(`#${childrenId}`);
            const icon = $(toggleElement).find('i');

            if (childrenDiv.hasClass('expanded')) {
                childrenDiv.removeClass('expanded').slideUp(200);
                icon.removeClass('bi-chevron-down').addClass('bi-chevron-right');
                $(toggleElement).removeClass('expanded');
            } else {
                childrenDiv.addClass('expanded').slideDown(200);
                icon.removeClass('bi-chevron-right').addClass('bi-chevron-down');
                $(toggleElement).addClass('expanded');
            }
        }

        // Show error message
        function showError(message) {
            $('#costCenterTree').html(`
                <div class="empty-state">
                    <i class="bi bi-exclamation-triangle text-warning"></i><br>
                    ${message}
                    <br><br>
                    <button class="btn btn-sm btn-primary" onclick="loadCostCenters()">
                        <i class="bi bi-arrow-clockwise"></i> Retry
                    </button>
                </div>
            `);
        }


        // Load main cost centers for dropdown
        function loadMainCostCentersForSelect() {
            const mainNodes = costCenterData.filter(x => x.IsMain);
            const select = $('#mainId');
            select.empty().append('<option value="">Choose main cost center...</option>');

            mainNodes.forEach(main => {
                select.append(`<option value="${main.Id}">${main.Name}</option>`);
            });
        }

        // Document ready
        $(document).ready(function() {
            loadCostCenters();

           

            // Handle tree node selection
            $(document).on('click', '.tree-node', function(e) {
                // Don't select if clicking on actions or expand toggle
                if ($(e.target).closest('.expand-toggle, .node-actions').length) {
                    return;
                }

                $('.tree-node').removeClass('selected');
                $(this).addClass('selected');
            });

         
        $('#addCostCenterBtn').on('click', function () {
            $('#editId').val('');
            $('#name').val('');
            $('#radioMain').prop('checked', false);
            $('#radioSub').prop('checked', false);
            $('#mainId').val('');
            $('#mainSelectDiv').hide();
            $('#saveButtonText').text('Save');
            $('#addCostCenterModal .modal-title').text('Add Cost Center');
            $('#addCostCenterModal').modal('show');
        });




        $(document).on('click', '.editCostCenterBtn', function () {
            const data = $(this).data('costcenter'); 
            if (!data) return;

            $('#editId').val(data.id ?? '');
            $('#name').val(data.name ?? '');

            if (data.isMain) {
                $('#radioMain').prop('checked', true);
                $('#mainId').closest('.mb-3').hide();
            } else {
                $('#radioSub').prop('checked', true);
                $('#mainId').closest('.mb-3').show();
                $('#mainId').val(data.mainId ?? '');
            }

            $('#saveButtonText').text('Update');
            $('#addCostCenterModal .modal-title').text('Edit Cost Center');
            $('#addCostCenterModal').modal('show');
        });

              $('#saveCostCenterBtn').on('click', function (e) {
            e.preventDefault();

            const name = $('#name').val().trim();
            const isMain = $('#radioMain').is(':checked');
            const isSub = $('#radioSub').is(':checked');
            const mainId = $('#mainId').val();
            const id = $('#editId').val();
            const projectId = $('#currentProjectId').val() || 0;

            if (!isMain && !isSub) {
                toastr.warning('Please choose Cost Center type (Main/Sub).');
                return;
            }

            if (name === '') {
                toastr.warning('Please enter Cost Center Name.');
                return;
            }

            if (isSub && !mainId) {
                toastr.warning('Please select a Main Cost Center.');
                return;
            }

            const costCenterData = {
                Id: id ? parseInt(id) : 0,
                Name: name,
                IsMain: isMain,
                IsSub: isSub,
                MainId: isSub ? parseInt(mainId) : null, // null if main
                ProjectId: projectId ? parseInt(projectId) : null, // null if missing
                UserId: parseInt($('#currentUserId').val() || 0) // optional field if you track user
            };

            $('#saveButtonSpinner').removeClass('d-none');
            $('#saveButtonText').text('Saving...');

            $.ajax({
                url: '/Lists/SaveCostCenter',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(costCenterData),
                success: function (res) {
                    $('#saveButtonSpinner').addClass('d-none');
                    $('#saveButtonText').text('Save');

                    if (res.status) {
                        toastr.success(id ? 'Cost Center updated successfully' : 'Cost Center added successfully');
                        $('#addCostCenterModal').modal('hide');

                        setTimeout(() => location.reload(), 1200);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    $('#saveButtonSpinner').addClass('d-none');
                    $('#saveButtonText').text('Save');
                    toastr.error(xhr.responseJSON?.message || 'Something went wrong.');
                }
            });
        });



               // Handle type selection (main vs sub)
        $('input[name="type"]').change(function() {
            const type = $(this).val();

            if (type === 'sub') {
                $('#mainSelectDiv').show();      
                loadMainCostCenters();             
            } else {
                $('#mainSelectDiv').hide();      
                $('#mainId').val('');              
            }
        });

        // ✅ Load Main Cost Centers via API
        function loadMainCostCenters() {
            $.ajax({
                url: '/Lists/GetMainCostCenters',
                type: 'GET',
                success: function (res) {
                    const ddl = $('#mainId');
                    ddl.empty().append('<option value="">Choose main cost center...</option>');

                    if (res.status && res.data?.length > 0) {
                        res.data.forEach(x => {
                            ddl.append(`<option value="${x.id}">${x.code} - ${x.name}</option>`);
                        });
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || 'Failed to load main cost centers');
                }
            });
        }


        loadMainCostCenters();


                $(document).on('click', '.deleteCostCenterBtn', function () {
            const data = $(this).data('costcenter');
            if (!data || !data.id) return;

            Swal.fire({
                title: 'Are you sure?',
                text: "This will delete the sub cost center!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Lists/DeleteSubCostCenter',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(data.id),
                        success: function (res) {
                            if (res.status) {
                                toastr.success(res.message);
                                loadCostCenters(); // reload tree
                            } else {
                                toastr.error(res.message);
                            }
                        },
                        error: function (xhr) {
                            toastr.error(xhr.responseJSON?.message || 'Something went wrong.');
                        }
                    });
                }
            });
        });


        });
    </script>
}