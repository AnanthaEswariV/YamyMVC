@{
    ViewData["Title"] = "Inventory Center";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 12px;
            margin: 0;
            padding: 0;
            background: #f5f5f5;
        }

        .inventory-header {
            background: #4472c4;
            color: white;
            padding: 8px 15px;
            font-weight: bold;
            text-align: center;
            font-size: 14px;
        }

        .toolbar {
            background: #e7e6e6;
            padding: 5px 15px;
            border-bottom: 1px solid #ccc;
            font-size: 12px;
        }

            .toolbar .nav-link {
                color: #333;
                padding: 2px 8px;
                font-size: 12px;
                text-decoration: none;
                border: 1px solid transparent;
            }

                .toolbar .nav-link:hover {
                    background-color: rgba(0,0,0,0.1);
                    border-radius: 3px;
                }

        .main-container {
            display: flex;
            height: calc(100vh - 80px);
            background: white;
        }

        /* Left Panel Styling */
        .left-panel {
            width: 330px;
            background: #f8f9fa;
            border-right: 2px solid #ddd;
            padding: 0;
            display: flex;
            flex-direction: column;
        }

        .filter-section {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }

        .filter-row {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            font-size: 11px;
        }

        .filter-label {
            width: 60px;
            font-weight: 600;
            color: #333;
            text-align: right;
            margin-right: 10px;
        }

        .filter-control {
            flex: 1;
            display: flex;
            align-items: center;
        }

            .filter-control select {
                flex: 1;
                font-size: 11px;
                padding: 2px 4px;
                border: 1px solid #ccc;
                background: white;
            }

            .filter-control input[type="text"] {
                flex: 1;
                font-size: 11px;
                padding: 3px 6px;
                border: 1px solid #ccc;
            }

        .checkbox-container {
            display: flex;
            align-items: center;
            margin-left: 8px;
            font-size: 11px;
        }

            .checkbox-container input {
                margin-right: 4px;
                transform: scale(0.8);
            }

        /* Items List */
        .items-list {
            flex: 1;
            margin: 8px;
            overflow: hidden;
        }

            .items-list .card {
                height: 100%;
            }

            .items-list .table-responsive {
                max-height: 400px;
                overflow-y: auto;
            }

        .custom-table {
            font-size: 11px;
        }

            .custom-table th {
                font-size: 11px;
                font-weight: 600;
                padding: 6px 8px;
            }

            .custom-table td {
                padding: 4px 8px;
                font-size: 11px;
                cursor: pointer;
            }

            .custom-table tbody tr:hover {
                background-color: #e3f2fd;
            }

            .custom-table tbody tr.selected {
                background-color: #b3d9ff !important;
            }

        .item-code {
            font-weight: 600;
            color: #000;
        }

        .item-type {
            color: #666;
        }

        /* Right Panel */
        .right-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: white;
        }

        .right-header {
            background: #f8f9fa;
            padding: 8px 12px;
            border-bottom: 1px solid #ddd;
            font-size: 11px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

            .header-info span {
                font-size: 11px;
                color: #555;
            }

        .go-to-link {
            color: #0066cc;
            text-decoration: none;
            font-size: 11px;
        }

        /* Right Panel Data Grid */
        .right-panel .card {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .right-panel .card-body {
            flex: 1;
            padding: 0;
            display: flex;
            flex-direction: column;
        }

        .data-grid {
            flex: 1;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

            .data-grid .table-responsive {
                flex: 1;
                overflow-y: auto;
            }

            .data-grid .custom-table {
                font-size: 11px;
                margin: 0;
            }

                .data-grid .custom-table th {
                    font-size: 10px;
                    font-weight: 600;
                    padding: 6px 8px;
                    white-space: nowrap;
                }

                .data-grid .custom-table td {
                    padding: 6px 8px;
                    font-size: 11px;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }

                .data-grid .custom-table tbody tr:hover {
                    background-color: #e3f2fd;
                }
    </style>
</head>
<body>
    <div class="inventory-header">
        Inventory Center
    </div>

    <div class="toolbar">
        <div class="container-fluid p-0">
            <ul class="nav nav-pills">
                <li class="nav-item dropdown me-2">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                        <i class="bi bi-gear-fill me-1"></i> Item Operations
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#"><i class="bi bi-plus-circle me-2"></i> New Item</a></li>
                    </ul>
                </li>
                <li class="nav-item me-2">
                    <a class="nav-link" href="#" id="btnPrint">
                        <i class="bi bi-printer me-1"></i> Print
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" id="btnExcel">
                        <i class="bi bi-file-earmark-excel me-1"></i> Excel
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="main-container">
        <!-- Left Panel -->
        <div class="left-panel">
            <div class="filter-section">
                <div class="filter-row">
                    <div class="filter-label">State</div>
                    <div class="filter-control">
                        <select>
                            <option>All</option>
                            <option>Active</option>
                            <option>Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="filter-row">
                    <div class="filter-label">Category</div>
                    <div class="filter-control">
                        <select>
                            <option>001 - category</option>
                            <option>002 - category</option>
                        </select>
                        <div class="checkbox-container">
                            <input type="checkbox" id="allCat" checked>
                            <label for="allCat">All</label>
                        </div>
                    </div>
                </div>

                <div class="filter-row">
                    <div class="filter-label">Type</div>
                    <div class="filter-control">
                        <select>
                            <option>11 - Inventory Part</option>
                            <option>12 - Service</option>
                        </select>
                        <div class="checkbox-container">
                            <input type="checkbox" id="allType" checked>
                            <label for="allType">All</label>
                        </div>
                    </div>
                </div>

                <div class="filter-row">
                    <div class="filter-label">Search By Item</div>
                    <div class="filter-control">
                        <input type="text" placeholder="">
                    </div>
                </div>
            </div>

            <div class="items-list">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped custom-table mb-0" id="itemsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item Code</th>
                                        <th>Type</th>
                                    </tr>
                                </thead>
                                <tbody>
                            
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <div class="right-header">
                <div class="header-info">
                    <span>Item Code ↕</span>
                    <span>Item Name ↕</span>
                    <span>Cost Price ↕</span>
                    <span>Sale Price ↕</span>
                    <span>Balance Qty ↕</span>
                </div>
                <a href="#" class="go-to-link">Go To Item </a>
            </div>

            <div class="card shadow-sm h-100">
                <div class="card-body p-0">
                    <div class="data-grid">
                        <div class="table-responsive">
                            <table class="table table-striped custom-table mb-0" id="dataTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Barcode</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>INV NO</th>
                                        <th>Type</th>
                                        <th>Qty In</th>
                                        <th>Qty Out</th>
                                        <th>Cost Price</th>
                                        <th>Sales Price</th>
                                        <th>Qty Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

  



</body>
</html>