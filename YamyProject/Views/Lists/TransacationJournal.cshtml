@{
    ViewData["Title"] = "TransactionJournal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<div class="card">
    <div class="card-header text-center">
        <strong>Transaction Journal</strong>
    </div>

    <div class="card-body">
        <!-- Filter Section -->
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox: Show All Data -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>

            <!-- Selection Method -->
            <div style="min-width: 300px;">
                <h6 class="text-center fw-bold">Selection Method</h6>
                <select class="form-select text-center" id="transactionSelect">
                    <option>Default</option>
                    <option>General Ledger</option>
                    <option>General Ledger Opening Balance</option>
                    <option>Customer Opening Balance</option>
                    <option>Vendor Opening Balance</option>
                    <option>Subcontractor Opening Balance</option>
                    <option>Sales Invoice</option>
                    <option>SalesReturn Invoice</option>
                    <option>Purchase Invoice</option>
                    <option>Customer Receipt</option>
                    <option>Vendor Payment</option>
                    <option>Petty Cash</option>
                    <option>Employee Salary</option>
                    <option>Leave Salary</option>
                    <option>End Of Service</option>
                    <option>Petty Cash Submition Approval</option>
                    <option>Purchase Return Invoice</option>
                    <option>Employee Petty Cash Payment</option>
                    <option>Opening Qty</option>
                    <option>Prepaid Expense</option>
                    <option>Fixed Assets</option>
                    <option>Fixed Assets Depreciation</option>
                    <option>PDC Payable</option>
                    <option>PDC Receivable</option>
                    <option>Debit Note</option>
                    <option>Credit Note</option>
                    <option>Employee Salary Payment</option>
                    <option>Loan Request</option>
                    <option>Vendor Advance Payment</option>
                    <option>Customer Advance Payment</option>
                    <option>RMS Bill</option>
                    <option>Manufacturing</option>
                </select>
            </div>

        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Ref_Id</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>A/C Code</th>
                    <th>A/C Name</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>CostCenter</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {

            const urlParams = new URLSearchParams(window.location.search);
            const transactionId = urlParams.get('transactionId');
            let selectionMethod = urlParams.get('selectionMethod') || 'Default';
            let fromDate = urlParams.get('fromDate');
            let toDate = urlParams.get('toDate');

            if (selectionMethod) {
                $("#transactionSelect").val(selectionMethod);
            }

            if (fromDate && toDate) {
                $("#chkAllData").prop("checked", false);
                $("#startDate, #endDate").prop("disabled", false);
                $("#startDate").val(fromDate);
                $("#endDate").val(toDate);
            }

            // --- Dropdown change - automatically load data ---
            $("#transactionSelect").on("change", function () {
                const selectedMethod = $(this).val()?.trim() || 'Default';

                const fDate = $("#chkAllData").is(":checked") ? null : $("#startDate").val();
                const tDate = $("#chkAllData").is(":checked") ? null : $("#endDate").val();

                loadJournal(selectedMethod, transactionId, fDate, tDate);
            });

            $("#chkAllData").on("change", function () {
                const checked = $(this).is(":checked");
                $("#startDate, #endDate").prop("disabled", checked);

            });

            $("#startDate, #endDate").on("change", function () {
                const fDate = $("#startDate").val();
                const tDate = $("#endDate").val();

                if (fDate && tDate && !$("#chkAllData").is(":checked")) {
                    const selectedMethod = $("#transactionSelect").val()?.trim() || 'Default';
                    loadJournal(selectedMethod, transactionId, fDate, tDate);
                }
            });

            $("#filterBtn").on("click", function () {
                const selectedMethod = $("#transactionSelect").val()?.trim() || 'Default';
                const fDate = $("#chkAllData").is(":checked") ? null : $("#startDate").val();
                const tDate = $("#chkAllData").is(":checked") ? null : $("#endDate").val();
                loadJournal(selectedMethod, transactionId, fDate, tDate);
            });

            // --- Initial load ---
            loadJournal(selectionMethod, transactionId, fromDate, toDate);

            // --- Load Journal Function ---
            function loadJournal(selectionMethod, transactionId, fromDate, toDate) {
              
                const data = {
                    selectionMethod: selectionMethod || 'Default',
                    transactionId: transactionId ? parseInt(transactionId) : null
                };

                if (fromDate && toDate) {
                    data.filterByDate = true;
                    data.fromDate = fromDate;
                    data.toDate = toDate;
                } else {
                    data.filterByDate = false;
                }

                $.ajax({
                url: '@Url.Action("GetJournal", "Lists")',
                    type: 'GET',
                    data: data,
                    beforeSend: function () {
                        // Destroy existing DataTable before showing loading message
                        if ($.fn.DataTable.isDataTable("#table1")) {
                            $("#table1").DataTable().clear().destroy();
                        }
                        $('#table1 tbody').html('<tr><td colspan="8" class="text-center py-4"><i class="fas fa-spinner fa-spin"></i> Loading...</td></tr>');
                    },
                    success: function (res) {
                      console.log(res);
                        const tbody = $('#table1 tbody').empty();

                        if (res.status && res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                // Format numbers with 2 decimal places
                                const debit = row.Debit != null ? parseFloat(row.Debit).toFixed(2) : '0.00';
                                const credit = row.Credit != null ? parseFloat(row.Credit).toFixed(2) : '0.00';

                                // Format date
                                let dateStr = '';
                                if (row.Date) {
                                    const d = new Date(row.Date);
                                    dateStr = d.toLocaleDateString('en-GB'); // DD/MM/YYYY format
                                }

                                tbody.append(`
                                    <tr>
                                        <td>${row.SN ?? ""}</td>
                                        <td>${row.RefId ?? ""}</td>
                                        <td>${dateStr}</td>
                                        <td>${row.Type ?? ""}</td>
                                        <td>${row.ACCode ?? ""}</td>
                                        <td>${row.ACName ?? ""}</td>
                                        <td class="text-end">${debit}</td>
                                        <td class="text-end">${credit}</td>
                                        <td>${row.CostCenterName ?? "-"}</td>
                                    </tr>
                                `);
                            });

                            // Initialize DataTable
                            $('#table1').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        className: 'btn btn-primary btn-sm',
                                        text: '<i class="fas fa-file-excel"></i> Excel',
                                        title: 'Transaction Journal - ' + selectionMethod,
                                        exportOptions: {
                                            columns: ':visible'
                                        }
                                    },
                                    {
                                        extend: 'pdfHtml5',
                                        className: 'btn btn-primary btn-sm',
                                        orientation: 'landscape',
                                        pageSize: 'A4',
                                        text: '<i class="fas fa-file-pdf"></i> PDF',
                                        title: 'Transaction Journal - ' + selectionMethod,
                                        exportOptions: {
                                            columns: ':visible'
                                        }
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15,
                                lengthMenu: [[10, 15, 25, 50, 100, -1], [10, 15, 25, 50, 100, "All"]],
                                language: {
                                    search: "Search:",
                                    lengthMenu: "Show _MENU_ entries",
                                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                                    infoEmpty: "Showing 0 to 0 of 0 entries",
                                    infoFiltered: "(filtered from _MAX_ total entries)",
                                    paginate: {
                                        first: "First",
                                        last: "Last",
                                        next: "Next",
                                        previous: "Previous"
                                    }
                                },
                                responsive: true
                            });

                            // Show success message
                            toastr.success(`Loaded ${res.data.length} records`, 'Success');

                        } else {
                            tbody.append('<tr><td colspan="8" class="text-center py-4 text-muted"><i class="fas fa-info-circle"></i> No records found</td></tr>');
                            toastr.info('No records found', 'Info');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('API Error:', xhr.responseText);
                        $('#table1 tbody').html('<tr><td colspan="8" class="text-center py-4 text-danger"><i class="fas fa-exclamation-triangle"></i> Error loading data</td></tr>');
                        toastr.error('Failed to load data: ' + error, 'Error');
                    }
                });
            }

                    // Inside loadJournal success after DataTable initialization:
        $('#table1 tbody').on('click', 'tr', function () {
            const row = $(this).find('td');
            const refId = row.eq(1).text().trim();   
            const vType = row.eq(3).text().trim();   
            const date = row.eq(2).text().trim();   
        
            if (refId && vType && date) {
                const params = new URLSearchParams({
                    refId: refId,
                    vType: vType,
                    date: date
                });
        window.location.href = '@Url.Action("GeneralJournal", "Lists")' + '?' + params.toString();
            }
        });


        });
    </script>
}