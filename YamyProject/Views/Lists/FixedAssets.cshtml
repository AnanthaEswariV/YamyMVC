                         const assetJsonForAttr = JSON.stringify(asset)
                             .replace(/&/g, '&amp;')
                             .replace(/'/g, '&#39;')
                             .replace(/"/g, '&quot;')
                             .replace(/</g, '&lt;')
                             .replace(/>/g, '&gt;');

                         const row = `<tr data-id="${asset.id}">
                             <td>${asset.name || '-'}</td>
                             <td>${PurchaseDate}</td>
                             <td>${EndDate}</td>
                             <td>${asset.purchasePrice}</td>
                             <td>
                                 <button class="btn btn-sm btn-primary editAsset"
                                         data-id="${asset.id}"
                                         data-asset="${assetJsonForAttr}"
                                         style="font-size: 10px; padding: 2px 6px;">
                                     <i class="fas fa-pen"></i>
                                 </button>
                                 <button class="btn btn-sm btn-danger deleteAsset"
                                         data-id="${asset.id}"
                                         style="font-size: 10px; padding: 2px 6px;">
                                     <i class="fas fa-prescription-bottle-alt"></i>
                                 </button>
                             </td>
                         </tr>`;
                         $tableBody.append(row);
                     });

                     console.log('✅ Table populated with', assets.length, 'rows');

                     // ✅ Auto-open edit modal if ID is in URL
                     const urlParams = new URLSearchParams(window.location.search);
                     const AssetId = urlParams.get('Id');

                     if (AssetId) {
                         console.log('🔍 Looking for asset ID:', AssetId);

                         // Wait for DOM to be fully updated
                         setTimeout(function() {
                             // Find all edit buttons
                             const allButtons = $('.editAsset');
                             console.log('📋 Found', allButtons.length, 'edit buttons');

                             // Log all button IDs
                             allButtons.each(function() {
                                 console.log('  - Button ID:', $(this).data('id'));
                             });

                             // Find the matching button
                             const editButton = $('.editAsset').filter(function() {
                                 const btnId = String($(this).data('id'));
                                 const targetId = String(AssetId);
                                 console.log(`Comparing: "${btnId}" === "${targetId}"`, btnId === targetId);
                                 return btnId === targetId;
                             });

                             if (editButton.length > 0) {
                                 console.log('✅ Found matching button for ID', AssetId);
                                 console.log('Asset data:', editButton.data('asset'));
                                 editButton.trigger('click');
                             } else {
                                 console.log('❌ No button found on first attempt, retrying...');
                                 toastr.info(`Loading item #${AssetId}...`);

                                 // Retry after 1.5 seconds
                                 setTimeout(function() {
                                     const $retryBtn = $('.editAsset').filter(function() {
                                         return String($(this).data('id')) === String(AssetId);
                                     });

                                     if ($retryBtn.length > 0) {
                                         console.log('✅ Found button on retry for ID', AssetId);
                                         $retryBtn.trigger('click');
                                     } else {
                                         console.log('❌ Asset ID', AssetId, 'not found after retry');
                                         console.log('Available IDs:', $('.editAsset').map(function() {
                                             return $(this).data('id');
                                         }).get());
                                         toastr.warning(`Asset #${AssetId} not found`);
                                     }
                                 }, 1500);
                             }
                         }, 300);
                     }
                 },
                 error: function(err) {
                     console.error("❌ Failed to fetch assets", err);
                     toastr.error("Failed to load assets");
                 }
             });
         }

        function formatDate(dateStr) {
            const d = new Date(dateStr);
            const month = ('0' + (d.getMonth() + 1)).slice(-2);
            const day = ('0' + d.getDate()).slice(-2);
            return d.getFullYear() + '-' + month + '-' + day;
        }

