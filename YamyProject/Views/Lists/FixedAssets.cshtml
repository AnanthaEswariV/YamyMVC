        function updateFixedAsset() {
            // Get form values
            const id = parseInt($("#editFixedAssetId").val());
            const categoryId = parseInt($("#editAssetCategory").val());
            const purchasePrice = parseFloat($("#editTotalInvoice").val());
            const depreciationLife = parseInt($("#editDepreciationLife").val());
            const name = $("#editAssetName").val()?.trim();

            // Frontend validation
            if (!id || id <= 0) {
                toastr.error("Invalid asset ID");
                return;
            }

            if (!name) {
                toastr.error("Please enter asset name");
                $("#editAssetName").focus();
                return;
            }

            if (!categoryId || categoryId <= 0) {
                toastr.error("Please select a category");
                $("#editAssetCategory").focus();
                return;
            }

            if (!purchasePrice || purchasePrice <= 0) {
                toastr.error("Please enter a valid purchase price");
                $("#editTotalInvoice").focus();
                return;
            }

            if (!depreciationLife || depreciationLife <= 0) {
                toastr.error("Please enter depreciation life");
                $("#editDepreciationLife").focus();
                return;
            }

            let payload = {
                Id: id,
                Name: name,
                Brand: $("#editAssetBrand").val() || "",
                CategoryId: categoryId,
                Model: $("#editModelEngNo").val() || "",
                Supplier: $("#editSupplierName").val() || "",
                Status: $("#editAssetStatus").val() || "",
                InvoiceNumber: $("#editInvoiceNumber").val() || "",
                PurchaseDate: $("#editPurchaseDate").val() || null,
                EndDate: $("#editEndDate").val() || null,
                DepreciationLife: depreciationLife,
                PurchasePrice: purchasePrice,
                DebitAccountId: parseInt($("#editFixedAssetsAccount").val()) || 0,
                CreditAccountId: parseInt($("#editAccumulatedDepreciation").val()) || 0,
                ExpenceAccountId: parseInt($("#editDepreciationExpense").val()) || 0,
                CreateJournal: $("#editMakeJournal").is(":checked"),
                CreatedBy: 0,
                ManufactureId: 0,
                CostCenter:  parseInt($("#editcostCenterSelect").val()) || 0,
            };

          

            $.ajax({
          url: '@Url.Action("UpdateFixedAsset", "Lists")',
                type: "POST",
                data: JSON.stringify(payload),
                contentType: "application/json",
                beforeSend: function() {
                    $("#editFixedAssetForm button[type='submit']").prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-1"></span>Updating...');
                },
                success: function(res) {
                    if (res.status) {
                        $("#editFixedAssetModal").modal("hide");
                        toastr.success(res.message || "Fixed Asset updated successfully!");

                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message || "Failed to update asset");
                    }
                },
                error: function(xhr, status, error) {
                    console.error("❌ Update failed:", xhr);

                    let errorMessage = "Failed to update asset";
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMessage = xhr.responseJSON.message;
                    } else if (xhr.responseText) {
                        try {
                            const response = JSON.parse(xhr.responseText);
                            errorMessage = response.message || errorMessage;
                        } catch (e) {
                            errorMessage = xhr.responseText;
                        }
                    }

                    toastr.error(errorMessage);
                    console.error("Full error:", {
                        status: xhr.status,
                        statusText: xhr.statusText,
                        response: xhr.responseText,
                        payload: payload
                    });
                },
                complete: function() {
                    $("#editFixedAssetForm button[type='submit']").prop("disabled", false).html('Update Asset');
                }
            });
        }

        $("#editFixedAssetForm").on("submit", function (e) {
            e.preventDefault();
            updateFixedAsset();
        });
        });

         let fixedTable;

        $(document).on("click", "#fixedassetTable tbody tr", function () {
            // Highlight selected row
            $("#fixedassetTable tbody tr").removeClass("table-active");
            $(this).addClass("table-active");

            const assetId = $(this).data("id");
            if (!assetId) return;

            $.ajax({
              url: '@Url.Action("GetFixedAssetsForGrid", "Lists")',
                type: 'GET',
                data: { assetId: assetId },
                success: function (res) {
                    if (!res.status) {
                        toastr.error("Failed to load asset details.");
                        return;
                    }

                    const rows = res.data.map(d => [
                        d.sn,
                        d.date,
                        d.days,
                        d.description,
                        d.amount,
                        d.note,
                        ""
                    ]);

                    if (fixedTable) {
                        // Clear old data and add new data
                        fixedTable.destroy();  // destroy old instance
                        fixedTable = null;
                    }

                    // Initialize (or re-initialize) the table
                    fixedTable = new simpleDatatables.DataTable("#fixedTable", {
                        searchable: true,
                        fixedHeight: true,
                        perPage: 10,
                        data: {
                            headings: ["S.No", "Date", "Days", "Description", "Amount", "Note", ""],
                            data: rows
                        }
                    });
                },
                error: function (err) {
                    console.error("Failed to load fixed asset details:", err);
                    toastr.error("Failed to load asset details.");
                }
            });
        });

        $(document).on("click", ".deleteAsset", function () {
            const assetId = $(this).data("id");

            if (!assetId) return;

            // Confirm deletion
            if (!confirm("Are you sure you want to delete this Fixed Asset?")) return;

            $.ajax({
               url: '@Url.Action("DeleteFixedAsset", "Lists")' + '?assetId=' + assetId,
                type: "DELETE",
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message || "Asset deleted successfully");


                                // Optional: reload page after short delay
                                setTimeout(() => location.reload(), 1500); loadFixedAssetCategories();
                    } else {
                        toastr.error(res.message || "Failed to delete asset");
                    }
                },
                error: function (err) {
                    console.error("Error deleting asset:", err);
                    toastr.error("Server error occurred while deleting asset");
                }
            });
        });


    </script>
}
