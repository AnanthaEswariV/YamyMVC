        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .fixed-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .fixed-main {
        margin: 0 -15px -15px -15px;
