    .employee-list {
        flex: 1;
        overflow-y: auto;
    }

    .employee-list-header {
        background: #f8f9fa;
        padding: 6px 12px;
        border-bottom: 1px solid #ddd;
        font-weight: bold;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
    }

    .employee-item {
        padding: 6px 12px;
        border-bottom: 1px solid #eee;
        cursor: pointer;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
    }

        .employee-item:hover {
            background: #f5f5f5;
        }

        .employee-item.active {
            background: #c8e6c9;
        }

    .employee-content {
        flex: 1;
        padding: 15px;
        background: white;
        position: relative;
    }

    .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }

}


</style>

