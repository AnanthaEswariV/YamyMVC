        $(document).ready(function () {

            function loadFixedAssetCategories() {
                $.ajax({
                   url: '@Url.Action("GetFixedAssetsCategoryList", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        if (!res.status) {
                            toastr.error(res.message || "Failed to load categories");
                            return;
                        }

                        const $ddlMain = $('#assetCategory');
                        const $ddlEdit = $('#editAssetCategory');

                        $ddlMain.empty().append('<option value="">-- Select --</option>');
                        $ddlEdit.empty().append('<option value="">-- Select --</option>');

                        res.data.forEach(cat => {
                            const option = $('<option>', {
                                value: cat.id,
                                text: cat.category_Name, 
                                'data-assets-account': cat.assetsAccountId,
                                'data-depreciation-account': cat.depreciationAccountId,
                                'data-expense-account': cat.expenceAccountId
                            });
                            $ddlMain.append(option.clone());
                            $ddlEdit.append(option.clone());
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("❌ Error fetching categories:", status, error);
                        toastr.error("Server error while loading categories");
                    }
                });
            }

            function bindCategoryChangeHandlers() {
                // Add form
                $('#assetCategory').on('change', function () {
                    const selected = $(this).find(':selected');
                    if (!selected.val()) return;

                    $('#fixedAssetsAccount').val(selected.data('assets-account')).trigger("change");
                    $('#accumulatedDepreciation').val(selected.data('depreciation-account')).trigger("change");
                    $('#depreciationExpense').val(selected.data('expense-account')).trigger("change");
                });

                // Edit form
                $('#editAssetCategory').on('change', function () {
                    const selected = $(this).find(':selected');
                    if (!selected.val()) return;

                    $('#editFixedAssetsAccount').val(selected.data('assets-account')).trigger("change");
                    $('#editAccumulatedDepreciation').val(selected.data('depreciation-account')).trigger("change");
                    $('#editDepreciationExpense').val(selected.data('expense-account')).trigger("change");
                });
            }

            function loadAccounts() {
                $.ajax({
                   url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function (data) {
                        const dropdowns = [
                            { ddl: '#fixedAssetsAccount', codeBox: '#code2' },
                            { ddl: '#accumulatedDepreciation', codeBox: '#code3' },
                            { ddl: '#depreciationExpense', codeBox: '#code4' },
                            { ddl: '#editFixedAssetsAccount', codeBox: '#editCode2' },
                            { ddl: '#editAccumulatedDepreciation', codeBox: '#editCode3' },
                            { ddl: '#editDepreciationExpense', codeBox: '#editCode4' }
                        ];

                        dropdowns.forEach(set => {
                            const $ddl = $(set.ddl);
                            $ddl.empty().append('<option value="">-- Select --</option>');

                            data.forEach(item => {
                                $ddl.append(
                                    $('<option>', {
                                        value: item.id,
                                        text: item.code + ' - ' + item.name,
                                        'data-code': item.code
                                    })
                                );
                            });

                            // 🔹 Update account code textbox on change
                            $ddl.off('change').on('change', function () {
                                const selected = $(this).find(':selected');
                                $(set.codeBox).val(selected.data('code') || "");
                            });
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("❌ Error loading accounts:", status, error);
                        toastr.error("Server error while loading accounts");
                    }
                });
            }

            function populateAndSelectCostCenter() {
            $.ajax({
                url: '@Url.Action("GetCostCenters", "Lists")',
                type: 'GET',
                success: function (res) {
                    console.log(res);  // Check the response structure here
                    const data = Array.isArray(res) ? res : (res.data || []);
                    if (!data.length) return;

                    const allSelects = $('#costCenterSelect, #editcostCenterSelect');

                    // Loop through each select dropdown
                    allSelects.each(function () {
                        const $select = $(this);
                        const selectedId = $select.data('selected-id');  

                        $select.empty().append('<option value="">-- Select --</option>');

                        // Populate the select with options
                        $.each(data, function (i, item) {
                            const isSelected = String(item.id) === String(selectedId);  
                            const option = `<option value="${item.id}" ${isSelected ? 'selected' : ''}>${item.code} - ${item.name}</option>`;
                            $select.append(option);
                        });
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Error loading cost centers:", error);
                    // Optionally, display a message for error
                }
            });
        }


            loadFixedAssetCategories();
            loadAccounts();
            populateAndSelectCostCenter();
            bindCategoryChangeHandlers();
            

