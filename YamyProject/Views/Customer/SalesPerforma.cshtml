@{
    ViewData["Title"] = "SalesPerforma";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
    /* Highlight selected row */
    #table1 tbody tr.selected {
        background-color: #c7e5b4;
    }

    .modal-dialog-scrollable .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong class="mx-auto">Sales Performa Center</strong>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#salesModal">
            <i class="bi bi-plus-circle"></i> New
        </button>
    </div>
    <div class="card-body" style="font-size:small">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <div style="min-width: 150px;">
                <select class="form-select" id="type">
                    <option value="">-- Select Customer --</option>
                </select>
            </div>

            <!-- Start Date -->
            <div style="min-width: 150px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 150px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkDate" class="form-check-input">
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>

            <div style="min-width: 150px;">
                <select class="form-select" id="method">
                    <option value="Default" selected>Default</option>
                    <option value="Item Wise">Item Wise</option>
                </select>
            </div>

            <div style="min-width: 150px;">
                <select class="form-select" id="paymentMethod">
                    <option value="">-- Select PaymentMethod --</option>
                    <option value="Cash">Cash</option>
                    <option value="Credit">Credit</option>
                </select>
            </div>
            
        </div>

        <!-- Default method: Two tables -->
        <div id="defaultTables" style="height: 80vh; display: flex; flex-direction: column;">
            <div class="card-body flex-grow-1" style="overflow-y: auto;">
                <table class="table table-striped" id="table1">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Date</th>
                            <th>INV No</th>
                            <th>Customer Name</th>
                            <th>Payment Method</th>
                            <th>Total</th>
                            <th>VAT</th>
                            <th>Net</th>
                            <th>JV No</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="card-footer p-0" style="height: 150px; overflow-y: auto;">
                <table class="table table-striped" id="table2">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>QTY</th>
                            <th>Price</th>
                            <th>Item VAT</th>
                            <th>Item Total</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <!-- Item Wise method: Single combined table -->
        <div id="itemWiseTable" style="display:none; height: 80vh; overflow-y: auto;">
            <table class="table table-striped" id="itemWiseTableData">
                <thead>
                    <tr>
                        <th>S.No</th>
                        <th>Date</th>
                        <th>INV No</th>
                        <th>Customer Name</th>
                        <th>Payment Method</th>
                        <th>Total</th>
                        <th>VAT</th>
                        <th>Net</th>
                        <th>Item Name</th>
                        <th>QTY</th>
                        <th>Price</th>
                        <th>Item VAT</th>
                        <th>Item Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="salesModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <form id="salescenterform" class="needs-validation" novalidate>
                <input type="hidden" id="invoiceId" value="0">
                <!-- Header -->
                <div class="modal-header bg-primary text-white py-2">
                    <h6 class="modal-title fw-bold mx-auto">Sales Invoice</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">

                    <!-- Row 1 -->
                    <div class="row g-2">
                        <div class="col-md-2">
                            <label class="form-label">Customer</label>
                            <select class="form-select form-select-sm" id="customerName" required>
                                <option value="">-- Select Customer --</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Date</label>
                            <input type="date" class="form-control form-control-sm" id="date">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Invoice</label>
                            <input class="form-control form-control-sm" id="invoiceCode" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Performa Invoice No</label>
                            <input id="poNo" class="form-control form-control-sm">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Quotation No</label>
                            <input id="billTo" class="form-control form-control-sm">
                        </div>
                    </div>

                    <!-- Row 2 -->
                    <div class="row g-2 mt-2">
                        <div class="col-md-4">
                            <label class="form-label">Invoice Type</label>
                            <select class="form-select form-select-sm" id="invoiceType">
                                <option value="Cash" selected>Cash</option>
                                <option value="Credit">Credit</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Emirates</label>
                            <select class="form-select form-select-sm" id="emirates">
                                <option value="Abu Dhabi" selected>Abu Dhabi</option>
                                <option value="Dubai">Dubai</option>
                                <option value="Sharjah">Sharjah</option>
                                <option value="Ajman">Ajman</option>
                                <option value="Fujairah">Fujairah</option>
                                <option value="Ras Al Khaimah"></option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Warehouse</label>
                            <select class="form-select" id="warehouseDropdown"><option value="">Select Warehouse</option></select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Payment Terms</label>
                            <input type="hidden" id="paymentTermsValue">
                            <select class="form-select form-select-sm" id="paymentTerms" disabled>
                                <option value="30">30</option>
                                <option value="60">60</option>
                                <option value="90">90</option>
                                <option value="120">120</option>
                                <option value="150">150</option>
                                <option value="180">180</option>
                                <option value="210">210</option>
                                <option value="240">240</option>
                                <option value="270">270</option>
                                <option value="300">300</option>
                                <option value="330">330</option>
                                <option value="360">360</option>
                            </select>
                        </div>

                    </div>

                    <!-- Row 3 -->
                    <div class="row g-2 mt-2">

                        <div class="col-md-2">
                            <label class="form-label">Due to</label>
                            <input type="date" class="form-control form-control-sm" id="duedate">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ship</label>
                            <input class="form-control form-control-sm" id="ship">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ship Date</label>
                            <input type="date" class="form-control form-control-sm" id="shipDate">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Via</label>
                            <select class="form-select form-select-sm" id="viaType">
                                <option value="DHL" selected>DHL</option>
                                <option value="MAIL">MAIL</option>
                                <option value="On Site">On Site</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Sales Man</label>
                            <input type="text" class="form-control form-control-sm" id="salesMan">
                        </div>

                        <div class="col-md-2">
                            <label for="accountName" class="form-label">Account Name</label>
                            <select id="accountName" class="form-select form-select-sm" required>
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-sm align-middle" id="editItemsTable">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>S.No</th>
                                    <th>Code</th>
                                    <th>Item Name</th>
                                    <th>QTY</th>
                                    <th>Price</th>
                                    <th>Disc</th>
                                    <th>Net</th>
                                    <th>VAT</th>
                                    <th>Amount</th>
                                    <th>Cost Center</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-success" id="addEditItemRowBtn">
                            <i class="bi bi-plus-circle"></i> Add Row
                        </button>
                    </div>

                    <!-- Notes & Totals -->
                    <div class="row mt-3">
                        <div class="col-md-8">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" rows="4"></textarea>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-2">
                                <label>Total Before VAT</label>
                                <input class="form-control form-control-sm text-end" id="totalBeforeVat" readonly>
                            </div>
                            <div class="mb-2">
                                <label>Total VAT</label>
                                <input class="form-control form-control-sm text-end" id="totalVat" readonly>
                            </div>
                            <div>
                                <label>Net Amount</label>
                                <input class="form-control form-control-sm text-end fw-bold" id="netAmount" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- CREATE INVOICE MODAL -->
<div class="modal fade" id="salesCenterModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <form id="salescentersform" class="needs-validation" novalidate>
                <input type="hidden" id="createInvoiceId" value="0">

                <div class="modal-header bg-primary text-white py-2">
                    <h6 class="modal-title fw-bold mx-auto">Create Sales Invoice</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row g-2">
                        <div class="col-md-2">
                            <label class="form-label">Customer</label>
                            <select class="form-select form-select-sm" id="createCustomerName" required>
                                <option value="">-- Select Customer --</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Date</label>
                            <input type="date" class="form-control form-control-sm" id="createDate">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Invoice</label>
                            <input class="form-control form-control-sm" id="createInvoiceCode" readonly>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">P.O No</label>
                            <input class="form-control form-control-sm" id="createPoNo">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Performa Invoice No</label>
                            <input class="form-control form-control-sm" id="createPerformaNo">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Quotation No</label>
                            <input class="form-control form-control-sm" id="createQuotationNo">
                        </div>
                    </div>



                    <div class="row g-2 mt-2">
                        <div class="col-md-4">
                            <label class="form-label">Bill To</label>
                            <input class="form-control form-control-sm" id="createBillTo">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Invoice Type</label>
                            <select class="form-select form-select-sm" id="createInvoiceType">
                                <option value="Cash" selected>Cash</option>
                                <option value="Credit">Credit</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Emirates</label>
                            <select class="form-select form-select-sm" id="createEmirates">
                                <option value="Abu Dhabi" selected>Abu Dhabi</option>
                                <option value="Dubai">Dubai</option>
                                <option value="Sharjah">Sharjah</option>
                                <option value="Ajman">Ajman</option>
                                <option value="Fujairah">Fujairah</option>
                                <option value="Ras Al Khaimah">Ras Al Khaimah</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Warehouse</label>
                            <select class="form-select" id="createWarehouseDropdown"><option value="">Select Warehouse</option></select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Payment Terms</label>
                            <input type="hidden" id="createPaymentTermsValue">
                            <select class="form-select form-select-sm" id="createPaymentTerms" disabled>
                                <option value="30">30</option>
                                <option value="60">60</option>
                                <option value="90">90</option>
                                <option value="120">120</option>
                                <option value="150">150</option>
                                <option value="180">180</option>
                                <option value="210">210</option>
                                <option value="240">240</option>
                                <option value="270">270</option>
                                <option value="300">300</option>
                                <option value="330">330</option>
                                <option value="360">360</option>
                            </select>
                        </div>

                    </div>

                    <div class="row g-2 mt-2">

                        <div class="col-md-2">
                            <label class="form-label">Due to</label>
                            <input type="date" class="form-control form-control-sm" id="createDuedate">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ship</label>
                            <input class="form-control form-control-sm" id="createShip">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ship Date</label>
                            <input type="date" class="form-control form-control-sm" id="createShipDate">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Via</label>
                            <select class="form-select form-select-sm" id="createViaType">
                                <option value="DHL" selected>DHL</option>
                                <option value="MAIL">MAIL</option>
                                <option value="On Site">On Site</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Sales Man</label>
                            <input type="text" class="form-control form-control-sm" id="createSalesMan">
                        </div>

                        <div class="col-md-2">
                            <label for="createAccountName" class="form-label">Account Name</label>
                            <select id="createAccountName" class="form-select form-select-sm" required>
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-sm align-middle" id="createItemsTable">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>S.No</th>
                                    <th>Code</th>
                                    <th>Item Name</th>
                                    <th>QTY</th>
                                    <th>Price</th>
                                    <th>Disc</th>
                                    <th>Net</th>
                                    <th>VAT</th>
                                    <th>Amount</th>
                                    <th>Cost Center</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-success" id="addCreateItemRowBtn">
                            <i class="bi bi-plus-circle"></i> Add Row
                        </button>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-8">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" rows="4" id="createNotes"></textarea>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-2">
                                <label>Total Before VAT</label>
                                <input class="form-control form-control-sm text-end" id="createTotalBeforeVat" readonly>
                            </div>
                            <div class="mb-2">
                                <label>Total VAT</label>
                                <input class="form-control form-control-sm text-end" id="createTotalVat" readonly>
                            </div>
                            <div>
                                <label>Net Amount</label>
                                <input class="form-control form-control-sm text-end fw-bold" id="createNetAmount" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>


        $(document).ready(function () {

            loadCustomers();
            loadSalesQuotation();
            loadItem();
            loadTax();
            loadWarehouses();
            populateAndSelectCostCenter();

            $("#chkDate").change(function () {
                if (this.checked) {
                    $("#startDate, #endDate").prop("disabled", false);
                } else {
                    $("#startDate, #endDate")
                        .prop("disabled", true)
                        .val("");
                }
            });

            $("#filterBtn").click(loadSalesQuotation);
            $("#type").change(loadSalesQuotation);
            $("#paymentMethod").change(loadSalesQuotation);
            $("#method").change(function () {
                if (this.value === "Default") {
                    $("#defaultTables").show();
                    $("#itemWiseTable").hide();
                } else {
                    $("#defaultTables").hide();
                    $("#itemWiseTable").show();
                }
                loadSalesQuotation();
            });

            function getTodayDate() {
                const today = new Date();
                const year = today.getFullYear();
                const month = String(today.getMonth() + 1).padStart(2, '0');
                const day = String(today.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            document.getElementById('salesModal').addEventListener('shown.bs.modal', function () {
                const todayDate = getTodayDate();
                const dateFields = ['date', 'duedate', 'shipDate'];
                dateFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (field && !field.value) {
                        field.value = todayDate;
                    }
                });
            });

            document.getElementById('salesCenterModal').addEventListener('shown.bs.modal', function () {
                const todayDate = getTodayDate();
                const dateFields = ['createDate', 'createDuedate', 'createShipDate'];
                dateFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (field && !field.value) {
                        field.value = todayDate;
                    }
                });
            });

            $('#paymentTerms, #createPaymentTerms').prop('disabled', true);
            setDueDate();

            function setDueDate() {
                const isCreateModal = $('#salesCenterModal').hasClass('show');
                const invoiceType = isCreateModal ? $('#createInvoiceType').val() : $('#invoiceType').val();
                const paymentTerms = isCreateModal ? $('#createPaymentTerms').val() : $('#paymentTerms').val();
                const dueDateField = isCreateModal ? '#createDuedate' : '#duedate';
                const dateField = isCreateModal ? '#createDate' : '#date';

                let days = 0;
                if (invoiceType === 'Credit') {
                    days = parseInt(paymentTerms, 10) || 30;
                }

                const baseDateStr = $(dateField).val();
                const baseDate = baseDateStr ? new Date(baseDateStr) : new Date();
                const dueDate = new Date(baseDate);
                dueDate.setDate(dueDate.getDate() + days);

                const yyyy = dueDate.getFullYear();
                const mm = String(dueDate.getMonth() + 1).padStart(2, '0');
                const dd = String(dueDate.getDate()).padStart(2, '0');
                $(dueDateField).val(`${yyyy}-${mm}-${dd}`);
            }

            $('#invoiceType, #createInvoiceType').on('change', function () {
                const type = $(this).val();
                setDueDate();
                loadAccountName(type);
            });

            $('#paymentTerms, #createPaymentTerms').on('change', function() {
                const isCreate = $(this).attr('id') === 'createPaymentTerms';
                const value = $(this).val();
                if (isCreate) {
                    $('#createPaymentTermsValue').val(value);
                } else {
                    $('#paymentTermsValue').val(value);
                }
                setDueDate();
            });

            function loadAccountName(invoiceType) {
                if (!invoiceType) {
                    console.warn('Invoice type not provided to loadAccountName');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function (accounts) {
                        const $accountName = $('#accountName');
                        const $createAccountName = $('#createAccountName');

                        $accountName.empty().append('<option value="">-- Select --</option>');
                        $createAccountName.empty().append('<option value="">-- Select --</option>');

                        $.each(accounts, function (_, item) {
                            const option = $('<option>', {
                                value: item.id,
                                text: `${item.code} - ${item.name}`
                            });
                            $accountName.append(option.clone());
                            $createAccountName.append(option);
                        });

                        $.ajax({
                            url: '/Customer/GetPaymentMethodInfo',
                            type: 'GET',
                            data: { method: invoiceType },
                            success: function (res) {
                                if (res.status) {
                                    $accountName.val(res.accountId);
                                    $createAccountName.val(res.accountId);
                                    const isCredit = invoiceType === 'Credit';
                                    $('#paymentTerms, #createPaymentTerms').prop('disabled', !isCredit);

                                    if (isCredit && res.paymentTerms) {
                                        $('#paymentTerms').val(res.paymentTerms);
                                        $('#createPaymentTerms').val(res.paymentTerms);
                                        $('#paymentTermsValue').val(res.paymentTerms);
                                        $('#createPaymentTermsValue').val(res.paymentTerms);
                                    } else {
                                        $('#paymentTerms, #createPaymentTerms').val('30');
                                    }
                                    setDueDate();
                                } else {
                                    toastr.error('Failed to load payment method info');
                                }
                            },
                            error: function(xhr) {
                                console.error('Error loading payment method info:', xhr);
                                toastr.error('Error loading payment configuration');
                            }
                        });
                    },
                    error: function(xhr) {
                        console.error('Error loading accounts:', xhr);
                        toastr.error('Failed to load account names');
                    }
                });
            }

