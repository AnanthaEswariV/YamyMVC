        $(document).on("change", ".itemNameSelect", function () {
            const selectedId = parseInt($(this).val(), 10);
            const row = $(this).closest("tr");

            if (selectedId) {
                const selectedItem = itemsList.find(item => item.id === selectedId);
                if (selectedItem) {
                    row.find(".itemCode").val(selectedItem.code || "");
                    row.find(".itemPrice").val(selectedItem.sales_price || 0);
                    // row.find(".itemPrice").data('cost-price', selectedItem.cost_price || 0);
                    calculateRow(row);
                } else {
                    console.log("Item not found in itemsList.");
                }
            } else {
                row.find(".itemCode").val("");
                row.find(".itemPrice").val(0);
                row.find(".itemPrice").data('cost-price', 0);
                calculateRow(row);
            }
        });

        function calculateRow(row) {
            const qty = parseFloat(row.find(".qty").val()) || 0;
            const price = parseFloat(row.find(".itemPrice").val()) || 0;
            const discount = parseFloat(row.find(".itemDiscount").val()) || 0;

            const net = qty * price - discount;
            row.find(".itemNet").text(net.toFixed(2));

            const taxPercent = parseFloat(row.find(".tax option:selected").data("value")) || 0;
            const taxAmount = net * (taxPercent / 100);
            const amount = net + taxAmount;

            row.find(".tax").attr("title", `Tax Amount: ${taxAmount.toFixed(2)}`);
            row.find(".itemAmount").text(amount.toFixed(2));

            calculateInvoiceTotals();
        }

        $(document).on("input", ".qty, .itemPrice, .itemDiscount", function() {
            const row = $(this).closest("tr");
            calculateRow(row);
        });

        $(document).on("change", ".tax", function() {
            const row = $(this).closest("tr");
            calculateRow(row);
        });

        function calculateInvoiceTotals() {
            let totalBeforeVat = 0;
            let totalVat = 0;

            const isCreateModal = $('#salesCenterModal').hasClass('show');
            const tableSelector = isCreateModal ? '#createItemsTable tbody tr' : '#editItemsTable tbody tr';

            $(tableSelector).each(function () {
                const row = $(this);
                const net = parseFloat(row.find(".itemNet").text()) || 0;
                const amount = parseFloat(row.find(".itemAmount").text()) || 0;

                totalBeforeVat += net;
                totalVat += (amount - net);
            });

            const netAmount = totalBeforeVat + totalVat;

            if (isCreateModal) {
                $('#createTotalBeforeVat').val(totalBeforeVat.toFixed(2));
                $('#createTotalVat').val(totalVat.toFixed(2));
                $('#createNetAmount').val(netAmount.toFixed(2));
            } else {
                $('#totalBeforeVat').val(totalBeforeVat.toFixed(2));
                $('#totalVat').val(totalVat.toFixed(2));
                $('#netAmount').val(netAmount.toFixed(2));
            }
        }

        function loadSalesQuotation() {
            const customerId = $("#type").val() || null;
            const paymentMethod = $("#paymentMethod").val() || null;
            const selectionMethod = $("#method").val() || "Default";
            const dateFrom = $("#startDate").val() || null;
            const dateTo = $("#endDate").val() || null;

            $.ajax({
                url: '@Url.Action("GetSalesProformas", "Customer")',
                type: 'GET',
                data: { customerId, paymentMethod, selectionMethod, dateFrom, dateTo },
                success: function (res) {
                    if (!res.status) {
                        toastr.error('Failed to load sales data.');
                        return;
                    }
                    console.log(res);
                    if (selectionMethod === "Default") {
                        populateDefaultTables(res.data);
                    } else {
                        populateItemWiseTable(res.data);
                    }
                },
                error: function () {
                    toastr.error('Error loading sales data.');
                }
            });
        }

        function populateDefaultTables(data) {
            const table1Body = $("#table1 tbody").empty();
            const table2Body = $("#table2 tbody").empty();

            data.forEach((sale, index) => {
                const row = $(`
                    <tr data-index="${index}">
                        <td>${index + 1}</td>
                        <td>${formatDate(sale.date)}</td>
                        <td>${sale.invoiceCode}</td>
                        <td>${sale.customerName}</td>
                        <td>${sale.paymentMethod}</td>
                        <td>${sale.total.toFixed(2)}</td>
                        <td>${sale.vat.toFixed(2)}</td>
                        <td>${sale.net.toFixed(2)}</td>
                        <td></td>
                        <td>
                            <button class="btn btn-sm btn-primary editSalesQuotationBtn">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button class="btn btn-sm btn-primary viewInvoiceBtn" data-sales-id="${sale.id}">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-success createInvoiceBtn" data-sales-id="${sale.id}">
                                <i class="fas fa-file-invoice"></i>
                            </button>
                        </td>
                    </tr>
                `);

                row.on("click", function (e) {
                    if ($(e.target).closest(".editSalesQuotationBtn, .viewInvoiceBtn, .createInvoiceBtn").length) return;

                    table2Body.empty();

                    if (!sale.items || sale.items.length === 0) {
                        table2Body.append('<tr><td colspan="5" class="text-center">No Items</td></tr>');
                        return;
                    }

                    sale.items.forEach(item => {
                        table2Body.append(`
                            <tr>
                                <td>${item.itemName}</td>
                                <td>${item.qty}</td>
                                <td>${item.price.toFixed(2)}</td>
                                <td>${item.vat.toFixed(2)}</td>
                                <td>${item.total.toFixed(2)}</td>
                            </tr>
                        `);
                    });
                });

                row.find(".editSalesQuotationBtn").on("click", function (e) {
                    e.stopPropagation();
                    openSalesModal(sale);
                });

                row.find(".createInvoiceBtn").on("click", function (e) {
                    e.stopPropagation();
                    openSalesCenterModal(sale);
                });

                table1Body.append(row);
            });
        }

