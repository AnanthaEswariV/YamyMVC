                            <td>${sale.invoiceCode}</td>
                            <td>${sale.customerName}</td>
                            <td>${sale.paymentMethod}</td>
                            <td>${sale.total.toFixed(2)}</td>
                            <td>${sale.vat.toFixed(2)}</td>
                            <td>${sale.net.toFixed(2)}</td>
                            <td>${item.itemName}</td>
                            <td>${item.qty}</td>
                            <td>${item.price.toFixed(2)}</td>
