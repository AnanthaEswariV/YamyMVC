        function loadWarehouses(selector) {
            $.ajax({
                url: '@Url.Action("GetWarehouses", "Inventory")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const dropdowns = selector ? $(selector) : $("#warehouseDropdown, #createWarehouseDropdown");
                        dropdowns.empty().append('<option value="">Select Warehouse</option>');
                        res.data.forEach(w => {
                            dropdowns.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        alert(res.message);
                    }
                }
            });
