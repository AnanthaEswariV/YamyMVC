        $(document).on("change", ".itemNameSelect", function () {
            const selectedId = parseInt($(this).val(), 10);
            const row = $(this).closest("tr");

            if (selectedId) {
                const selectedItem = itemsList.find(item => item.id === selectedId);

                if (selectedItem) {
                    row.find("td:nth-child(2) input").val(selectedItem.code || "");
                    row.find("td:nth-child(5) input").val(selectedItem.cost_price || 0);
                    calculateRow(row);
                }
            } else {
                row.find("td:nth-child(2) input").val("");
                row.find("td:nth-child(5) input").val(0);
                calculateRow(row);
            }
        });

        function calculateRow(row) {
            const qty = parseFloat(row.find("td:nth-child(4) input").val()) || 0;
            const price = parseFloat(row.find("td:nth-child(5) input").val()) || 0;
            const discount = parseFloat(row.find("td:nth-child(6) input").val()) || 0;

            const net = qty * price - discount;
            row.find("td:nth-child(7)").text(net.toFixed(2));

            const taxPercent = parseFloat(row.find(".tax option:selected").data("value")) || 0;
            const taxAmount = net * (taxPercent / 100);
            const amount = net + taxAmount;

            row.find(".tax").attr("title", `Tax Amount: ${taxAmount.toFixed(2)}`);
            row.find("td:nth-child(9)").text(amount.toFixed(2));

            calculateInvoiceTotals(row.closest('table'));
        }

        $(document).on("change", ".tax, .qty", function() {
            const row = $(this).closest("tr");
            calculateRow(row);
        });

        $(document).on("input", "td:nth-child(4) input, td:nth-child(5) input, td:nth-child(6) input", function() {
            const row = $(this).closest("tr");
            calculateRow(row);
        });

        function calculateInvoiceTotals(table) {
            let totalBeforeVat = 0;
            let totalVat = 0;

            table.find('tbody tr').each(function () {
                const row = $(this);
                const net = parseFloat(row.find("td:nth-child(7)").text()) || 0;
                const amount = parseFloat(row.find("td:nth-child(9)").text()) || 0;

                totalBeforeVat += net;
                totalVat += (amount - net);
            });

            const netAmount = totalBeforeVat + totalVat;

            const modalId = table.closest('.modal').attr('id');
            const prefix = modalId === 'salesModal' ? 'edit' : 'create';

            $(`#${prefix}TotalBeforeVat`).val(totalBeforeVat.toFixed(2));
            $(`#${prefix}TotalVat`).val(totalVat.toFixed(2));
            $(`#${prefix}NetAmount`).val(netAmount.toFixed(2));
        }

