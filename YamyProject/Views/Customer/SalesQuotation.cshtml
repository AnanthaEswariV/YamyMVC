        $('#salescenterform').on('submit', function (e) {
            e.preventDefault();
            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            $('#editPaymentTermsValue').val($('#editPaymentTerms').val());

            const invoiceData = {
                Id: $("#salescenterform").data("invoiceId") || 0,
                InvoiceDate: $('#editDate').val(),
                CustomerId: parseInt($('#editCustomerName').val()) || 0,
                InvoiceCode: $('#editInvoiceCode').val().trim(),
                PONumber: $('#editPoNo').val().trim(),
                BillTo: $('#editBillTo').val().trim(),
                City: $('#editEmirates').val(),
                SalesMan: $('#editSalesMan').val().trim(),
                ShipDate: $('#editShipDate').val(),
                ShipVia: $('#editViaType').val(),
                ShipTo: $('#editShip').val().trim(),
                PaymentMethod: $('#editInvoiceType').val(),
                AccountCashId: parseInt($('#editAccountName').val()) || 0,
                PaymentTerms: $('#editPaymentTermsValue').val(),
                PaymentDate: $('#editDuedate').val(),
                TotalBefore: parseFloat($('#editTotalBeforeVat').val()) || 0,
                Vat: parseFloat($('#editTotalVat').val()) || 0,
                NetTotal: parseFloat($('#editNetAmount').val()) || 0,
                WarehouseId: parseInt($('#editWarehouseDropdown').val()) || 0,
                Items: []
            };

            $('#editItemsTable tbody tr').each(function () {
                const row = $(this);

                const qty = parseFloat(row.find('.qty').val()) || 0;
                const price = parseFloat(row.find('td:nth-child(5) input').val()) || 0;
                const discount = parseFloat(row.find('td:nth-child(6) input').val()) || 0;
                const taxId = parseInt(row.find('.tax').val()) || 0;
                const taxPercent = parseFloat(row.find('.tax option:selected').data('value')) || 0;

                const taxableAmount = (qty * price) - discount;
                const calculatedVat = taxableAmount * (taxPercent / 100);

                const item = {
                    ItemId: parseInt(row.find('.itemNameSelect').val()) || 0,
                    Quantity: qty,
                    CostPrice: parseFloat(row.find('td:nth-child(5) input').data('cost-price')) || 0,
                    Price: price,
                    Discount: discount,
                    TaxId: taxId,
                    VatPercentage: taxPercent,
                    Vat: calculatedVat,
                    Total: parseFloat(row.find('td:nth-child(9)').text()) || 0,
                    CostCenterId: parseInt(row.find('.costCenterSelect').val()) || 0,
                };

                invoiceData.Items.push(item);
            });

            $.ajax({
                url: '@Url.Action("SaveQuotation", "Customer")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(invoiceData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message);
                        $('#salesModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error("❌ AJAX ERROR", xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

