@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>

        $(document).ready(function () {
            loadEditAccountName();
            loadCustomers();
            loadSalesQuotation();
            loadItem();
            loadTax();
            loadWarehouses();
            populateAndSelectCostCenter();

            $("#chkDate").change(function () {
                if (this.checked) {
                    $("#startDate, #endDate").prop("disabled", false);
                } else {
                    $("#startDate, #endDate")
                        .prop("disabled", true)
                        .val("");
                }
            });
            $("#filterBtn").click(loadSalesQuotation);
            $("#type").change(loadSalesQuotation);
            $("#paymentMethod").change(loadSalesQuotation);
            $("#method").change(function () {
                if (this.value === "Default") {
                    $("#defaultTables").show();
                    $("#itemWiseTable").hide();
                } else {
                    $("#defaultTables").hide();
                    $("#itemWiseTable").show();
                }
                loadSalesQuotation();
            });

           function getTodayDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

           // EDIT MODAL - Set dates on open
           $('#salesModal').on('shown.bs.modal', function () {
            const todayDate = getTodayDate();
            const dateFields = ['editDate', 'editDuedate', 'editShipDate'];
            dateFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !field.value) {
                    field.value = todayDate;
                }
            });
        });

           // CREATE MODAL - Set dates on open
           $('#salesCenterModal').on('shown.bs.modal', function () {
            const todayDate = getTodayDate();
            const dateFields = ['createDate', 'createDuedate', 'createShipDate'];
            dateFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !field.value) {
                    field.value = todayDate;
                }
            });
        });

            // EDIT MODAL - Payment Terms Logic
            function setEditDueDate() {
                const invoiceType = $('#editInvoiceType').val();
                let days = 0;

                if (invoiceType === 'Credit') {
                    $('#editPaymentTerms').prop('disabled', false);
                    days = parseInt($('#editPaymentTerms').val()) || 0;
                } else {
                    $('#editPaymentTerms').prop('disabled', true);
                    days = 0;
                }

                const today = new Date();
                const dueDate = new Date();
                dueDate.setDate(today.getDate() + days);

                const yyyy = dueDate.getFullYear();
                const mm = String(dueDate.getMonth() + 1).padStart(2, '0');
                const dd = String(dueDate.getDate()).padStart(2, '0');

                $('#editDuedate').val(`${yyyy}-${mm}-${dd}`);
            }

            $('#editInvoiceType').on('change', setEditDueDate);
            $('#editPaymentTerms').on('change', setEditDueDate);

            // CREATE MODAL - Payment Terms Logic
            function setCreateDueDate() {
                const invoiceType = $('#createInvoiceType').val();
                let days = 0;

                if (invoiceType === 'Credit') {
                    $('#createPaymentTerms').prop('disabled', false);
                    days = parseInt($('#createPaymentTerms').val()) || 0;
                } else {
                    $('#createPaymentTerms').prop('disabled', true);
                    days = 0;
                }

                const today = new Date();
                const dueDate = new Date();
                dueDate.setDate(today.getDate() + days);

                const yyyy = dueDate.getFullYear();
                const mm = String(dueDate.getMonth() + 1).padStart(2, '0');
                const dd = String(dueDate.getDate()).padStart(2, '0');

                $('#createDuedate').val(`${yyyy}-${mm}-${dd}`);
            }

            $('#createInvoiceType').on('change', setCreateDueDate);
            $('#createPaymentTerms').on('change', setCreateDueDate);

            // EDIT MODAL - Load Account Name
            function loadEditAccountName(invoiceType) {
                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function(accounts) {
                        const $ddl = $("#editAccountName");
                        $ddl.empty().append('<option value="">-- Select --</option>');

                        $.each(accounts, function(i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name,
                                    'data-code': item.code
                                })
                            );
                        });

                        $.ajax({
                            url: '/Customer/GetPaymentMethodInfo',
                            type: 'GET',
                            data: { method: invoiceType },
                            success: function(res) {
                                if (res.status) {
                                    $ddl.val(res.accountId);
                                    $("#editPaymentTerms").prop('disabled', !res.paymentTermsEnabled);
                                    $("#editPaymentTermsValue").val(res.paymentTermsEnabled ? $("#editPaymentTerms").val() : "");
                                }
                            }
                        });
                    }
                });
            }

            $("#editInvoiceType").on("change", function() {
                loadEditAccountName($(this).val());
