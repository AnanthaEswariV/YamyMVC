        function calculateInvoiceTotals() {
            let totalBeforeVat = 0;
            let totalVat = 0;

            $('#salesModal tbody tr').each(function () {
                const row = $(this);

                const net = parseFloat(row.find("td:nth-child(7)").text()) || 0;
                const amount = parseFloat(row.find("td:nth-child(9)").text()) || 0;

                totalBeforeVat += net;
                totalVat += (amount - net);
            });

            const netAmount = totalBeforeVat + totalVat;

            $('#totalBeforeVat').val(totalBeforeVat.toFixed(2));
            $('#totalVat').val(totalVat.toFixed(2));
            $('#netAmount').val(netAmount.toFixed(2));
        }

        function openSalesModal(invoice) {

            // 🔹 Header
            $("#customerName").val(invoice.customerId || 0);
            $("#date").val(invoice.date ? invoice.date.split('T')[0] : '');
            $("#invoiceCode").val(invoice.invoiceCode || '');
            $("#poNo").val(invoice.poNumber || '');
            $("#billTo").val(invoice.billTo || '');
            $("#emirates").val(invoice.city || '');
            $("#salesMan").val(invoice.salesMan || '');
            $("#shipDate").val(invoice.shipDate ? invoice.shipDate.split('T')[0] : '');
            $("#viaType").val(invoice.shipVia || '');
            $("#ship").val(invoice.shipTo || '');
            $("#invoiceType").val(invoice.paymentMethod || '');
            $("#accountName").val(invoice.accountCashId || '');
            $("#paymentTermsValue").val(invoice.paymentTerms || '');
            $("#duedate").val(invoice.paymentDate ? invoice.paymentDate.split('T')[0] : '');
            $("#totalBeforeVat").val(invoice.total || 0);
            $("#totalVat").val(invoice.vat || 0);
            $("#netAmount").val(invoice.net || 0);
            $("#warehouseDropdown").val(invoice.warehouseId || '');

               const tbody = $("#salesModal tbody");
             tbody.empty();

             // Load data first
             Promise.all([loadItem(), loadTax()]).then(() => {

                 // Create combined items list
                 const allItems = [...itemsList];
                 (invoice.items || []).forEach(invoiceItem => {
                     const exists = allItems.find(item => Number(item.id) === Number(invoiceItem.itemId));
                     if (!exists && invoiceItem.itemId) {
                         allItems.push({
                             id: invoiceItem.itemId,
                             itemName: invoiceItem.itemName,
                             code: invoiceItem.itemCode,
                             cost_price: invoiceItem.costPrice || 0
                         });
                     }
                 });

                 // Create rows
                 (invoice.items || []).forEach((item, idx) => {

                     const row = $(`
                         <tr>
                             <td>${idx + 1}</td>
                             <td><input type="text" class="form-control form-control-sm itemCode" value="${item.itemCode || ''}" readonly></td>
                             <td><select class="form-select form-select-sm itemNameSelect"></select></td>
                             <td><input type="number" class="form-control form-control-sm qty" value="${item.qty || 0}"></td>
                             <td><input type="number" class="form-control form-control-sm itemPrice" value="${item.price || 0}" data-cost-price="${item.costPrice || 0}" step="0.01"></td>
                             <td><input type="number" class="form-control form-control-sm itemDiscount" value="${item.discount || 0}" step="0.01" disabled></td>
                             <td class="text-center itemNet">${((item.qty * item.price) - item.discount || 0).toFixed(2)}</td>
                             <td><select class="form-select form-select-sm tax"></select></td>
                             <td class="text-center itemAmount">${(item.total || 0).toFixed(2)}</td>
                             <td><select class="form-select form-select-sm costCenterSelect" data-selected-id="${item.costCenterId || ''}"></select></td>
                         </tr>
                     `);

                     // Populate item dropdown
                     const itemSelect = row.find('.itemNameSelect');
                     itemSelect.append('<option value="">Select Item</option>');
                     allItems.forEach(itm => {
                         const selected = Number(itm.id) === Number(item.itemId) ? 'selected' : '';
                         itemSelect.append(`<option value="${itm.id}" ${selected}>${itm.itemName || itm.code}</option>`);
                         if (selected) console.log('✓ Matched item:', itm.itemName, 'ID:', itm.id);
                     });

                     // Populate tax dropdown
                     const taxSelect = row.find('.tax');
                     taxSelect.append('<option value="">-- Select Tax --</option>');
                     taxesList.forEach(tax => {
                         const matchByPercentage = Number(tax.value) === Number(item.vatP || item.vatPercentage);
                         const matchById = Number(tax.id) === Number(item.taxId);
                         const selected = (matchByPercentage || matchById) ? 'selected' : '';
                         const text = `${tax.name}-${tax.value}%`;
                         taxSelect.append(`<option value="${tax.id}" data-value="${tax.value}" ${selected}>${text}</option>`);
                         if (selected) console.log('✓ Matched tax:', text, 'ID:', tax.id);
                     });

                     tbody.append(row);
                 });

                 populateAndSelectCostCenter();

                 // Recalculate all rows
                  $("#salesModal tbody tr").each(function() {
                     calculateRow($(this));
                 });
             });

             $("#salescenterform").data("invoiceId", invoice.id || 0);
             $("#salesModal .modal-title").text("Edit Invoice");
             $("#salesModal").modal("show");

        }

        $('#salescenterform').on('submit', function (e) {
            e.preventDefault();
            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            $('#paymentTermsValue').val($('#paymentTerms').val());

                 const invoiceData = {
            Id: $("#salescenterform").data("invoiceId") || 0,
            Date: $('#date').val(),
            CustomerId: parseInt($('#customerName').val()) || 0,
            InvoiceCode: $('#invoiceCode').val().trim(),
            PONumber: $('#poNo').val().trim(),
            BillTo: $('#billTo').val().trim(),
            City: $('#emirates').val(),
            SalesMan: $('#salesMan').val().trim(),
            ShipDate: $('#shipDate').val(),
            ShipVia: $('#viaType').val(),
            ShipTo: $('#ship').val().trim(),
            PaymentMethod: $('#invoiceType').val(),
            AccountCashId: parseInt($('#accountName').val()) || 0,
            PaymentTerms: $('#paymentTermsValue').val(),
            PaymentDate: $('#duedate').val(),
            TotalBefore: parseFloat($('#totalBeforeVat').val()) || 0,
            Vat: parseFloat($('#totalVat').val()) || 0,
            NetTotal: parseFloat($('#netAmount').val()) || 0,
            WarehouseId: parseInt($('#warehouseDropdown').val()) || 0,
            Items: []
        };

             $('#salesModal tbody tr').each(function () {
                 const row = $(this);

                 const qty = parseFloat(row.find('.qty').val()) || 0;
                 const price = parseFloat(row.find('.itemPrice').val()) || 0;
                 const discount = parseFloat(row.find('.itemDiscount').val()) || 0;
                 const taxId = parseInt(row.find('.tax').val()) || 0;
                 const taxPercentage = parseFloat(row.find('.tax option:selected').data('value')) || 0;

                 const taxableAmount = (qty * price) - discount;
                 const calculatedVat = taxableAmount * (taxPercentage / 100);

                 const item = {
                     ItemId: parseInt(row.find('.itemNameSelect').val()) || 0,
                     Quantity: qty,
                     CostPrice: parseFloat(row.find('.itemPrice').data('cost-price')) || 0,
                     Price: price,
                     TaxId: taxId,
                     VatPercentage: taxPercentage,
                     Vat: calculatedVat,
                     Total: parseFloat(row.find('.itemAmount').text()) || 0,
                     CostCenterId: parseInt(row.find('.costCenterSelect').val()) || 0,
                 };

                  invoiceData.Items.push(item);
             });

            $.ajax({
                  url: '@Url.Action("SaveSalesReturnInvoice", "Customer")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(invoiceData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message);
                        $('#salesModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error("❌ AJAX ERROR", xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });



    </script>
