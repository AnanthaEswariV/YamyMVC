@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<YamyProject.SharedResource> Localizer
@{
    ViewData["Title"] = "Customer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .warehouse-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
    }

    .employee-toolbar {
        background: #e7e6e6;
        margin: 0 -15px;
        padding: 5px 15px;
        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .employee-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .dataTables_wrapper {
        padding: 50px;
    }
    /* Force scroll inside modal */
    .modal-dialog-scrollable .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }

    #exportButtons {
        display: flex;
        gap: 10px;
    }

    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<div class="warehouse-header">
    <center>@Localizer["Customer_Center"]</center>
</div>
<div class="employee-toolbar">
    <div class="container">

        <!-- Top Controls -->
        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <ul class="nav nav-pills">
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                            <i class="bi bi-gear-fill me-1"></i> @Localizer["Customer_Operations"]
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newCustomerModal">
                                    <i class="bi bi-plus-circle me-2"></i>@Localizer["New_Customer"]
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>

        <div class="row">
            <!-- Customer Table -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="customerTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>@Localizer["Lbl_Name"]</th>
                                        <th>@Localizer["Amount"]</th>
                                        <th>@Localizer["Lbl_Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title">@Localizer["Customer_Operations"]</h5>
                    </div>
                    <div class="card-body">

                        <!-- Date Filter -->
                        <div class="row mb-3 align-items-end">
                            <div class="col-auto">
                                <label for="startDate" class="form-label mb-1">@Localizer["Start_Date"]</label>
                                <input type="date" id="startDate" class="form-control form-control-sm">
                            </div>
                            <div class="col-auto">
                                <label for="endDate" class="form-label mb-1">@Localizer["End_Date"]</label>
                                <input type="date" id="endDate" class="form-control form-control-sm">
                            </div>
                            <div class="col-auto">
                                <button type="button" id="btnFilterDate" class="btn btn-primary btn-sm">
                                    <i class="bi bi-funnel-fill me-1"></i>@Localizer["Set"]
                                </button>
                            </div>
                            <div class="col-auto ms-auto">
                                <div id="exportButtons" class="d-flex gap-2"></div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>@Localizer["Customer_Name"]</strong>
                                    <span id="customerNames"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>@Localizer["Customer_Code"]</strong>
                                    <span id="customerCodes"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>@Localizer["Email"]</strong>
                                    <span id="customerEmails"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>@Localizer["Phone_Number"]</strong>
                                    <span id="customerPhones"></span>
                                </div>
                            </div>
                        </div>

                        <ul class="nav nav-tabs" id="myTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="home-tab" data-bs-toggle="tab" href="#home"
                                   role="tab" aria-controls="home" aria-selected="true">@Localizer["Transactions"]</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="profile-tab" data-bs-toggle="tab" href="#profile"
                                   role="tab" aria-controls="profile" aria-selected="false">@Localizer["Cash_Invoice"]</a>
                            </li>
                        </ul>

                        <div class="tab-content" id="myTabContent">
                            <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
                                <div class="table-responsive" style="overflow-y: auto;">
                                    <table class="table table-striped custom-table mb-0" id="pettyCashVoucherTable">
                                        <thead class="table-light">
                                            <tr>
                                                <th>@Localizer["Lbl_No"]</th>
                                                <th>@Localizer["Lbl_Date"]</th>
                                                <th>@Localizer["Voucher_No"]</th>
                                                <th>@Localizer["Voucher_Type"]</th>
                                                <th>@Localizer["Description"]</th>
                                                <th>@Localizer["Debit"]</th>
                                                <th>@Localizer["Credit"]</th>
                                                <th>@Localizer["Balance"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                                <div class="table-responsive" style="overflow-y: auto;">
                                    <table class="table table-striped custom-table mb-0" id="pettyCashTransactionsTable">
                                        <thead class="table-light">
                                            <tr>
                                                <th>@Localizer["Lbl_No"]</th>
                                                <th>@Localizer["Voucher_No"]</th>
                                                <th>@Localizer["Lbl_Date"]</th>
                                                <th>@Localizer["Account_Name"]</th>
                                                <th>@Localizer["Type"]</th>
                                                <th>@Localizer["Amount"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="newCustomerModal" tabindex="-1"
     aria-labelledby="newCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <form id="newCustomerForm" class="needs-validation" novalidate>
                <input type="hidden" id="customerId" value="0" />
                <div class="modal-header">
                    <h5 class="modal-title" id="newCustomerModalLabel">
                        @Localizer["Customers_New_Customer"]
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <h6 class="mb-3">@Localizer["Customer_Information"]</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="customerName" class="form-label">@Localizer["Customer_Name"]</label>
                            <input type="text" class="form-control" id="customerName"
                                   placeholder="@Localizer["Customer_Name"]" required>
                        </div>
                        <div class="col-md-4">
                            <label for="customerCode" class="form-label">@Localizer["Customer_Code"]</label>
                            <input type="text" class="form-control" id="customerCode"
                                   placeholder="@Localizer["Customer_Code"]" readonly>
                        </div>
                        <div class="col-md-4">
                            <label for="customerCategory" class="form-label">@Localizer["Customer_Category"]</label>
                            <select id="customerCategory" class="form-select" required>
                                <option value="">-- @Localizer["Select_Category"] --</option>
                            </select>
                            <button class="btn btn-outline-secondary" type="button" id="btnAddCategory" title="@Localizer["Add_new_category"]" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>

                        <div class="row align-items-center g-2 mt-3">
                            <label for="debitAmount" class="col-auto col-form-label fw-bold">@Localizer["Opening_Balance"]</label>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="debitAmount" placeholder="@Localizer["Debit"]" style="width: 80px;">
                            </div>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="creditAmount" placeholder="@Localizer["Credit"]" style="width: 80px;">
                            </div>
                            <div class="col-auto">
                                <input type="date" class="form-control form-control-sm" id="balanceDate" style="width: 130px;" required>
                            </div>
                        </div>
                    </div> 

                    <hr>
                 

                    <h6 class="mb-3">@Localizer["Contact_Address_Data"]</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="mainPhone" class="form-label">@Localizer["Main_Phone"]</label>
                            <input type="text" id="mainPhone" class="form-control" placeholder="@Localizer["Main_Phone"]">
                        </div>
                        <div class="col-md-4">
                            <label for="workPhone" class="form-label">@Localizer["Work_Phone"]</label>
                            <input type="text" id="workPhone" class="form-control" placeholder="@Localizer["Work_Phone"]">
                        </div>
                        <div class="col-md-4">
                            <label for="mobileFax" class="form-label">@Localizer["Mobile_Fax"]</label>
                            <input type="text" id="mobileFax" class="form-control" placeholder="@Localizer["Mobile_Fax"]">
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label">@Localizer["Email"]</label>
                            <input type="email" id="email" class="form-control" placeholder="@Localizer["Email"]">
                        </div>
                        <div class="col-md-6">
                            <label for="ccEmail" class="form-label">@Localizer["CC_Email"]</label>
                            <input type="email" id="ccEmail" class="form-control" placeholder="@Localizer["CC_Email"]">
                        </div>
                        <div class="col-md-6">
                            <label for="website" class="form-label">@Localizer["Website"]</label>
                            <input type="text" id="website" class="form-control" placeholder="@Localizer["Website"]">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">@Localizer["Country"]</label>
                            <select id="countryDropdown" class="form-select form-select-sm" required>
                                <option value="">-- @Localizer["Select"] --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">@Localizer["City"]</label>
                            <select id="cityDropdown" class="form-select form-select-sm" required>
                                <option value="">-- @Localizer["Select"] --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="region" class="form-label">@Localizer["Region"]</label>
                            <input type="text" id="region" class="form-control" placeholder="@Localizer["Region"]">
                        </div>
                        <div class="col-md-6">
                            <label for="buildingName" class="form-label">@Localizer["Building_Name"]</label>
                            <input type="text" id="buildingName" class="form-control" placeholder="@Localizer["Building_Name"]">
                        </div>
                    </div>

                    <hr>

                    <h6 class="mb-3">@Localizer["Account_Settings_Other"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="accountReceivable" class="form-label">@Localizer["Account_Receivable"]</label>
                            <select id="accruedSalaries" class="form-select form-select-sm" required>
                                <option value="">-- @Localizer["Select"] --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="trn" class="form-label">@Localizer["TRN"]</label>
                            <input type="text" id="trn" class="form-control" placeholder="@Localizer["TRN"]">
                        </div>
                        <div class="col-md-3">
                            <label for="facilityName" class="form-label">@Localizer["Facility_Name"]</label>
                            <input type="text" id="facilityName" class="form-control" placeholder="@Localizer["Facility_Name"]">
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="activeCheckbox" checked>
                                <label class="form-check-label" for="activeCheckbox">@Localizer["Active"]</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Project"]</label>
                            <div id="projectContainer" class="form-control" style="height:120px; overflow-y:auto;">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Btn_Close"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Btn_Save"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="addCategoryForm" novalidate>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addCategoryModalLabel">@Localizer["Add_new_category"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="newCategoryName" class="form-control" placeholder="@Localizer["Category_Name"]" required />
                    <div class="invalid-feedback">Please enter a category name.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Btn_Close"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Btn_Save"]</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

             var btnExcel = "@Localizer["Btn_Excel"]";
            var Print   = "@Localizer["Print"]";
        var currentCustomerId = 0;

        $(document).ready(function () {
            loadCustomerCategories();
            loadCustomers();
            let countryCities = [];

            function loadCountryCityDropdowns(apiUrl, countryIdSelector, cityIdSelector) {
                const $country = $(countryIdSelector);
                const $city = $(cityIdSelector);

                $.getJSON(apiUrl, function (data) {
                    countryCities = data;
                    $country.append(data.map(c => `<option value="${c.id}">${c.name}</option>`));
                });

                $country.on('change', function () {
                    const selectedCountryId = $(this).val();
                    $city.html('<option value="">-- @Localizer["Select"] --</option>');

                    if (selectedCountryId) {
                        const cities = countryCities.find(c => c.id == selectedCountryId)?.cities || [];
                        $city.append(cities.map(city => `<option value="${city.id}">${city.name}</option>`));
                    }
                });
            }

            loadCountryCityDropdowns('@Url.Action("GetCountryCities", "HR")', '#countryDropdown', '#cityDropdown');

            $.ajax({
                url: '@Url.Action("GetCountryOfIssue", "HR")',
                type: 'GET',
                success: function (data) {
                    let $ddl = $('#countryOfIssue');
                    $ddl.empty().append('<option value="">-- @Localizer["Select"] --</option>');
                    $.each(data, function (i, country) {
                        $ddl.append('<option value="' + country.id + '">' + country.name + '</option>');
                    });
                },
                error: function () {
                    alert("Error loading countries");
                }
            });

            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function (data) {
                    const dropdowns = [
                        { ddl: '#accruedSalaries', codeBox: '#code1' },
                    ];

                    dropdowns.forEach(set => {
                        let $ddl = $(set.ddl);
                        $ddl.empty().append('<option value="">-- @Localizer["Select"] --</option>');

                        $.each(data, function (i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name,
                                    'data-code': item.code
                                })
                            );
                        });

                        $ddl.on('change', function () {
                            let selected = $(this).find(':selected');
                            let code = selected.data('code');
                            $(set.codeBox).val(code || "");
                        });
                    });
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                }
            });

            $.ajax({
                url: '@Url.Action("GetProjects", "Construction")',
                type: 'GET',
                success: function(res) {
                    if (!res.status || !res.data) return;
                    const container = $('#projectContainer');
                    container.empty();

                    $.each(res.data, function(i, item) {
                        const checkboxId = 'project_' + item.id;
                        const checkbox = $('<div class="form-check">')
                            .append(
                                $('<input>', {
                                    type: 'checkbox',
                                    class: 'form-check-input project-checkbox',
                                    id: checkboxId,
                                    'data-id': item.id,
                                    'data-code': item.code,
                                    'data-name': item.name
                                })
                            )
                            .append(
                                $('<label>', {
                                    class: 'form-check-label',
                                    for: checkboxId,
                                    text: item.code + ' ' + item.name
                                })
                            );
                        container.append(checkbox);
                    });
                },
                error: function(xhr, status, error) {
                    console.error("❌ Error loading projects:", status, error);
                }
            });

            $(document).on("click", ".editCustomerBtn", function () {
                const customer = $(this).data("customer");
                if (!customer) return;

                $("#customerId").val(customer.id || 0);
                $("#customerCode").val(customer.code || '');
                $("#customerName").val(customer.name || '');
                $("#customerCategory").val(customer.cat_id || '');
                $("#debitAmount").val(customer.debit != null ? customer.debit : 0);
                $("#creditAmount").val(customer.credit != null ? customer.credit : 0);

                const balanceDate = customer.date ? new Date(customer.date).toISOString().slice(0, 10) : '';
                $("#balanceDate").val(balanceDate);

                $("#mainPhone").val(customer.mainPhone || '');
                $("#workPhone").val(customer.workPhone || '');
                $("#mobileFax").val(customer.mobile || '');
                $("#email").val(customer.email || '');
                $("#ccEmail").val(customer.ccMail || '');
                $("#website").val(customer.website || '');
                $("#countryDropdown").val(customer.country).trigger('change');
                setTimeout(() => {
                    $("#cityDropdown").val(customer.city);
                }, 100);
                $("#region").val(customer.region || '');
                $("#buildingName").val(customer.buildingName || '');
                $("#accruedSalaries").val(customer.accountId || '');
                $("#trn").val(customer.trn || '');
                $("#facilityName").val(customer.facilityName || '');
                $("#activeCheckbox").prop("checked", customer.active === 0);

                $.ajax({
                    url: '@Url.Action("GetProjects", "Construction")',
                    type: 'GET',
                    success: function (res) {
                        if (!res.status || !res.data) return;

                        const container = $('#projectContainer');
                        container.empty();

                        const selectedProjects = customer.projectSite ? customer.projectSite.split(',').map(Number) : [];
                        $.each(res.data, function (i, item) {
                            const checkboxId = 'project_' + item.id;
                            const isChecked = selectedProjects.includes(item.id);

                            const checkbox = $('<div class="form-check">')
                                .append(
                                    $('<input>', {
                                        type: 'checkbox',
                                        class: 'form-check-input project-checkbox',
                                        id: checkboxId,
                                        'data-id': item.id,
                                        checked: isChecked
                                    })
                                )
                                .append(
                                    $('<label>', {
                                        class: 'form-check-label',
                                        for: checkboxId,
                                        text: item.code + ' ' + item.name
                                    })
                                );
                            container.append(checkbox);
                        });

                        $('#additionalNotes').val(selectedProjects.join(', '));
                    },
                    error: function (xhr, status, error) {
                        console.error("❌ Error loading projects:", status, error);
                    }
                });

                //$("#newCustomerModalLabel").text("Edit Customer");
                $("#newCustomerModalLabel").text('@Html.Raw(Localizer["Edit_Customer"])');
                $("#newCustomerModal").modal("show");
            });

            $('#newCustomerForm').on('submit', function (e) {
                e.preventDefault();

                const form = this;
                if (!form.checkValidity()) {
                    form.classList.add('was-validated');
                    return;
                }

                const customerId = $('#customerId').val();
                const isEdit = customerId && parseInt(customerId) > 0;

                const selectedProjectIds = $('.project-checkbox:checked').map(function () {
                    return $(this).data('id');
                }).get();

                const customerData = {
                    Id: isEdit ? parseInt(customerId) : 0,
                    Code: $('#customerCode').val().trim(),
                    Name: $('#customerName').val().trim(),
                    CategoryId: $('#customerCategory').val() ? parseInt($('#customerCategory').val()) : null,
                    Debit: parseFloat($('#debitAmount').val()) || 0,
                    Credit: parseFloat($('#creditAmount').val()) || 0,
                    OpeningBalanceDate: $('#balanceDate').val() ? new Date($('#balanceDate').val()).toISOString() : null,
                    MainPhone: $('#mainPhone').val().trim(),
                    WorkPhone: $('#workPhone').val().trim(),
                    Mobile: $('#mobileFax').val().trim(),
                    Email: $('#email').val().trim(),
                    CCEmail: $('#ccEmail').val().trim(),
                    Website: $('#website').val().trim(),
                    CountryId: $('#countryDropdown').val() ? parseInt($('#countryDropdown').val()) : null,
                    CityId: $('#cityDropdown').val() ? parseInt($('#cityDropdown').val()) : null,
                    Region: $('#region').val().trim(),
                    BuildingName: $('#buildingName').val().trim(),
                    AccountId: $('#accruedSalaries').val() ? parseInt($('#accruedSalaries').val()) : null,
                    TRN: $('#trn').val().trim(),
                    FacilityName: $('#facilityName').val().trim(),
                    Active: $('#activeCheckbox').is(':checked'),
                    ProjectSites: selectedProjectIds
                };

                $.ajax({
                    url: '@Url.Action("SaveCustomer", "Customer")',
                    type: 'POST',
                    contentType: 'application/json',
                    dataType: 'json',
                    data: JSON.stringify(customerData),
                    success: function (res) {
                        if (res.status) {
                            toastr.success(isEdit ? 'Customer updated successfully' : 'Customer added successfully');
                            $('#newCustomerModal').modal('hide');
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            toastr.error(res.message);
                        }
                    },
                    error: function (xhr) {
                        console.error("❌ AJAX ERROR", xhr);
                        toastr.error(xhr.responseJSON?.message || xhr.statusText);
                    }
                });
            });

            $('#addCategoryForm').on('submit', function (e) {
                e.preventDefault();

                const form = this;
                if (!form.checkValidity()) {
                    form.classList.add('was-validated');
                    return;
                }

                const categoryName = $('#newCategoryName').val().trim();

                $.ajax({
                    url: '@Url.Action("AddCategory", "Customer")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ Name: categoryName }),
                    success: function (res) {
                        if (res.status) {
                            toastr.success('Category added successfully');
                            $('#addCategoryModal').modal('hide');
                            $('#customerCategory').append(new Option(res.name, res.id, true, true));
                        } else {
                            toastr.error(res.message);
                        }
                    },
                    error: function (xhr) {
                        toastr.error(xhr.responseJSON?.message || xhr.statusText);
                    }
                });
            });

            function loadCustomerCategories(selectedId = null) {
                $.ajax({
                    url: '@Url.Action("GetCustomerCategories", "Customer")',
                    type: 'GET',
                    success: function (res) {
                        const $ddl = $('#customerCategory');
                        $ddl.empty().append('<option value="">-- @Localizer["Select_Category"] --</option>');

                        if (res && res.length > 0) {
                            res.forEach(cat => {
                                const option = new Option(cat.name, cat.id, selectedId == cat.id, selectedId == cat.id);
                                $ddl.append(option);
                            });
                        }
                    },
                    error: function (xhr) {
                        console.error('❌ Error loading categories:', xhr.responseJSON?.message || xhr.statusText);
                    }
                });
            }

            $('#btnAddCustomer').on('click', function () {
                clearCustomerForm();
                $("#newCustomerModalLabel").text("New Customer");
                $("#newCustomerModal").modal("show");
            });

            $("#btnFilterDate").on("click", function () {
                if (currentCustomerId > 0) {
                    loadTransactions(currentCustomerId);
                    loadCashInvoices(currentCustomerId);
                }
            });

            $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                const target = $(e.target).attr("href");
                $("#exportButtons").empty();

                if(target === "#home") {
                    if ($.fn.DataTable.isDataTable("#pettyCashVoucherTable")) {
                        var table = $("#pettyCashVoucherTable").DataTable();
                        table.buttons().container().appendTo('#exportButtons');
                        table.columns.adjust().draw();
                    }
                }
                else if(target === "#profile") {
                    if ($.fn.DataTable.isDataTable("#pettyCashTransactionsTable")) {
                        var table = $("#pettyCashTransactionsTable").DataTable();
                        table.buttons().container().appendTo('#exportButtons');
                        table.columns.adjust().draw();
                    }
                }
            });
        });

        function loadCustomers(state = "All") {
            $.ajax({
                url: '@Url.Action("GetCustomers", "Customer")',
                type: "GET",
                data: { state: state },
                success: function (res) {
                    if (res.status) {
                        if ($.fn.DataTable.isDataTable("#customerTable")) {
                            $("#customerTable").DataTable().destroy();
                        }

                        let tbody = $("#customerTable tbody");
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                let rowData = JSON.stringify(row);

                                let tr = `
                                    <tr class="customer-row" data-customer-id="${row.id}">
                                        <td>${row.code} - ${row.name}</td>
                                        <td>${row.amount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary editCustomerBtn"
                                                data-customer='${rowData}'>
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger deleteCustomerBtn"
                                                data-id='${row.id}'>
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $(".customer-row").on("dblclick", function () {
                                let customerId = $(this).data("customer-id");
                                loadCustomerDetails(customerId);
                            });
                        } else {
                            tbody.append(`<tr><td colspan="3" class="text-center" style="padding:40px; color:#6c757d; font-style:italic;">No records found</td></tr>`);
                        }
                    }
                },
                error: function (xhr, status, error) {
                    if ($.fn.DataTable.isDataTable("#customerTable")) {
                        $("#customerTable").DataTable().destroy();
                    }
                    $("#customerTable tbody").html(`<tr><td colspan="3" class="text-center" style="color:red; padding:40px;">Error loading data: ${error}</td></tr>`);
                }
            });
        }

        function loadCustomerDetails(customerId) {
            currentCustomerId = customerId;

            $.ajax({
                url: '@Url.Action("GetCustomerDetails", "Customer")',
                type: "GET",
                data: { id: customerId },
                success: function (res) {
                    if (res.status) {
                        let customer = res.data.customer;
                        $("#customerNames").text(customer.name || '-');
                        $("#customerCodes").text(customer.code || '-');
                        $("#customerEmails").text(customer.email || '-');
                        $("#customerPhones").text(customer.mobile || '-');

                        loadTransactions(customerId);
                        loadCashInvoices(customerId);
                    } else {
                        alert("Failed to load customer details.");
                    }
                },
                error: function (xhr, status, error) {
                    alert("Error fetching customer details: " + error);
                }
            });
        }

        function loadTransactions(customerId) {
            let startDate = $("#startDate").val();
            let endDate = $("#endDate").val();

            if ($.fn.DataTable.isDataTable("#pettyCashVoucherTable")) {
                $("#pettyCashVoucherTable").DataTable().destroy();
            }

            let tbody = $("#pettyCashVoucherTable tbody");
            tbody.empty();

            $.ajax({
                url: '@Url.Action("GetInvoices", "Customer")',
                type: "GET",
                data: {
                    id: customerId,
                    startDate: startDate,
                    endDate: endDate
                },
                success: function (res) {
                    if (res.status && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            tbody.append(`
                                <tr>
                                    <td>${row.sn}</td>
                                    <td>${row.date}</td>
                                    <td>${row.voucherNo}</td>
                                    <td>${row.type}</td>
                                    <td>${row.accountName}</td>
                                    <td class="text-end">${row.debit}</td>
                                    <td class="text-end">${row.credit}</td>
                                    <td class="text-end">${row.balance}</td>
                                </tr>
                            `);
                        });

                        let table = $("#pettyCashVoucherTable").DataTable({
                            dom: 'rtip',
                            order: [[0, 'asc']],
                            pageLength: 15,
                            columnDefs: [
                             { targets: 0, type: "num" }
                            ],
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i>' +btnExcel,
                                      className: 'btn btn-primary btn-sm',
                                    title: 'Customer Transactions'
                                },
                                {
                                    extend: 'print',
                                    text: '<i class="fas fa-print me-1"></i> ' +Print,
                                     className: 'btn btn-primary btn-sm',
                                    title: 'Customer Transactions'
                                }
                            ]
                        });

                        var activeTab = $('.nav-link.active[data-bs-toggle="tab"]').attr('href');
                        if (activeTab === '#home' || !activeTab) {
                            $("#exportButtons").empty();
                            table.buttons().container().appendTo('#exportButtons');
                        }
                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="8" class="text-center text-muted p-4">
                                    No transactions found
                                </td>
                            </tr>
                        `);

                        var activeTab = $('.nav-link.active[data-bs-toggle="tab"]').attr('href');
                        if (activeTab === '#home' || !activeTab) {
                            $("#exportButtons").empty();
                        }
                    }
                }
            });
        }

        function loadCashInvoices(customerId) {
            let startDate = $("#startDate").val();
            let endDate = $("#endDate").val();

            if ($.fn.DataTable.isDataTable("#pettyCashTransactionsTable")) {
                $("#pettyCashTransactionsTable").DataTable().destroy();
            }

            let tbody = $("#pettyCashTransactionsTable tbody");
            tbody.empty();

            $.ajax({
                url: '@Url.Action("GetCashInvoice", "Customer")',
                type: "GET",
                data: {
                    id: customerId,
                    startDate: startDate,
                    endDate: endDate
                },
                success: function (res) {
                    if (res.status && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            let isTotal = row.sn === "Total";

                            tbody.append(`
                                <tr ${isTotal ? 'class="table-secondary fw-bold"' : ''}>
                                    <td>${row.sn}</td>
                                    <td>${row.voucherNo}</td>
                                    <td>${row.date}</td>
                                    <td>${row.accountName}</td>
                                    <td>${row.type}</td>
                                    <td class="text-end">${row.amount}</td>
                                </tr>
                            `);
                        });

                        let table = $("#pettyCashTransactionsTable").DataTable({
                            dom: 'rtip',
                            order: [[0, 'asc']],
                            pageLength: 15,
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                      className: 'btn btn-primary btn-sm',
                                    title: 'Customer Cash Invoices'
                                },
                                {
                                    extend: 'print',
                                    text: '<i class="fas fa-print me-1"></i> Print',
                                     className: 'btn btn-primary btn-sm',
                                    title: 'Customer Cash Invoices'
                                }
                            ]
                        });

                        var activeTab = $('.nav-link.active[data-bs-toggle="tab"]').attr('href');
                        if (activeTab === '#profile') {
                            $("#exportButtons").empty();
                            table.buttons().container().appendTo('#exportButtons');
                        }
                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="6" class="text-center text-muted p-4">
                                    No cash invoices found
                                </td>
                            </tr>
                        `);

                        var activeTab = $('.nav-link.active[data-bs-toggle="tab"]').attr('href');
                        if (activeTab === '#profile') {
                            $("#exportButtons").empty();
                        }
                    }
                }
            });
        }

        function clearCustomerForm() {
            $('#newCustomerForm')[0].reset();
            $('#customerId').val(0);
            $('#projectContainer').empty();
        }
    </script>
}
