            document.getElementById('salesModal').addEventListener('shown.bs.modal', function () {
            const todayDate = getTodayDate();

            // Fill all date fields
            const dateFields = [
                'date',
                'duedate',
                'shipDate'
            ];

            dateFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !field.value) {
                    field.value = todayDate;
                }
            });
        });

    

            $('#paymentTerms').prop('disabled', true);
            setDueDate(); 

            function setDueDate() {
                const invoiceType = $('#invoiceType').val();
                let days = 0;

                if (invoiceType === 'Credit') {
                    $('#paymentTerms').prop('disabled', false);
                    days = parseInt($('#paymentTerms').val()) || 0; // get selected payment term
                } else {
                    $('#paymentTerms').prop('disabled', true);
                    days = 0; // Cash: due today
                }

                const today = new Date();
                const dueDate = new Date();
                dueDate.setDate(today.getDate() + days);

                const yyyy = dueDate.getFullYear();
                const mm = String(dueDate.getMonth() + 1).padStart(2, '0');
                const dd = String(dueDate.getDate()).padStart(2, '0');

                $('#duedate').val(`${yyyy}-${mm}-${dd}`);
            }

            $('#invoiceType').on('change', setDueDate);

            $('#paymentTerms').on('change', setDueDate);

                   $(document).on("click", ".editInvoiceBtn", function () {
            const invoice = $(this).data("invoice");
            if (!invoice) return;
            console.log('Edit Invoice:', invoice);
            console.log('Invoice items:', invoice.items); // Debug full items

            // Header Fields
            $("#customerName").val(invoice.customerId || 0);
            $("#date").val(invoice.date ? invoice.date.split('T')[0] : '');
            $("#invoiceCode").val(invoice.invoiceNo || '');
            $("#poNo").val(invoice.pO_Num || '');
            $("#billTo").val(invoice.bill_To || '');
            $("#emirates").val(invoice.city || '');
            $("#salesMan").val(invoice.sales_Man || '');
            $("#shipDate").val(invoice.ship_Date ? invoice.ship_Date.split('T')[0] : '');
            $("#viaType").val(invoice.ship_Via || '');
            $("#ship").val(invoice.ship_To || '');
            $("#invoiceType").val(invoice.paymentMethod || '');
            $("#accountName").val(invoice.account_Cash_Id || '');
            $("#paymentTermsValue").val(invoice.payment_Terms || '');
            $("#duedate").val(invoice.payment_Date ? invoice.payment_Date.split('T')[0] : '');
            $("#totalBeforeVat").val(invoice.total || 0);
            $("#totalVat").val(invoice.vat || 0);
            $("#netAmount").val(invoice.net || 0);
            $("#warehouseDropdown").val(invoice.warehouse_Id || '');

            // Clear existing rows
            $("#salesModal tbody").empty();

            // Load items and taxes first, then populate rows
            Promise.all([
                loadItem(),
                loadTax()
            ]).then(() => {
                console.log('Items loaded:', itemsList);
                console.log('Taxes loaded:', taxesList);

                // Create a combined items list
                const allItems = [...itemsList];

                // Add items from invoice that might not be in itemsList
                (invoice.items || []).forEach(invoiceItem => {
                    const exists = allItems.find(item => Number(item.id) === Number(invoiceItem.itemId));
                    if (!exists && invoiceItem.itemId) {
                        allItems.push({
                            id: invoiceItem.itemId,
                            itemName: invoiceItem.itemName,
                            code: invoiceItem.itemCode
                        });
                    }
                });

                console.log('Combined items list:', allItems);

                // Add invoice items
                (invoice.items || []).forEach((item, idx) => {
                    console.log('Processing item:', item);
                    console.log('Item tax info - vatP:', item.vatP, 'itemVat:', item.itemVat, 'All properties:', Object.keys(item));

                    const row = $(`
                        <tr>
                            <td>${idx + 1}</td>
                            <td><input type="text" class="form-control form-control-sm" value="${item.itemCode || ''}" readonly></td>
                            <td><select class="form-select form-select-sm itemNameSelect"></select></td>
                            <td><input type="number" class="form-control form-control-sm qty" value="${item.qty || 0}"></td>
                            <td><input class="form-control form-control-sm" value="${item.price || 0}" data-cost-price="${item.costPrice || 0}"></td>
                            <td><input class="form-control form-control-sm" value="${item.discount || 0}" disabled></td>
                            <td class="text-center">${(item.net || 0).toFixed(2)}</td>
                            <td><select class="form-select form-select-sm tax"></select></td>
                            <td class="text-center">${(item.itemTotal || 0).toFixed(2)}</td>
                            <td><select class="form-select form-select-sm costCenterSelect" data-selected-id="${item.cost_Center_Id || ''}"></select></td>
                        </tr>
                    `);

                    // Populate item dropdown
                    const itemSelect = row.find('.itemNameSelect');
                    itemSelect.append('<option value="">Select Item</option>');

                    allItems.forEach(itm => {
                        const selected = Number(itm.id) === Number(item.itemId) ? 'selected' : '';
                        itemSelect.append(`<option value="${itm.id}" ${selected}>${itm.itemName || itm.code}</option>`);

                        if (selected) {
                            console.log('✓ Matched item:', itm.itemName, 'ID:', itm.id);
                        }
                    });

                    // Populate tax dropdown
                    // Try multiple possible property names for tax percentage
                    const taxPercentage = item.vatP || item.vat_P || item.taxPercentage || item.tax_Percentage || 0;
                    console.log('Using tax percentage:', taxPercentage);

                    const taxSelect = row.find('.tax');
                    taxSelect.append('<option value="">-- Select Tax --</option>');

                    let matchFound = false;
                    taxesList.forEach(tax => {
                        const selected = Number(tax.value) === Number(taxPercentage) ? 'selected' : '';
                        const text = `${tax.name}-${tax.value}%`;
                        taxSelect.append(`<option value="${tax.id}" data-value="${tax.value}" ${selected}>${text}</option>`);

                        if (selected) {
                            matchFound = true;
                            console.log('✓ Matched tax:', text, 'Tax value:', tax.value, 'Item tax:', taxPercentage);
                        }
                    });

                    if (!matchFound) {
                        console.warn('⚠ No tax match found for item. Item tax:', taxPercentage, 'Available tax values:', taxesList.map(t => t.value));
                    }

                    $("#salesModal tbody").append(row);
                });

                // Now populate cost centers AFTER all rows are added
                populateAndSelectCostCenter();

                // Recalculate all rows
                $("#salesModal tbody tr").each(function() {
                    calculateRow($(this));
                });
            });

            // Save invoice ID for submit
            $("#salescenterform").data("invoiceId", invoice.id || 0);

            // Update modal title
            $("#salesModal .modal-title").text("Edit Invoice");

            // Show modal
            $("#salesModal").modal("show");
        });

            $('#salescenterform').on('submit', function (e) {
            e.preventDefault();

            const invoiceId = $("#salescenterform").data("invoiceId") || 0;
        $('#paymentTermsValue').val($('#paymentTerms').val());
            // Collect invoice header data
                 const invoiceData = {
            Id: invoiceId,
            InvoiceDate: $('#date').val() ? new Date($('#date').val()).toISOString() : new Date().toISOString(),
            CustomerId: parseInt($('#customerName').val()) || 0,
            InvoiceCode: $('#invoiceCode').val().trim() || '',
            WarehouseId: parseInt($('#warehouseDropdown').val()) || 0,
            PoNo: $('#poNo').val().trim() || '',
            BillTo: $('#billTo').val().trim() || '',
            City: $('#emirates').val() || '',
            SalesMan: $('#salesMan').val().trim() || '',
            ShipDate: $('#shipDate').val() ? new Date($('#shipDate').val()).toISOString() : new Date().toISOString(),
            ShipVia: $('#viaType').val() || '',
            ShipTo: $('#ship').val().trim() || '',
            PaymentMethod: $('#invoiceType').val() || '',
            AccountCashId: parseInt($('#accountName').val()) || 0,
            PaymentCreditAccountId: 0,
