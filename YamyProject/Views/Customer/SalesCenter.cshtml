            PaymentDate: $('#duedate').val() ? new Date($('#duedate').val()).toISOString() : new Date().toISOString(),
            TotalBeforeVat: parseFloat($('#totalBeforeVat').val()) || 0,
            Vat: parseFloat($('#totalVat').val()) || 0,
            NetTotal: parseFloat($('#netAmount').val()) || 0,
            SalesRevenueAccountId: 0,
            VatAccountId: 0,
            InventoryCost: 0,
            CogsAccountId: 0,
            Items: []
        };


            // Collect table items
            $('#salesModal tbody tr').each(function () {
                const row = $(this);
               let price = parseFloat(row.find('td:nth-child(5) input').val()) || 0;
        let qty = parseFloat(row.find('.qty').val()) || 0;
        let discount = parseFloat(row.find('td:nth-child(6) input').val()) || 0;
        // let taxP = parseFloat(row.find('.tax').val()) || 0;
        let taxId = parseInt(row.find('.tax').val()) || 0;
        let taxP = parseFloat(row.find('.tax option:selected').data('value')) || 0;

        const vat = ((price * qty) - discount) * (taxP / 100) || 0;

        const item = {
            ItemId: parseInt(row.find('.itemNameSelect').val()) || 0,
            Qty: qty,
            Price: price,
            CostPrice: parseFloat(row.find('td:nth-child(5) input').data('cost-price')) || 0,
            Discount: discount,
            VatP: taxP,
            Vat: vat,
            Total: parseFloat(row.find('td:nth-child(9)').text()) || 0,
            CostCenterId: parseInt(row.find('.costCenterSelect').val()) || 0
        };


                invoiceData.Items.push(item);
            });

            // AJAX POST to API
            $.ajax({
                 url: '@Url.Action("SaveInvoice", "Customer")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(invoiceData),
                success: function (res) {
                    if (res.status) {
                        toastr.success('Invoice saved successfully');
                        $('#salesModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error("❌ AJAX ERROR", xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
