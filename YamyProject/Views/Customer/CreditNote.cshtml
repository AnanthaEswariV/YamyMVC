
@{
    ViewData["Title"] = "CreditNote";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
    /* Highlight selected row */
    #table1 tbody tr.selected {
        background-color: #c7e5b4;
    }

    .modal-dialog-scrollable .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong class="mx-auto">Credit Note</strong>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#invoiceModal">
            <i class="bi bi-plus-circle"></i> New
        </button>
    </div>
    <div class="card-body" style="font-size:small">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Start Date -->
            <div style="min-width: 150px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 150px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkDate" class="form-check-input">
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>

        </div>

        <!-- Default method: Two tables -->
        <div id="defaultTables" style="height: 80vh; display: flex; flex-direction: column;">
            <div class="card-body flex-grow-1" style="overflow-y: auto;">
                <table class="table table-striped" id="table1">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Date</th>
                            <th>JV No</th>
                            <th>INV No</th>
                            <th>Amount</th>
                            <th>VAT</th>
                            <th>Credit Account</th>
                            <th>Debit Account</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- Invoice Modal -->
<div class="modal fade" id="invoiceModal" tabindex="-1" aria-labelledby="invoiceModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
             <form id="invoiceModalForm">
            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="invoiceModalLabel">Credit Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">

                <!-- Filters Row -->
                <div class="row g-3 mb-3">
                    <!-- Customer Code -->
                    <div class="col-md-2">
                        <label for="customerCode" class="form-label">Customer Code</label>
                        <input type="text" class="form-control" id="customerCode" readonly>
                    </div>

                    <!-- Customer Dropdown -->
                    <div class="col-md-4">
                        <label for="customerSelect" class="form-label">Customer</label>
                        <div class="input-group">
                            <select class="form-select" id="customerSelect">
                            </select>
                        </div>
                    </div>

                    <!-- Show Invoice Button -->
                    <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-primary w-100" id="showInvoiceBtn">
                                Show Invoice
                            </button>

                    </div>
                </div>

                <!-- Invoice Details Form -->
                <div class="row g-3 mb-3">
                    <div class="col-md-2">
                        <label for="invoiceDate" class="form-label">Date</label>
                        <input type="date" class="form-control" id="invoiceDate">
                    </div>

                    <div class="col-md-2">
                        <label for="invoiceNo" class="form-label">Invoice #</label>
                        <input type="text" class="form-control" id="invoiceNo" disabled>
                    </div>

                    <div class="col-md-3">
                        <label for="debitAccount" class="form-label">Debit Account</label>
                        <select class="form-select" id="accountName">
                        </select>
                    </div>

                    <div class="col-md-1">
                        <label for="vat" class="form-label">VAT</label>
                        <input type="number" class="form-control" id="vat" step="0.001">
                    </div>

                    <div class="col-md-2">
                        <label for="amount" class="form-label">Amount</label>
                        <input type="number" class="form-control" id="amount" step="0.001">
                    </div>

                    <div class="col-md-2">
                        <label for="totalAmount" class="form-label">Total Amount</label>
                        <input type="number" class="form-control" id="totalAmount"  step="0.001" disabled>
                    </div>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" id="description" rows="2"></textarea>
                </div>

                <!-- Invoice Table -->
                <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>INV Date</th>
                                <th>Invoice No</th>
                                <th>Total</th>
                                <th>Balance</th>
                                <th>Select</th>
                                <th>Amount</th>
                                <th>Remaining</th>
                                <th>View</th>
                            </tr>
                        </thead>
                        <tbody id="invoiceTableBody">
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- Modal Footer -->
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
            </form>
        </div>
    </div>
</div>

<!-- Invoice Items Modal -->
<div class="modal fade" id="invoiceItemsModal" tabindex="-1" aria-labelledby="invoiceItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="invoiceItemsModalLabel">Invoice Items</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Item Name</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">VAT</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceItemsBody">
                        <tr><td colspan="6" class="text-center text-muted py-4">Select an invoice to view items</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>

        $(document).ready(function () {

            $('#chkDate').change(function () {
                const enabled = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', !enabled);
            });
             loadCustomers();
            loadCreditNotes();

            $('#filterBtn').click(function () {
                loadCreditNotes();
            });

            function getTodayDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

            document.getElementById('invoiceModal').addEventListener('shown.bs.modal', function () {
             const todayDate = getTodayDate();

             // Fill all date fields
             const dateFields = [
                 'invoiceDate'
             ];

             dateFields.forEach(fieldId => {
                 const field = document.getElementById(fieldId);
                 if (field && !field.value) {
                     field.value = todayDate;
                 }
             });
         });

             $('#showInvoiceBtn').on('click', function() {
            const customerId = $('#customerSelect').val();

            if (!customerId) {
                alert('Please select a customer');
                return;
            }

            const tbody = $('#invoiceTableBody');
            tbody.html(`
                <tr>
                    <td colspan="10" class="text-center py-4">
                        <div class="spinner-border text-primary"></div> Loading...
                    </td>
                </tr>
            `);

            // Call API
            $.ajax({
                url: '@Url.Action("GetCustomerInvoices", "Customer")?customerId=' + $('#customerSelect').val(),
                type: 'GET',
                success: function(res) {
                    tbody.empty();

                    if (!res.status || res.data.length === 0) {
                        tbody.html(`<tr><td colspan="10" class="text-center text-muted py-4">No invoices found</td></tr>`);
                        return;
                    }
                    res.data.forEach((row, index) => {
            const balance = parseFloat(row.remaining); // Remaining from API
            const amount = parseFloat(row.amount || row.remaining); // initial amount = remaining if not set
            const remainingAfterAmount = balance - amount;

            const tr = $(`
                <tr data-id="${row.id}">
                    <td>${index + 1}</td>
                    <td>${row.formattedDate}</td>
                    <td>${row.invoiceNo}</td>
                    <td>${row.totalWithVAT.toFixed(3)}</td>
                       <td class="balance">${balance.toFixed(3)}</td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input selectInvoice" ${row.selected ? 'checked' : ''}>
                    </td>
                    <td>
                        <input type="number" class="form-control form-control-sm invoiceAmount" value="${amount.toFixed(3)}" step="0.001">
                    </td>
                     <td class="remaining">${remainingAfterAmount.toFixed(3)}</td> <!-- updated -->
                    <td>
                          <button type="button" class="btn btn-sm btn-info viewInvoiceBtn">
                            View
                          </button>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-danger deleteInvoiceBtn">DEL</button>
                    </td>
                </tr>
            `);
            tbody.append(tr);
        });

                },
                error: function() {
                    tbody.html(`<tr><td colspan="10" class="text-center text-danger py-4">Error loading invoices</td></tr>`);
                }
            });
        });

            $(document).on('change', '.selectInvoice', function() {
            const row = $(this).closest('tr');
            const remaining = parseFloat(row.find('td:nth-child(8)').text());
            if ($(this).is(':checked')) {
                row.find('.invoiceAmount').val(remaining.toFixed(3));
            } else {
                row.find('.invoiceAmount').val('0.000');
            }
        });


        });

        function loadCreditNotes() {

            const useDate = $('#chkDate').is(':checked');
            const dateFrom = useDate ? $('#startDate').val() : null;
            const dateTo = useDate ? $('#endDate').val() : null;

            $.ajax({
                url: '@Url.Action("GetCreditNotes", "Customer")',
                type: 'GET',
                data: {
                    dateFrom: dateFrom,
                    dateTo: dateTo,
                    selectionMethod: 'Default'
                },
                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div> Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    console.log(res);
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load credit notes');
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {

                             $.each(res.data, function (i, row) {

            const tr = $(`
                <tr>
                    <td>${i + 1}</td>
                    <td>${formatDate(row.date)}</td>
                    <td>${row.jvNo ?? ''}</td>
                    <td>${row.invoiceNo ?? ''}</td>
                    <td>${row.amount.toFixed(2)}</td>
                    <td>${row.vat.toFixed(2)}</td>
                    <td>${row.creditAccount}</td>
                    <td>${row.debitAccount}</td>
                    <td class="text-center">
                        <button
                            type="button"
                            class="btn btn-sm btn-primary editCreditNoteBtn">
                            <i class="fas fa-pen"></i>
                        </button>
                    </td>
                </tr>
            `);

            // ✅ Store FULL object here
            tr.data('creditNote', row);

            tbody.append(tr);
        });

                        // Initialize DataTable
                        $('#table1').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[1, 'desc']],
                            pageLength: 15
                        });

                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    No credit notes found
                                </td>
                            </tr>
                        `);
                    }
                },
                error: function () {
                    toastr.error('Error loading credit notes');
                }
            });
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            const d = new Date(dateStr);
            return d.toLocaleDateString('en-GB');
        }

        function loadCustomers() {
            $.ajax({
                url: '@Url.Action("GetCustomers", "Customer")', 
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const customerDdl = $("#customerSelect");

                        customerDdl.empty().append('<option value="">-- Select Customer --</option>');

                        res.data.forEach(c => {
                            const option = `<option value="${c.id}" data-code="${c.code}">${c.name}</option>`;
                            customerDdl.append(option);
                        });
                    } else {
                        toastr.error('Failed to load customers.');
                    }
                },
                error: function () {
                    toastr.error('Error loading customers.');
                }
            });
        }

        $('#customerSelect').on('change', function() {
            const selectedOption = $(this).find('option:selected');
            const code = selectedOption.data('code') || '';
            $('#customerCode').val(code); 

                 // 🔹 On customer change → always load CUSTOMER account
        loadAccountName("Customer");
        });

        $(document).on('input', '.invoiceAmount', function () {

            const row = $(this).closest('tr');
            const balance = parseFloat(row.find('.balance').text()) || 0;
            const amount = parseFloat($(this).val()) || 0;

            const remaining = balance - amount;
            row.find('.remaining').text(remaining.toFixed(3));

            recalculateInvoiceTotals();
        });

        function recalculateInvoiceTotals() {

            let total = 0;

            // Sum all row amounts (this is TOTAL)
            $('.invoiceAmount').each(function () {
                total += parseFloat($(this).val()) || 0;
            });

            const vat = 0.750; // 🔹 FIXED VAT
            const netAmount = total - vat;

            // Prevent negative net amount
            $('#amount').val(Math.max(netAmount, 0).toFixed(3));
            $('#vat').val(vat.toFixed(3));
            $('#totalAmount').val(total.toFixed(3));
        }

        $(document).on('click', '.viewInvoiceBtn', function() {
            const row = $(this).closest('tr');
            const invoiceId = row.data('id');


            const tbody = $('#invoiceItemsBody');
            tbody.html('<tr><td colspan="6" class="text-center">Loading...</td></tr>');

            const url = '@Url.Action("GetInvoiceItems", "Customer")' + '?salesId=' + invoiceId;

            $.ajax({
                url: url,
                type: 'GET',
                success: function(res) {
                    tbody.empty();
                    if (res.status && res.data.length > 0) {
                        $.each(res.data, function(i, item) {
                            const tr = $(`
                                <tr>
                                    <td>${i + 1}</td>
                                     <td>${item.itemName}</td>
                                     <td class="text-end">${item.qty.toFixed(2)}</td>
                                     <td class="text-end">${item.price.toFixed(2)}</td>
                                     <td class="text-end">${item.vat.toFixed(2)}</td>
                                     <td class="text-end">${item.total.toFixed(2)}</td>
                                </tr>
                            `);
                            tbody.append(tr);
                        });
                    } else {
                        tbody.html('<tr><td colspan="6" class="text-center text-muted">No items found</td></tr>');
                    }

                    $('#invoiceItemsModal').modal('show');
                },
                error: function() {
                    tbody.html('<tr><td colspan="6" class="text-center text-danger">Error loading items</td></tr>');
                }
            });
        });

        function loadAccountName(type) {

            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function (accounts) {

                    const $ddl = $("#accountName");
                    $ddl.empty().append('<option value="">-- Select --</option>');

                    $.each(accounts, function (i, item) {
                        $ddl.append(
                            $('<option>', {
                                value: item.id,
                                text: item.code + ' - ' + item.name,
                                'data-code': item.code
                            })
                        );
                    });

                    // 🔹 Always get default accounts
                    setDefaultAccount(type);
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error loading accounts:", error);
                }
            });
        }

        function setDefaultAccount(type) {

            $.ajax({
                url: '/Customer/GetDefaultAccounts',
                type: 'GET',
                success: function (res) {

                    if (!res.status) {
                        console.error("❌ Failed to load default accounts");
                        return;
                    }

                    let accountId = 0;

                    if (type === "Customer") {
                        accountId = res.data.customerAccountId;
                    }

                    if (accountId > 0) {
                        $("#accountName").val(accountId);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("❌ Error calling GetDefaultAccounts:", error);
                }
            });
        }

       
        
        $('#invoiceModalForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

                  const creditNoteData = {
            Id: parseInt($(this).data('creditNoteId')) || 0,
            Date: $('#invoiceDate').val(), // yyyy-MM-dd ✔
            CustomerId: parseInt($('#customerSelect').val()) || 0,
            InvoiceCode: $('#invoiceNo').val().trim(),
            AccountCashId: parseInt($('#accountName').val()) || 0,
            Level4CustomerId: 0,
            Level4VatId: 0,
            Level4SalesReturn: 0,
            Amount: parseFloat($('#amount').val()) || 0,
            Vat: parseFloat($('#vat').val()) || 0,
            TotalAmount: parseFloat($('#totalAmount').val()) || 0,
            Description: $('#description').val().trim(),
            CustomerCode: $('#customerCode').val().trim(),
            Items: []
        };

           $('#invoiceTableBody tr').each(function (index) {
            const row = $(this);

            const amount = parseFloat(row.find('.invoiceAmount').val()) || 0;
            const total = parseFloat(row.find('td:nth-child(4)').text()) || 0;
            const remaining = parseFloat(row.find('.remaining').text()) || 0;
            const vat = total - amount;

            const item = {
                InvoiceId: parseInt(row.find('td:nth-child(3)').text()) || 0,
                InvoiceNo: row.find('td:nth-child(3)').text().trim(),
                InvoiceDate: row.data('invoicedate'),
                Amount: amount,
                Total: total,
                Balance: total,
                Remaining: remaining,
                Vat: vat,
                Selected: true
            };

            creditNoteData.Items.push(item);
        });


            // ✅ AJAX Call
            $.ajax({
                url: '/Customer/SaveCreditNote', 
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(creditNoteData), // send proper JSON
                dataType: 'json', // expect JSON response
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message);
                        $('#invoiceModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error("❌ AJAX ERROR", xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

             function openCreditNoteModal(creditNote) {
            console.log("Edit Credit Note:", creditNote);

            // Store ID for submit
            $("#invoiceModalForm").data("creditNoteId", creditNote.id || 0);

            // Header
            $("#customerSelect").val(creditNote.creditAccount || '').trigger('change');
            $("#customerCode").val(creditNote.customerCode || '');
            $("#invoiceDate").val(creditNote.date ? creditNote.date.split('T')[0] : '');
            $("#invoiceNo").val(creditNote.invoiceNo || '');
            $("#accountName").val(creditNote.accountCashId || '').trigger('change');
            $("#amount").val(creditNote.amount ?? 0);
            $("#vat").val(creditNote.vat ?? 0);
            $("#totalAmount").val(creditNote.totalAmount ?? 0);
            $("#description").val(creditNote.description || '');

            // Clear table
            $("#invoiceTableBody").empty();

            // Items
            (creditNote.items || []).forEach((item, index) => {
                $("#invoiceTableBody").append(`
                    <tr
                        data-invoiceid="${item.invoiceId}"
                        data-invoicedate="${item.invoiceDate}">

                        <td>${index + 1}</td>
                        <td>${item.invoiceDate ? item.invoiceDate.split('T')[0] : ''}</td>
                        <td>${item.invoiceNo || ''}</td>
                        <td>${item.total ?? 0}</td>
                        <td>${item.total ?? 0}</td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input invoiceSelect"
                                ${item.selected ? 'checked' : ''}>
                        </td>
                        <td>
                            <input type="number"
                                class="form-control form-control-sm invoiceAmount"
                                value="${item.amount ?? 0}" step="0.001">
                        </td>
                        <td class="remaining">${item.remaining ?? 0}</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-info viewInvoice">View</button>
                        </td>
                    </tr>
                `);
            });

            // Modal title
            $("#invoiceModalLabel").text("Edit Credit Note");

            // Show modal
            $("#invoiceModal").modal("show");
        }

                $(document).on('click', '.editCreditNoteBtn', function () {

