    @section Scripts {
    <script>
            (function() {
                const table = document.getElementById("salesTable");
                if (!table) return;

                const dateFrom = document.getElementById("dateFrom")?.value;
                const dateTo   = document.getElementById("dateTo")?.value;

                table.addEventListener("click", async function (e) {
                    const row = e.target.closest("tr.group-row");
                    if (!row) return;

                    const level    = parseInt(row.dataset.level, 10); // 1 or 2
                    const state    = row.dataset.state;               // "e" or "c"
                    const load     = row.dataset.load;                // "u" or "l"
                    const key      = row.dataset.key;                 // type or "catId|type"
                    const arrowEl  = row.querySelector(".group-arrow");

                    if (state === "e") {
                        // Expand
                        if (load === "u") {
                            if (level === 1) {
                                await loadCategories(row, key);              // type
                            } else if (level === 2) {
                                const parts = key.split("|");                // "catId|type"
                                const catId = parseInt(parts[0], 10);
                                const itemType = parts[1];
                                await loadItems(row, catId, itemType);
                            }
                            row.dataset.load = "l";
                        } else {
                            toggleChildren(row, true);
                        }

                        row.dataset.state = "c";
                        if (arrowEl) arrowEl.textContent = "▼";
                    } else if (state === "c") {
                        // Collapse
                        toggleChildren(row, false);
                        row.dataset.state = "e";
                        if (arrowEl) arrowEl.textContent = "►";     
                    }
                });

                async function loadCategories(parentRow, itemType) {
                    const rowId = parentRow.dataset.rowId;

                    const res = await fetch(`/sales-analysis/categories?type=${encodeURIComponent(itemType)}`);
                    if (!res.ok) return;
                    const data = await res.json(); // [{id, name}]

                    let insertIndex = parentRow.rowIndex; // 0-based
                    data.forEach(cat => {
                        insertIndex++;
                        const newRow = table.insertRow(insertIndex);
                        newRow.classList.add("group-row", "level-2");
                        newRow.dataset.level  = "2";
                        newRow.dataset.state  = "e";
                        newRow.dataset.load   = "u";
                        newRow.dataset.key    = cat.id + "|" + itemType; // same as WinForms key
                        newRow.dataset.parent = rowId;
                        newRow.dataset.rowId  = `cat-${cat.id}-type-${itemType}`;

                        newRow.innerHTML = `
        <td>
            <span class="group-arrow">►</span>
            <span class="group-label ms-4">${cat.name}</span>
        </td>
        <td colspan="8"></td>`;
                    });
                }

                async function loadItems(parentRow, categoryId, itemType) {
                    const parentId = parentRow.dataset.rowId;
                    const from = dateFrom || "";
                    const to   = dateTo || "";

                    const res = await fetch(
                        `/sales-analysis/items?categoryId=${categoryId}&type=${encodeURIComponent(itemType)}&from=${from}&to=${to}`
                    );
                    if (!res.ok) return;

                    const items = await res.json(); // [{id, itemName, qty, amount, ...}]
                    let insertIndex = parentRow.rowIndex;

                    items.forEach(it => {
                        insertIndex++;
                        const newRow = table.insertRow(insertIndex);
                        newRow.classList.add("group-row", "level-3");
                        newRow.dataset.level  = "3";
                        newRow.dataset.state  = "n"; // no expand
                        newRow.dataset.load   = "l";
                        newRow.dataset.key    = it.id;
                        newRow.dataset.parent = parentId;

                        newRow.innerHTML = `
        <td>
            <span class="group-label ms-5">${it.itemName}</span>
        </td>
        <td class="text-end">${it.qty}</td>
        <td class="text-end">${it.amount}</td>
        <td class="text-end">${it.percentOfSales}%</td>
        <td class="text-end">${it.avgPrice}</td>
        <td class="text-end">${it.cogs}</td>
        <td class="text-end">${it.avgCogs}</td>
        <td class="text-end">${it.grossMargin}</td>
        <td class="text-end">${it.grossMarginPercent}%</td>`;
                    });
                }

                // Similar to your ToggleSalesChildren
                function toggleChildren(parentRow, show) {
                    const parentId = parentRow.dataset.rowId;
                    const rows = table.querySelectorAll("tr.group-row");
                    rows.forEach(r => {
                        if (r.dataset.parent === parentId) {
                            r.style.display = show ? "" : "none";

                            // If hiding, also hide its children recursively
                            if (!show) {
                                toggleChildren(r, false);
                                const arrow = r.querySelector(".group-arrow");
                                if (arrow) arrow.textContent = "►";
                                r.dataset.state = "e";
                            }
                        }
                    });
                }
            })();
    </script>
    }
