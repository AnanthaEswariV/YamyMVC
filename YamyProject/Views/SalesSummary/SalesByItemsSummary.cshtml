@model ItemSalesReportViewModel
@{
    ViewData["Title"] = "Sales By Item Summary";
    }

<style>
    body {
        background: #f5f6f8;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .report-wrap {
        padding: 16px 24px;
    }

    .report-card {
        background: #ffffff;
        border-radius: 4px;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, .06);
        padding: 12px 18px 24px;
    }

    .toolbar {
        margin-bottom: 8px;
    }

        .toolbar .btn {
            font-size: .8rem;
            padding: 4px 10px;
        }

    .filters-row label {
        font-size: .8rem;
        font-weight: 600;
        margin-right: 4px;
    }

    .filters-row .form-select,
    .filters-row .form-control {
        font-size: .8rem;
        height: calc(1.5rem + 6px);
        padding: 2px 6px;
    }

    .filters-row .input-group-text {
        padding: 2px 6px;
        font-size: .75rem;
    }

    .report-meta {
        font-size: .75rem;
        line-height: 1.2;
    }

    .report-title h6 {
        font-size: .8rem;
        letter-spacing: .05em;
    }

    .report-title h5 {
        font-size: 1rem;
        margin-bottom: 2px;
    }

    .report-title span {
        font-size: .85rem;
        font-weight: 600;
    }

    .report-table-wrapper {
        margin-top: 16px;
        border: 1px solid #e5e7eb;
        background: #fafafa;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .78rem;
    }

        .report-table thead th {
            background: #e5e7eb;
            padding: 6px 8px;
            text-align: right;
            border-bottom: 1px solid #e5e7eb;
            font-weight: 600;
            white-space: nowrap;
        }

            .report-table thead th:first-child {
                text-align: left;
                width: 32%;
            }

        .report-table tbody td {
            padding: 4px 8px;
            border-bottom: 1px solid #f1f1f1;
            white-space: nowrap;
        }

        .report-table tbody tr:last-child td {
            border-bottom: none;
        }

        .report-table tbody td.text-end {
            text-align: right;
        }

    .group-row {
        background: #dde4f1;
        font-weight: 600;
    }

        .group-row.level-2 {
            background: #c9d7f0;
        }

        .group-row td {
            border-bottom-color: #dde4f1;
        }

    .group-arrow {
        display: inline-block;
        width: 14px;
        text-align: center;
        margin-right: 4px;
        font-size: .6rem;
    }

    .indent-1 {
        padding-left: 28px !important;
    }

    .indent-2 {
        padding-left: 44px !important;
    }
</style>

