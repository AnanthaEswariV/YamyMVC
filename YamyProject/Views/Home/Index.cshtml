@{
    ViewData["Title"] = "Accounting Dashboard";
}

<div class="container-fluid p-3">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">Accounting Dashboard</h2>
            <p class="text-muted mb-0">Overview of financial activities and balances</p>
        </div>
    </div>

    <!-- Top Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:28px; color:green; margin-right:10px;">💰</div>
                    <div>
                        <p class="mb-1 text-muted">Total Income</p>
                        <h5 class="mb-0 fw-bold">$250,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:28px; color:red; margin-right:10px;">💸</div>
                    <div>
                        <p class="mb-1 text-muted">Total Expenses</p>
                        <h5 class="mb-0 fw-bold">$145,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:28px; color:blue; margin-right:10px;">🏦</div>
                    <div>
                        <p class="mb-1 text-muted">Current Balance</p>
                        <h5 class="mb-0 fw-bold">$105,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:28px; color:orange; margin-right:10px;">💳</div>
                    <div>
                        <p class="mb-1 text-muted">Petty Cash</p>
                        <h5 class="mb-0 fw-bold">$8,500</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart + Account Overview -->
    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Monthly Income vs Expense</h5>
                </div>
                <div class="card-body text-center" style="height:250px;">
                    <p class="text-muted mt-5">[Chart Placeholder]</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Account Overview</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>💵 Cash in Hand</span>
                        <strong>$12,300</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>🏦 Bank Accounts</span>
                        <strong>$89,700</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>💳 Credit Accounts</span>
                        <strong>-$2,000</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>🧾 Receivables</span>
                        <strong>$5,000</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions + Activity -->
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Recent Transactions</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Type</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>2025-10-01</td>
                                <td>Invoice Payment - Client A</td>
                                <td><span class="badge bg-success">Income</span></td>
                                <td class="text-end">$2,500</td>
                            </tr>
                            <tr>
                                <td>2025-10-02</td>
                                <td>Office Rent</td>
                                <td><span class="badge bg-danger">Expense</span></td>
                                <td class="text-end">$1,200</td>
                            </tr>
                            <tr>
                                <td>2025-10-02</td>
                                <td>Petty Cash Refill</td>
                                <td><span class="badge bg-warning text-dark">Transfer</span></td>
                                <td class="text-end">$500</td>
                            </tr>
                            <tr>
                                <td>2025-10-03</td>
                                <td>Salary Payment</td>
                                <td><span class="badge bg-danger">Expense</span></td>
                                <td class="text-end">$5,000</td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="text-end">
                        <button class="btn btn-outline-primary btn-sm">View All</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <button class="btn btn-primary w-100 mb-2">➕ Add Transaction</button>
                    <button class="btn btn-success w-100 mb-2">💰 Add Income</button>
                    <button class="btn btn-danger w-100 mb-2">💸 Add Expense</button>
                    <button class="btn btn-secondary w-100">📊 Generate Report</button>
                </div>
            </div>
        </div>
    </div>
</div>
