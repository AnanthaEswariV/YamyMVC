@model YamyProject.Core.Models.AccountingDashboardViewModel;
@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = "Accounting Dashboard";
    string Fmt(decimal v) => v < 0
    ? $"-AED {Math.Abs(v).ToString("N2", CultureInfo.InvariantCulture)}"
    : $"AED {v.ToString("N2", CultureInfo.InvariantCulture)}";

    var selectedYear = Model.SelectedYear > 0 ? Model.SelectedYear : DateTime.Now.Year;
    var currentYear  = DateTime.Now.Year;
    var yearRange    = Enumerable.Range(currentYear - 5, 6).Reverse();

    var labels   = JsonSerializer.Serialize(Model.MonthlyData.Select(m => m.Month));
    var incomes  = JsonSerializer.Serialize(Model.MonthlyData.Select(m => m.Income));
    var expenses = JsonSerializer.Serialize(Model.MonthlyData.Select(m => m.Expense));
}

<div class="container-fluid p-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h4 class="mb-0 fw-bold">Accounting Dashboard</h4>
            <span class="text-muted" style="font-size:.82rem">
                Year-to-date as of @DateTime.Now.ToString("dd MMM yyyy", new CultureInfo("en-US"))
            </span>
        </div>


        <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 mb-0">
            <label class="form-label mb-0 text-muted fw-semibold" style="font-size:.82rem">
                Financial Year
            </label>
            <select name="year" class="form-select form-select-sm" style="width:auto"
                    onchange="this.form.submit()">
                @foreach (var y in yearRange)
                {
                    if (y == selectedYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </form>
    </div>


   <div class="row g-3 mb-4">

        <div class="col-6 col-lg-3">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2 bg-success-subtle fs-4">💰</div>
                    <div>
                        <div class="text-muted text-uppercase fw-semibold" style="font-size:.72rem;letter-spacing:.05em">Total Income</div>
                        <div class="fw-bold text-success fs-5">@Fmt(Model.TotalIncome)</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2 bg-danger-subtle fs-4">💸</div>
                    <div>
                        <div class="text-muted text-uppercase fw-semibold" style="font-size:.72rem;letter-spacing:.05em">Total Expenses</div>
                        <div class="fw-bold text-danger fs-5">@Fmt(Model.TotalExpenses)</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2 bg-primary-subtle fs-4">🏦</div>
                    <div>
                        <div class="text-muted text-uppercase fw-semibold" style="font-size:.72rem;letter-spacing:.05em">Net Balance</div>
                        <div class="fw-bold fs-5 @(Model.CurrentBalance < 0 ? "text-danger" : "text-primary")">
                            @Fmt(Model.CurrentBalance)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 p-2 bg-warning-subtle fs-4">💳</div>
                    <div>
                        <div class="text-muted text-uppercase fw-semibold" style="font-size:.72rem;letter-spacing:.05em">Petty Cash</div>
                        <div class="fw-bold text-warning fs-5">@Fmt(Model.PettyCash)</div>
                    </div>
                </div>
            </div>
        </div>

    </div> 


    <div class="row g-3 mb-4">

        <div class="col-lg-8">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted text-uppercase fw-semibold"
                              style="font-size:.78rem;letter-spacing:.07em">
                            Monthly Income vs Expense
                        </span>
                        <span class="badge bg-secondary-subtle text-secondary">@selectedYear</span>
                    </div>
                    <div style="position:relative;height:230px">
                        <canvas id="monthlyChart"
                                role="img"
                                aria-label="Bar chart of monthly income vs expenses for @selectedYear">
                        </canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border rounded-3 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="text-muted text-uppercase fw-semibold mb-3 pb-2 border-bottom"
                         style="font-size:.78rem;letter-spacing:.07em">
                        Account Overview
                    </div>

                    @{
                        var acctRows = new[]
                        {
                            ("💵 Cash in Hand",    Fmt(Model.CashInHand),   false),
                            ("🏦 Bank Accounts",   Fmt(Model.BankBalance),  false),
                            ("💳 Credit (Payable)", Fmt(Model.CreditBalance), Model.CreditBalance < 0),
                            ("🧾 Receivables",     Fmt(Model.Receivables),  false),
                        };
                    }

                    @foreach (var (label, val, isNeg) in acctRows)
                    {
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <span style="font-size:.9rem">@label</span>
                            <span class="fw-semibold @(isNeg ? "text-danger" : "")">@val</span>
                        </div>
                    }

                    @if (Model.TotalIncome > 0)
                    {
                        var pct = Math.Min(100, (double)Model.TotalExpenses / (double)Model.TotalIncome * 100);
                        <div class="mt-3">
                            <div class="d-flex justify-content-between mb-1 text-muted" style="font-size:.75rem">
                                <span>Expense Ratio</span>
                                <span>@pct.ToString("N1")%</span>
                            </div>
                            <div class="progress" style="height:5px;border-radius:3px">
                                <div class="progress-bar @(pct > 80 ? "bg-danger" : "bg-success")"
                                     style="width:@pct.ToString("N1", CultureInfo.InvariantCulture)%">
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>


    <div class="row g-3">

        <div class="col-lg-8">
            <div class="card border rounded-3 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-muted text-uppercase fw-semibold mb-3 pb-2 border-bottom"
                         style="font-size:.78rem;letter-spacing:.07em">
                        Recent Transactions
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-2" style="font-size:.87rem">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-muted fw-semibold text-uppercase" style="font-size:.72rem;letter-spacing:.06em">Date</th>
                                    <th class="text-muted fw-semibold text-uppercase" style="font-size:.72rem;letter-spacing:.06em">Voucher</th>
                                    <th class="text-muted fw-semibold text-uppercase" style="font-size:.72rem;letter-spacing:.06em">Description</th>
                                    <th class="text-muted fw-semibold text-uppercase" style="font-size:.72rem;letter-spacing:.06em">Type</th>
                                    <th class="text-muted fw-semibold text-uppercase text-end" style="font-size:.72rem;letter-spacing:.06em">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.RecentTransactions.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">
                                            No transactions found for @selectedYear.
                                        </td>
                                    </tr>
                                }
                                @foreach (var tx in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td class="text-nowrap text-muted" style="font-size:.82rem">
                                            @tx.Date.ToString("dd MMM yyyy")
                                        </td>
                                        <td>
                                            <code class="bg-light px-2 py-1 rounded" style="font-size:.75rem">
                                                @tx.VoucherCode
                                            </code>
                                        </td>
                                        <td>
                                            @(tx.Description.Length > 35
                                                ? tx.Description[..35] + "…"
                                                : tx.Description)
                                        </td>
                                        <td>
                                            <span class="badge @tx.BadgeClass">@tx.TxType</span>
                                        </td>
                                        <td class="text-end fw-semibold
                                            @(tx.TxType == "Income" ? "text-success" : "text-danger")">
                                            @Fmt(tx.Amount)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-1">
                        <a asp-controller="Account" asp-action="PaymentVoucher"
                           class="btn btn-sm btn-outline-secondary">View Payments</a>
                        <a asp-controller="Account" asp-action="ReceiptVoucher"
                           class="btn btn-sm btn-outline-secondary">View Receipts</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border rounded-3 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-muted text-uppercase fw-semibold mb-3 pb-2 border-bottom"
                         style="font-size:.78rem;letter-spacing:.07em">
                        Quick Actions
                    </div>
                    <div class="d-flex flex-column gap-2">

                        <a asp-controller="Account" asp-action="ReceiptVoucher"
                           class="btn btn-success btn-sm d-flex align-items-center gap-2 text-start py-2 px-3">
                            <span class="bg-white bg-opacity-25 rounded p-1 lh-1">💰</span>
                            Add Income (Receipt)
                        </a>

                        <a asp-controller="Account" asp-action="PaymentVoucher"
                           class="btn btn-danger btn-sm d-flex align-items-center gap-2 text-start py-2 px-3">
                            <span class="bg-white bg-opacity-25 rounded p-1 lh-1">💸</span>
                            Add Expense (Payment)
                        </a>

                        <a asp-controller="Account" asp-action="GJVoucher"
                           class="btn btn-primary btn-sm d-flex align-items-center gap-2 text-start py-2 px-3">
                            <span class="bg-white bg-opacity-25 rounded p-1 lh-1">📋</span>
                            Journal Voucher
                        </a>

                        <a asp-controller="Account" asp-action="BankCenter"
                           class="btn btn-purple btn-sm d-flex align-items-center gap-2 text-start py-2 px-3"
                           style="background:#7c3aed;border-color:#7c3aed;color:#fff">
                            <span class="bg-white bg-opacity-25 rounded p-1 lh-1">🏦</span>
                            Bank Center
                        </a>

                        <a href="#"
                           class="btn btn-secondary btn-sm d-flex align-items-center gap-2 text-start py-2 px-3">
                            <span class="bg-white bg-opacity-25 rounded p-1 lh-1">📊</span>
                            Generate Report
                        </a>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const labels   = @Html.Raw(labels);
            const incomes  = @Html.Raw(incomes);
            const expenses = @Html.Raw(expenses);

            new Chart(document.getElementById('monthlyChart'), {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Income',
                            data: incomes,
                            backgroundColor: 'rgba(34,197,94,.75)',
                            borderRadius: 5,
                            borderSkipped: false,
                            barPercentage: 0.65
                        },
                        {
                            label: 'Expense',
                            data: expenses,
                            backgroundColor: 'rgba(239,68,68,.75)',
                            borderRadius: 5,
                            borderSkipped: false,
                            barPercentage: 0.65
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: { font: { size: 11 }, boxWidth: 12, boxHeight: 12 }
                        },
                        tooltip: {
                            callbacks: {
                                  label: ctx =>
        ` ${ctx.dataset.label}: AED ${Number(ctx.parsed.y)
            .toLocaleString('en-AE', { minimumFractionDigits: 2 })}`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: {
                            beginAtZero: true,
                                   ticks: {
            callback: v => 'AED ' + Number(v).toLocaleString('en-AE')
        }
                        }
                    }
                }
            });
        })();
    </script>
}