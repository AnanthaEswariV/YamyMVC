@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid p-3">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">Dashboard Overview</h2>
        </div>
    </div>

    <!-- Top Statistic Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:30px; color:purple; margin-right:10px;">👁️</div>
                    <div>
                        <p class="mb-1 text-muted">Profile Views</p>
                        <h5 class="mb-0 fw-bold">112,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:30px; color:blue; margin-right:10px;">👤</div>
                    <div>
                        <p class="mb-1 text-muted">Followers</p>
                        <h5 class="mb-0 fw-bold">183,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:30px; color:green; margin-right:10px;">➕</div>
                    <div>
                        <p class="mb-1 text-muted">Following</p>
                        <h5 class="mb-0 fw-bold">80,000</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body d-flex align-items-center">
                    <div style="font-size:30px; color:red; margin-right:10px;">🔖</div>
                    <div>
                        <p class="mb-1 text-muted">Saved Posts</p>
                        <h5 class="mb-0 fw-bold">112</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart + Comments -->
    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Profile Visits (Chart Placeholder)</h5>
                </div>
                <div class="card-body text-center" style="height:250px;">
                    <p class="text-muted mt-5">[Chart Placeholder]</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Visitor Regions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>🌍 Europe</span>
                        <strong>862</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>🌎 America</span>
                        <strong>375</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>🌏 Indonesia</span>
                        <strong>1025</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>🌏 India</span>
                        <strong>500</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span>🌏 UAE</span>
                        <strong>806</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Comments + Profile -->
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Latest Comments</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Comment</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="~/assets/images/faces/5.jpg" width="40" height="40" class="rounded-circle me-2" />
                                        <strong>Si Cantik</strong>
                                    </div>
                                </td>
                                <td>Congratulations on your graduation!</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="~/assets/images/faces/2.jpg" width="40" height="40" class="rounded-circle me-2" />
                                        <strong>Si Ganteng</strong>
                                    </div>
                                </td>
                                <td>Wow amazing design! Can you make another tutorial for this?</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body text-center">
                    <img src="~/assets/images/faces/1.jpg" class="rounded-circle mb-3" width="80" height="80" />
                    <h5 class="fw-bold mb-0">John Duck</h5>
                    <p class="text-muted">johnducky</p>
                    <button class="btn btn-primary w-100">Start Conversation</button>
                </div>
            </div>
        </div>
    </div>
</div>
