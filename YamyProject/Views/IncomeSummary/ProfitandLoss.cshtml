    </style>
    <script>
               $(function () {


            // --- Render empty state ---
            function renderEmpty(title, message) {
                return `
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <h3>${title}</h3>
                    <p>${message || ''}</p>
                </div>
                `;
            }

            // --- Build tree recursively ---
            function buildTree(nodes, container) {
                container.empty();
                const ul = $("<ul></ul>");
                nodes.forEach(node => ul.append(createNodeLi(node, 0)));
                container.append(ul);
                ul.show();
            }

            function createNodeLi(node, level) {
                const li = $("<li>").addClass(`level-${level}`);
                const nodeDiv = $("<div>").addClass(`tree-node level-${level}`);

                // --- Normalize values ---
                const id = node.id ?? '';
                const code = node.code ?? '';
                const name = node.name ?? '';
                const debit = (node.debit === 0 || node.debit) ? node.debit : '';
                const credit = (node.credit === 0 || node.credit) ? node.credit : '';
                const date = formatDateForInput(node.date ?? node.due ?? '');

                // --- Attach data attributes ---
                nodeDiv.attr({
                    'data-id': id,
                    'data-code': code,
                    'data-name': name,
                    'data-debit': debit,
                    'data-credit': credit,
                    'data-date': date
                });

                // --- Toggle / dot ---
                if (node.children && Array.isArray(node.children) && node.children.length) {
                    const toggle = $("<div class='toggle'>▶</div>");
                    toggle.on("click", function (e) {
                        e.stopPropagation();
                        const $childUl = $(this).closest('.tree-node').next("ul");
                        if ($childUl.is(":visible")) {
                            $childUl.slideUp(250);
                            $(this).removeClass('expanded').text("▶");
                        } else {
                            $childUl.slideDown(250);
                            $(this).addClass('expanded').text("▼");
                        }
                    });
                    nodeDiv.append(toggle);
                } else {
                    nodeDiv.append("<div class='dot-indicator'>•</div>");
                }

                const infoDiv = $("<div class='account-info'></div>");
                infoDiv.append(`<div class='account-code'>${code}</div>`);
                infoDiv.append(`<div class='account-name'>${name}</div>`);
                nodeDiv.append(infoDiv);

                // --- Actions for level 4 ---
                if (level === 3) {
                    const actionContainer = $("<div class='action-container'></div>");
                    const editBtn = $(`<button class="btn btn-sm btn-outline-primary ms-2" title="Edit"><i class="fas fa-pen"></i></button>`);

                    editBtn.on("click", e => {
                        e.stopPropagation();
                        const $node = $(e.currentTarget).closest('.tree-node');
                        openEditModal(
                            $node.attr('data-id'),
                            $node.attr('data-name'),
                            $node.attr('data-debit'),
                            $node.attr('data-credit'),
                            $node.attr('data-date')
                        );
                    });

                          const deleteBtn = $(`<button class="btn btn-sm btn-outline-danger ms-2" title="Delete"><i class="fas fa-trash-alt"></i></button>`);

        deleteBtn.on("click", e => {
            e.stopPropagation();
            const $node = $(e.currentTarget).closest('.tree-node');
            const nid = $node.attr('data-id');
            const nname = $node.attr('data-name');

            // Call the ajax delete function
            deleteLevel4Account(nid, nname);
        });


                    actionContainer.append(editBtn, deleteBtn);
                    nodeDiv.append(actionContainer);
                    nodeDiv.css('cursor', 'default');
                } else {
                    nodeDiv.on('click', function (e) {
                        e.stopPropagation();
                        const $toggle = $(this).find('> .toggle');
                        if ($toggle.length) $toggle.trigger('click');
                    });
                }

                li.append(nodeDiv);

                // --- Recursion for children ---
                if (node.children && Array.isArray(node.children) && node.children.length) {
                    const childUl = $("<ul></ul>").hide();
                    node.children.forEach(child => childUl.append(createNodeLi(child, level + 1)));
                    li.append(childUl);
                }

                return li;
            }

            // --- Search setup ---
            function setupSearch() {
                $('#searchInput').on('input', function () {
                    const searchTerm = $(this).val().toLowerCase().trim();
                    if (!searchTerm) {
                        $('.tree li').show();
                        $('.tree ul').hide();
                        $('.tree > ul').show();
                        $('.toggle').text('▶').removeClass('expanded');
                        return;
                    }

                    $('.tree li').each(function () {
                        const $li = $(this);
                        const code = $li.find('.account-code').first().text().toLowerCase();
                        const name = $li.find('.account-name').first().text().toLowerCase();
                        if (code.includes(searchTerm) || name.includes(searchTerm)) {
                            $li.show();
                            $li.parents('li').show();
                            $li.parents('ul').show();
                            $li.parents('li').find('> .tree-node .toggle').text('▼').addClass('expanded');
                        } else {
                            $li.hide();
                        }
                    });
                });
            }

            // --- Load tree ---
            function loadChartOfAccounts() {
                $("#coaTree").html('<div class="loading"><div class="spinner"></div>Loading accounts...</div>');
                $.getJSON("/Lists/GetCOA")
                    .done(function (data) {
                        if (data && data.status === false) {
                            $("#coaTree").html(renderEmpty("Unable to Load Accounts", data.message));
                            return;
                        }
                        let nodes = (data && data.data && Array.isArray(data.data)) ? data.data : data;
                        if (!Array.isArray(nodes)) {
                            $("#coaTree").html(renderEmpty("Data Format Error", "Unexpected data format received from server."));
                            return;
                        }
                        buildTree(nodes, $("#coaTree"));
                        setupSearch();
                    })
                    .fail(function (xhr, status, error) {
                        $("#coaTree").html(renderEmpty("Connection Error", "Unable to load Chart of Accounts. Please try again."));
                    });
            }


        function openEditModal(id, name, debit = 0, credit = 0, date = null) {
            $("#editAccountId").val(id);
            $("#editAccountName").val(name);
            $("#editDebit").val(debit);
            $("#editCredit").val(credit);
            $("#editDate").val(formatDateForInput(date));
            $("#editAccountModal").modal("show");
        }


        $("#saveEditAccount").on("click", function () {
            const payload = {
                Id: parseInt($("#editAccountId").val()) || 0,
                Name: $("#editAccountName").val(),
                Debit: parseFloat($("#editDebit").val()) || 0,
                Credit: parseFloat($("#editCredit").val()) || 0,
                Date: $("#editDate").val() || null
            };

            $.ajax({
                url: "/Lists/EditCoaLevel4",
                type: "PUT",
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message || "Account updated successfully");
                        $("#editAccountModal").modal("hide");
                        loadChartOfAccounts(); // reload tree after edit
                    } else {
                        toastr.warning(res.message || "Failed to update");
                    }
                },
                error: function (xhr) {
                    toastr.error("Error updating account");
                }
            });
        });

            function formatDateForInput(d) {
            if (!d) return '';
            const dt = new Date(d);
            if (isNaN(dt.getTime())) return '';
            const month = (dt.getMonth() + 1).toString().padStart(2, '0');
            const day = dt.getDate().toString().padStart(2, '0');
            return `${dt.getFullYear()}-${month}-${day}`;
        }


                function deleteLevel4Account(id, name) {
            if (!id) {
                toastr.error("Invalid account selected.");
                return;
            }

            if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

            $.ajax({
                url: `/Lists/DeleteCoaLevel4?id=${id}`,
                type: 'DELETE',
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message || "Account deleted successfully");
                        loadChartOfAccounts(); // reload tree after deletion
                    } else {
                        toastr.error(res.message || "Failed to delete account");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Error deleting account");
                }
            });
        }



            // --- Initial load ---
            loadChartOfAccounts();

            // Expose edit modal for debugging
            window.openEditModal = openEditModal;
        });



        $(document).ready(function () {

            // Load LEVEL 1 (All)
            function loadLevel1() {
                $.ajax({
                    url: '/Lists/GetLevel1Accounts',
                    type: 'GET',
                    success: function (res) {
                        const $ddl1 = $('#coaModal select').eq(0);
                        $ddl1.empty().append('<option value="">Select Level 1</option>');
                        if (res.status && res.data?.length > 0) {
                            res.data.forEach(row => {
                                $ddl1.append(`<option value="${row.id}">${row.name}</option>`);
                            });
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load Level 1 accounts.');
                    }
                });
            }

            // Load LEVEL 2 based on selected Level 1
            function loadLevel2(level1Id) {
                const $ddl2 = $('#coaModal select').eq(1);
                const $ddl3 = $('#coaModal select').eq(2);
                $ddl2.empty().append('<option value="">Select Level 2</option>');
                $ddl3.empty().append('<option value="">Select Level 3</option>');
                if (!level1Id) return;
                console.log(level1Id);
                $.ajax({
                    url: '/Lists/GetLevel2AccountsByLevel1?level1Id=' + level1Id,
                    type: 'GET',
                    success: function (res) {
                        if (res.status && res.data?.length > 0) {
                            res.data.forEach(row => {
                                $ddl2.append(`<option value="${row.id}">${row.name}</option>`);
                            });
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load Level 2 accounts.');
                    }
                });
            }

            // Load LEVEL 3 based on selected Level 2
            function loadLevel3(level2Id) {
                const $ddl3 = $('#coaModal select').eq(2);
                $ddl3.empty().append('<option value="">Select Level 3</option>');
                if (!level2Id) return;

                $.ajax({
                    url: '/Lists/GetLevel3AccountsByLevel2?id=' + level2Id,
                    type: 'GET',
                    success: function (res) {
                        if (res.status && res.data?.length > 0) {
                            res.data.forEach(row => {
                                $ddl3.append(`<option value="${row.id}">${row.name}</option>`);
                            });
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load Level 3 accounts.');
                    }
                });
            }

            // When modal opens → load Level 1
            $('#coaModal').on('shown.bs.modal', function () {
                loadLevel1();
                $('#coaModal select').eq(1).empty().append('<option value="">Select Level 2</option>');
                $('#coaModal select').eq(2).empty().append('<option value="">Select Level 3</option>');
            });

            // On Level 1 change → load Level 2
            $('#coaModal select').eq(0).on('change', function () {
                const level1Id = $(this).val();
                loadLevel2(level1Id);
            });

            // On Level 2 change → load Level 3
            $('#coaModal select').eq(1).on('change', function () {
                const level2Id = $(this).val();
                loadLevel3(level2Id);
            });

               // 🔹 Submit form
        $('#coaForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const idVal = $('#level4Id').val();
            const isEdit = idVal && parseInt(idVal) > 0;

            // ✅ Safe defaults
            const debitVal = parseFloat($('#txtDebit').val()) || 0;
            const creditVal = parseFloat($('#txtCredit').val()) || 0;
            const dateVal = $('#txtDate').val() || null;

            const payload = {
                Id: isEdit ? parseInt(idVal) : 0,
                Name: $('#txtLevel4').val().trim(),
                Level3Id: parseInt($('#ddlLevel3').val()),
                Debit: debitVal,
                Credit: creditVal,
                Date: dateVal
            };

            $.ajax({
                url: isEdit ? '/Lists/UpdateLevel4Account' : '/Lists/AddLevel4Account',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? 'Level 4 Account updated successfully' : 'Level 4 Account added successfully');
                        $('#coaModal').modal('hide');
                        $('#coaForm')[0].reset();
                        $('#level4Id').val(0);
                        $('#coaModalLabel').text('COA - New Account');
                        form.classList.remove('was-validated');
                        loadLevel4Accounts();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });



        });




    </script>
