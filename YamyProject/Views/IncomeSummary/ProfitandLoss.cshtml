@model IEnumerable<EquityBalanceRowViewModel>
@using Microsoft.AspNetCore.Mvc.ViewFeatures

@{
    ViewData["Title"] = "Profit And Loss";
    }

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

<div class="container-fluid py-3">

    <!-- Toolbar buttons (top) -->
    <div class="d-flex flex-wrap gap-2 mb-2">
        <button class="btn btn-sm btn-outline-secondary">Customize Report</button>
        <button class="btn btn-sm btn-outline-secondary">Comment On</button>
        <button class="btn btn-sm btn-outline-secondary">Memorize</button>
        <button class="btn btn-sm btn-outline-secondary">Print ▼</button>
        <button class="btn btn-sm btn-outline-secondary">Excel</button>
        <button class="btn btn-sm btn-outline-secondary">Hide</button>
        <button class="btn btn-sm btn-outline-secondary">Refresh</button>
    </div>

    <!-- Filters row -->
    <div class="row g-2 align-items-end mb-3">
        <div class="col-auto">
            <label class="form-label mb-0 fw-semibold">Dates</label>
            <input type="text" class="form-control form-control-sm" placeholder="">
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">From</label>
            <input type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">To</label>
            <input type="date" class="form-control form-control-sm" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Show Columns</label>
            <select class="form-select form-select-sm">
                <option>All Columns</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Sort By</label>
            <select class="form-select form-select-sm">
                <option>Account Number</option>
                <option>Account Name</option>
                <option>Amount</option>
            </select>
        </div>
        <div class="col ms-auto">
            <label class="form-label mb-0">Search</label>
            <input id="searchInput" type="text"
                   class="form-control form-control-sm"
                   placeholder="Search accounts..." />
        </div>
    </div>

    <!-- Header (time + company + title) -->
    <div class="row mb-3">
        <div class="col">
            <div class="d-flex justify-content-between align-items-start">
                <div class="small text-muted">
                    @DateTime.Now.ToString("HH:mm")<br />
                    @DateTime.Now.ToString("dd/MM/yyyy")
                </div>

                <div class="text-center flex-grow-1">
                    <h5 class="mb-0 fw-semibold">COMPANY L.L.C.</h5>
                    <h4 class="mb-0">Profit &amp; loss</h4>
                    <div class="small text-muted">All Transaction</div>
                </div>

                <div style="width:80px"></div>
            </div>
        </div>
    </div>

    <!-- Card: tree header + body -->
    <div class="card shadow-sm">
        <div class="card-header py-2 bg-secondary-subtle">
            <div class="row">
                <div class="col fw-semibold">Account Name</div>
                <div class="col-auto fw-semibold text-end">Amount</div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="tree">
                <ul class="list-unstyled mb-0" id="plTree">
                    @foreach (var root in Model)
                        {
                        @await Html.PartialAsync(
                        "_EquityBalanceNode",
                                        root,
                                        new ViewDataDictionary(ViewData) { ["Level"] = 0 }
                                        )
                                        }
                </ul>
            </div>
        </div>
    </div>

</div>

    @section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        .tree-row {
            padding: 6px 0;
            border-bottom: 1px solid #f1f1f1;
            cursor: pointer;
            font-size: 0.9rem;
        }

            .tree-row:hover {
                background-color: #f5f5f5;
            }

        .tree-item.level-0 > .tree-row {
            background-color: #dcdcdc;
            font-weight: 600;
        }

        .tree-item.level-1 > .tree-row {
            background-color: #f0f4ff;
            font-weight: 600;
        }

        .tree-item.level-2 > .tree-row {
            background-color: #ffffff;
        }

        .tree-item.level-3 > .tree-row {
            background-color: #f9f9f9;
        }

        .toggle {
            display: inline-block;
            width: 16px;
            text-align: center;
            font-size: 0.7rem;
            color: #555;
        }

            .toggle.placeholder {
                visibility: hidden;
            }

            .toggle.expanded {
                transform: rotate(90deg);
            }

        .account-label {
            padding-left: 2px;
        }

        .amount {
            min-width: 130px;
        }
    </style>

    <script>
        $(function () {
            // expand/collapse
            $('#plTree').on('click', '.tree-row', function (e) {
                const $row = $(this);
                const $toggle = $row.find('.toggle').first();
                const $li = $row.closest('li');
                const $children = $li.children('ul.child-list');

                if ($children.length === 0) return;

                if ($children.is(':visible')) {
                    $children.slideUp(150);
                    $toggle.removeClass('expanded').text('▶').addClass('collapsed');
                } else {
                    $children.slideDown(150);
                    $toggle.addClass('expanded').text('▼').removeClass('collapsed');
                }
            });

            // search
            $('#searchInput').on('input', function () {
                const term = $(this).val().toLowerCase().trim();
                if (!term) {
                    // show all and collapse to top level
                    $('#plTree li').show();
                    $('#plTree ul.child-list').hide();
                    $('#plTree .toggle').text('▶').removeClass('expanded');
                    return;
                }

                $('#plTree li').each(function () {
                    const $li = $(this);
                    const text = $li.find('> .tree-row').data('name')?.toLowerCase() || "";
                    if (text.includes(term)) {
                        $li.show();
                        $li.parents('li').show();
                        $li.parents('ul.child-list').show();
                        $li.parents('li').find('> .tree-row .toggle')
                            .text('▼').addClass('expanded');
                    } else {
                        $li.hide();
                    }
                });
            });
        });
    </script>
    }




