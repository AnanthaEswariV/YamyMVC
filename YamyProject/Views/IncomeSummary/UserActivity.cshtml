@model UserActivityReportViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "User Activity Report";
    }
@* 
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
 *@
<style>
    .uar-window {
        border: 1px solid #c0c0c0;
        border-radius: 4px;
        background: #f5f6f8;
        overflow: hidden;
    }

    .uar-titlebar {
        background: #1a3764;
        color: #fff;
        padding: 6px 12px;
        display: flex;
        align-items: center;
    }

        .uar-titlebar h5 {
            flex: 1;
            text-align: center;
            margin: 0;
            color: #fff;
            /* font-weight: 600; */
        }

    .uar-filter-bar {
        background: #dedede;
        padding: 10px 16px;
        border-bottom: 1px solid #c0c0c0;
        display: flex;
        justify-content: center;
        gap: 20px;
        align-items: center;
    }

        .uar-filter-bar label {
            margin-bottom: 0;
            font-size: .85rem;
            font-weight: 600;
        }

        .uar-filter-bar .form-control-sm {
            min-width: 180px;
        }

        .uar-filter-bar .form-check-label {
            font-size: .85rem;
        }

    .uar-table-wrap {
        max-height: calc(100vh - 210px);
        overflow-y: auto;
    }

    .uar-table thead {
        background: #c0c0c0;
    }

        .uar-table thead th {
            font-size: .85rem;
            font-weight: 600;
            border-bottom: 1px solid #a0a0a0;
            white-space: nowrap;
        }

    .uar-table tbody tr:nth-child(odd) {
        background: #f5f0ff;
    }

    .uar-table tbody tr:nth-child(even) {
        background: #ffffff;
    }

    .uar-table tbody td {
        font-size: .85rem;
        vertical-align: middle;
    }
</style>

<div class="container-fluid py-3">
    <div class="uar-window shadow-sm">
        <!-- Title bar -->
        <div class="uar-titlebar">
            @* <div style="width:70px;"></div> <!-- spacer to visually center title --> *@
            <h5>User Activity Report</h5>
       
        </div>

        <!-- Filter bar -->
        <form asp-action="UserActivity" asp-controller="Reports" method="get">
            <div class="uar-filter-bar">
                <div class="d-flex align-items-center gap-2">
                    <label asp-for="FromDate">From</label>
                    <input asp-for="FromDate" type="date" class="form-control form-control-sm" />
                </div>

                <div class="d-flex align-items-center gap-2">
                    <label asp-for="ToDate">To</label>
                    <input asp-for="ToDate" type="date" class="form-control form-control-sm" />
                </div>

                <div class="form-check ms-3">
                    <input asp-for="AllDates" class="form-check-input" type="checkbox" id="chkAllDates" />
                    <label class="form-check-label" for="chkAllDates">All</label>
                </div>

             @*    <button type="submit" class="btn btn-sm btn-primary ms-3 px-3">
                    Refresh
                </button> *@
            </div>
        </form>

        <!-- Grid -->
        <div class="uar-table-wrap table-responsive">
            <table class="table table-sm mb-0 uar-table">
                <thead>
                    <tr>
                        <th style="width:70px;">ID</th>
                        <th style="width:120px;">Username</th>
                        <th>action type</th>
                        <th>module name</th>
                        <th style="width:90px;">record id</th>
                        <th>details</th>
                        <th style="width:190px;">action time</th>
                        <th style="width:150px;">ip address</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Rows != null && Model.Rows.Any())
                        {
                        foreach (var row in Model.Rows)
                            {
                            <tr>
                                <td>@row.Id</td>
                                <td>@row.Username</td>
                                <td>@row.ActionType</td>
                                <td>@row.ModuleName</td>
                                <td>@row.RecordId</td>
                                <td>@row.Details</td>
                                <td>@row.ActionTime.ToString("M/d/yyyy h:mm tt")</td>
                                <td>@row.IpAddress</td>
                            </tr>
                            }
                        }
                    else
                        {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                No activity found for the selected period.
                            </td>
                        </tr>
                        }
                </tbody>
            </table>
        </div>
    </div>
</div>
