@using System.Globalization
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model CashFlowStatementViewModel 

@{
    ViewData["Title"] = "Statement of Cash Flow";
}

@* <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
 *@
<style>
    body {
        background: #f5f6f8;
    }

    .cf-wrap {
        padding-top: .75rem;
        padding-bottom: 1.5rem;
    }

    .cf-toolbar label {
        font-size: .85rem;
        font-weight: 600;
        margin-right: .25rem;
    }

    .cf-toolbar .form-select,
    .cf-toolbar .form-control {
        height: 32px;
        padding: 2px 8px;
        font-size: .85rem;
    }

    .cf-timebox {
        font-size: .8rem;
        color: #555;
        margin-top: 40px;
        text-align: left;
    }

    .cf-report-card {
        background: #ffffff;
        border-radius: 2px;
        box-shadow: 0 0 0 1px #dfe1e5;
        width: 980px;
    }

    .cf-report-header {
        text-align: center;
        padding-top: 1.25rem;
        padding-bottom: .75rem;
    }

    .cf-report-header h5 {
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .03em;
        margin-bottom: .15rem;
    }

    .cf-report-header .subtitle {
        font-weight: 600;
        margin-bottom: 0;
    }

    .cf-report-header .subsubtitle {
        font-size: .9rem;
        color: #555;
        margin-top: .15rem;
    }

    .cf-table {
        margin-top: .5rem;
        font-size: .85rem;
    }

    .cf-table thead th {
        background: #e3e4e8;
        font-weight: 600;
        border-bottom: 1px solid #cfd1d6;
        padding: 6px 10px;
    }

    .cf-table tbody tr td {
        border-top: 1px solid #f1f2f4;
        padding: 4px 10px;
    }

    .cf-name {
        white-space: nowrap;
    }

    .cf-name.level-0 { padding-left: 14px; }
    .cf-name.level-1 { padding-left: 28px; }
    .cf-name.level-2 { padding-left: 42px; }
    .cf-name.level-3 { padding-left: 56px; }

    .cf-section-row td {
        background: #f2f3f7;
        font-weight: 700;
        text-transform: uppercase;
        font-size: .8rem;
    }

    .cf-total-row td {
        font-weight: 700;
        border-top: 1px solid #d0d2d7;
    }

    .cf-toggle-icon {
        display: inline-block;
        width: 14px;
        text-align: center;
        margin-right: 4px;
        font-size: .75rem;
    }
</style>

<div class="container-fluid cf-wrap">

    <!-- Filters row (Dates / From / To / Show Columns / Sort By) -->
    <form method="get" asp-action="CashFlowStatement" asp-controller="Reports" class="cf-toolbar mb-2">
        <div class="row g-2 align-items-end">
            <div class="col-auto d-flex align-items-center">
                <label class="me-1">Dates</label>
                <select asp-for="DateFilterMode" class="form-select form-select-sm">
                    <option value="Today">Today</option>
                    <option value="ThisMonth">This Month</option>
                    <option value="ThisYear">This Year</option>
                    <option value="Custom">Custom</option>
                </select>
            </div>

            <div class="col-auto">
                <label>From</label>
                <input asp-for="FromDate" type="date" class="form-control form-control-sm" />
            </div>

            <div class="col-auto">
                <label>To</label>
                <input asp-for="ToDate" type="date" class="form-control form-control-sm" />
            </div>

            <div class="col-auto">
                <label>Show_Columns</label>
                <select asp-for="ShowColumns" class="form-select form-select-sm">
                    <option value="All">All</option>
                    <option value="Active">Active Only</option>
                </select>
            </div>

            <div class="col-auto">
                <label>Sort By</label>
                <select asp-for="SortBy" class="form-select form-select-sm">
                    <option value="Name">Name</option>
                    <option value="Amount">Amount</option>
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">
                    Run Report
                </button>
            </div>
        </div>
    </form>

    <!-- Layout: left time/date, right report -->
    <div class="row">
        <div class="col-auto">
            <div class="cf-timebox">
                <div>@DateTime.Now.ToString("hh:mm tt", CultureInfo.InvariantCulture)</div>
                <div>@DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <div class="col d-flex justify-content-center">
            <div class="cf-report-card">

                <!-- Report header -->
                <div class="cf-report-header">
                    <h5>@(Model.CompanyName ?? "ARC MASTER CONTRCTING L.L.C.")</h5>
                    <p class="subtitle mb-0">Statement of Cash Flow</p>
                    <p class="subsubtitle">All Transaction</p>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table cf-table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 70%;">Account Name</th>
                                <th class="text-end" style="width: 30%;">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                        @* rows *@
                        @if (Model.Rows != null && Model.Rows.Any())
                        {
                            foreach (var row in Model.Rows)
                            {
                                 var rowClass = row.RowType switch
                                {
                                    CashFlowRowType.Section => "cf-section-row",
                                    CashFlowRowType.Total   => "cf-total-row",
                                    _                       => ""
                                }; 

                                <tr class="@rowClass">
                                    <td class="cf-name level-@row.Level">
                                        @if (row.RowType == CashFlowRowType.Section @* || row.IsGroup *@)
                                        {
                                            <span class="cf-toggle-icon">▶</span>
                                        }
                                        else
                                        {
                                            <span class="cf-toggle-icon">&nbsp;</span>
                                        }
                                            @row.Name
                                    </td>
                                    <td class="text-end">
                                            @if (row.Balance.HasValue)
                                        {
                                                @row.Balance.Value.ToString("N2")
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted py-3">
                                    No data for the selected period.
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>