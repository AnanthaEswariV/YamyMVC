@model IncomeByCustomerReportViewModel
@* @addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers *@

@{
    ViewData["Title"] = "Expense From Vendor Detail";
    }
<style>
    :root {
        --pad: 12px;
    }

    body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
        background: #f5f6f8;
        margin: 0;
    }

    .wrap {
        max-width: 980px;
        margin: 24px auto;
        padding: 0 var(--pad);
    }

    .filters {
        display: flex;
        gap: .75rem;
        align-items: center;
        margin: 8px 0 18px;
    }

        .filters label {
            font-weight: 600;
        }

        .filters input[type="date"] {
            padding: 6px 8px;
        }

        .filters button {
            padding: 8px 12px;
            border: 1px solid #d0d5dd;
            background: #fff;
            border-radius: 8px;
            cursor: pointer;
        }

    .card {
        background: #fff;
        padding: 8px 12px 16px;
        border-radius: 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,.05);
    }

    .report-header {
        text-align: center;
        margin: 6px 0 10px;
    }

        .report-header h3 {
            margin: 6px 0;
            font-weight: 700;
            letter-spacing: .2px;
        }

    .muted {
        color: #667085;
    }

    table.dataTable tbody td, table.dataTable thead th {
        padding: 8px 10px;
    }

    th.text-end, td.text-end {
        text-align: right;
    }

    .brand {
        font-size: 1.1rem;
    }
</style>

<div class="container-fluid py-3">
    @* 
    <!-- Top toolbar -->
    <div class="d-flex justify-content-end gap-2 mb-2">
        <button type="button" class="btn btn-sm btn-outline-secondary">Customize Report</button>
        <button type="button" class="btn btn-sm btn-outline-secondary">Comment On Report</button>
        <button type="button" class="btn btn-sm btn-outline-secondary">Memorize</button>
        <button type="button" class="btn btn-sm btn-outline-secondary">Print</button>
        <button type="button" class="btn btn-sm btn-outline-secondary">Excel</button>
    </div> *@

    <!-- Filters -->
    <form asp-action="IncomeByCustomerDetail" method="get" class="mb-3">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <label class="fw-semibold">From</label>
            <input asp-for="FromDate" type="date" class="form-control form-control-sm" style="max-width: 160px;" id="FromDate" />

            <label class="fw-semibold ms-2">To</label>
            <input asp-for="ToDate" type="date" class="form-control form-control-sm" style="max-width: 160px;" " id="ToDate" />

            <div class="form-check ms-3">
                <input asp-for="AllDates" class="form-check-input" type="checkbox" id="chkAllDates" />
                <label class="form-check-label" for="chkAllDates">All</label>
            </div>

            <button type="submit" class="btn btn-sm btn-primary ms-3">Apply</button>
        </div>
    </form>

    <!-- Report header -->
    <div class="text-center mb-3">
        <h5 class="mb-0 fw-bold">@Model.CompanyName</h5>
        <div class="fw-semibold">Expense From Vendor Detail</div>
        <div class="fw-semibold">All Transaction</div>

        @if (Model.FromDate.HasValue || Model.ToDate.HasValue)
            {
            <div class="small mt-1">
                @Model.FromDate?.ToString("dd/MM/yyyy") - @Model.ToDate?.ToString("dd/MM/yyyy")
            </div>
            }
    </div>

    <!-- Report table -->
    <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
        <table class="table table-bordered table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="display:none">Id</th>
                    <th style="width: 90px;">transaction id</th>
                    <th>Vendor</th>
                    <th>Type</th>
                    <th style="width: 110px;">Date</th>
                    <th style="width: 110px;">Num</th>
                    <th>Memo</th>
                    <th>Account</th>
                    <th class="text-end" style="width: 110px;">Debit</th>
                    <th class="text-end" style="width: 110px;">Credit</th>
                    <th class="text-end" style="width: 110px;">Balance</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Rows != null && Model.Rows.Any())
                    {
                    var balance = 0.0M;
                    foreach (var row in Model.Rows)
                        {
                        balance = balance + (decimal)(row.Debit - row.Credit);
                        <tr>
                            <td style="display:none">@row.Id</td>
                            <td>@row.TransactionId</td>
                            <td>@row.Customer</td>
                            <td>@row.Type</td>
                            <td>@row.Date</td>
                            <td>@row.Num</td>
                            <td>@row.Memo</td>
                            <td>@row.Account</td>
                            <td class="text-end">@row.Debit</td>
                            <td class="text-end">@row.Credit</td>
                            <td class="text-end">@balance</td>
                        </tr>
                        }
                    }
                else
                    {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-3">
                            No transactions found for the selected period.
                        </td>
                    </tr>
                    }
            </tbody>
        </table>
    </div>
</div>