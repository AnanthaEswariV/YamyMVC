@model IncomeSummaryViewModel
@{
    ViewData["Title"] = "Income By Customer ";
 }
    <style>
        :root {
            --pad: 12px;
        }
        body {
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
            background: #f5f6f8;
            margin: 0;
        }
        .wrap {
            max-width: 980px;
            margin: 24px auto;
            padding: 0 var(--pad);
        }
        .filters {
            display: flex;
            gap: .75rem;
            align-items: center;
            margin: 8px 0 18px;
        }
            .filters label {
                font-weight: 600;
            }
            .filters input[type="date"] {
                padding: 6px 8px;
            }
            .filters button {
                padding: 8px 12px;
                border: 1px solid #d0d5dd;
                background: #fff;
                border-radius: 8px;
                cursor: pointer;
            }
        .card {
            background: #fff;
            padding: 8px 12px 16px;
            border-radius: 12px;
            box-shadow: 0 1px 2px rgba(0,0,0,.05);
        }
        .report-header {
            text-align: center;
            margin: 6px 0 10px;
        }
            .report-header h3 {
                margin: 6px 0;
                font-weight: 700;
                letter-spacing: .2px;
            }
        .muted {
            color: #667085;
        }
        table.dataTable tbody td, table.dataTable thead th {
            padding: 8px 10px;
        }
        th.text-end, td.text-end {
            text-align: right;
        }
        .brand {
            font-size: 1.1rem;
        }
    </style>

    <div class="wrap">
        <form class="filters" onsubmit="event.preventDefault(); /* demo only */">
            <label for="from">From</label>
        <input id="from" asp-from="model.DateFrom" type="date"  disabled />
            <label for="to">To</label>
        <input id="to" asp-from="model.DateTo" type="date" disabled />
            <label style="margin-left:.5rem; display:flex; align-items:center; gap:.35rem;">
                <input id="all" type="checkbox" checked /> All
            </label>
        <button type="submit" id="filterBtn">Apply</button>
        </form>

        <div class="card">
            <div class="report-header">
                <div class="brand"><strong>ARC MASTER CONTRACTING</strong></div>
                <div style="font-weight:700;">Income By Customer</div>
                <div>All Transaction</div>
                <div class="muted" id="now"></div>
            </div>

            <table id="reportTable" class="display" style="width:100%">
                <thead>
                    <tr>
                        <th style="display:none">Id</th>
                        <th style="width:60px;">Sn</th>
                        <th>Name</th>
                        <th class="text-end">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    
                @if (Model.Customer !=null|| Model.Customer?.Any() == true)
                    {
                    var Sn = 0;

                    foreach (var d in Model.Customer!)
                        {
                        Sn++;
                        <tr data-id="@d.Id">
                            <td style="display:none">@d.Id</td>
                            <td>@Sn</td>
                            <td>@d.Name</td>
                            <td class="text-end">@d.Balance</td>
                        </tr>
                        }
                   
                    }                              
                </tbody>
            </table>
        </div>
    </div>
    @section Scripts {
     
    <script>
             $(document).ready(function () {

            // Load data on page load
            //loadBankBalanceSummary();

            // Checkbox toggle (Enable/Disable date filters)
            $('#all').change(function () {
                const isChecked = $(this).is(':checked');
                $('#from, #to').prop('disabled', isChecked);
            //loadBankBalanceSummary();
            });

            // Filter button click
            $('#filterBtn').click(function () {
                // loadBankBalanceSummary();
            });
        });

        $(function () {
            $('#reportTable').DataTable({
                pageLength: 20,
                lengthChange: false,
                ordering: false
            });

            // Disable From/To when All is checked
            function toggleDates() {
                const all = $('#all').is(':checked');
                $('#from,#to').prop('disabled', all);
            }
            $('#all').on('change', toggleDates);
            toggleDates();

            // Time stamp (optional)
            const d = new Date();
            const pad = n => n.toString().padStart(2, '0');
            const dd = pad(d.getDate());
            const mm = pad(d.getMonth() + 1);
            const yyyy = d.getFullYear();
            let hh = d.getHours();
            const ampm = hh >= 12 ? 'PM' : 'AM';
            hh = hh % 12; hh = hh || 12;
            const min = pad(d.getMinutes());

            const now = document.getElementById('now');
            if (now) {
                now.textContent = `${dd}/${mm}/${yyyy}  ${hh}:${min} ${ampm}`;
            }
        });
    </script>
    <script>
        $(document).ready(function () {

                   $('#reportTable tbody').on('dblclick', 'tr', function () {
            const id = $(this).data('id');
            if (!id) return;

            const url = '@Url.Action("IncomeByCustomerDetail", "IncomeSummary")' + '?id=' + id;
            window.location.href = url;
        });
        });
    </script>

}