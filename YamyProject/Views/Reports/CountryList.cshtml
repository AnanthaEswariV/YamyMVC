
@{
    ViewData["Title"] = "CountryList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<div class="card">
    <div class="card-header text-center">
        <strong>Country List</strong>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="btnAddCountry">
                <i class="bi bi-plus-circle me-2"></i>Add Country
            </button>

        </div>
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Country</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>


<div class="modal fade" id="countryModal" tabindex="-1" aria-labelledby="countryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="countryModalLabel">Add Country</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="countryForm">
                    <input type="hidden" id="countryId" />

                    <div class="mb-3">
                        <label class="form-label">Country Name</label>
                        <input type="text" id="txtCountry" class="form-control" placeholder="Enter Country Name" required />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSaveCountry">Save</button>
            </div>

        </div>
    </div>
</div>



@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>


    <script>

        $(document).ready(function () {

            loadCountries();

            function loadCountries() {
            $.ajax({
             url: '@Url.Action("GetCountrys", "Reports")',
                type: 'GET',
                beforeSend: function () {
                    $('#table2 tbody').html(`
                        <tr>
                            <td colspan="2" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load country list');
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tbody = $('#table2 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                                $.each(res.data, function (i, row) {
            const tr = $(`
                <tr data-id="${row.id}">
                    <td>${row.sn}</td>
                    <td>${row.name}</td>
                    <td>
                        <button class="btn btn-sm btn-primary editCountryBtn" data-country='${JSON.stringify(row)}'>
                            <i class="fas fa-pen"></i>
                        </button>
                    </td>
                </tr>
            `);
            tbody.append(tr);
        });


                        // Initialize DataTable
                        $('#table2').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });
                    } else {
                        tbody.append(`<tr><td colspan="2" class="text-center text-muted py-4">No countries found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading country list');
                }
            });
        }

           $('#btnSaveCountry').click(function () {
            const name = $('#txtCountry').val().trim();
            const id = parseInt($('#countryId').val()) || 0;

            if (name === "") {
                toastr.error("Please enter country name");
                return;
            }

            const countryData = { Id: id, Name: name };

            $.ajax({
                url: '@Url.Action("SaveCountry", "Reports")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(countryData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(id > 0 ? 'Country updated successfully' : 'Country added successfully');
                        $('#countryModal').modal('hide');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });


             $(document).on('click', '.editCountryBtn', function () {
            const country = $(this).data('country');
            if (!country) return;

            $('#countryId').val(country.id ?? 0);
            $('#txtCountry').val(country.name ?? '');
            $('#countryModalLabel').text('Edit Country');

            $('#countryModal').modal('show');
        });


           $(document).on('click', '#btnAddCountry', function () {
            $('#countryId').val(0);
            $('#txtCountry').val('');
            $('#countryModalLabel').text('Add Country');
            $('#countryModal').modal('show');
        });





        });




    </script>

    }