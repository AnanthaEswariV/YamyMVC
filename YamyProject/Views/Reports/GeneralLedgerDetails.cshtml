
@{
    ViewData["Title"] = "GeneralLedgerDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>General Ledger Details</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Num</th>
                    <th>Description</th>
                    <th>Credit</th>
                    <th>Debit</th>
                    <th>Balance</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>




    <script>
        // Helper to get URL query parameter
        function getQueryParam(param) {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get(param);
        }

        // Load General Ledger Details
        function loadGeneralLedgerDetails() {
            const id = getQueryParam('id');
            if (!id) {
                toastr.error('Account ID missing');
                return;
            }

            const includeAllDates = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            if (!includeAllDates && (!startDate || !endDate)) {
                toastr.warning('Please select both start and end dates.');
                return;
            }

            $.ajax({
            url: '@Url.Action("GetGeneralLedger", "Reports")',
                type: 'GET',
                data: {
                    id,
                    fromDate: startDate || null,
                    toDate: endDate || null,
                    includeAllDates
                },
                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res || !res.data || res.data.length === 0) {
                        toastr.warning('No data found for this account.');
                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().clear().destroy();
                        }
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    let serial = 1;
                    const tableData = res.data.map(tx => [
                        serial++,
                        tx.type || '',
                        tx.date || '',
                        tx.num || '',
                        tx.description || '',
                        (parseFloat(tx.credit) || 0).toLocaleString(),
                        (parseFloat(tx.debit) || 0).toLocaleString(),
                        (parseFloat(tx.balance) || 0).toLocaleString()
                    ]);

                    $('#table1').DataTable({
                        dom: 'Bfrtip',
                        data: tableData,
                        columns: [
                            { title: "S.No" },
                            { title: "Type" },
                            { title: "Date" },
                            { title: "Num" },
                            { title: "Description" },
                            { title: "Credit", className: "text-end" },
                            { title: "Debit", className: "text-end" },
                            { title: "Balance", className: "text-end" }
                        ],
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                className: 'btn btn-primary btn-sm'
                            },
                            {
                                extend: 'pdfHtml5',
                                text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                className: 'btn btn-primary btn-sm',
                                orientation: 'landscape',
                                pageSize: 'A4'
                            }
                        ],
                        ordering: false,
                        paging: true,
                        pageLength: 15,
                        createdRow: function (row, data) {
                            if ((data[4] || '').toLowerCase().includes('total')) {
                                $(row).addClass('table-info fw-bold');
                            }
                        }
                    });
                },
                error: function () {
                    toastr.error('Error loading ledger details.');
                }
            });
        }

        $(document).ready(function () {
            // Initialize date inputs to today
            const today = new Date().toISOString().split('T')[0];
            $('#startDate, #endDate').val(today);

            // Initial load
            loadGeneralLedgerDetails();

            // Toggle date inputs when checkbox changes
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
                loadGeneralLedgerDetails();
            });

            // Filter button click
            $('#filterBtn').click(loadGeneralLedgerDetails);
        });
    </script>


}