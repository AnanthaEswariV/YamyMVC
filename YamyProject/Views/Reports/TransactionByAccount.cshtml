
@{
    ViewData["Title"] = "TransactionByAccount";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Transaction By Account</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="table3">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Balance</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

        @section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // ✅ Get accountId from query string
            const urlParams = new URLSearchParams(window.location.search);
            const accountId = urlParams.get('accountId');

            if (!accountId) {
                toastr.warning('No account selected.');
                return;
            }

            // Load data on page load
            loadTransactionByAccount(accountId);

            // Checkbox toggle
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
                loadTransactionByAccount(accountId);
            });

            // Filter button click
            $('#filterBtn').click(function () {
                loadTransactionByAccount(accountId);
            });

      

                 $('#table3 tbody').on('click', 'tr', function () {
            const transactionId = $(this).data('transaction-id');
            const type = $(this).data('type'); // selectionMethod
            let transactionDate = $(this).data('date');

            if (!transactionId) {
                toastr.warning('No transaction ID found for this record.');
                return;
            }

            if (transactionDate) {
                const d = new Date(transactionDate);
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2,'0');
                const dd = String(d.getDate()).padStart(2,'0');
                transactionDate = `${yyyy}-${mm}-${dd}`;
            }

            // Build query string
            const query = new URLSearchParams({
                transactionId: transactionId,
                selectionMethod: type || 'Default',
                filterByDate: true,
                fromDate: transactionDate,
                toDate: transactionDate
            }).toString();
            console.log(query);
            // Navigate to TransactionJournal
            window.location.href = `/Lists/TransacationJournal?${query}`;
        });
         




        });

        function loadTransactionByAccount(accountId) {
            const includeAllDates = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            $.ajax({
                url: '/Reports/GetMasterTransactionByAccount',
                type: 'GET',
                data: {
                    accountId: accountId,
                    startDate: startDate || null,
                    endDate: endDate || null,
                    includeAllDates: includeAllDates
                },
               
                beforeSend: function () {
                    $('#table3 tbody').html(`
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load transaction details');
                        return;
                    }
                    if ($.fn.DataTable.isDataTable('#table3')) {
                        $('#table3').DataTable().clear().destroy();
                    }
                  
                    const tbody = $('#table3 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            const tr = `
                               <tr data-transaction-id="${row.transaction_id}" data-date="${row.date}">
                                    <td>${i + 1}</td>
                                    <td>${row.date ? new Date(row.date).toISOString().split('T')[0] : ''}</td>
                                    <td>${row.type ?? ''}</td>
                                    <td>${row.description ?? ''}</td>
                                    <td class="text-end">${(row.debit ?? 0).toLocaleString()}</td>
                                    <td class="text-end">${(row.credit ?? 0).toLocaleString()}</td>
                                    <td class="text-end">${(row.Amount ?? 0).toLocaleString()}</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        $('#table3').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });
                    } else {
                        tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No transactions found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading transaction data');
                }
            });
        }
    </script>

}