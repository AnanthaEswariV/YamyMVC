
@{
    ViewData["Title"] = "ChequeReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Cheque Report</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
            <!-- Report Type -->
            <div style="min-width: 250px;">
                <select class="form-select" id="checkNo">
                    <option value="">-- Select CheckNo --</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>V No</th>
                    <th>Type</th>
                    <th>Account Name</th>
                    <th>Amount</th>
                    <th>Bank Name</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
             $(document).ready(function () {
            loadChequeNumbers();

            $('#checkNo').on('change', function () {
                const chequeNo = $(this).val();
                // pass null / empty string when no selection
                loadChequeReport(chequeNo);
            });

            // Optionally call it initially with no chequeNo to show all
            loadChequeReport();
        });

        function loadChequeNumbers() {
            $.ajax({
                url: '/Reports/GetChequeNumbers',
                method: 'GET',
                dataType: 'json',
                success: function(result) {
                    const dropdown = $('#checkNo');
                    dropdown.empty().append('<option value="">-- Select CheckNo --</option>');
                    if (result.status && result.data.length) {
                        result.data.forEach(function(item) {
                            dropdown.append(`<option value="${item.checkNo}">${item.checkNo}</option>`);
                        });
                    } else {
                        toastr.warning(result.message || "No cheque numbers found");
                    }
                },
                error: function() {
                    toastr.error("Failed to load cheque numbers");
                }
            });
        }

        function loadChequeReport(chequeNo) {
            const url = '/Reports/GetChequeDetails' + (chequeNo ? `?chequeNo=${chequeNo}` : '');

            $.ajax({
                url: url,
                type: 'GET',
                dataType: 'json',
                beforeSend: function () {
                    $('#table2 tbody').html(`
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load cheque report');
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tbody = $('#table2 tbody').empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function(i, row) {
                            const tr = $(`
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${row.date}</td>
                                    <td>${row.id}</td>
                                    <td>${row.type}</td>
                                    <td>${row.accountName}</td>
                                   <td>${row.amount}</td>
                                    <td>${row.bankName}</td>
                                </tr>
                            `);
                            tbody.append(tr);
                        });

                        $('#table2').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });
                    } else {
                        tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading cheque report');
                }
            });
        }


</script>
}