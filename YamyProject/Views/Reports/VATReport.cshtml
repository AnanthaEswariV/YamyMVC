
@{
    ViewData["Title"] = "VATReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>VAT Report</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
            <!-- Report Type -->
            <div style="min-width: 250px;">
                <select class="form-select" id="reportType">
                    <option value="">-- Select Type --</option>
                    <option value="Vat Input" selected>VAT Input</option>
                    <option value="Vat Output">VATOutput</option>
                </select>
            </div>

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>INV No</th>
                    <th>Name</th>
                    <th>Payment Method</th>
                    <th>Amount Before VAT</th>
                    <th>VAT Amount</th>
                    <th>Total Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
        function loadVatReport() {
            const type = $('#reportType').val();
            const includeAllDates = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            if (!type) {
                toastr.warning('Please select a report type.');
                return;
            }

            if (!includeAllDates && (!startDate || !endDate)) {
                toastr.warning('Please select both start and end dates.');
                return;
            }

            $.ajax({
               url: '@Url.Action("GetVatReport", "Reports")',
                type: 'GET',
                data: {
                    type: type,
                    fromDate: startDate || null,
                    toDate: endDate || null,
                    includeAllDates: includeAllDates
                },
                success: function (res) {
                    if (!res || !res.data || res.data.length === 0) {
                        toastr.warning('No data found for this selection.');
                        if ($.fn.DataTable.isDataTable('#table2')) {
                            $('#table2').DataTable().clear().destroy();
                        }
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    let serial = 1;
                    const tableData = res.data.map(row => [
                        serial++,
                        row.type || '',
                        row.date || '',
                        row.invNo || '',
                        row.name || '',
                        row.paymentMethod || '',
                        (parseFloat(row.amountBeforeVat) || 0).toLocaleString(),
                        (parseFloat(row.vatAmount) || 0).toLocaleString(),
                        (parseFloat(row.totalAmount) || 0).toLocaleString()
                    ]);

                    $('#table2').DataTable({
                        dom: 'Bfrtip',
                        data: tableData,
                        columns: [
                            { title: "S.No" },
                            { title: "Type" },
                            { title: "Date" },
                            { title: "INV No" },
                            { title: "Name" },
                            { title: "Payment Method" },
                            { title: "Amount Before VAT", className: "text-end" },
                            { title: "VAT Amount", className: "text-end" },
                            { title: "Total Amount", className: "text-end" }
                        ],
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                className: 'btn btn-primary btn-sm'
                            },
                            {
                              extend: 'print',
                              text: '<i class="fas fa-print me-1"></i> Print',
                              className: 'btn btn-primary btn-sm',
                            }
                        ],
                        ordering: false,
                        paging: true,
                        pageLength: 15
                    });
                },
                error: function () {
                    toastr.error('Error loading VAT report.');
                }
            });
        }

        $(document).ready(function () {
            // Initialize date inputs to today
            const today = new Date().toISOString().split('T')[0];
            $('#startDate, #endDate').val(today);

            // Initial load
            loadVatReport();

            // Bind events
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
            });
              // Filter + ReportType change triggers
            $('#filterBtn').on('click', loadVatReport);
            $('#reportType').on('change', loadVatReport);
            
        });
    </script>


}

