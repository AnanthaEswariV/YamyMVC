@{
    ViewData["Title"] = "General Ledger";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>General Ledger</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
            <!-- Report Type -->
            <div style="min-width: 250px;">
                <select class="form-select" id="reportType">
                    <option value="">-- Select Report Type --</option>
                    <option value="Default" selected>Default</option>
                    <option value="Simple">Simple</option>
                </select>
            </div>

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Num</th>
                    <th>Description</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Balance</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {

            loadGeneralLedger();

            // Toggle date inputs
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
            });

            // Filter + ReportType change triggers
            $('#filterBtn').on('click', loadGeneralLedger);
            $('#reportType').on('change', loadGeneralLedger);

                    function loadGeneralLedger() {
            const reportType = $('#reportType').val();
            const includeAllDates = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            if (!includeAllDates && (!startDate || !endDate)) {
                toastr.warning('Please select both start and end dates.');
                return;
            }

            $.ajax({
                url: '@Url.Action("GetSalesReport", "Reports")',
                type: 'GET',
                data: { reportType, startDate: startDate || null, endDate: endDate || null },
                beforeSend: function () {
                    $('#table2 tbody').html(`
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res || !res.data) {
                        toastr.error('Invalid response from server');
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tableData = [];
                    let serial = 1;

                    res.data.forEach(account => {
                        // Account header row
                        tableData.push({
                            data: ['', `<strong>${account.name}</strong>`, '', '', '', '', '', ''],
                            rowType: 'account'
                        });

                        // Transaction rows
                        account.transactions.forEach(tx => {
                            tableData.push({
                                data: [
                                    serial++,
                                    tx.type || '',
                                    tx.date || '',
                                    tx.num || '',
                                    tx.description || '',
                                    (tx.debit || 0).toLocaleString(),
                                    (tx.credit || 0).toLocaleString(),
                                    (tx.balance || 0).toLocaleString()
                                ],
                                rowType: 'transaction',
                                transactionId: tx.num // ✅ attach transaction ID here
                            });
                        });

                        // Account total row
                        tableData.push({
                            data: [
                                '',
                                '<strong>TOTAL</strong>',
                                '', '', '',
                                `<strong>${(account.totalDebit || 0).toLocaleString()}</strong>`,
                                `<strong>${(account.totalCredit || 0).toLocaleString()}</strong>`,
                                `<strong>${(account.balance || 0).toLocaleString()}</strong>`
                            ],
                            rowType: 'total'
                        });
                    });

                    // Initialize DataTable
                    $('#table2').DataTable({
                        dom: 'Bfrtip',
                        data: tableData.map(r => r.data),
                        columns: [
                            { title: "S.No" },
                            { title: "Type / Account" },
                            { title: "Date" },
                            { title: "Num" },
                            { title: "Description" },
                            { title: "Debit", className: "text-end" },
                            { title: "Credit", className: "text-end" },
                            { title: "Balance", className: "text-end" }
                        ],
                        createdRow: function (row, data, idx) {
                            const rowInfo = tableData[idx];

                            // Only transaction rows get transactionId
                            if (rowInfo.rowType === 'transaction') {
                                $(row).attr('data-id', rowInfo.transactionId);
                                $(row).addClass('table-light'); // optional styling
                            }

                            if ($(data[1]).text().toLowerCase().includes('total')) {
                                $(row).addClass('table-info fw-bold');
                            } else if (rowInfo.rowType === 'account') {
                                $(row).addClass('table-secondary fw-bold');
                            }
                        },
                        buttons: [
                            { extend: 'excelHtml5', className: 'btn btn-primary btn-sm', text: 'Excel' },
                            { extend: 'pdfHtml5', className: 'btn btn-primary btn-sm', text: 'PDF', orientation: 'landscape', pageSize: 'A4' }
                        ],
                        ordering: false,
                        paging: true,
                        pageLength: 15
                    });

                    // Double click: only transaction rows
                    $('#table2 tbody').off('dblclick').on('dblclick', 'tr', function () {
                        const transactionId = $(this).attr('data-id');
                        if (transactionId) {
                            window.location.href = `/Reports/GeneralLedgerDetails?id=${transactionId}`;
                        }
                    });
                },
                error: function () {
                    toastr.error('Error loading general ledger data');
                }
            });
        }




        });
    </script>

}
