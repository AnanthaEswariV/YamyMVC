
@{
    ViewData["Title"] = "CostCenterSummary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Cost Center Summary</strong>
    </div>

    <div class="card-body">
     @*    <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
            <!-- Report Type -->
            <div style="min-width: 250px;">
                <select class="form-select" id="name">
                    <option value="">-- Select Name --</option>
                </select>
            </div>

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div> *@

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Description</th>
                    <th>Voucher No</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Balance</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>


                function loadCostCenterSummary() {
            const costCenterId = $('#name').val();
            const includeAllDates = $('#chkAllData').is(':checked');
            const fromDate = $('#startDate').val();
            const toDate = $('#endDate').val();

            // // Validate dates only if not including all data
            // if (!includeAllDates && (!fromDate || !toDate)) {
            //     toastr.warning('Please select both start and end dates.');
            //     return;
            // }

            // Properly destroy DataTable first
            if ($.fn.DataTable.isDataTable('#table2')) {
                const table = $('#table2').DataTable();
                table.clear();
                table.destroy(true); // true removes all events and data
            }

            // Reset table to original state
            $('#table2').empty().html(`
                <thead>
                    <tr>
                        <th>S.No</th>
                        <th>Description</th>
                        <th>Voucher No</th>
                        <th>Debit</th>
                        <th>Credit</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <div class="spinner-border text-primary me-2"></div>Loading...
                        </td>
                    </tr>
                </tbody>
            `);

            // Remove previous summary
            $('#summaryRow').remove();

                    $.ajax({
            url: '@Url.Action("GetCostCenterReport", "Reports")',
            type: 'GET',
            data: {
                costCenterId: costCenterId || null,
                fromDate: includeAllDates ? null : fromDate,
                toDate: includeAllDates ? null : toDate,
                includeAllDates
            },
            success: function (res) {
                // Remove old summary
                $('#summaryRow').remove();

                // Destroy old DataTable
                if ($.fn.DataTable.isDataTable('#table2')) {
                    $('#table2').DataTable().clear().destroy(true);
                }

                // Clear tbody
                $('#table2 tbody').empty();

                if (!res || !res.data || res.data.length === 0) {
                    // Always show table, but with "No data available"
                    $('#table2 tbody').html('<tr><td colspan="6" class="text-center text-muted py-4">No data available</td></tr>');
                    toastr.warning('No data found.');
                    return;
                }

                // Prepare data
                let serial = 1;
                const tableData = res.data.map(item => [
                    serial++,
                    item.name || '',
                    item.voucherNo || '',
                    parseFloat(String(item.debit || '0').replace(/,/g, '')) || 0,
                    parseFloat(String(item.credit || '0').replace(/,/g, '')) || 0,
                    parseFloat(String(item.balance || '0').replace(/,/g, '')) || 0,
                    item.id || ''
                ]);

                // Initialize DataTable
                const table = $('#table2').DataTable({
                    dom: 'Bfrtip',
                    data: tableData,
                    columns: [
                        { title: "S.No", width: "60px" },
                        { title: "Description" },
                        { title: "Voucher No", width: "120px" },
                        {
                            title: "Debit",
                            className: "text-end",
                            render: $.fn.dataTable.render.number(',', '.', 2)
                        },
                        {
                            title: "Credit",
                            className: "text-end",
                            render: $.fn.dataTable.render.number(',', '.', 2)
                        },
                        {
                            title: "Balance",
                            className: "text-end",
                            render: $.fn.dataTable.render.number(',', '.', 2)
                        },
                        { title: "Id", visible: false }
                    ],
                    buttons: [
                        { extend: 'excelHtml5', text: '<i class="fas fa-file-excel me-1"></i> Excel', className: 'btn btn-primary btn-sm', exportOptions: { columns: [0,1,2,3,4,5] } },
                        { extend: 'print', text: '<i class="fas fa-print me-1"></i> Print', className: 'btn btn-primary btn-sm',  exportOptions:  { columns: [0,1,2,3,4,5] } }
                    ],
                    ordering: false,
                    paging: true,
                    pageLength: 15,
                    searching: true,
                    info: true,
                    autoWidth: false
                });

                // Row click
                $('#table2').off('click', 'tbody tr').on('click', 'tbody tr', function () {
                    if (!$(this).hasClass('dataTables_empty')) {
                        const rowData = table.row(this).data();
                        if (rowData && rowData[6]) {
                            window.location.href = `/Reports/CostCenterDetails?id=${rowData[6]}`;
                        }
                    }
                });

                // Show total balance
                const summaryHtml = `<div id="summaryRow" class="mt-3 text-end"><strong>Total Balance:</strong> ${res.totalBalance || '0.00'}</div>`;
                $('#table2').closest('.card-body').append(summaryHtml);

                // toastr.success('Data loaded successfully.');
            },
            error: function (xhr, status, error) {
                toastr.error(xhr.responseJSON?.message || 'Error loading Cost Center Summary.');
                // Show table with error row
                $('#table2 tbody').html('<tr><td colspan="6" class="text-center text-muted py-4">Failed to load data</td></tr>');
            }
        });

        }

        $(document).ready(function () {
            const today = new Date().toISOString().split('T')[0];
            $("#startDate, #endDate").val(today);

            // Enable/disable date fields
            $('#chkAllData').change(function () {
                const disabled = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', disabled);
            });

            // Load cost centers into dropdown
            loadCostCenters();

            // Filter button click
            $('#filterBtn').click(function () {
                loadCostCenterSummary();
            });

            // Load all data by default on page load
            loadCostCenterSummary();

                   function loadCostCenters() {
            $.ajax({
               url: '@Url.Action("GetCostCenters", "Lists")',
                type: 'GET',
                success: function (res) {
                    // res is directly an array
                    if (Array.isArray(res) && res.length > 0) {
                        let options = '<option value="">-- Select Name --</option>';
                        res.forEach(item => {
                            options += `<option value="${item.id}">${item.name}</option>`;
                        });
                        $('#name').html(options);
                    }
                },
                error: function () {
                    toastr.error('Failed to load cost center list.');
                }
            });
        }

        });
    </script>





}


