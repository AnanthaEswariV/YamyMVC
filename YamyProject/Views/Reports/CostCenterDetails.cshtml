```
<div class="card-body">
    <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
        <!-- Checkbox -->
        <div class="d-flex align-items-center gap-2">
            <input type="checkbox" id="chkAllData" class="form-check-input" checked>
            <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
        </div>

        <!-- Start Date -->
        <div style="min-width: 200px;">
            <h6 class="fw-bold mb-1">Start Date</h6>
            <input type="date" class="form-control" id="startDate" disabled>
        </div>

        <!-- End Date -->
        <div style="min-width: 200px;">
            <h6 class="fw-bold mb-1">End Date</h6>
            <input type="date" class="form-control" id="endDate" disabled>
        </div>

        <!-- Filter Button -->
        <div style="min-width: 150px;">
            <button class="btn btn-primary" id="filterBtn">Filter</button>
        </div>
    </div>

    <!-- Table -->
    <table class="table table-striped" id="table3">
        <thead>
            <tr>
                <th>S.No</th>
                <th>Date</th>
                <th>Description</th>
                <th>Voucher No</th>
                <th>Debit</th>
                <th>Credit</th>
                <th>Balance</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>


</div>

@section Scripts { <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css"> <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    $(document).ready(function () {
        const urlParams = new URLSearchParams(window.location.search);
        const costCenterId = urlParams.get('id');

        if (!costCenterId) {
            toastr.warning('No cost center selected.');
            return;
        }

        const today = new Date().toISOString().split('T')[0];
        $('#startDate, #endDate').val(today);

        loadTransactions(costCenterId);

        $('#chkAllData').change(function () {
            const isChecked = $(this).is(':checked');
            $('#startDate, #endDate').prop('disabled', isChecked);
        });

        $('#filterBtn').click(function () {
            loadTransactions(costCenterId);
        });

        function loadTransactions(id) {
            const includeAllDates = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            if (!includeAllDates && (!startDate || !endDate)) {
                toastr.warning('Please select both start and end dates.');
                return;
            }

            $.ajax({
                url: '/Reports/GetCostCenterTransactions',
                type: 'GET',
                data: {
                    costCenterId: id,
                    fromDate: includeAllDates ? null : startDate,
                    toDate: includeAllDates ? null : endDate,
                    includeAllDates: includeAllDates
                },
                beforeSend: function () {
                    $('#table3 tbody').html(`
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res || !res.data || res.data.length === 0) {
                        toastr.warning('No transactions found.');
                        if ($.fn.DataTable.isDataTable('#table3')) {
                            $('#table3').DataTable().clear().destroy();
                        }
                        $('#table3 tbody').html(`<tr><td colspan="7" class="text-center text-muted py-4">No transactions found</td></tr>`);
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table3')) {
                        $('#table3').DataTable().clear().destroy();
                    }

                    const tableData = res.data.map((row, i) => [
                        i + 1,
                        row.date || '',
                        row.description || '',
                        row.voucherNo || '',
                        row.debit || '0.00',
                        row.credit || '0.00',
                        row.balance || '0.00',
                       
                    ]);

                    const table = $('#table3').DataTable({
                        dom: 'Bfrtip',
                        data: tableData,
                        columns: [
                            { title: "S.No" },
                            { title: "Date" },
                            { title: "Description" },
                            { title: "Voucher No" },
                            { title: "Debit", className: "text-end" },
                            { title: "Credit", className: "text-end" },
                            { title: "Balance", className: "text-end" },
                            
                        ],
                        buttons: [
                            { extend: 'excelHtml5', text: '<i class="fas fa-file-excel me-1"></i> Excel', className: 'btn btn-primary btn-sm' },
                            { extend: 'pdfHtml5', text: '<i class="fas fa-file-pdf me-1"></i> PDF', className: 'btn btn-primary btn-sm', orientation: 'landscape', pageSize: 'A4' }
                        ],
                        ordering: false,
                        pageLength: 15
                    });

                    // Row click: redirect to TransactionJournal
                    $('#table3 tbody').off('click').on('click', 'tr', function () {
                        const rowData = table.row(this).data();
                        if (!rowData) return;

                        const transactionId = rowData[7];
                        const transactionDate = rowData[1]; // Date
                        const type = rowData[2]; // Description/Type

                        if (!transactionId) {
                            toastr.warning('No transaction ID found.');
                            return;
                        }

                        const query = new URLSearchParams({
                            transactionId: transactionId,
                            selectionMethod: type || 'Default',
                            filterByDate: true,
                            fromDate: transactionDate,
                            toDate: transactionDate
                        }).toString();

                        window.location.href = `/Lists/TransacationJournal?${query}`;
                    });
                },
                error: function () {
                    toastr.error('Error loading transactions.');
                }
            });
        }
    });
</script>
}