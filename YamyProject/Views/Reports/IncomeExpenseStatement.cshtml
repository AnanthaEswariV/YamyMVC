
@{
    ViewData["Title"] = "IncomeExpenseStatement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Income By Expenses Statement</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Account Name</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        $(document).ready(function () {

            // Default dates
            const today = new Date().toISOString().slice(0, 10);
            $('#startDate').val(new Date(new Date().setMonth(new Date().getMonth() - 1)).toISOString().slice(0, 10));
            $('#endDate').val(today);

            // Toggle date inputs
            $('#chkAllData').on('change', function () {
                const disabled = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', disabled);
            });

            // Load initially
            loadIncomeStatement();

            // Filter click
            $('#filterBtn').on('click', loadIncomeStatement);

            function loadIncomeStatement() {

                const showAll = $('#chkAllData').is(':checked');
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();

                if (!showAll && (!startDate || !endDate)) {
                    toastr.warning("Please select both start and end dates.");
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetIncomeStatement", "Reports")',
                    type: 'GET',
                    data: { startDate, endDate },
                    beforeSend: function () {
                        $('#table1 tbody').html(`
                            <tr>
                                <td colspan="3" class="text-center py-4">
                                    <div class="spinner-border text-primary me-2"></div> Loading...
                                </td>
                            </tr>
                        `);
                    },
                    success: function (res) {

                        const tbody = $('#table1 tbody');
                        tbody.empty();

                        if (!res.status || !res.data || res.data.length === 0) {
                            tbody.html('<tr><td colspan="3" class="text-center text-muted">No records found</td></tr>');
                            return;
                        }

                        let sn = 1;

                        res.data.forEach(row => {

                            const indent = '&nbsp;'.repeat((row.level - 1) * 6);

                            const isBold =
                                row.level === 1 ||
                                row.name.toUpperCase().startsWith("TOTAL") ||
                                row.name.toUpperCase().includes("GROSS PROFIT") ||
                                row.name.toUpperCase().includes("NET INCOME");

                            tbody.append(`
                                <tr class="${isBold ? 'fw-bold' : ''}">
                                    <td>${sn++}</td>
                                    <td>${indent}${row.name}</td>
                                    <td class="text-end">${row.amount ?? ''}</td>
                                </tr>
                            `);
                        });

                        // Reinitialize DataTable
                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().destroy();
                        }

                        $('#table1').DataTable({
                            paging: true,
                            pageLength: 25,
                            ordering: false,
                            searching: false,
                            info: false,
                            dom: 'Bfrtip',
                            buttons: [
                                { extend: 'excelHtml5', className: 'btn btn-primary btn-sm' },
                                { extend: 'pdfHtml5', className: 'btn btn-primary btn-sm', orientation: 'portrait' }
                            ]
                        });
                    },
                    error: function () {
                        toastr.error('Error loading Income Statement.');
                    }
                });
            }

            // Optional: row click → journal
            $('#table1 tbody').on('click', 'tr', function () {
                const accountName = $(this).find('td:nth-child(2)').text().trim();
                if (!accountName) return;

                window.location.href = `/Lists/TransacationJournal?type=${encodeURIComponent(accountName)}`;
            });
        });
    </script>

   }