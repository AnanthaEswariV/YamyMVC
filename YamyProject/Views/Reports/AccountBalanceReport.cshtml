@{
    ViewData["Title"] = "Balance Sheet Summary";
  //  Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ================== CSS LINKS ================== -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }
    .dt-buttons .btn-primary:hover {
        background-color: #3b51a0 !important;
    }
    .child-row {
        display: none;
    }
    .toggle-icon {
        cursor: pointer;
        user-select: none;
        font-weight: bold;
    }
</style>

<!-- ================== PAGE CONTENT ================== -->
<div class="card">
    <div class="card-header text-center">
        <strong>Balance Sheet Summary</strong>
    </div>
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-3">
                <label for="reportDate" class="form-label">Select Date</label>
                <input type="date" id="reportDate" class="form-control" />
            </div>
            <div class="col-md-3 align-self-end">
                <button class="btn btn-primary" id="btnLoadReport">Load Report</button>
            </div>
        </div>

        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th style="width:60px;">S.No</th>
                    <th>Account Name</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
                      $(document).ready(function () {
            const today = new Date().toISOString().split('T')[0];
            $('#reportDate').val(today);
            loadBalanceSheetReport();

            $('#btnLoadReport').on('click', loadBalanceSheetReport);

            // Use event delegation on table body for better DataTables compatibility
            $('#table1').on('click', '.toggle-icon', function (e) {
                e.preventDefault();
                e.stopPropagation();

                const tr = $(this).closest('tr');
                const rowId = tr.attr('data-row-id');
                const icon = $(this).text().trim();

               

                if (icon === '►') {
                    // Expand
                    $(this).text('▼');
                    expandChildren(rowId);
                } else if (icon === '▼') {
                    // Collapse
                    $(this).text('►');
                    collapseChildren(rowId, new Set());
                }
            });

            // Collapse children with recursion guard
            function collapseChildren(rowId, seen) {
                if (seen.has(rowId)) return;
                seen.add(rowId);

                const children = $(`#table1 tbody tr[data-parent-row='${rowId}']`);
               

                children.each(function () {
                    const childRowId = $(this).attr('data-row-id');

                    // Hide this row
                    $(this).hide();

                    // Reset icon if it has children
                    $(this).find('.toggle-icon').text('►');

                    // Recursively collapse children
                    collapseChildren(childRowId, seen);
                });
            }

            // Expand direct children only
            function expandChildren(rowId) {
                const children = $(`#table1 tbody tr[data-parent-row='${rowId}']`);
           
                children.each(function () {
                    $(this).show();
                });
            }

                   function loadBalanceSheetReport() {
            const reportDate = $('#reportDate').val();
            if (!reportDate) {
                toastr.warning('Please select a date.');
                return;
            }

            $.ajax({
                url: '@Url.Action("GetBalanceSheetReport", "Reports")',
                type: 'GET',
                data: { date: reportDate },
                beforeSend: function () {
                    $('#table1 tbody').html('<tr><td colspan="3" class="text-center py-4"><div class="spinner-border text-primary me-2"></div>Loading...</td></tr>');
                },
                success: function (res) {
                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="3" class="text-center py-4 text-muted">No records found.</td></tr>');
                        return;
                    }

                    // Check if ALL top-level balances are zero = no transactions for this date
                    const hasAnyData = res.data.some(acc => acc.balance !== 0);
                    if (!hasAnyData) {
                        tbody.html('<tr><td colspan="3" class="text-center py-4 text-muted">No transactions found for the selected date.</td></tr>');
                        return;
                    }

                    let rowIndex = 0;
                    let uniqueRowCounter = 0;

                    function renderRows(accounts, level = 1, parentRowId = null, ancestorPath = []) {
                        accounts.forEach(acc => {
                            const isDuplicate = ancestorPath.some(ancestor =>
                                ancestor.id === acc.id &&
                                ancestor.name === acc.name &&
                                ancestor.level === level
                            );

                            if (isDuplicate) {
                                console.warn(`Skipping circular reference: ${acc.name} (id=${acc.id}) at level ${level}`);
                                return;
                            }

                            rowIndex++;
                            uniqueRowCounter++;
                            const currentRowId = `row_${uniqueRowCounter}`;

                            const indent = '&nbsp;'.repeat((level - 1) * 6);
                            const hasChildren = acc.children && acc.children.length > 0;
                            const toggleIcon = hasChildren
                                ? '<span class="toggle-icon" style="cursor:pointer;user-select:none;font-weight:bold;margin-right:4px;">►</span>'
                                : '';

                            const parentAttr = parentRowId ? ` data-parent-row="${parentRowId}"` : '';
                            const hideStyle = level > 1 ? ' style="display:none;"' : '';

                            const rowHtml = `
                                <tr data-id="${acc.id}"
                                    data-row-id="${currentRowId}"${parentAttr}
                                    data-level="${level}"${hideStyle}>
                                    <td>${rowIndex}</td>
                                    <td>${indent}${toggleIcon}${acc.name}</td>
                                    <td class="text-end">${Number(acc.balance).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>
                                </tr>
                            `;

                            tbody.append(rowHtml);

                            const newAncestorPath = [...ancestorPath, { id: acc.id, name: acc.name, level: level }];

                            if (hasChildren) {
                                renderRows(acc.children, level + 1, currentRowId, newAncestorPath);
                            }
                        });
                    }

                    renderRows(res.data);

                    // Toggle expand/collapse on click
                    tbody.off('click', '.toggle-icon').on('click', '.toggle-icon', function () {
                        const icon = $(this);
                        const parentRow = icon.closest('tr');
                        const parentRowId = parentRow.data('row-id');
                        const isExpanded = icon.text() === '▼';

                        function toggleChildren(rowId, show) {
                            $(`tr[data-parent-row="${rowId}"]`).each(function () {
                                const childRow = $(this);
                                if (show) {
                                    childRow.show();
                                } else {
                                    childRow.hide();
                                    const childIcon = childRow.find('.toggle-icon');
                                    if (childIcon.text() === '▼') {
                                        childIcon.text('►');
                                        toggleChildren(childRow.data('row-id'), false);
                                    }
                                }
                            });
                        }

                        if (isExpanded) {
                            icon.text('►');
                            toggleChildren(parentRowId, false);
                        } else {
                            icon.text('▼');
                            toggleChildren(parentRowId, true);
                        }
                    });

                    // Destroy and reinitialize DataTable
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().destroy();
                    }

                    $('#table1').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            { extend: 'excelHtml5', text: 'Excel', className: 'btn btn-primary btn-sm' },
                            { extend: 'pdfHtml5', text: 'PDF', className: 'btn btn-primary btn-sm', orientation: 'portrait', pageSize: 'A4' }
                        ],
                        order: [[0, 'asc']],
                        pageLength: 1000,
                        ordering: false,
                        searching: true,
                        paging: true
                    });
                },
                error: function (xhr, status, error) {
                    console.error('AJAX Error:', error);
                    toastr.error('Error loading balance sheet report');
                }
            });
        }

                    // Handle row click for level 4 accounts
        $('#table1 tbody').on('click', 'tr', function () {
            const accountId = $(this).data('id');      // Get account id
            const level = $(this).data('level');       // Get row level

            // Only proceed if level is 4
            if (level === 4) {
                if (!accountId) {
                    toastr.warning('No account ID found for this row.');
                    return;
                }

                // Redirect to TransactionByAccount page with accountId
                window.location.href = `/Reports/TransactionByAccount?accountId=${accountId}`;
            }
        });

        });
    </script>
}
