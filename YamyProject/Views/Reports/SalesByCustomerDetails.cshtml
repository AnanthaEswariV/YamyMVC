
@{
    ViewData["Title"] = "SalesByCustomerDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Sales By Customer Details</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>Sale Id</th>
                    <th>Customer</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Invoice No</th>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {

            const customerId = new URLSearchParams(window.location.search).get('id');

            if (!customerId) {
                toastr.error("Customer ID is missing!");
                return;
            }

            // Initial load
            loadCustomerSalesDetails();

            // Checkbox toggle
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);

                if (isChecked) {
                    $('#startDate, #endDate').val('');
                }

                loadCustomerSalesDetails();
            });

            // Filter click
            $('#filterBtn').click(function () {
                loadCustomerSalesDetails();
            });

            // Click row → open invoice journal (optional)
            $('#table1 tbody').on('click', 'tr', function () {
                const type = $(this).find('td:nth-child(3)').text().trim();
                if (!type || type === 'TOTAL') return;

                window.location.href =
                    `/Lists/TransacationJournal?selectionMethod=${encodeURIComponent(type)}`;
            });
        });

        function loadCustomerSalesDetails() {

            const customerId = new URLSearchParams(window.location.search).get('id');
            if (!customerId) return;

            const showAll = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            $.ajax({
                url: '@Url.Action("GetSalesDetailsByCustomer", "Reports")',
                type: 'GET',
                data: {
                    customerId: customerId,
                    startDate: showAll ? null : startDate,
                    endDate: showAll ? null : endDate
                },
                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load sales details');
                        return;
                    }

                    // Destroy DataTable
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {

                        $.each(res.data, function (i, row) {

                            const isTotal = row.customer === 'TOTAL';

                            const tr = `
                                <tr class="${isTotal ? 'fw-bold table-secondary' : ''}">
                                    <td>${row.id ?? ''}</td>
                                    <td>${row.customer ?? ''}</td>
                                    <td>${row.type ?? ''}</td>
                                    <td>${row.date ?? ''}</td>
                                    <td>${row.num ?? ''}</td>
                                    <td>${row.item ?? ''}</td>
                                    <td class="text-end">${row.qty ?? ''}</td>
                                    <td class="text-end">${row.price ?? ''}</td>
                                    <td class="text-end">${row.amount ?? '0.00'}</td>
                                </tr>
                            `;
                            tbody.append(tr);
                        });

                        // Initialize DataTable
                        $('#table1').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                  extend: 'print',
                                  text: '<i class="fas fa-print me-1"></i> Print',
                                  className: 'btn btn-primary btn-sm',
                                }
                                ],
                            order: [[3, 'asc'], [0, 'asc']], // Date → Sale Id
                            pageLength: 25
                        });

                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    No records found
                                </td>
                            </tr>
                        `);
                    }
                },
                error: function () {
                    toastr.error('Error fetching customer sales details');
                }
            });
        }
    </script>

}
