
@{
    ViewData["Title"] = "PurchaseByItemSummary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<style>
    /* Button style overrides */
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<div class="card">
    <div class="card-header text-center">
        <strong>Purchase By Item Summary</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">
            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th></th>
                    <th>QTY</th>
                    <th>Amount</th>
                    <th>% Sales</th>
                    <th>AVG Price</th>
                    <th>COGS</th>
                    <th>AVG COGS</th>
                    <th>Gross Margin</th>
                    <th>Margin %</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {

            const table = $('#table1');

            function appendRow(level, name, key, state, loadState, rowIndex, rowClass, additionalCols = [], itemId = null) {

                const padding = (level - 1) * 30;
                const arrow = (level === 1 || level === 2) ? '► ' : '';

                let colsHtml = additionalCols.length
                    ? additionalCols.map(col => `<td>${col}</td>`).join('')
                    : `<td colspan="8"></td>`;

                const tr = $(`
                    <tr class="${rowClass}"
                        data-state="${state}"
                        data-loadstate="${loadState}"
                        data-key="${key ?? ''}"
                        ${itemId ? `data-id="${itemId}"` : ''}
                        style="${level > 1 ? 'display:none' : ''}">
                        <td style="padding-left:${padding}px">${arrow}${name}</td>
                        ${colsHtml}
                    </tr>
                `);

                if (rowIndex !== undefined) {
                    table.find('tbody tr').eq(rowIndex).after(tr);
                } else {
                    table.find('tbody').append(tr);
                }
            }

            /* ---------------- LOAD TYPES ---------------- */
            function loadItemTypes() {
                $.get('@Url.Action("GetItemTypes", "Reports")', res => {
                    if (!res.status) return toastr.error('Failed to load item types');
                    table.find('tbody').empty();

                    res.data.forEach(t => {
                        appendRow(
                            1,
                            t.name,
                            t.key,
                            t.state,
                            t.loadState,
                            undefined,
                            'level1'
                        );
                    });
                });
            }

            /* ---------------- LOAD CATEGORIES ---------------- */
            function loadCategories(row) {
                const type = row.data('key');

                $.get('@Url.Action("GetItemCategoriesByType", "Reports")', { type }, res => {
                    if (!res.status) return toastr.error('Failed to load categories');

                    let index = row.index();
                    res.data.forEach(c => {
                        appendRow(
                            2,
                            c.name,
                            c.key,
                            c.state,
                            c.loadState,
                            index,
                            'level2'
                        );
                        index++;
                    });
                });
            }

            /* ---------------- LOAD ITEMS ---------------- */
            function loadItems(row) {
                const [catId, type] = row.data('key').split('|');

                $.get('@Url.Action("GetItemsByCategorys", "Reports")', {
                    categoryId: catId,
                    type: type,
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val()
                }, res => {
                    if (!res.status) return toastr.error('Failed to load items');

                    let index = row.index();
                    res.data.forEach(item => {
                        appendRow(
                            3,
                            item.name,
                            '',
                            'n',
                            'l',
                            index,
                            'level3',
                            [
                                Number(item.qty).toFixed(2),
                                Number(item.amount).toFixed(2),
                                item.grossMarginPercent,
                                Number(item.avgPrice).toFixed(2),
                                Number(item.cogs).toFixed(2),
                                Number(item.avgCogs).toFixed(2),
                                Number(item.grossMargin).toFixed(2),
                                item.grossMarginPercent
                            ],
                            item.id
                        );
                        index++;
                    });
                });
            }

            /* ---------------- TOGGLE EXPAND / COLLAPSE ---------------- */
            table.on('click', 'tr', function () {

                const row = $(this);
                const state = row.data('state');
                const loadState = row.data('loadstate');

                const level = row.hasClass('level1') ? 1 :
                              row.hasClass('level2') ? 2 : 3;

                if (level === 3) return;

                if (state === 'e') {

                    if (loadState === 'u') {
                        level === 1 ? loadCategories(row) : loadItems(row);
                        row.data('loadstate', 'l');
                    }

                    row.data('state', 'c');
                    row.find('td:first').html(row.find('td:first').html().replace('►', '▼'));

                    table.find('tbody tr').each(function () {
                        const tr = $(this);
                        const trLevel = tr.hasClass('level1') ? 1 :
                                        tr.hasClass('level2') ? 2 : 3;

                        if (tr.index() > row.index() && trLevel === level + 1) {
                            tr.show();
                        }
                    });

                } else {

                    row.data('state', 'e');
                    row.find('td:first').html(row.find('td:first').html().replace('▼', '►'));

                    const parentIndex = row.index();

                    table.find('tbody tr').each(function () {
                        const tr = $(this);
                        const trLevel = tr.hasClass('level1') ? 1 :
                                        tr.hasClass('level2') ? 2 : 3;

                        if (tr.index() > parentIndex && trLevel > level) {
                            tr.hide();
                            tr.data('state', 'e');
                            tr.data('loadstate', 'u');
                            tr.find('td:first').html(tr.find('td:first').html().replace('▼', '►'));
                        }
                    });
                }
            });


                       table.on('click', 'tr.level3', function (e) {
            // Prevent this click from triggering expand/collapse
            e.stopPropagation();

            const itemId = $(this).data('id');
            if (itemId) {
                // Redirect to details page
                window.location.href = '@Url.Action("PurchaseByItemDetails", "Reports")?id=' + itemId;
            }
        });


            /* ---------------- FILTER ---------------- */
            $('#filterBtn').click(loadItemTypes);

            $('#chkAllData').change(function () {
                $('#startDate, #endDate').prop('disabled', this.checked);
            });

            /* ---------------- INITIAL LOAD ---------------- */
            loadItemTypes();

        });
    </script>

}
