@{
    ViewData["Title"] = "City List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>City List</strong>
    </div>
    <div class="card-body">

            <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="btnAddCity">
                <i class="bi bi-plus-circle me-2"></i>Add City
            </button>
            </div>
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>City</th>
                    <th>Country Id</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="cityListModal" tabindex="-1" aria-labelledby="cityListModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="cityListModalLabel">Add City</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <form id="cityForm">
                    <!-- Country -->
                    <div class="mb-3">
                        <label for="cmbCountry" class="form-label">Country</label>
                        <select id="cmbCountry" class="form-select" required>
                            <option value="">-- Select Country --</option>
                        </select>
                    </div>

                    <!-- City -->
                    <div class="mb-3">
                        <label for="txtCity" class="form-label">City</label>
                        <input type="text" id="txtCity" class="form-control" placeholder="Enter City Name" required />
                    </div>
                </form>
            </div>

            <!-- Modal Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnSaveCity" class="btn btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>
        $(document).ready(function () {
            loadCities();
            loadCountry();

            function loadCities() {
                $.ajax({
                   url: '@Url.Action("GetCitys", "Reports")',
                    type: 'GET',

                    beforeSend: function () {
                        $('#table2 tbody').html(`
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <div class="spinner-border text-primary me-2"></div>Loading...
                                </td>
                            </tr>
                        `);
                    },

                    success: function (res) {
                        if (!res.status) {
                            toastr.error(res.message || 'Failed to load city list');
                            return;
                        }

                        if ($.fn.DataTable.isDataTable('#table2')) {
                            $('#table2').DataTable().clear().destroy();
                        }

                        const tbody = $('#table2 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
        $.each(res.data, function (i, row) {
            const tr = $(`
                <tr data-id="${row.id}">
                    <td>${i + 1}</td>
                    <td>${row.name}</td>
                    <td>${row.countryName || row.country_Id}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary editCityBtn">
                            <i class="fas fa-pen"></i>
                        </button>
                    </td>
                </tr>
            `);

            // Attach row data to the edit button dynamically
            tr.find('.editCityBtn').data('city', row);

            tbody.append(tr);
        });

                            // ✅ Initialize DataTable
                            $('#table2').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                        extend: 'pdfHtml5',
                                        text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                        className: 'btn btn-primary btn-sm',
                                        orientation: 'landscape',
                                        pageSize: 'A4'
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15
                            });
                        } else {
                            tbody.append(`<tr><td colspan="4" class="text-center text-muted py-4">No cities found</td></tr>`);
                        }
                    },

                    error: function () {
                        toastr.error('Error loading city list');
                    }
                });
            }

            function loadCountry() {
                $.ajax({
                    url: '@Url.Action("GetCountry", "Reports")',
                    type: 'GET',
                    success: function(result) {
                        const dropdown = $('#cmbCountry');
                        dropdown.empty().append('<option value="">-- Select Country --</option>');

                        if (result.status) {
                            result.data.forEach(w => {
                                dropdown.append(`<option value="${w.id}">${w.name}</option>`);
                            });
                        } else {
                            toastr.error(result.message || 'Failed to load warehouses');
                        }
                    },
                    error: function(err) {
                        console.error(err);
                        toastr.error('Error loading country data');
                    }
                });
            }

                $('#btnAddCity').click(function () {
            $('#cityId').val(0);
            $('#txtCity').val('');
            $('#cmbCountry').val('');
            $('#cityListModalLabel').text('Add City');
            $('#cityListModal').modal('show');
        });

        $(document).on('click', '.editCityBtn', function () {
            const city = $(this).data('city');
            if (!city) return;

            $('#cityId').val(city.id ?? 0);
            $('#txtCity').val(city.name ?? '');
            $('#cityListModalLabel').text('Edit City');

            $.ajax({
                url: '@Url.Action("GetCountry", "Reports")',
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#cmbCountry');
                    dropdown.empty().append('<option value="">-- Select Country --</option>');

                    if (result.status && result.data.length > 0) {
                        result.data.forEach(w => {
                            dropdown.append(`<option value="${w.id}">${w.name}</option>`);
                        });

                        // 🔹 Set the selected value AFTER options are added
                        const selectedCountryId = city.countryId ?? city.country_Id; // Use correct property
                        dropdown.val(selectedCountryId);
                    } else {
                        toastr.error(result.message || 'Failed to load countries');
                    }
                },
                error: function(err) {
                    console.error(err);
                    toastr.error('Error loading countries');
                }
            });

            $('#cityListModal').modal('show');
        });

        // 💾 Save City (Add / Edit)
        $('#btnSaveCity').click(function () {
            const form = $('#cityForm')[0];
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const cityData = {
                Id: parseInt($('#cityId').val()) || 0,
                Name: $('#txtCity').val().trim(),
                CountryId: parseInt($('#cmbCountry').val())
            };

            $.ajax({
               url: '@Url.Action("SaveCity", "Reports")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(cityData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(cityData.Id > 0 ? 'City updated successfully' : 'City added successfully');
                        $('#cityListModal').modal('hide');
                        setTimeout(function () { location.reload(); }, 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });


        });
    </script>
}
