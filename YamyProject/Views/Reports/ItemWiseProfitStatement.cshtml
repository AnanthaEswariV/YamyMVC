
@{
    ViewData["Title"] = "ItemWiseProfitStatement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Item Wise Profit Statement</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table3">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>INV No</th>
                    <th>Customer Name</th>
                    <th>Item Name</th>
                    <th>Cost Price</th>
                    <th>Sales Price</th>
                    <th>QTY</th>
                    <th>Cost Amount</th>
                    <th>Sales Amount</th>
                    <th>Profit</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initial load
            loadItemWiseProfit();

            // Checkbox change → enable/disable date fields
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
                loadItemWiseProfit();
            });

            // Filter button click
            $('#filterBtn').click(function () {
                loadItemWiseProfit();
            });
        });

        function loadItemWiseProfit() {
            const showAll = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            $.ajax({
               url: '@Url.Action("GetItemWiseProfit", "Reports")',
                type: 'GET',
                data: {
                    isDateChecked: !showAll,
                    startDate: startDate || null,
                    endDate: endDate || null
                },
                beforeSend: function () {
                    $('#table3 tbody').html(`
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load profit statement');
                        return;
                    }

                    if ($.fn.DataTable.isDataTable('#table3')) {
                        $('#table3').DataTable().clear().destroy();
                    }

                    const tbody = $('#table3 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${row.date ? new Date(row.date).toLocaleDateString() : ''}</td>
                                    <td>${row.invNo ?? ''}</td>
                                    <td>${row.customerName ?? ''}</td>
                                    <td>${row.itemName ?? ''}</td>
                                    <td class="text-end">${row.costPrice?.toFixed(2) ?? '0.00'}</td>
                                    <td class="text-end">${row.salesPrice?.toFixed(2) ?? '0.00'}</td>
                                    <td class="text-end">${row.qty ?? '0.00'}</td>
                                    <td class="text-end">${row.costAmount?.toFixed(2) ?? '0.00'}</td>
                                    <td class="text-end">${row.salesAmount?.toFixed(2) ?? '0.00'}</td>
                                    <td class="text-end">${row.profit?.toFixed(2) ?? '0.00'}</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        $('#table3').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: { columns: ':visible' }
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: { columns: ':visible' },
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 15
                        });
                    } else {
                        tbody.append(`<tr><td colspan="11" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error fetching item wise profit statement');
                }
            });
        }
    </script>
}


