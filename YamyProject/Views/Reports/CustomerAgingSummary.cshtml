
@{
    ViewData["Title"] = "CustomerAgingSummary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Customer Aging Summary</strong>
    </div>

    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Name</th>
                    <th>Current</th>
                    <th>1 - 30</th>
                    <th>31 - 60</th>
                    <th>61 - 90</th>
                    <th>> 90</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        $(document).ready(function () {

            loadCustomerAgingSummary();

            // Checkbox toggle
            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
                loadCustomerAgingSummary();
            });

            // Filter button
            $('#filterBtn').click(function () {
                loadCustomerAgingSummary();
            });

            // Double click → customer details
            $('#table1 tbody').on('dblclick', 'tr', function () {
                const id = $(this).data('id');
                if (id) {
                    window.location.href = `/Reports/CustomerAgingDetails?id=${id}`;
                }
            });
        });

        function loadCustomerAgingSummary() {

            const showAll = $('#chkAllData').is(':checked');
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();

            $.ajax({
                url: '@Url.Action("GetCustomerAgingSummary", "Reports")',
                type: 'GET',
                data: {
                    showAll: showAll,
                    startDate: startDate || null,
                    endDate: endDate || null
                },
                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="8" class="text-center py-4">
                                <div class="spinner-border text-primary me-2"></div>
                                Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {

                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load customer aging summary');
                        return;
                    }
                    console.log(res);
                    // Reset DataTable
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {

                        $.each(res.data, function (i, row) {

                            const isTotal = row.customer === "TOTAL";

                            tbody.append(`
                                <tr data-id="${row.id || ''}" class="${isTotal ? 'fw-bold table-secondary' : ''}">
                                    <td>${row.sn ?? ''}</td>
                                    <td>${row.customer ?? ''}</td>
                                    <td class="text-end">${row.current ?? '0.00'}</td>
                                    <td class="text-end">${row.days_1_30 ?? '0.00'}</td>
                                    <td class="text-end">${row.days_31_60 ?? '0.00'}</td>
                                    <td class="text-end">${row.days_61_90 ?? '0.00'}</td>
                                    <td class="text-end">${row.days_91_Plus ?? '0.00'}</td>
                                    <td class="text-end">${row.total ?? '0.00'}</td>
                                </tr>
                            `);
                        });

                        // DataTable initialization
                        $('#table1').DataTable({
                            dom: 'Bfrtip',
                            order: [[0, 'asc']],
                            pageLength: 25,
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ]
                        });

                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No records found
                                </td>
                            </tr>
                        `);
                    }
                },
                error: function () {
                    toastr.error('Error fetching customer aging summary');
                }
            });
        }
    </script>


}