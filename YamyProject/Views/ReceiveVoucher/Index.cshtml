@model ReceiveVoucherCenterViewModel
@{
    ViewData["Title"] = "Payment Voucher Center";
    }

<style>
    .apvc-wrap {
        font-family: Segoe UI, Roboto, Arial, sans-serif;
        background: #f7f7fc;
        padding: 10px;
    }

    .apvc-window {
        background: #fff;
        border: 1px solid #cfd3e1;
        border-top: 6px solid #3b82f6;
        border-radius: 6px;
    }

    .apvc-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .6rem .8rem;
        color: #1f2a44;
        font-weight: 600;
        border-bottom: 1px solid #e5e7f2;
    }

    .apvc-toolbar {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 10px;
        background: #fafbff;
        border-bottom: 1px solid #e5e7f2;
    }

        .apvc-toolbar label {
            font-size: .85rem;
            color: #333;
            margin-right: 6px;
        }

        .apvc-toolbar select,
        .apvc-toolbar input[type="date"] {
            height: 30px;
            padding: 4px 6px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            background: #fff;
        }

        .apvc-toolbar .spacer {
            flex: 1;
        }

    .apvc-grid,
    .apvc-detail-grid {
        width: 100%;
        border-collapse: collapse;
    }

        .apvc-grid thead th,
        .apvc-detail-grid thead th {
            background: #edf2ff;
            color: #1f2a44;
            font-weight: 600;
            text-align: left;
            padding: 8px;
            border-bottom: 1px solid #dbe3f5;
            font-size: .9rem;
        }

        .apvc-grid tbody tr {
            cursor: pointer;
        }

            .apvc-grid tbody tr:hover {
                background: #f5f7ff;
            }

        .apvc-grid td,
        .apvc-detail-grid td {
            padding: 8px;
            border-bottom: 1px solid #eef2ff;
            font-size: .92rem;
            color: #1f2937;
        }

    .apvc-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        gap: 8px;
    }

    .apvc-btn {
        border: 1px solid #cbd5e1;
        background: #fff;
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

        .apvc-btn.primary {
            background: #3b82f6;
            color: #fff;
            border-color: #3b82f6;
        }

        .apvc-btn.danger {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444;
        }

        .apvc-btn.ghost {
            background: #f1f5f9;
        }

    .apvc-checkbox {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-left: 6px;
    }

    .amount {
        text-align: right;
    }

    .muted {
        color: #6b7280;
    }
</style>

<div class="apvc-wrap">
    <div class="apvc-window">
        <!-- TITLE -->
        <div class="apvc-title">
            <span>Payment Voucher Center</span>
        </div>

        <!-- TOOLBAR / FILTERS -->
        <div class="apvc-toolbar">
            <form method="get"
                  asp-action="Index"
                  id="filterForm"
                  class="d-flex flex-wrap align-items-end gap-3 mb-0 w-100">

                <div>
                    <label for="FromDate">From</label>
                    <input type="date" id="FromDate" name="FromDate"
                           class="form-control form-control-sm" />
                </div>

                <div>
                    <label for="ToDate">To</label>
                    <input type="date" id="ToDate" name="ToDate"
                           class="form-control form-control-sm" />
                </div>

                <label class="apvc-checkbox mt-3">
                    <input class="form-check-input" type="checkbox" id="All" name="All" checked />
                    <span>All</span>
                </label>

                <button type="submit" class="apvc-btn ghost mt-3" id="btnFilter">
                    <i class="bi bi-search"></i> Filter
                </button>

                <div class="spacer"></div>

                <a asp-controller="ReceiveVoucher"
                   asp-action="Create"
                   class="apvc-btn primary"
                   id="btnNew">
                    <i class="bi bi-plus-circle-dotted"></i>
                    New Settlement
                </a>
            </form>
        </div>

        <!-- MAIN GRID -->
        <div style="overflow:auto; max-height:420px;">
            @if (Model?.ReceiptVouchers != null && Model.ReceiptVouchers.Any())
                {
                <table class="apvc-grid" id="mainGrid">
                    <thead>
                        <tr>
                            <th style="width:60px;">Sn</th>
                            <th style="width:120px;">Date</th>
                            <th style="width:100px;">JV No</th>
                            <th style="width:140px;">Receipt Code</th>
                            <th style="width:140px;">Amount</th>
                            <th>Debit Account</th>
                            <th>Credit Account</th>
                            <th style="width:90px;">Edit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ReceiptVouchers)
                            {
                            <tr data-payment-id="@item.Id">
                                <td>@item.SN</td>
                                <td>@item.Date</td>
                                <td>@item.JVNO</td>
                                <td>@item.ReceiptCode</td>
                                <td class="amount">@item.Amount</td>
                                <td>@item.DebitAccount</td>
                                <td>@item.CreditAccount</td>
                                <td>
                                    <a class="menu-link px-2 js-render-modal"
                                       asp-controller="ReceiveVoucher"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                            }
                    </tbody>
                </table>
                }
            else
                {
                <div class="p-3 muted">
                    No vouchers found.
                </div>
                }
        </div>

        <!-- DETAIL GRID -->
        <div style="border-top:1px solid #e5e7f2; margin-top:6px;">
            <table class="apvc-detail-grid" id="detailGrid">
                <thead>
                    <tr>
                        <th style="width:40%;">Date</th>
                        <th style="width:40%;">Name</th>
                        <th style="width:20%;">Payment</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-muted">
                            Select a voucher to see details.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

    @section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const mainBody   = document.querySelector('#mainGrid tbody');
            const detailBody = document.querySelector('#detailGrid tbody');

            const fromInput  = document.getElementById('FromDate');
            const toInput    = document.getElementById('ToDate');
            const chkAll     = document.getElementById('All');
            const filterForm = document.getElementById('filterForm');

            if (!mainBody || !detailBody) return;

            // --- URLs (adjust action names if your controller is different) ---
            const filterUrl       = '@Url.Action("Filter", "ReceiveVoucher")';
            const editUrlTemplate = '@Url.Action("Edit", "ReceiveVoucher", new { id = "__id__" })';
            const detailUrlBase   = '@Url.Action("GetPaymentDetailsAsync", "ReceiveVoucher")';

            // Helper to format JS Date -> yyyy-MM-dd
            function toIsoString(d) {
                const year  = d.getFullYear();
                const month = String(d.getMonth() + 1).padStart(2, '0');
                const day   = String(d.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            // Make date inputs read-only when "All" is checked
            function toggleDateReadonly() {
                const isAll = chkAll && chkAll.checked;
                if (fromInput) {
                    fromInput.readOnly = isAll;
                    fromInput.classList.toggle('bg-light', isAll);
                }
                if (toInput) {
                    toInput.readOnly = isAll;
                    toInput.classList.toggle('bg-light', isAll);
                }
            }

            // Normalize date range if one side is missing / invalid
            function normalizeDates() {
                const today = new Date();

                let fromVal = fromInput.value;
                let toVal   = toInput.value;

                if (!fromVal && !toVal) {
                    const todayStr = toIsoString(today);
                    fromVal = todayStr;
                    toVal   = todayStr;
                }
                else if (!fromVal && toVal) {
                    const toDate = new Date(toVal);
                    if (!Number.isNaN(toDate.getTime())) {
                        toDate.setMonth(toDate.getMonth() - 1);
                        fromVal = toIsoString(toDate);
                    } else {
                        fromVal = toIsoString(today);
                    }
                }
                else if (fromVal && !toVal) {
                    toVal = toIsoString(today);
                }

                // Swap if from > to
                if (fromVal && toVal && fromVal > toVal) {
                    const tmp = fromVal;
                    fromVal = toVal;
                    toVal = tmp;
                }

                fromInput.value = fromVal;
                toInput.value   = toVal;

                return { from: fromVal, to: toVal };
            }

            // Apply filter via AJAX
            async function applyFilter() {
                // If "All" is checked, do nothing (server uses full range / ignore filter)
                if (chkAll && chkAll.checked) {
                    return;
                }

                const { from, to } = normalizeDates();
                const url = `${filterUrl}?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}&all=false`;

                try {
                    const response = await fetch(url, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }

                    const vm = await response.json();
                    const vouchers = vm.receiptVouchers ?? vm.ReceiptVouchers ?? [];

                    mainBody.innerHTML = '';
                    detailBody.innerHTML =
                        '<tr><td colspan="4" class="text-muted">Select a voucher to see details.</td></tr>';

                    if (!vouchers.length) {
                        mainBody.innerHTML =
                            '<tr><td colspan="9" class="text-muted">No vouchers for this period.</td></tr>';
                        return;
                    }

                    vouchers.forEach((item, index) => {
                        const id            = item.id            ?? item.Id;
                        const sn            = item.sn            ?? item.SN ?? (index + 1);
                        const dateRaw       = item.date          ?? item.Date;
                        const jvno          = item.jvno          ?? item.JVNO;
                        const receiptCode   = item.receiptCode   ?? item.ReceiptCode;
                        const amount        = item.amount        ?? item.Amount;
                        const debitAccount  = item.debitAccount  ?? item.DebitAccount;
                        const creditAccount = item.creditAccount ?? item.CreditAccount;

                        let dateText = dateRaw ?? '';
                        if (dateRaw && typeof dateRaw === 'string') {
                            const d = new Date(dateRaw);
                            if (!Number.isNaN(d.getTime())) {
                                dateText = d.toLocaleDateString();
                            }
                        }

                        const tr = document.createElement('tr');
                        tr.setAttribute('data-payment-id', id);

                        const editUrl = editUrlTemplate.replace('__id__', id);

                        tr.innerHTML =
                            `<td>${sn}</td>` +
                            `<td>${id ?? ''}</td>` +
                            `<td>${dateText}</td>` +
                            `<td>${jvno ?? ''}</td>` +
                            `<td>${receiptCode ?? ''}</td>` +
                            `<td class="amount">${amount ?? ''}</td>` +
                            `<td>${debitAccount ?? ''}</td>` +
                            `<td>${creditAccount ?? ''}</td>` +
                            `<td>
                                <a class="menu-link px-2 js-render-modal"
                                   href="${editUrl}">
                                    Edit
                                </a>
                             </td>`;

                        mainBody.appendChild(tr);
                    });
                } catch (error) {
                    console.error(error);
                    mainBody.innerHTML =
                        '<tr><td colspan="9" class="text-danger">Error loading vouchers.</td></tr>';
                }
            }

            // Handle form submit (Filter button)
            if (filterForm) {
                filterForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    applyFilter();
                });
            }

            // Handle "All" checkbox -> make dates read-only
            if (chkAll) {
                chkAll.addEventListener('change', toggleDateReadonly);
                toggleDateReadonly();
            }

            // Row click -> load detail rows
            mainBody.addEventListener('click', function (e) {
                const row = e.target.closest('tr[data-payment-id]');
                if (!row) return;

                const paymentId = row.getAttribute('data-payment-id');

                const url = detailUrlBase + '?paymentId=' + encodeURIComponent(paymentId);

                fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(rows => {
                        detailBody.innerHTML = '';

                        if (!rows || rows.length === 0) {
                            detailBody.innerHTML =
                                '<tr><td colspan="4" class="text-muted">No details for this voucher.</td></tr>';
                            return;
                        }

                        rows.forEach(r => {
                            const tr = document.createElement('tr');

                            const dateRaw     = r.date        ?? r.Date        ?? '';
                            const name        = r.Vouchertype ?? r.VoucherType ?? '';
                            const payment     = r.payment     ?? r.Payment     ?? '';
                            const description = r.description ?? r.Description ?? '';

                            let dateText = dateRaw;
                            if (dateRaw && typeof dateRaw === 'string') {
                                const d = new Date(dateRaw);
                                if (!Number.isNaN(d.getTime())) {
                                    dateText = d.toLocaleDateString();
                                }
                            }

                            tr.innerHTML =
                                '<td>' + dateText + '</td>' +
                                '<td>' + (name ?? '') + '</td>' +
                                '<td class="amount">' + (payment ?? '') + '</td>' +
                                '<td>' + (description ?? '') + '</td>';

                            detailBody.appendChild(tr);
                        });
                    })
                    .catch(error => {
                        console.error(error);
                        detailBody.innerHTML =
                            '<tr><td colspan="4" class="text-danger">Error loading details.</td></tr>';
                    });
            });
        });
    </script>
    }
