@model ReceiveVoucherViewModel
@{
    ViewData["Title"] = "Receive Voucher";

    var readOnlyTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Subcontractor", "Vendor" ,"Employee"
    };
    var isEmployeeType = Model?.Type != null &&
                         string.Equals(Model.Type, "Employee", StringComparison.OrdinalIgnoreCase);
    var isReadOnly = !readOnlyTypes.Contains(Model.Type);
    }
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    .pv-wrap {
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f3f4f8;
        padding: 10px;
    }

    .pv-window {
        background: #fff;
        border: 1px solid #cfd3e1;
        border-top: 5px solid #0d6efd;
        border-radius: 4px;
    }

    .pv-header {
        padding: .45rem .75rem;
        font-weight: 600;
        font-size: 1.1rem;
        color: #fff;
        background: #123b7a;
        border-radius: 4px 4px 0 0;
        text-align: center;
    }

    .pv-tabs {
        border-bottom: 1px solid #e0e4f0;
        padding: 0 .75rem;
        background: #f8f9fc;
    }

        .pv-tabs .nav-link {
            padding: .4rem .9rem;
            font-size: .9rem;
        }

    .pv-ribbon {
        padding: .5rem .75rem;
        border-bottom: 1px solid #e0e4f0;
        background: #fdfdff;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .pv-ribbon .btn {
            min-width: 105px;
        }

        .pv-ribbon .pv-nav-btn {
            width: 34px;
            height: 34px;
            border-radius: .25rem;
            border: 1px solid #cfd3e1;
            background: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .pv-ribbon .pv-code {
            min-width: 120px;
            border-radius: .25rem;
            border: 1px solid #cfd3e1;
            background: #e9edf7;
            font-size: .88rem;
            padding: .25rem .5rem;
            text-align: center;
        }

        .pv-ribbon .vr {
            height: 32px;
            margin: 0 .4rem;
        }

    .pv-body {
        padding: .75rem;
    }

    .section-title {
        font-weight: 600;
        background: #f6f7fb;
        padding: .4rem .6rem;
        border-bottom: 1px solid #e1e4f0;
        font-size: .9rem;
    }

    .fieldset {
        border: 1px solid #e1e4f0;
        border-radius: .35rem;
        margin-bottom: .75rem;
        background: #fff;
    }

    .tiny {
        font-size: .83rem;
    }

    #payerArea {
        background: #fafbff;
    }

    /* Details grid */
    #invoiceTable thead {
        background: #f5f6fb;
        font-size: .88rem;
    }

    #invoiceTable tbody tr.selected-row {
        background-color: #d9f9c8;
    }

    #invoiceTable td,
    #invoiceTable th {
        padding: .3rem .4rem;
    }

    .pv-footer {
        padding: .6rem .75rem .8rem;
        border-top: 1px solid #e1e4f0;
        display: flex;
        justify-content: flex-end;
        gap: .5rem;
        background: #f8f9fc;
        border-radius: 0 0 4px 4px;
    }
</style>

<div class="pv-wrap">
    <div class="pv-window">
        <!-- Top blue header -->
        <div class="pv-header">
            Payment Voucher
        </div>

        <!-- Tabs (Main / Reports) -->
        <div class="pv-tabs">
            <ul class="nav nav-tabs border-0">
                <li class="nav-item">
                    <a class="nav-link active" href="#">Main</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link disabled" tabindex="-1">Reports</a>
                </li>
            </ul>
        </div>

        <!-- Ribbon -->
        <div class="pv-ribbon">
            <button type="button" class="pv-nav-btn" title="Previous">
                <i class="bi bi-arrow-left-short"></i>
            </button>

            <div class="pv-code">
                @(Model?.VoucherNo ?? "PV-0000")
            </div>

            <button type="button" class="pv-nav-btn" title="Next">
                <i class="bi bi-arrow-right-short"></i>
            </button>

            <div class="vr"></div>

            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-file-earmark-plus"></i> New
            </button>

            <button type="submit" form="rvForm" class="btn btn-primary" id="btnSave">
                <i class="bi bi-save"></i> Save
            </button>

            <button type="button" class="btn btn-outline-danger">
                <i class="bi bi-trash"></i> Delete
            </button>

            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-files"></i> Create a Copy
            </button>
    
            <button type="button" class="btn btn-outline-secondary" id="btnPrint">
                <i class="bi bi-printer"></i> Print
            </button>

            <button type="button" class="btn btn-outline-secondary" id="btnEmail">
                <i class="bi bi-envelope"></i> Email
            </button>

            <div class="form-check tiny ms-2">
                <input class="form-check-input" type="checkbox" id="PrintAfterSave" checked>
                <label class="form-check-label" for="PrintAfterSave">Print After Save</label>
            </div>
        </div>

        <!-- Body -->
        <div class="pv-body">
            <form asp-action="Create" asp-controller="ReceiptVouchers" method="post" id="rvForm"
                  class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                <!-- Header info row -->
                <div class="fieldset mb-2">
                    <div class="section-title">Header</div>
                    <div class="p-3">
                        <div class="row g-3 align-items-end">
                            <div class="col-12 col-md-3">
                                <label class="form-label">Date</label>
                                <input asp-for="Date" class="form-control" type="date" />
                                <span class="text-danger small" asp-validation-for="Date"></span>
                            </div>

                            <fieldset class="col-12 col-md-3" @(isReadOnly ? "disabled" : null)>
                                <label class="form-label">Payment Type</label>
                                <select class="form-select" asp-for="PaymentType"
                                        asp-items="Model.PaymentTypes" id="PaymentType"></select>
                            </fieldset>

                            @if (!isEmployeeType)
                                {
                                <div class="col-12 col-md-2 d-flex align-items-center">
                                    <div class="form-check ms-1 mt-3">
                                        <input class="form-check-input" type="checkbox"
                                               id="IsSubcontractor" asp-for="IsSubcontractor">
                                        <label class="form-check-label tiny" for="IsSubcontractor">
                                            Subcontractors
                                        </label>
                                    </div>
                                </div>
                                }

                            <div class="col-12 col-md-3">
                                <label class="form-label">Payment Method</label>
                                <select class="form-select" asp-for="PaymentMethod"
                                        asp-items="Model.PaymentMethods" id="PaymentMethod"></select>
                            </div>

                            <div class="w-100"></div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Amount</label>
                                <input asp-for="Amount" id="Amount" class="form-control text-end"
                                       placeholder="0.000" readonly />
                                <span class="text-danger small" asp-validation-for="Amount"></span>
                            </div>
                            <div class="col-12 col-md-9">
                                <label class="form-label">Amount In Word</label>
                                <input asp-for="AmountInWords" class="form-control" id="AmountInWords" readonly />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- hidden keys -->
                <input type="hidden" asp-for="CreditAccountId" id="CreditAccountId" />
                <input type="hidden" asp-for="CreditCostCenterId" id="CreditCostCenterId" />
                <input type="hidden" asp-for="DebitAccountId" id="DebitAccountId" />
                <input type="hidden" asp-for="DebitCostCenterId" id="DebitCostCenterId" />
                <input type="hidden" asp-for="DebitEmployeeId" id="DebitEmployeeId" />
                <input type="hidden" asp-for="vendorId" id="vendorId" />

                <!-- Pay To - Debit -->
                <div class="fieldset">
                    <div class="section-title">Pay To - Debit</div>
                    <div class="p-3">
                        <div class="row g-3">
                            <div class="col-12 col-md-3">
                                <label class="form-label">Account Code</label>
                                <input asp-for="Debit.AccountCode" class="form-control" id="DebitAccountCode" />
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Account Name</label>
                                <select class="form-select" asp-for="DebitAccountId"
                                        asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                        id="filterCreditAccount">
                                </select>
                                <span class="text-danger" asp-validation-for="DebitAccountId"></span>
                            </div>
                            <div class="col-12 col-md-3">
                                <label class="form-label">Cost Center</label>
                                <select class="form-select" asp-for="CreditCostCenterId"
                                        asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                        id="filterCreditCostCenter">
                                </select>
                            </div>

                            <div class="w-100"></div>

                            <div id="payerArea" asp-for="Description"
                                 class="position-relative border rounded p-3 mt-2" style="min-height:190px;">
                                <!-- Employee panel -->
                                <div id="panelEmployee" class="pane d-none">
                                    <div class="row g-3">
                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Employee Code</label>
                                            <input asp-for="Debit.EmployeeCode" class="form-control" id="EmployeeCode" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Employee Name</label>
                                            <select class="form-select" asp-for="DebitEmployeeId"
                                                    asp-items="@(new SelectList(Model.Employees, "Id", "Name"))"
                                                    id="filterEmployee">
                                            </select>
                                            <span class="text-danger" asp-validation-for="DebitEmployeeId"></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Vendor panel -->
                                <div id="panelVendor" class="pane d-none">
                                    <div class="row g-3">
                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Vendor Code</label>
                                            <input asp-for="Debit.VendorCode" class="form-control" id="VendorCode" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Vendor Name</label>
                                            <select class="form-select" asp-for="vendorId"
                                                    asp-items="@(new SelectList(Model.vendors, "Id", "Name"))"
                                                    id="filterVendor">
                                            </select>
                                            <span class="text-danger" asp-validation-for="vendorId"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 mt-2">
                                <label class="form-label">Note</label>
                                <textarea asp-for="Debit.Note" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pay From - Credit -->
                <div class="fieldset">
                    <div class="section-title">Pay From - Credit</div>
                    <div class="p-3">
                        <div class="row g-3 align-items-end">
                            <div class="col-12 col-md-3">
                                <label class="form-label">Account Code</label>
                                <input asp-for="Credit.AccountCode" class="form-control" id="CreditAccountCode" />
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Account Name</label>
                                <select class="form-select" asp-for="DebitAccountId"
                                        asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                        id="filterDebitAccount">
                                </select>
                            </div>
                            <div class="col-12 col-md-3">
                                <label class="form-label">Cost Center</label>
                                <select class="form-select" asp-for="DebitCostCenterId"
                                        asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"
                                        id="filterDebitCostCenter">
                                </select>
                            </div>

                            <div class="w-100"></div>

                            <!-- Cheque -->
                            <div class="col-12 col-md-3 cheque-only d-none">
                                <label class="form-label">Cheque Name</label>
                                <input asp-for="Credit.ChequeName" class="form-control" />
                            </div>
                            <div class="col-12 col-md-2 cheque-only d-none">
                                <label class="form-label d-block">Cheque</label>
                                <div class="form-check mt-1">
                                    <input class="form-check-input" type="checkbox" asp-for="Credit.IsCheque" />
                                    <label class="form-check-label tiny">Is Cheque</label>
                                </div>
                            </div>
                            <div class="col-12 col-md-3 cheque-only d-none">
                                <label class="form-label">Cheque No</label>
                                <input asp-for="Credit.ChequeNo" class="form-control" />
                            </div>
                            <div class="col-12 col-md-3 cheque-only d-none">
                                <label class="form-label">Cheque Date</label>
                                <input asp-for="Credit.ChequeDate" type="date" class="form-control" />
                            </div>

                            <!-- Transfer -->
                            <div class="col-12 col-md-3 transfer-only d-none">
                                <label class="form-label">Transfer Date</label>
                                <input asp-for="Credit.transferDate" type="date" class="form-control" />
                            </div>
                            <div class="col-12 col-md-4 transfer-only d-none">
                                <label class="form-label">TRNS / Name</label>
                                <input class="form-control" asp-for="Credit.TRNSNAme" />
                            </div>
                            <div class="col-12 col-md-4 transfer-only d-none">
                                <label class="form-label">TRNS / REF</label>
                                <input class="form-control" asp-for="Credit.TRNSRef" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Details grid -->
                <div class="fieldset mb-0">
                    <div class="section-title">Details</div>
                    <div class="p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0" id="invoiceTable">
                                <thead>
                                    <tr>
                                        <th style="width:60px">No</th>
                                        <th style="width:140px">ID</th>
                                        <th style="width:140px">Date</th>
                                        <th style="width:140px">Inv No</th>
                                        <th style="width:140px" class="text-end">Amount</th>
                                        <th style="width:70px" class="text-center">Pay</th>
                                        <th style="width:160px" class="text-end">Payment</th>
                                        <th style="width:140px">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model?.Items != null && Model.Items.Any())
                                        {
                                        for (var i = 0; i < Model.Items.Count; i++)
                                            {
                                            <tr>
                                                <td class="text-center">@(i + 1)</td>
                                                <td>
                                                    <input class="form-control form-control-sm item-humId"
                                                           name="Items[i].humId" asp-for="Items[i].humId" readonly />
                                                </td>
                                                <td>
                                                    <input class="form-control form-control-sm item-date"
                                                           name="Items[i].invId" asp-for="Items[i].invId" readonly />
                                                </td>
                                                <td>
                                                    <input class="form-control form-control-sm item-invno"
                                                           name="Items[i].InvoiceNo" asp-for="Items[i].InvoiceNo" readonly />
                                                </td>
                                                <td>
                                                    <input step="0.01" class="form-control form-control-sm text-end item-Amount"
                                                           asp-for="Items[i].Amount" readonly />
                                                </td>
                                                <td class="text-center">
                                                    <input type="checkbox" class="form-check-input row-select"
                                                           asp-for="Items[i].Pay" />
                                                </td>
                                                <td>
                                                    <input step="0.01" min="0"
                                                           class="form-control form-control-sm text-end item-Payment"
                                                           asp-for="Items[i].Payment" data-max="Items[i].amount"
                                                           disabled />
                                                </td>
                                                <td>
                                                    <input class="form-control form-control-sm item-Description"
                                                           asp-for="Items[i].Description" />
                                                </td>
                                            </tr>
                                            }
                                        }
                                    else
                                        {
                                        <tr class="text-center text-muted">
                                            <td colspan="10">No invoices found for this vendor.</td>
                                        </tr>
                                        }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Footer buttons -->
                <div class="pv-footer">
                    <button type="submit" name="close" value="1" class="btn btn-primary">
                        Save &amp; Close
                    </button>
                    <button type="submit" class="btn btn-secondary">
                        Save
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Close
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>



    @section Scripts {
    <script>
        (function(){
          // -------- Helpers --------
          function toWordsDemo(n){
             // return n ? (Number(n).toLocaleString(undefined,{maximumFractionDigits:3}) + ' only') : 'zero';
               const v = Number(String(n).replace(/,/g,''));
              if (!isFinite(v)) return 'zero';
              const [i, f=''] = v.toFixed(3).split('.');        // keep up to 3 decimals
              const frac = f.replace(/0+$/,'');                 // trim trailing zeros
              const fracPart = frac ? ` and ${frac}/${'1'.padEnd(frac.length+1,'0')}` : '';
              return `${Number(i).toLocaleString()}${fracPart} only`;
              }

          const $amount = $('#Amount');
          const $amountWords = $('#AmountInWords');
          function syncAmountWords(){
            const n = parseFloat($amount.val() || '0') || 0;
            $amountWords.val(toWords(n));
          }
          $amount.on('input', syncAmountWords);
          syncAmountWords();

          // Print (leave as-is)
          $('#btnPrint').on('click', ()=> window.open('@Url.Action("PrintPreview", "ReceiptVouchers", new { id = Model?.Id })','_blank'));

          // PaymentMethod toggle: 1=Cash, 2=Cheque, 3=Transfer
          (function () {
            const $method   = $('#PaymentMethod');
            const $cheque   = $('.cheque-only');
            const $transfer = $('.transfer-only');

            function setGroup($el, show){
              $el.toggleClass('d-none', !show);
              $el.find('input,select,textarea').prop('disabled', !show);
              if(!show){
                $el.find('input[type="text"], input[type="date"], input[type="number"], textarea').val('');
                $el.find('input[type="checkbox"]').prop('checked', false);
                $el.find('select').each(function(){ this.selectedIndex = 0; });
              }
            }
            function onChange(val){
              setGroup($cheque,   val === '2');
              setGroup($transfer, val === '3');
            }
            onChange(String($method.val()));
            $method.on('change', function(){ onChange(this.value); });
          })();

          // -------- Vendor mirror & invoice loader --------
          (function(){
                    const id = @JsonSerializer.Serialize(Model?.Id ?? 0);
                             const Type= @JsonSerializer.Serialize(Model?.PaymentType ?? 0);
                                         if (id>0 || Type !=1 )  return;
                         
                const vendors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                            Model.vendors.Select(c => new { id = c.Id, code = c.Code, name = c.Name })));

           const byId = Object.fromEntries(vendors.map(x => [String(x.id), x]));
           const $sel       = $('#filterVendor');
           const $hiddenId  = $('#vendorId');
           const $codeInput = $('#VendorCode');
            function syncFromSelect() {
              const m = byId[String($sel.val())];
              if (!m) {
                $codeInput.val('');
                $hiddenId.val('');
                return;
              }
              $hiddenId.val(String(m.id));
              $codeInput.val(m.code ?? '');
            }

            function getCurrentVendorId(){
              return Number($sel.val() || $hiddenId.val() || 0);
            }
            async function loadInvoicesForCustomer(vendorId) {
                
                  if (!vendorId  ) { alert('Select a vendor first.'); return; }

              const url = '/ReceiveVoucher/GetVendorInvoiceRowsAsync?vendorId=' + encodeURIComponent(vendorId);
              console.log('FETCH:', url);
              const res = await fetch(url, { headers:{'Accept':'application/json'} });
              if (!res.ok) {
                alert('Failed to load invoices. HTTP ' + res.status);
                return;
              }
              const rows = await res.json(); // expected: [{ sn, humId, date, invoiceNo, amount }]
              renderInvoiceRows(rows || []);
          //    recalcHeaderTotals();
            }
            // init
            (function init(){
              const pre = $hiddenId.val();
              if (pre && byId[pre]) $sel.val(pre);
              syncFromSelect();

              const initialId = getCurrentVendorId();
              if (initialId) loadInvoicesForCustomer(initialId);

              $sel.on('change', function(){
                syncFromSelect();
                loadInvoicesForCustomer(getCurrentVendorId());
              });

              $codeInput.on('blur', function(){
                const val = $(this).val()?.toString() ?? '';
                if (!val) return;
                const m = vendors.find(c => String(c.code) === val);
                if (m){
                  $sel.val(String(m.id));
                  syncFromSelect();
                  loadInvoicesForCustomer(m.id);
                }
              });
            })();
          })();
             //----------- Employees ------------
                  (function(){
                  const id = @JsonSerializer.Serialize(Model?.Id ?? 0);
                          const Type= @JsonSerializer.Serialize(Model?.PaymentType ?? 0);
                                 if (id>0 || Type !=2 )  return;
              const Employees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Employees.Select(c => new { id = c.Id, code = c.Code, name = c.Name })));
debugger
     const byEmployeesId = Object.fromEntries(Employees.map(x => [String(x.id), x]));
     const $selEmployee = $('#filterEmployee');
     const $hiddenEmployeeId    = $('#DebitEmployeeId');
     const $EmployeeInput = $('#EmployeeCode');
          function syncEmployeesFromSelect() {
        const m = byEmployeesId[String($selEmployee.val())];
        if (!m) {
          $EmployeeInput.val('');
          $hiddenEmployeeId.val('');
          return;
        }
        $hiddenEmployeeId.val(String(m.id));
        $EmployeeInput.val(m.code ?? '');
      }
          function getCurrentEmployeesId(){
                            return Number($EmployeeInput.val()  || 0);
          }
          async function loadInvoicesForEmployee(EmployeeId) {
              debugger
                if (!EmployeeId  ) { alert('Select a Employee first.'); return; }

                            const url = '/ReceiveVoucher/GetEmployeeInvoiceRowsAsync?EmployeeId=' + encodeURIComponent(EmployeeId);
            console.log('FETCH:', url);
            const res = await fetch(url, { headers:{'Accept':'application/json'} });
            if (!res.ok) {
              alert('Failed to load invoices. HTTP ' + res.status);
              return;
            }
            const rows = await res.json(); // expected: [{ sn, humId, date, invoiceNo, amount }]
            renderInvoiceRows(rows || []);
        //    recalcHeaderTotals();
          }
          // init
          (function init(){
                    const pre = $hiddenEmployeeId.val();
            if (pre && byEmployeesId[pre]) $selEmployee.val(pre);
                    syncEmployeesFromSelect();

            const initialId = getCurrentEmployeesId();
            if (initialId) loadInvoicesForEmployee(initialId);

            debugger
            $selEmployee.on('change', function(){
                
                      syncEmployeesFromSelect();
              loadInvoicesForEmployee(getCurrentEmployeesId());
            });

            debugger
            $EmployeeInput.on('blur', function(){
              const val = $(this).val()?.toString() ?? '';
              if (!val) return;
              const m = vendors.find(c => String(c.code) === val);
              if (m){
                $selEmployee.val(String(m.id));
                        syncEmployeesFromSelect();
                loadInvoicesForEmployee(m.id);
              }
            });
          })();
        })();

          // -------- Invoice table render & totals --------
          function renderInvoiceRows(rows){
              
            const $tbody = $('#invoiceTable tbody');
            $tbody.empty();
                  const id = @JsonSerializer.Serialize(Model?.Id ?? 0);
                       if (id>0)
                           return;
            if(!rows.length){
              $tbody.append('<tr class="text-center text-muted"><td colspan="10">No invoices found for this vendor.</td></tr>');
              return;
            }
            rows.forEach((r,i)=>{
              // API returns: Date, InvoiceNo, Amount, humId
              const dateStr = r.date ? new Date(r.date).toISOString().slice(0,10) : '';
              const amount  = Number(r.amount ?? 0);   // remaining amount from API
              const humId   = r.humId ?? '';           // you named it humId in the controller
                 
              $tbody.append(`
                <tr data-original-remaining="${amount}">
                  <td class="text-center">${i+1}</td>
                  <td><input class="form-control form-control-sm item-humId" name="Items[${i}].humId"     value="${humId}" readonly></td>
                  <td><input class="form-control form-control-sm item-date"  name="Items[${i}].InvDate"   value="${dateStr}" readonly></td>
                  <td><input class="form-control form-control-sm item-invno" name="Items[${i}].InvoiceNo" value="${r.invoiceNo ?? ''}" readonly></td>
                  <td><input type="number" step="0.01" class="form-control form-control-sm text-end item-Amount" name="Items[${i}].Amount" value="${amount.toFixed(2)}" readonly></td>
                  <td class="text-center"><input type="checkbox" class="form-check-input row-select" name="Items[${i}].Selected"></td>
                  <td><input type="number" step="0.01" min="0" class="form-control form-control-sm text-end item-Payment" name="Items[${i}].Payment" value="0.00" data-max="${amount}" disabled></td>
                  <td><input type="text" class="form-control form-control-sm text-end item-Description" name="Items[${i}].Description" ></td>
                </tr>
              `);
            });
          }
               //     <td><input type="number" step="0.01" class="form-control form-control-sm text-end item-net"   name="Items[${i}].Net"   value="${amount.toFixed(2)}" readonly></td>
              //    <td><input type="number" step="0.01" class="form-control form-control-sm text-end item-net"   name="Items[${i}].Net"   value="${amount.toFixed(2)}" readonly></td>
             // <td class="text-center">
                  //   <button type="button" class="btn btn-link btn-sm view-btn" data-invno="${r.invoiceNo ?? ''}">View</button>
                  // </td>

          // Single-select: only one invoice can be paid at a time
          $('#invoiceTable').on('change', '.row-select', function(){
            if (this.checked){
              // uncheck others

              $('.row-select').not(this).prop('checked', false).trigger('change');
              // enable amount for this row, disable others
              const $tr = $(this).closest('tr');
              $('.item-amount').prop('disabled', true).val('0.00');
              const max = Number($tr.data('original-remaining') || 0);
              $tr.find('.item-Payment').prop('disabled', false).val(max.toFixed(2));
              $tr.find('.item-remaining').val('0.00');
            } else {
              const $tr = $(this).closest('tr');
              const max = Number($tr.data('original-remaining') || 0);
              $tr.find('.item-Payment').prop('disabled', true).val('0.00');
         //     $tr.find('.item-Payment').val(max.toFixed(2));
            }
            recalcHeaderTotals();
          });

          // When user edits amount, cap it to remaining and adjust remaining
          $('#invoiceTable').on('input', '.item-Payment', function(){
            const $tr = $(this).closest('tr');
            const max = Number($tr.data('original-remaining') || 0);
            let val = Number(this.value || 0);
            if (val < 0) val = 0;
            if (val > max) val = max;
            this.value = val.toFixed(2);
            $tr.find('.item-remaining').val((max - val).toFixed(2));
            recalcHeaderTotals();
          });
          // Header totals
          window.recalcHeaderTotals = function(){
            const sum = $('.row-select:checked').length
              ? $('.row-select:checked').closest('tr').find('.item-Payment').toArray().reduce((t,el)=> t + (parseFloat(el.value||'0')||0), 0)
              : 0;
            $('#Amount').val(sum.toFixed(3));
            $('#AmountInWords').val(toWords(sum));
          };
          // optional: handle "View" button (adjust to your real details URL)
          $('#invoiceTable').on('click', '.view-btn', function(){
            const inv = $(this).data('invno');
            if (inv) window.open('/Sales/DetailsByInvNo?invNo=' + encodeURIComponent(inv), '_blank');
          });
        })();
        function toWords(n){
          n = Math.trunc(+String(n).replace(/,/g,'')) || 0;
          if (n < 0) return 'minus ' + toWords(-n);
          if (n === 0) return 'zero only';
          const A=['','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve','thirteen','fourteen','fifteen','sixteen','seventeen','eighteen','nineteen'];
          const B=['','','twenty','thirty','forty','fifty','sixty','seventy','eighty','ninety'];
          function h(x){ return x<20?A[x]:x<100?B[(x/10|0)]+(x%10?'-'+A[x%10]:''):A[(x/100|0)]+' hundred'+(x%100?' '+h(x%100):''); }
          function c(x,s){ return x? h(x)+' '+s : ''; }
          return (c((n/1e12|0),'trillion')+' '+c((n%1e12/1e9|0),'billion')+' '+c((n%1e9/1e6|0),'million')+' '+c((n%1e6/1e3|0),'thousand')+' '+(n%1e3?h(n%1e3):'')).trim()+' only';
        }

    </script>
