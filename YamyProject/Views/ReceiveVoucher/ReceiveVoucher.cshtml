    <script>
        $(function () {
          const $paymentType = $('#PaymentType');
          const $panelEmp    = $('#panelEmployee');
          const $panelVendor = $('#panelVendor');

          function setDisabled($c, disabled) {
            $c.find('input, select, textarea, button').prop('disabled', disabled);
          }
          function isVendorSelected() {
            const val  = String($paymentType.val() ?? '').trim().toLowerCase();
            const text = String($paymentType.find('option:selected').text() ?? '').trim().toLowerCase();

            // Adjust '2' to whatever value your enum uses for Vendor
            return val === 'vendor' || val === '1' || text === 'vendor';
          }

          function swapPanels() {
            const isVendor = isVendorSelected();

            // show/hide both panels
            
            $panelVendor.toggleClass('d-none', !isVendor);
            $panelEmp.toggleClass('d-none', isVendor);

            // enable only the visible panel
            setDisabled($panelVendor, !isVendor);
            setDisabled($panelEmp, isVendor);
          }

          // init + bind
          $paymentType.on('change', swapPanels);
          swapPanels(); // run once on load
        });
    </script>
