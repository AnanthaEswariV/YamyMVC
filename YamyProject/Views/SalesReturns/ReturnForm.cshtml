    <script>
        // (Optional) hide the modal and then fetch details
        window.addEventListener('sales:selected', async (e) => {
          const saleId = e.detail.id;

          // Hide the modal
          const modalEl = document.getElementById('lookupModal');
          bootstrap.Modal.getInstance(modalEl)?.hide();

          // Build the correct URL to your attribute-routed action
          // If your controller has [Route("SalesReturns")] on it, keep "SalesReturns" here.
          const url = '@Url.Action("GetSaleDetails", "SalesReturns")' + '?id=' + encodeURIComponent(saleId);
          
          const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
          if (!res.ok) { alert('Failed to load sale.'); return; }
          const data = await res.json();

          // --- Fill header fields (adapt ids/names to your form) ---
          $('#SalesRefId').val(data.header.id);
          $('#PONO').val(data.header.invoiceId);
          $('#Date').val(data.header.date);          // if DateOnly you might format on server
          $('#CustomerId').val(data.header.customerId).trigger('change');
          $('#customerCode').val(data.header.customerCode).trigger('change');
          $('#customerName').val(data.header.billTo);
          $('#SalesMane').val(data.header.salesMan);
          $('#Val').val(data.header.shipVia);
          $('#Ship').val(data.header.shipTo);
          // ...

          // --- Fill items grid ---
          const $tbody = $('#itemsTable tbody');
          $tbody.empty();
          (data.items || []).forEach((it, i) => {
            // Build a row using your model bindings (example uses plain inputs)
            $tbody.append(`

              <tr>
                <td style="display:none"><input type="hidden" name="Items[${i}].ItemId" value="${it.itemId ?? ''}" class="item-id"></td>
                <td>${i + 1}</td>
                <td><input type="text" name="Items[${i}].ItemCode" class="form-control item-code" value="${it.itemCode ?? ''}" readonly></td>
                <td><input type="text" name="Items[${i}].ItemName" class="form-control item-name" value="${it.itemName ?? ''}" readonly></td>
                <td class="text-center">
                <input type="hidden" name="Items[${i}].SelectedROw" value="false">
                <input type="checkbox"
                class="form-check-input row-select"
                name="Items[${i}].SelectedROw"
                value="true" ${it.selectedRow ? 'checked' : ''}>
                </td>
                <td><input class="form-control form-control-sm item-QTY" name="Items[${i}].QTY" value="${it.qty ?? 0}" readonly></td>
                      <td><input class="form-control form-control-sm item-ReturnQTY"
                  name="Items[${i}].ReturnQTY"
                  value="${it.selectedRow ? (toNum(it.returnQty) || 1) : 0}"
                  ${it.selectedRow ? '' : 'disabled readonly'}></td>
                <td><input class="form-control form-control-sm item-Price" name="Items[${i}].Price" value="${it.price ?? 0}" readonly></td>
                <td><input class="form-control form-control-sm item-Disc" name="Items[${i}].Disc" value="${it.discount ?? 0}" readonly></td>
                <td>
                     <input class="form-control form-control-sm item-VatPersint" name="Items[${i}].VatPersint" value="${it.vatPct ?? 0}" readonly>
                </td>
                <td><input class="form-control form-control-sm item-VatAmonut" name="Items[${i}].VatAmonut" value="${it.vat ?? 0}" readonly></td>
                <td><input class="form-control form-control-sm item-Amount" name="Items[${i}].Amount" value="${it.total ?? 0}" readonly></td>
                <td>
                  <select class="form-select form-select-sm" name="Items[${i}].CostCenterId">
                    ${$('#tpl-cc').html() /* reuse cost center template */}
                  </select>
                </td>
                <td style="display:none"><input type="hidden" name="Items[${i}].CostPrice" class="item-CostPrice" value="${it.costPrice ?? 0}"></td>
                <td style="display:none"><input type="hidden" name="Items[${i}].Type" class="item-Type" value="${it.type ?? ''}"></td>
                <td style="display:none"><input type="hidden" name="Items[${i}].Method" class="item-Method" value="${it.method ?? ''}"></td>
                <td style="display:none"><input type="hidden" name="Items[${i}].WarehouseId" class="item-WarehouseId" value="${it.warehouseId ?? ''}"></td>
              </tr>
            `);

          });

          if (window.updateRowIndexes) updateRowIndexes();
          if (window.calcTotals) calcTotals();
        });
