    <script>
        (function(){
          function toNum(v){
            const n = parseFloat(String(v ?? '').replace(/,/g,''));
            return Number.isFinite(n) ? n : 0;
          }
          function msg(text){
            if (window.toastr) toastr.error(text);
            else alert(text);
          }

          // Handle "qty" change => your editable field is ReturnQTY
          $(document).on('input change', '#itemsTable tbody .item-ReturnQTY', function(){
            const $input = $(this);
            const $tr = $input.closest('tr');

            // row references
            const $itemId   = $tr.find('.item-id');        // hidden item id
            const $qtyAvail = $tr.find('.item-QTY');       // available/original qty (readonly)
            const $retQty   = $input;                      // return qty (editable)

            let ret = toNum($retQty.val());
            const avail = toNum($qtyAvail.val() || $qtyAvail.text());

            // if itemId missing/null => reset
            const itemIdVal = ($itemId.val() ?? '').toString().trim();
            if (!itemIdVal){
              $retQty.val('0');
              msg('Please choose an item first.');
              return;
            }

            // guard negatives
            if (ret < 0){
              $retQty.val('0');
              msg('Return Qty cannot be negative.');
              return;
            }

            // If return qty > available qty -> reset and warn (WinForms behavior)
            if (ret > avail){
              $retQty.val('0');
              msg('Qty not available in sales');
              return;
            }

            // ok -> keep as is (you can format if needed)
          });

          // Handle checkbox change => Selected_Item => reset qty to 0
          $(document).on('change', '#itemsTable tbody .row-select', function(){
            const $tr = $(this).closest('tr');
            const $retQty = $tr.find('.item-ReturnQTY');
            $retQty.val('0').trigger('input'); // trigger to recalc downstream if you have totals logic
          });
        })();

                // checkbox toggles ReturnQTY enable/disable
        $(document).on('change', '#itemsTable tbody .row-select', function(){
          const $tr = $(this).closest('tr');
          toggleReturnQty($tr, $(this).is(':checked'));
        });

        function toNum(v){ const n = parseFloat(String(v ?? '').replace(/,/g,'')); return Number.isFinite(n)?n:0; }
        function toggleReturnQty($tr, checked){
          const $ret = $tr.find('.item-ReturnQTY');
          if (!checked){
            $ret.val('0').prop('disabled', true).prop('readonly', true)
                .removeClass('is-invalid').siblings('.invalid-feedback').remove();
          }else{
            if (!toNum($ret.val())) $ret.val('1'); // default 1 if empty/0
            $ret.prop('disabled', false).prop('readonly', false).removeClass('is-invalid');
          }
        }
        // guard: ReturnQTY cannot exceed available Qty and cannot be negative/empty
        $(document).on('input change', '#itemsTable tbody .item-ReturnQTY', function(){
          const $tr = $(this).closest('tr');
          const avail = toNum($tr.find('.item-QTY').val() || $tr.find('.item-QTY').text());
          let v = toNum($(this).val());
          if (v <= 0){ $(this).val('0'); return; }
          if (v > avail){ $(this).val('0'); if (window.toastr) toastr.error('Qty not available in sales'); else alert('Qty not available in sales'); }
        });

        // block save unless at least one checked with qty > 0
        function validateSelectedWithQty(){
          let any = false, ok = true;
          $('#itemsTable tbody tr').each(function(){
            const $tr = $(this);
            const sel = $tr.find('.row-select').is(':checked');
            const qty = toNum($tr.find('.item-ReturnQTY').val());
            if (sel){ any = true; if (qty <= 0){ ok = false; $tr.find('.item-ReturnQTY').addClass('is-invalid'); } }
          });
          if (!any){ if (window.toastr) toastr.error('Please tick “Select To Return” for at least one row.'); else alert('Please tick “Select To Return” for at least one row.'); }
          return any && ok;
        }

        $('#btnAjaxSave, #btnAjaxSaveClose').on('click', function(e){
          e.preventDefault();
          if (!validateSelectedWithQty()) return;
          // proceed: $('#invoiceForm').trigger('submit'); or postAjax(...)
          $('#invoiceForm').trigger('submit');
        });

    </script>
    <script>
        /* helpers — make sure these exist once on the page */
        function toNum(v){ const n = parseFloat(String(v ?? '').replace(/,/g,'')); return Number.isFinite(n)?n:0; }
        function isTemplateRow($tr){ return $tr.hasClass('template') || $tr.is('[data-template="true"]'); }
        function clearInvalid($el){
          $el.removeClass('is-invalid'); $el.siblings('.invalid-feedback').remove();
        }
        function setInvalid($el, msg){
          $el.addClass('is-invalid');
          let $fb = $el.siblings('.invalid-feedback');
          if ($fb.length===0){ $fb=$('<div class="invalid-feedback"></div>'); $el.after($fb); }
          $fb.text(msg || 'Invalid');
        }

        /* === safer validator for single field === */
        function validateFieldAndMaybeClear(evt){
          try{
            const $input = $(evt.currentTarget || evt.target);
            if (!$input || $input.length===0) return true;

            const $tr = $input.closest('tr');
            const $rows = $('#itemsTable tbody tr');
            const $firstRealRow = $rows.filter((_,tr)=>!isTemplateRow($(tr))).first();
            const isFirstRow = $tr.is($firstRealRow);

            const v = String(($input.val() ?? '')).trim();

            // decide rule by class
            if ($input.is('.item-id')){
              if (isFirstRow && v === '') { setInvalid($input, 'Item ID is required for the first row.'); return false; }
              clearInvalid($input); return true;
            }

            if ($input.is('.item-ReturnQTY')){
              const qty = toNum(v);
              if (qty <= 0){ setInvalid($input, 'Return Qty must be > 0'); return false; }
              clearInvalid($input); return true;
            }

            if ($input.is('.item-Amount')){
              const amt = toNum(v || $input.text());
              if (amt <= 0){ setInvalid($input, 'Amount must be > 0'); return false; }
              clearInvalid($input); return true;
            }

            // default: clear error when user types
            clearInvalid($input);
            return true;
          } catch (err){
            // show where it failed
            console.error('validateFieldAndMaybeClear error on', evt && evt.target, err);
            if (window.toastr) toastr.error('Validation error. Check console for details.');
            return false;
          }
        }

        /* bind once */
        $(document).on('input change', '#itemsTable tbody input, #itemsTable tbody select', validateFieldAndMaybeClear);
    </script>

