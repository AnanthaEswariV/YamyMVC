
@{
    ViewData["Title"] = "ProjectEstimation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <bold> <strong>Project Estimation</strong></bold>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-center mb-4">
            <div style="min-width: 300px;">
                <h6 class="fw-bold mb-2 text-center">Project Name</h6>
                <select class="form-select" id="projectName">
                    <option value="">-- Select Project --</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th> 
                    <th>Project Name</th>
                    <th>Tender Name</th>
                    <th>Submit Date</th>
                    <th>Fees</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Tender Items Modal -->
<div class="modal fade" id="tenderItemsModal" tabindex="-1" aria-labelledby="tenderItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white shadow-sm">
                <h5 class="modal-title fw-semibold d-flex align-items-center" id="tenderItemsModalLabel">
                    <i class="fas fa-list-alt me-2"></i> Tender Items
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="table2" style="font-size:13px; width:100%;">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Unit</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Tender Modal -->
<div class="modal fade" id="tenderModal" tabindex="-1" aria-labelledby="tenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"
         style="max-width: 95%;">

        <div class="modal-content rounded-4 shadow-lg border-0">

            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="tenderModalLabel">Project - Edit Estimate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="tenderForm">
                    <input type="hidden" id="TenderId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" class="form-control" id="tenderDate">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project</label>
                            <div class="input-group">
                                <select class="form-select" id="projectDropdown">
                                    <option value="">-- Select Project --</option>
                                </select>
                                <a href="/Construction/ProjectCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project Code</label>
                            <input type="text" class="form-control" id="projectCode" placeholder="Account Code" readonly>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <select class="form-select" id="debitAccount">
                                <option value="">-- Select Account --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tender Name</label>
                            <div class="input-group">
                                <select class="form-select" id="tenderDropdown">
                                    <option value="">-- Select Tender --</option>
                                </select>
                                <a href="/Construction/TenderCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Submission Date</label>
                            <input type="date" class="form-control" id="submissionDate">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Fees</label>
                            <input type="text" class="form-control" id="fees" placeholder="Fees">
                        </div>

                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" class="form-control" id="tenderDescription" placeholder="Description">
                        </div>

                        <div class="col-md-6">
                            <label for="warehouseDropdown" class="form-label fw-semibold">Warehouse</label>
                            <select id="warehouseDropdown" class="form-select">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>

                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>Sr</th>
                                    <th>Description of Work</th>
                                    <th>View</th>
                                    <th style="width: 90px;">Qty</th>
                                    <th style="width: 90px;">Unit</th>
                                    <th style="width: 90px;">Length</th>
                                    <th style="width: 90px;">Width</th>
                                    <th style="width: 90px;">Thick</th>
                                    <th style="width: 90px;">Rate</th>
                                    <th>Amount</th>
                                    <th>Margin %</th>
                                    <th>Margin Amount</th>
                                    <th>Total</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody id="tenderTableBody"></tbody>
                            <!-- Total Row -->
                            <tfoot class="table-secondary fw-semibold">
                                <tr>
                                    <td colspan="15" class="text-center">
                                        <button type="button" class="btn btn-sm btn-success" id="btnAddRow">
                                            <i class="fas fa-plus me-1"></i> Add Row
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="11" class="text-end">Total Amount:</td>
                                    <td>
                                        <input type="text" id="grandTotal" class="form-control text-center fw-bold" readonly value="0.00" style="width: 100px;">
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btnSaveEstimation">Save Tender</button>
            </div>

        </div>
    </div>
</div>

<!-- BOM Modal -->
<div class="modal fade" id="bomModal" tabindex="-1" aria-labelledby="bomModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header bg-primary text-white shadow-sm">
                <h5 class="modal-title fw-semibold" id="bomModalLabel">
                    Assembly - New Item
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- BOM Table -->
                <table class="table table-bordered table-striped align-middle" style="font-size:13px;">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Item Code</th>
                            <th>Assembly Item Name</th>
                            <th>Qty</th>
                            <th>Cost</th>
                            <th>Total</th>
                            <th>DEL</th>
                        </tr>
                    </thead>
                    <tbody id="bomTableBody">
                        <tr>
                            <td>1</td>
                            <td><input class="form-control form-control-sm"></td>
                            <td><select class="form-select form-select-sm itemNameSelect"></select></td>
                            <td><input class="form-control form-control-sm"></td>
                            <td><input class="form-control form-control-sm"></td>
                            <td><input class="form-control form-control-sm" readonly></td>
                            <td>
                                <button class="btn btn-sm btn-danger">X</button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Total -->
                <div class="row mb-3 align-items-end">
                    <div class="col-md-4">
                        <button type="button" class="btn btn-primary add-btn">
                            Add Item
                        </button>
                    </div>

                    <div class="col-md-4 ms-auto">
                        <label class="form-label">Total Cost</label>
                        <input type="text" class="form-control" readonly>                                            
                    </div>
                </div>


                <!-- Accounts -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">COGS Account</label>
                        <select id="cogsAccount" class="form-select form-select-sm"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Income Account</label>
                        <select id="incomeAccount" class="form-select form-select-sm"></select>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Asset Account</label>
                        <select id="assetAccount" class="form-select form-select-sm"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Preferred Vendor</label>
                        <select id="preferredVendor" class="form-select form-select-sm"></select>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-primary">Save</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>


var itemsList = [];
var currentBomRow = null;   // tender row that opened the BOM modal
var currentBomKey = "";     // localStorage key = "Assembly_" + item description

// ── helpers ──────────────────────────────────────────────────────────────────

function parseDecimal(val) {
    const v = parseFloat(val);
    return isNaN(v) ? 0 : v;
}

function escapeHtml(text) {
    return String(text ?? "").replace(/[&<>"'`=\/]/g, s => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;',
        "'": '&#39;', '/': '&#x2F;', '`': '&#x60;', '=': '&#x3D;'
    })[s]);
}

// ── tender row calculations ───────────────────────────────────────────────────

function calculateTenderRow($row, changedField) {
    const qty      = parseDecimal($row.find(".qty").val());
    const rate     = parseDecimal($row.find(".rate").val());
    const subTotal = qty * rate;

    let marginPct = parseDecimal($row.find(".margin").val());
    let marginAmt = parseDecimal($row.find(".marginamount").val());

    if (changedField === "margin") {
        marginAmt = subTotal * (marginPct / 100);
    } else if (changedField === "marginamount" && subTotal > 0) {
        marginPct = (marginAmt / subTotal) * 100;
    } else {
        marginAmt = subTotal * (marginPct / 100);
    }

    if (!isFinite(marginAmt)) marginAmt = 0;
    if (!isFinite(marginPct)) marginPct = 0;

    $row.find(".amount").val(subTotal.toFixed(2));
    $row.find(".margin").val(marginPct.toFixed(2));
    if (changedField !== "marginamount") {
        $row.find(".marginamount").val(marginAmt.toFixed(2));
    }
    $row.find(".total").val((subTotal + marginAmt).toFixed(2));
    calculateGrandTotal();
}

function calculateGrandTotal() {
    let total = 0;
    $("#tenderTableBody tr").each(function () {
        total += parseDecimal($(this).find(".total").val());
    });
    const grand = total + parseDecimal($("#fees").val());
    $("#grandTotal").val(grand.toFixed(2));
}

function getChangedFieldClass(el) {
    const known = ["qty", "rate", "margin", "marginamount"];
    return $(el).attr("class").split(/\s+/).find(c => known.includes(c));
}

// ── tender table rows ─────────────────────────────────────────────────────────

function buildRowHtml(sr, item = {}) {
    return `
        <tr>
            <td><input type="text" class="form-control text-center sr" value="${sr}" readonly></td>
            <td><input type="text" class="form-control description"
                 value="${escapeHtml(item.description ?? '')}"
                 title="${escapeHtml(item.description ?? '')}"
                 oninput="this.title=this.value" style="min-width:200px;"></td>
            <td><button type="button" class="btn btn-sm btn-info view-btn">BOM</button></td>
            <td><input type="text" class="form-control qty"         value="${item.qty    ?? ''}"></td>
            <td><input type="text" class="form-control unit"        value="${escapeHtml(item.unit ?? '')}"></td>
            <td><input type="text" class="form-control length"      value="${item.length ?? ''}"></td>
            <td><input type="text" class="form-control width"       value="${item.width  ?? ''}"></td>
            <td><input type="text" class="form-control thick"       value="${item.thick  ?? ''}"></td>
            <td><input type="text" class="form-control rate"        value="${item.rate   ?? ''}"></td>
            <td><input type="text" class="form-control amount"   readonly value="${item.amount ?? ''}"></td>
            <td><input type="text" class="form-control margin"      value="${item.margin ?? ''}"></td>
            <td><input type="text" class="form-control marginamount" value="${item.marginAmount ?? ''}"></td>
            <td><input type="text" class="form-control total"    readonly value="${item.total ?? ''}"></td>
            <td><input type="text" class="form-control note"        value="${escapeHtml(item.note ?? '')}"></td>
        </tr>`;
}

function addEmptyRow() {
    $("#tenderTableBody").append(buildRowHtml(0));
    updateSrNumbers();
}

function updateSrNumbers() {
    $("#tenderTableBody tr").each(function (i) {
        $(this).find(".sr").val(i + 1);
    });
}

// ── BOM table ─────────────────────────────────────────────────────────────────

function calculateBomRow($row) {
    const qty   = parseFloat($row.find("td:nth-child(4) input").val()) || 0;
    const cost  = parseFloat($row.find("td:nth-child(5) input").val()) || 0;
    $row.find("td:nth-child(6) input").val((qty * cost).toFixed(2));
    calculateBomTotal();
}

function calculateBomTotal() {
    let total = 0;
    $("#bomTableBody tr").each(function () {
        total += parseFloat($(this).find("td:nth-child(6) input").val()) || 0;
    });
    $(".bom-total-input").val(total.toFixed(2));
    return total;
}

function reindexBomRows() {
    $("#bomTableBody tr").each(function (i) {
        $(this).find("td:first-child").text(i + 1);
    });
}

function attachBomRowListeners(tr) {
    // Auto-add row when last row gets input
    $(tr).find("input, select").on("input change", function () {
        const $rows = $("#bomTableBody tr");
        const isLast = $(tr).is($rows.last());
        const hasValue = $(tr).find("input, select").toArray()
            .some(el => $(el).val().toString().trim() !== "" && $(el).val() !== "");
        if (isLast && hasValue) {
            addBomRow();
        }
        calculateBomRow($(tr));
    });

    // Delete button
    $(tr).find(".btn-danger").on("click", function () {
        $(tr).remove();
        reindexBomRows();
        calculateBomTotal();
    });
}

function addBomRow(itemData = null) {
    const index = $("#bomTableBody tr").length + 1;
    const tr = document.createElement("tr");
    tr.innerHTML = `
        <td>${index}</td>
        <td><input class="form-control form-control-sm" value="${itemData ? escapeHtml(itemData.Code) : ''}"></td>
        <td><select class="form-select form-select-sm itemNameSelect"></select></td>
        <td><input class="form-control form-control-sm" value="${itemData ? itemData.Qty : ''}"></td>
        <td><input class="form-control form-control-sm" value="${itemData ? itemData.Cost : ''}"></td>
        <td><input class="form-control form-control-sm" readonly value="${itemData ? itemData.Total : ''}"></td>
        <td><button class="btn btn-sm btn-danger">X</button></td>
    `;
    $("#bomTableBody").append(tr);
    attachBomRowListeners(tr);

    // Load items into this row's dropdown, then restore selection if editing
    loadItem($(tr).find(".itemNameSelect")).then(() => {
        if (itemData && itemData.Name) {
            const $sel = $(tr).find(".itemNameSelect");
            $sel.find("option").each(function () {
                if ($(this).text().trim() === itemData.Name) {
                    $sel.val($(this).val());
                    return false;
                }
            });
        }
    });

    return tr;
}

// ── localStorage helpers ──────────────────────────────────────────────────────

// KEY FIX: key is always "Assembly_" + item description (trimmed, original case)
function getAssemblyStorageKey(description) {
    return "Assembly_" + (description || "").trim();
}

// Returns [] if not found, or array of assembly items
function getAssemblyForItem(description) {
    if (!description || !description.trim()) return [];

    const key = getAssemblyStorageKey(description);
    const raw = localStorage.getItem(key);

    if (!raw) {
        console.warn("[Assembly] No data in localStorage for key:", key);
        return [];
    }

    try {
        const parsed = JSON.parse(raw);
        if (!parsed || !Array.isArray(parsed.Items) || parsed.Items.length === 0) {
            console.warn("[Assembly] Items array empty for key:", key);
            return [];
        }

        console.log("[Assembly] Found", parsed.Items.length, "items for:", description);

        return parsed.Items.map(x => ({
            Code:            x.Code            || "",
            Name:            x.Name            || description,
            Cost:            parseFloat(x.Cost)  || 0,
            Qty:             parseFloat(x.Qty)   || 0,
            Total:           parseFloat(x.Total) || 0,
            AssetAccountId:  parseInt(parsed.AssetAccountId)  || 0,
            COGSAccountId:   parseInt(parsed.COGSAccountId)   || 0,
            IncomeAccountId: parseInt(parsed.IncomeAccountId) || 0,
            VendorAccountId: parseInt(parsed.VendorAccountId) || 0
        }));
    } catch (e) {
        console.error("[Assembly] Parse error for key:", key, e);
        return [];
    }
}

// ── API loaders ───────────────────────────────────────────────────────────────

function loadItem(selector) {
    return new Promise((resolve, reject) => {
        $.ajax({
            url: '@Url.Action("GetItems", "Lists")',
            type: 'GET',
            success: function (res) {
                if (res.status) {
                    itemsList = res.data;
                    const $ddl = $(selector);
                    $ddl.empty().append('<option value="">Select Item</option>');
                    res.data.forEach(item => {
                        $ddl.append(`<option value="${item.id}">${item.itemName}</option>`);
                    });
                    resolve();
                } else {
                    reject("Failed to load items");
                }
            },
            error: reject
        });
    });
}

function loadWarehouses() {
    $.ajax({
        url: '@Url.Action("GetWarehouses", "Inventory")',
        type: 'GET',
        success: function (result) {
            const $ddl = $('#warehouseDropdown');
            $ddl.empty().append('<option value="">Select Warehouse</option>');
            if (result.status && result.data) {
                result.data.forEach(w => $ddl.append(`<option value="${w.id}">${w.display}</option>`));
            }
        }
    });
}

function loadAccountsAndDefaults() {
    $.ajax({
        url: '@Url.Action("GetAllLevel4Accounts", "Lists")',
        type: 'GET',
        success: function (accounts) {
            [
                { ddl: '#incomeAccount', category: 'Sales' },
                { ddl: '#assetAccount',  category: 'Inventory' },
                { ddl: '#cogsAccount',   category: 'COGS' }
            ].forEach(cfg => {
                const $ddl = $(cfg.ddl);
                $ddl.empty().append('<option value="">-- Select --</option>');
                accounts.forEach(acc => {
                    $ddl.append(`<option value="${acc.id}">${acc.code} - ${acc.name}</option>`);
                });
                $.ajax({
                    url: '@Url.Action("GetDefaultAccountByCategory", "Lists")',
                    type: 'GET',
                    data: { category: cfg.category },
                    success: function (res) {
                        if (res.status && res.accountId > 0) $ddl.val(res.accountId);
                    }
                });
            });
        }
    });
}

function loadPreferredVendors() {
    $.ajax({
        url: '@Url.Action("GetVendorAndSub", "Vendor")',
        type: 'GET',
        success: function (res) {
            if (res.status) {
                const $ddl = $('#preferredVendor');
                $ddl.empty().append('<option value="">-- Select Vendor --</option>');
                res.data.forEach(v => $ddl.append(`<option value="${v.id}">${v.code} - ${v.name}</option>`));
            }
        }
    });
}

function loadProjects() {
    $.ajax({
        url: '@Url.Action("GetProjectManagement", "Construction")',
        type: 'GET',
        success: function (result) {
            if (result.status) {
                const $ddl = $('#projectName');
                $ddl.empty().append('<option value="">-- Select Project --</option>');
                result.data.forEach(p => $ddl.append(`<option value="${p.id}">${p.name}</option>`));
            }
        }
    });
}

function loadProjectTenders(projectId) {
    $.ajax({
        url: '@Url.Action("GetProjectTenders", "Construction")',
        type: 'GET',
        data: { projectId: projectId },
        success: function (res) {
            if (!res.status) { toastr.error('Failed to load project tenders'); return; }

            if ($.fn.DataTable.isDataTable('#table1')) $('#table1').DataTable().clear().destroy();
            const $tbody = $('#table1 tbody').empty();

            if (res.data && res.data.length > 0) {
                res.data.forEach((row, i) => {
                    $tbody.append(`
                        <tr data-id="${row.id}">
                            <td>${i + 1}</td>
                            <td>${row.date ?? ''}</td>
                            <td>${row.projectName ?? ''}</td>
                            <td>${row.tenderName ?? ''}</td>
                            <td>${row.submitDate ?? ''}</td>
                            <td>${row.fees ?? 0}</td>
                            <td>
                                <button class="btn btn-sm btn-primary editTenderBtn"
                                    data-tender='${JSON.stringify(row)}'>
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-primary viewItemsBtn"
                                    data-id="${row.id}">
                                    <i class="fas fa-book"></i>
                                </button>
                            </td>
                        </tr>`);
                });
                $('#table1').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'excelHtml5', text: '<i class="fas fa-file-excel me-1"></i> Excel', className: 'btn btn-primary btn-sm' },
                        { extend: 'print',      text: '<i class="fas fa-print me-1"></i> Print',     className: 'btn btn-primary btn-sm' }
                    ],
                    order: [[0, 'asc']], pageLength: 25
                });
            } else {
                $tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
            }
        }
    });
}

function loadTenderItems(tenderId) {
    $.ajax({
        url: '@Url.Action("GetTenderItems", "Construction")',
        type: 'GET',
        data: { tenderId: tenderId },
        success: function (res) {
            if ($.fn.DataTable.isDataTable('#table2')) $('#table2').DataTable().clear().destroy();
            const $tbody = $('#table2 tbody').empty();

            if (res.status && res.data && res.data.length > 0) {
                res.data.forEach((item, i) => {
                    $tbody.append(`
                        <tr>
                            <td>${i + 1}</td>
                            <td>${item.itemName ?? ''}</td>
                            <td>${item.qty ?? 0}</td>
                            <td>${item.rate ?? 0}</td>
                            <td>${item.unit ?? ''}</td>
                            <td>${item.amount ?? 0}</td>
                        </tr>`);
                });
                $('#table2').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'excelHtml5', text: '<i class="fas fa-file-excel me-1"></i> Excel', className: 'btn btn-primary btn-sm' },
                        { extend: 'print',      text: '<i class="fas fa-print me-1"></i> Print',     className: 'btn btn-primary btn-sm' }
                    ],
                    order: [[0, 'asc']], pageLength: 10
                });
            } else {
                $tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>`);
            }
        }
    });
}

function populateBankAccounts() {
    $.ajax({
        url: '@Url.Action("GetAccruedSalaries", "HR")',
        type: 'GET',
        success: function (res) {
            const data = Array.isArray(res) ? res : res.data || [];
            if (!data.length) return;
            const $ddl = $('#debitAccount').empty().append('<option value="">-- Select --</option>');
            data.forEach(item => $ddl.append(`<option value="${item.id}">${item.code} - ${item.name}</option>`));
        }
    });
}

// ── document ready ────────────────────────────────────────────────────────────

$(document).ready(function () {

    // Initial loads
    loadWarehouses();
    loadAccountsAndDefaults();
    loadPreferredVendors();
    loadProjects();
    populateBankAccounts();
    loadProjectTenders();
    loadItem(".itemNameSelect");

    // Project filter for main table
    $('#projectName').on('change', function () {
        const id = $(this).val();
        if (id) {
            loadProjectTenders(id);
        } else {
            if ($.fn.DataTable.isDataTable('#table1')) $('#table1').DataTable().clear().destroy();
            $('#table1 tbody').html(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
        }
    });

    // View items button
    $(document).on('click', '.viewItemsBtn', function () {
        const tenderId = $(this).data('id');
        if (tenderId) { $('#tenderItemsModal').modal('show'); loadTenderItems(tenderId); }
    });

    // Load modal project dropdown
    $.ajax({
        url: '@Url.Action("GetProjectManagement", "Construction")',
        type: 'GET',
        success: function (res) {
            if (res.status) {
                const $ddl = $('#projectDropdown').empty().append('<option value="">-- Select Project --</option>');
                res.data.forEach(p => $ddl.append(`<option value="${p.id}" data-code="${p.code}">${p.name}</option>`));
            }
        }
    });

    $('#projectDropdown').on('change', function () {
        $('#projectCode').val($(this).find('option:selected').data('code') || '');
    });

    // Load modal tender dropdown
    $.ajax({
        url: '@Url.Action("GetTenders", "Construction")',
        type: 'GET',
        success: function (res) {
            if (res.status) {
                const $ddl = $('#tenderDropdown');
                res.data.forEach(t => $ddl.append(`<option value="${t.id}">${t.name}</option>`));
            }
        }
    });

    // ── Edit tender button ────────────────────────────────────────────────────
    $(document).on("click", ".editTenderBtn", function () {
        const tender = JSON.parse($(this).attr("data-tender") || "null");
        if (!tender) return;

        $("#TenderId").val(tender.id ?? 0);
        $("#tenderDate").val(tender.date ?? new Date().toISOString().slice(0, 10));
        $("#projectDropdown").val(tender.project_Id ?? 0);
        $("#projectCode").val(tender.code ?? "");
        $("#debitAccount").val(tender.account_Id ?? 0);
        $("#warehouseDropdown").val(tender.warehouse_Id ?? 0);
        $("#tenderDropdown").val(tender.tender_Name_Id ?? 0);
        $("#submissionDate").val(tender.submitDate ?? new Date().toISOString().slice(0, 10));
        $("#fees").val(tender.fees ?? 0);
        $("#tenderDescription").val(tender.description ?? "");
        $("#tenderTableBody").empty();

        $.ajax({
            url: '@Url.Action("GetTenderItems", "Construction")',
            type: 'GET',
            data: { tenderId: tender.id },
            success: function (res) {
                if (res && res.status && res.data && res.data.length > 0) {
                    res.data.forEach((item, i) => {
                        $("#tenderTableBody").append(`
                            <tr>
                                <td><input type="text" class="form-control sr" value="${item.sr ?? i + 1}" readonly></td>
                                <td><input type="text" class="form-control description" value="${item.name ?? ''}"></td>
                                <td><button type="button" class="btn btn-sm btn-info view-btn">BOM</button></td>
                                <td><input type="text" class="form-control qty"          value="${item.qty ?? 0}"></td>
                                <td><input type="text" class="form-control unit"         value="${item.unit_Name ?? ''}"></td>
                                <td><input type="text" class="form-control length"       value="${item.length ?? 0}"></td>
                                <td><input type="text" class="form-control width"        value="${item.width ?? 0}"></td>
                                <td><input type="text" class="form-control thick"        value="${item.thickness ?? 0}"></td>
                                <td><input type="text" class="form-control rate"         value="${item.rate ?? 0}"></td>
                                <td><input type="text" class="form-control amount" readonly value="${item.amount ?? 0}"></td>
                                <td><input type="text" class="form-control margin"       value="${item.margin_Percentage ?? 0}"></td>
                                <td><input type="text" class="form-control marginamount" value="${item.margin_Amount ?? 0}"></td>
                                <td><input type="text" class="form-control total"  readonly value="${item.totoal ?? 0}"></td>
                                <td><input type="text" class="form-control note"         value="${item.note ?? ''}"></td>
                            </tr>`);
                    });
                    $("#tenderTableBody tr").each(function () { calculateTenderRow($(this), "rate"); });
                    calculateGrandTotal();
                } else {
                    addEmptyRow();
                }
            },
            error: function () { toastr.error("Failed to load BOQ items"); addEmptyRow(); }
        });

        $("#tenderModalLabel").text("Edit Project Tender");
        $("#tenderModal").modal("show");
    });

    // ── Tender table input changes ────────────────────────────────────────────
    $("#tenderTableBody").on("input change", ".qty, .rate, .margin, .marginamount", function () {
        calculateTenderRow($(this).closest("tr"), getChangedFieldClass(this));
    });

    // Auto-add row when last row gets any value
    $("#tenderTableBody").on("input change", "tr:last-child input", function () {
        const hasValue = $(this).closest("tr").find("input").toArray()
            .some(el => $(el).val().trim() !== "");
        if (hasValue) addEmptyRow();
    });

    $("#fees").on("input change", calculateGrandTotal);

    $("#tenderModal").on('shown.bs.modal', function () {
        $("#btnAddRow").off('click').on("click", function () { addEmptyRow(); toastr.success("New row added!"); });
    });

    // ── BOM modal — open ──────────────────────────────────────────────────────
    // FIX: set currentBomKey from the row's description BEFORE opening modal
    $(document).on("click", ".view-btn", function () {
        currentBomRow = $(this).closest("tr");
        const description = currentBomRow.find(".description").val().trim();

        if (!description) {
            toastr.warning("Please enter an item description before opening BOM.");
            return;
        }

        // ✅ KEY FIX: modal title = item description = localStorage key suffix
        currentBomKey = getAssemblyStorageKey(description);
        $("#bomModalLabel").text(description);

        // Clear BOM table
        $("#bomTableBody").empty();

        // Restore accounts to defaults first
        loadAccountsAndDefaults();
        loadPreferredVendors();

        // Load existing assembly data if saved
        const existing = localStorage.getItem(currentBomKey);
        if (existing) {
            try {
                const parsed = JSON.parse(existing);
                console.log("[BOM] Restoring existing data for:", currentBomKey, parsed);

                // Restore account selections
                if (parsed.AssetAccountId)  setTimeout(() => $("#assetAccount").val(parsed.AssetAccountId), 400);
                if (parsed.COGSAccountId)   setTimeout(() => $("#cogsAccount").val(parsed.COGSAccountId), 400);
                if (parsed.IncomeAccountId) setTimeout(() => $("#incomeAccount").val(parsed.IncomeAccountId), 400);
                if (parsed.VendorAccountId) setTimeout(() => $("#preferredVendor").val(parsed.VendorAccountId), 400);

                // Restore rows
                if (Array.isArray(parsed.Items) && parsed.Items.length > 0) {
                    parsed.Items.forEach(item => addBomRow(item));
                    calculateBomTotal();
                } else {
                    addBomRow();
                }
            } catch (e) {
                console.error("[BOM] Restore error:", e);
                addBomRow();
            }
        } else {
            console.log("[BOM] No existing data, starting fresh for:", currentBomKey);
            addBomRow();
        }

        new bootstrap.Modal(document.getElementById("bomModal")).show();
    });

    // ── BOM item dropdown change ──────────────────────────────────────────────
    $(document).on("change", "#bomTableBody .itemNameSelect", function () {
        const id  = parseInt($(this).val(), 10);
        const $row = $(this).closest("tr");
        if (id && itemsList.length) {
            const found = itemsList.find(x => x.id === id);
            if (found) {
                $row.find("td:nth-child(2) input").val(found.code || "");
                $row.find("td:nth-child(5) input").val(found.cost_price || 0);
                calculateBomRow($row);
            }
        } else {
            $row.find("td:nth-child(2) input").val("");
            $row.find("td:nth-child(5) input").val(0);
            calculateBomRow($row);
        }
    });

    $(document).on("input", "#bomTableBody input", function () {
        calculateBomRow($(this).closest("tr"));
    });

    // ── BOM modal — save ──────────────────────────────────────────────────────
    // FIX: use currentBomKey (set when modal opened) not modal title text
    $(document).on("click", "#bomModal .modal-footer .btn-primary", function () {

        if (!currentBomKey) {
            toastr.warning("No item linked. Please close and reopen BOM from a row.");
            return;
        }

        const items = [];
        let grandTotal = 0;

        $("#bomTableBody tr").each(function (i) {
            const $row = $(this);
            const code  = $row.find("td:eq(1) input").val().trim();
            const $sel  = $row.find("td:eq(2) select");
            const name  = $sel.find("option:selected").text().trim();
            const qty   = parseFloat($row.find("td:eq(3) input").val()) || 0;
            const cost  = parseFloat($row.find("td:eq(4) input").val()) || 0;
            const total = qty * cost;

            // Only save rows that have a real item selected
            if (name && name !== "Select Item" && qty > 0) {
                $row.find("td:eq(5) input").val(total.toFixed(2));
                grandTotal += total;
                items.push({ ItemId: i + 1, Code: code, Name: name, Qty: qty, Cost: cost, Total: total });
            }
        });

        if (items.length === 0) {
            toastr.warning("Please add at least one assembly item with qty > 0.");
            return;
        }

        const model = {
            RefId:           currentBomKey.replace("Assembly_", ""),
            AssetAccountId:  parseInt($("#assetAccount").val())   || 0,
            IncomeAccountId: parseInt($("#incomeAccount").val())  || 0,
            VendorAccountId: parseInt($("#preferredVendor").val())|| 0,
            COGSAccountId:   parseInt($("#cogsAccount").val())    || 0,
            TotalCost:       grandTotal,
            Items:           items
        };

        // ✅ Save with key that matches what getAssemblyForItem() will look for
        localStorage.setItem(currentBomKey, JSON.stringify(model));
        console.log("[BOM] Saved to localStorage:", currentBomKey, model);

        // Update tender row
        if (currentBomRow) {
            const rowQty    = parseDecimal(currentBomRow.find(".qty").val());
            const rowRate   = parseDecimal(currentBomRow.find(".rate").val());
            const newAmount = (rowQty * rowRate) + grandTotal;
            const marginPct = parseDecimal(currentBomRow.find(".margin").val());
            const marginAmt = isFinite((newAmount * marginPct) / 100)
                              ? (newAmount * marginPct) / 100 : 0;

            currentBomRow.find(".amount").val(newAmount.toFixed(2));
            currentBomRow.find(".marginamount").val(marginAmt.toFixed(2));
            currentBomRow.find(".total").val((newAmount + marginAmt).toFixed(2));
            calculateGrandTotal();
            toastr.success(`Assembly saved: ${items.length} item(s), total ${grandTotal.toFixed(2)}`);
        }

        $("#bomModal").modal("hide");
    });

    // ── Save estimation ───────────────────────────────────────────────────────
    $("#btnSaveEstimation").click(function () {

        const model = {
            Id:           parseInt($("#TenderId").val())        || 0,
            Date:         $("#tenderDate").val(),
            SubmissionDate: $("#submissionDate").val(),
            ProjectId:    parseInt($("#projectDropdown").val()) || 0,
            TenderNameId: parseInt($("#tenderDropdown").val())  || 0,
            TenderName:   $("#tenderDropdown option:selected").text(),
            AccountId:    parseInt($("#debitAccount").val())    || 0,
            WarehouseId:  parseInt($("#warehouseDropdown").val())|| 0,
            Fees:         $("#fees").val() || "0",
            Description:  $("#tenderDescription").val(),
            TotalAmount:  $("#grandTotal").val() || "0",
            Items: []
        };

        // Build items — each carries its own AssemblyItems
        $("#tenderTableBody tr").each(function () {
            const $row       = $(this);
            const sr          = $row.find(".sr").val();
            const description = $row.find(".description").val().trim();
            if (!description) return;

            const assemblyItems = getAssemblyForItem(description);

            // Debug: show what is being sent
            console.log(`[Save] Item "${description}" → AssemblyItems: ${assemblyItems.length}`);

            model.Items.push({
                Sr:               sr || "",
                Name:             description,
                Unit:             $row.find(".unit").val()         || "",
                Qty:              $row.find(".qty").val()           || "0",
                Rate:             $row.find(".rate").val()          || "0",
                Amount:           $row.find(".amount").val()        || "0",
                Length:           $row.find(".length").val()        || "0",
                Width:            $row.find(".width").val()         || "0",
                Thick:            $row.find(".thick").val()         || "0",
                Note:             $row.find(".note").val()          || "",
                MarginAmount:     $row.find(".marginamount").val()  || "0",
                MarginPercentage: $row.find(".margin").val()        || "0",
                AssemblyItems:    assemblyItems   // ✅ array of assembly items or []
            });
        });

        console.log("[Save] Full model:", JSON.stringify(model, null, 2));

        if (!model.ProjectId)    { toastr.warning("Project must be selected");    return; }
        if (!model.TenderNameId) { toastr.warning("Tender must be selected");     return; }
        if (model.Items.length === 0) { toastr.warning("Insert items first");     return; }
        if (parseFloat(model.TotalAmount) <= 0) {
            toastr.warning("Total must be bigger than zero"); return;
        }

        $.ajax({
            url: '@Url.Action("SaveOrUpdateEstimation", "Construction")',
            type: 'POST',
            data: JSON.stringify(model),
            contentType: 'application/json; charset=utf-8',
            beforeSend: function () {
                $("#btnSaveEstimation").prop("disabled", true).text("Generating Estimate...");
            },
            success: function (res) {
                if (res.status) {
                    toastr.success(res.message);
                    // Clear all assembly data from localStorage
                    for (let i = localStorage.length - 1; i >= 0; i--) {
                        const key = localStorage.key(i);
                        if (key && key.startsWith("Assembly_")) localStorage.removeItem(key);
                    }
                    $("#tenderModal").modal("hide");
                    loadProjectTenders($('#projectName').val());
                } else {
                    toastr.warning(res.message);
                }
            },
            error: function (xhr) {
                toastr.error(xhr.responseJSON?.message || xhr.responseText || "Unexpected error");
            },
            complete: function () {
                $("#btnSaveEstimation").prop("disabled", false).text("Generate Estimate");
            }
        });
    });

    // ── Initial state ─────────────────────────────────────────────────────────
    addEmptyRow();
    calculateGrandTotal();

}); // end document.ready

    </script>
}

