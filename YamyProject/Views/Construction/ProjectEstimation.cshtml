
@{
    ViewData["Title"] = "ProjectEstimation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <bold> <strong>Project Estimation</strong></bold>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-center mb-4">
            <div style="min-width: 300px;">
                <h6 class="fw-bold mb-2 text-center">Project Name</h6>
                <select class="form-select" id="projectName">
                    <option value="">-- Select Project --</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Project Name</th>
                    <th>Tender Name</th>
                    <th>Submit Date</th>
                    <th>Fees</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Tender Items Modal -->
<div class="modal fade" id="tenderItemsModal" tabindex="-1" aria-labelledby="tenderItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white shadow-sm">
                <h5 class="modal-title fw-semibold d-flex align-items-center" id="tenderItemsModalLabel">
                    <i class="fas fa-list-alt me-2"></i> Tender Items
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="table2" style="font-size:13px; width:100%;">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Unit</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Tender Modal -->
<div class="modal fade" id="tenderModal" tabindex="-1" aria-labelledby="tenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content rounded-4 shadow-lg border-0">

            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="tenderModalLabel">Project - Edit Estimate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="tenderForm">
                    <input type="hidden" id="TenderId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" class="form-control" id="tenderDate">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project</label>
                            <div class="input-group">
                                <select class="form-select" id="projectDropdown">
                                    <option value="">-- Select Project --</option>
                                </select>
                                <a href="/Construction/ProjectCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project Code</label>
                            <input type="text" class="form-control" id="projectCode" placeholder="Account Code" readonly>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <select class="form-select" id="debitAccount">
                                <option value="">-- Select Account --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Tender Name</label>
                            <div class="input-group">
                                <select class="form-select" id="tenderDropdown">
                                    <option value="">-- Select Tender --</option>
                                </select>
                                <a href="/Construction/TenderCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Submission Date</label>
                            <input type="date" class="form-control" id="submissionDate">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Fees</label>
                            <input type="text" class="form-control" id="fees" placeholder="Fees">
                        </div>

                        <div class="col-md-3 d-flex align-items-end">
                            <button class="btn btn-primary w-100" type="button" disabled>Import BOQ</button>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" class="form-control" id="tenderDescription" placeholder="Description">
                        </div>

                        <div class="col-md-6">
                            <label for="warehouseDropdown" class="form-label fw-semibold">Warehouse</label>
                            <select id="warehouseDropdown" class="form-select">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>

                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width:90px;">Sr</th>
                                    <th>Description of Work</th>
                                    <th style="width: 90px;">Qty</th>
                                    <th style="width: 90px;">Unit</th>
                                    <th style="width: 90px;">Length</th>
                                    <th style="width: 90px;">Width</th>
                                    <th style="width: 90px;">Thick</th>
                                    <th style="width: 90px;">Rate</th>
                                    <th>Amount</th>
                                    <th>Margin %</th>
                                    <th>Margin Amount</th>
                                    <th>Total</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody id="tenderTableBody"></tbody>
                            <!-- Total Row -->
                            <tfoot class="table-secondary fw-semibold">
                                <tr>
                                    <td colspan="11" class="text-end">Total Amount:</td>
                                    <td>
                                        <input type="text" id="grandTotal" class="form-control text-center fw-bold" readonly value="0.00" style="width: 100px;">
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btnSaveEstimation">Save Tender</button>
            </div>

        </div>
    </div>
</div>





@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
  

    <script>

        function loadWarehouses() {
            $.ajax({
                url: '/Inventory/GetWarehouses',
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        // Check if there are warehouses to display
                        if (result.data && result.data.length > 0) {
                            result.data.forEach(w => {
                                dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                            });
                        } else {
                            dropdown.append('<option value="">No warehouses available</option>');
                        }
                    } else {
                        alert(result.message || 'Error loading warehouses');
                    }
                },
                error: function(err) {
                    console.error('Error fetching data:', err);
                    alert('Failed to load warehouse data. Please try again later.');
                }
            });
        }

        $(document).ready(function () {

            loadWarehouses();

            function loadProjects() {
                $.ajax({
                    url: '/Construction/GetProjects',
                    type: 'GET',
                    success: function (result) {
                        if (result.status) {
                            const $dropdown = $('#projectName');
                            $dropdown.empty();
                            $dropdown.append('<option value="">-- Select Project --</option>');

                            $.each(result.data, function (index, project) {
                                $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                            });
                        } else {
                            toastr.error('Failed to load projects');
                        }
                    },
                    error: function () {
                        toastr.error('Error loading projects');
                    }
                });
            }

            loadProjects();

            function loadProjectTenders(projectId) {
                $.ajax({
                    url: '/Construction/GetProjectTenders',
                    type: 'GET',
                    data: { projectId: projectId },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error('Failed to load project tenders');
                            return;
                        }

                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().clear().destroy();
                        }

                        const tbody = $('#table1 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                const tr = `
                                    <tr data-id="${row.id}" style="cursor:pointer;">
                                        <td>${i + 1}</td>
                                        <td>${row.date ?? ''}</td>
                                        <td>${row.projectName ?? ''}</td>
                                        <td>${row.tenderName ?? ''}</td>
                                        <td>${row.submitDate ?? ''}</td>
                                        <td>${row.fees ?? 0}</td>
                                        <td>
                                                        <button class="btn btn-sm btn-primary editTenderBtn" data-tender='${JSON.stringify(row)}' title="Edit Tender">
            <i class="fas fa-pen"></i>
        </button>

                                            <button class="btn btn-sm btn-primary viewItemsBtn" data-id="${row.id}" title="View Items">
                                                <i class="fas fa-book"></i>
                                            </button>
                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            // Initialize DataTable
                            $('#table1').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                        extend: 'pdfHtml5',
                                        text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                        className: 'btn btn-primary btn-sm'
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 25
                            });
                        } else {
                            tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading project tenders');
                    }
                });
            }

            $('#projectName').on('change', function () {
                const projectId = $(this).val();
                if (projectId) {
                    loadProjectTenders(projectId);
                } else {
                    // Clear table if nothing selected
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }
                    $('#table1 tbody').html(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                }
            });

            $(document).on('click', '.viewItemsBtn', function () {
            const tenderId = $(this).data('id');
            if (!tenderId) return;

            $('#tenderItemsModal').modal('show');
            loadTenderItems(tenderId);
        });

            function loadTenderItems(tenderId) {
            $.ajax({
                url: '/Construction/GetTenderItems',
                type: 'GET',
                data: { tenderId: tenderId },
                success: function (res) {
                    // Destroy DataTable if already exists
                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tbody = $('#table2 tbody');
                    tbody.empty();

                    if (res.status && res.data && res.data.length > 0) {
                        $.each(res.data, function (i, item) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${item.itemName ?? ''}</td>
                                    <td>${item.qty ?? 0}</td>
                                    <td>${item.rate ?? 0}</td>
                                    <td>${item.unit ?? ''}</td>
                                    <td>${item.amount ?? 0}</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable with export buttons
                        $('#table2').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 10
                        });
                    } else {
                        tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Failed to load tender items');
                }
            });
        }

            function populateBankAccounts() {
            $.ajax({
                url: '/HR/GetAccruedSalaries',
                type: 'GET',
                success: function(res) {
                    const data = Array.isArray(res) ? res : res.data || [];

                    if (!data.length) return;

                    // Target both debit and credit selects
                    const accountSelectors = ['#debitAccount'];

                    accountSelectors.forEach(function(selector) {
                        const $select = $(selector);
                        const selectedId = $select.data('selected-id'); 

                        // Clear existing options and add default
                        $select.empty().append('<option value="">-- Select --</option>');

                        // Append new options
                        $.each(data, function(i, item) {
                            const $option = $('<option>', {
                                value: item.id,
                                text: `${item.code} - ${item.name}`,
                                selected: String(item.id) === String(selectedId)
                            });

                            $select.append($option);
                        });
                    });
                },
                error: function(err) {
                    console.error('Failed to fetch bank accounts:', err);
                }
            });
        }

            populateBankAccounts();

            $.ajax({
            url: '/Construction/GetProjects',
            type: 'GET',
            dataType: 'json',
            success: function (response) {
                if (response.status) {
                    var dropdown = $('#projectDropdown');
                    dropdown.empty().append('<option value="">-- Select Project --</option>');
                    response.data.forEach(function (project) {
                        dropdown.append(
                            $('<option>', {
                                value: project.id,
                                text: project.name,
                                'data-code': project.code
                            })
                        );
                    });
                } else {
                    console.error('Failed to load projects:', response.message);
                }
            },
            error: function (xhr, status, error) {
                console.error('Error fetching projects:', error);
            }
        });

            $('#projectDropdown').on('change', function () {
            var selectedOption = $(this).find('option:selected');
            var projectCode = selectedOption.data('code') || '';

            // Fill the input with project code
            $('input[placeholder="Account Code"]').val(projectCode);
        });

            $.ajax({
            url: '/Construction/GetTenders',
            type: 'GET',
            dataType: 'json',
            success: function(response) {
                if (response.status) {
                    var dropdown = $('#tenderDropdown');
                    response.data.forEach(function(tender) {
                        dropdown.append(
                            $('<option>', {
                                value: tender.id,
                                text: tender.name
                            })
                        );
                    });
                } else {
                    console.error('Failed to load tenders:', response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error fetching tenders:', error);
            }
        });

           



        });
        
        $(document).ready(function () {

             $(document).on("click", ".editTenderBtn", function () {
            const tenderStr = $(this).attr("data-tender");
            const tender = tenderStr ? JSON.parse(tenderStr) : null;
            if (!tender) {
                console.warn("No tender data found!");
                return;
            }

            // Fill main tender info
            $("#TenderId").val(tender.id ?? 0);
            $("#tenderDate").val(tender.date ?? new Date().toISOString().slice(0,10));
            $("#projectDropdown").val(tender.project_Id ?? 0);
            $("#projectCode").val(tender.code ?? "");
            $("#debitAccount").val(tender.account_Id ?? 0);
            $("#warehouseDropdown").val(tender.warehouse_Id ?? 0);
            $("#tenderDropdown").val(tender.tender_Name_Id ?? 0);
            $("#submissionDate").val(tender.submitDate ?? new Date().toISOString().slice(0,10));
            $("#fees").val(tender.fees ?? 0);
            $("#tenderDescription").val(tender.description ?? "");

            // Clear existing BOQ rows
            $("#tenderTableBody").empty();

            $.ajax({
                url: '/Construction/GetTenderItems',
                type: 'GET',
                data: { tenderId: tender.id },
                success: function(res) {
                    if (!res || !res.status) {
                        toastr.warning("No BOQ items found");
                        addEmptyRow();
                        return;
                    }
                    const items = res.data;
                   
                    if (items.length > 0) {
                        items.forEach((item, index) => {
                            const sr = item.sr ?? String.fromCharCode(65 + index);
                            $("#tenderTableBody").append(`
                                <tr>
                                    <td><input type="text" class="form-control sr" value="${sr}" name="Items[0].Sr" readonly></td>
                                    <td><input type="text" class="form-control description" value="${item.name ?? ''}" name="Items[0].Description" placeholder="Description of work"></td>
                                    <td><input type="text" class="form-control qty" value="${item.qty ?? 0}" name="Items[0].Qty"></td>
                                    <td><input type="text" class="form-control unit" value="${item.unit_Name ?? ''}" name="Items[0].Unit"></td>
                                    <td><input type="text" class="form-control length" value="${item.length ?? 0}" name="Items[0].Length"></td>
                                    <td><input type="text" class="form-control width" value="${item.width ?? 0}" name="Items[0].Width"></td>
                                    <td><input type="text" class="form-control thick" value="${item.thickness ?? 0}" name="Items[0].Thick"></td>
                                    <td><input type="text" class="form-control rate" value="${item.rate ?? 0}" name="Items[0].Rate" ></td>
                                    <td><input type="text" class="form-control amount" readonly value="${item.amount ?? 0}" name="Items[0].Amount"></td>
                                     <td><input type="text" class="form-control margin" value="${item.margin_Percentage ?? 0}" name="Items[0].MarginPercentage"></td>
                                    <td><input type="text" class="form-control marginamount" value="${item.margin_Amount ?? 0}" name="Items[0].MarginAmount"></td>
                                    <td><input type="text" class="form-control total" readonly value="${item.totoal ?? 0}"  name="Items[0].Total"></td>
                                    <td><input type="text" class="form-control note" value="${item.note ?? 0}" name="Items[0].Note"></td>
                                </tr>
                            `);
                        });

        $("#tenderTableBody tr").each(function () {
            calculateRow($(this), "rate");
        });

        calculateGrandTotal();
                    } else {
                        addEmptyRow();
                    }
                },
                error: function() {
                    toastr.error("Failed to load BOQ items");
                    addEmptyRow();
                }
            });


            $("#tenderModalLabel").text("Edit Project Tender");
            $("#tenderModal").modal("show");
        });

            function addEmptyRow() {
            $("#tenderTableBody").append(`
                <tr>
                    <td><input type="text" class="form-control sr" value="A" readonly></td>
                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                    <td><input type="text" class="form-control qty"></td>
                    <td><input type="text" class="form-control unit"></td>
                    <td><input type="text" class="form-control length"></td>
                    <td><input type="text" class="form-control width"></td>
                    <td><input type="text" class="form-control thick"></td>
                    <td><input type="text" class="form-control rate" ></td>
                    <td><input type="text" class="form-control amount" readonly></td>
                       <td><input type="text" class="form-control margin"></td>
                    <td><input type="text" class="form-control marginamount"></td>
                    <td><input type="text" class="form-control total readonly" ></td>
                    <td><input type="text" class="form-control note" ></td>
                </tr>
            `);
        }


                    $("#btnSaveEstimation").click(function () {

            const model = {
                Id: parseInt($("#TenderId").val()) || 0,
                Date: $("#tenderDate").val(),
                ProjectId: parseInt($("#projectDropdown").val()) || 0,
                TenderNameId: parseInt($("#tenderDropdown").val()) || 0,
                AccountId: parseInt($("#debitAccount").val()) || 0,
                WarehouseId: parseInt($("#warehouseDropdown").val()) || 0,
                SubmissionDate: $("#submissionDate").val(),
                Fees: parseFloat($("#fees").val()) || 0,
                Description: $("#tenderDescription").val(),
                Amount: parseFloat($("#grandTotal").val()) || 0,
                Items: []
            };

            // Loop through BOQ items
            $("#tenderTableBody tr").each(function () {
                const $row = $(this);
                const description = $row.find(".description").val();
                if (description && description.trim() !== "") {
                    const item = {
                        Sr: $row.find(".sr").val(),
                        Description: description,
                        Unit: $row.find(".unit").val(),
                        Qty: parseFloat($row.find(".qty").val()) || 0,
                        Rate: parseFloat($row.find(".rate").val()) || 0,
                        Amount: parseFloat($row.find(".amount").val()) || 0,
                        Length: parseFloat($row.find(".length").val()) || 0,
                        Width: parseFloat($row.find(".width").val()) || 0,
                        Thick: parseFloat($row.find(".thick").val()) || 0,
                        Note: $row.find(".note").val(),
                        MarginAmount: parseFloat($row.find(".marginamount").val()) || 0,
                        MarginPercentage: parseFloat($row.find(".margin").val()) || 0
                    };
                    model.Items.push(item);
                }
            });

            // Validation (optional)
            if (!model.ProjectId) {
                toastr.warning("Please select a Project");
                return;
            }
            if (!model.TenderNameId) {
                toastr.warning("Please select a Tender Name");
                return;
            }

            $.ajax({
                url: '/Construction/SaveOrUpdateEstimation',
                type: 'POST',
                data: JSON.stringify(model),
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {
                    $("#btnSaveEstimation").prop("disabled", true).text("Saving...");
                },
                success: function (response) {
                    if (response.status) {
                        toastr.success(response.message || "Saved successfully!");
                        $("#tenderModal").modal("hide");
                    } else {
                        toastr.warning(response.message || "Save failed!");
                    }
                },
                error: function (xhr) {
                    toastr.error("Error: " + (xhr.responseText || "Unexpected error"));
                },
                complete: function () {
                    $("#btnSaveEstimation").prop("disabled", false).text("Save Tender");
                }
            });
        });

            function escapeHtml(text) {
                return String(text ?? "").replace(/[&<>"'`=\/]/g, s => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;',
                    "'": '&#39;', '/': '&#x2F;', '`': '&#x60;', '=': '&#x3D;'
                })[s]);
            }

            function parseDecimal(val) {
                const v = parseFloat(val);
                return isNaN(v) ? 0 : v;
            }

            function buildRowHtml(sr, item = {}) {
                return `

                <tr>
                    <td><input type="text" class="form-control text-center sr" value="${sr}" readonly></td>
                    <td><input type="text" class="form-control description" value="${escapeHtml(item.description)}"></td>
                    <td><input type="text" step="any" class="form-control qty" value="${item.qty ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control length" value="${item.length ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control width" value="${item.width ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control thick" value="${item.thick ?? ''}"></td>
                    <td><input type="text" class="form-control unit" value="${escapeHtml(item.unit)}"></td>
                    <td><input type="text" step="any" class="form-control rate" value="${item.rate ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control amount" readonly value="${item.amount ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control margin" value="${item.margin ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control marginamount" value="${item.marginAmount ?? ''}"></td>
                    <td><input type="text" step="any" class="form-control total" readonly value="${item.total ?? ''}"></td>
                    <td><input type="text" class="form-control note" value="${escapeHtml(item.note)}"></td>
                </tr>`;
            }
           
            function addEmptyRow() {
            $("#tenderTableBody").append(buildRowHtml(0)); 
            updateSrNumbers();
        }

            function updateSrNumbers() {
            $("#tenderTableBody tr").each(function (index) {
                $(this).find(".sr").val(index + 1);
            });
        }

                   function calculateRow($row, changedField) {
            const qty = parseDecimal($row.find(".qty").val());
            const rate = parseDecimal($row.find(".rate").val());

            // ✅ Base amount = Qty * Rate (updated)
            const subTotal = qty * rate;

            let marginPct = parseDecimal($row.find(".margin").val());
            let marginAmt = parseDecimal($row.find(".marginamount").val());

            // Margin recalculation
            if (changedField === "margin") {
                marginAmt = subTotal * (marginPct / 100);
            } else if (changedField === "marginamount" && subTotal > 0) {
                marginPct = (marginAmt / subTotal) * 100;
            } else {
                marginAmt = subTotal * (marginPct / 100);
            }

            // Safety checks
            if (!isFinite(marginAmt)) marginAmt = 0;
            if (!isFinite(marginPct)) marginPct = 0;

            const total = subTotal + marginAmt;

            // Update row fields
            $row.find(".amount").val(subTotal.toFixed(2));
            $row.find(".margin").val(marginPct.toFixed(2));
            $row.find(".marginamount").val(marginAmt.toFixed(2));
            $row.find(".total").val(total.toFixed(2));

            calculateGrandTotal();
        }


            function calculateGrandTotal() {
                let totalSum = 0;
                $("#tenderTableBody tr").each(function () {
                    totalSum += parseDecimal($(this).find(".total").val());
                });
                
                const fees = parseDecimal($("#fees").val());
                const grand = totalSum + fees;

               $("#grandTotal").val(grand.toFixed(2));
            }

                $("#tenderTableBody").on("input change", ".qty, .rate, .margin, .marginamount", function () {
            const $row = $(this).closest("tr");
            const field = getChangedFieldClass(this);
            calculateRow($row, field);
        });

                function getChangedFieldClass(el) {
            const knownFields = ["qty", "rate", "margin", "marginamount"];
            const classes = $(el).attr("class").split(/\s+/);
            return classes.find(cls => knownFields.includes(cls));
        }



            $("#tenderTableBody").on("input change", "tr:last-child input", function () {
                const $last = $(this).closest("tr");
                const hasValue = $last.find("input").toArray().some(el => $(el).val().trim() !== "");
                if (hasValue) addEmptyRow();
            });

            $("#fees").on("input change", calculateGrandTotal);

            addEmptyRow();
            calculateGrandTotal();
        });


    </script>


}
