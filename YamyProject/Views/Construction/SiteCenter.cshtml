@{
    ViewData["Title"] = "SiteCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3a4eb0 !important;
            color: #fff !important;
        }

</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card shadow-sm">
    <div class="card-header text-center">
        <strong>Site Center</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-3">
            <button type="button" class="btn btn-primary" id="addSiteBtn" data-bs-toggle="modal" data-bs-target="#siteModal">
                <i class="bi bi-plus-circle me-2"></i>Add Site
            </button>
        </div>

        <!-- Site Table -->
        <table id="projectSiteTable" class="table table-striped table-bordered align-middle">
            <thead class="table-primary text-center">
                <tr>
                    <th>SN</th>
                    <th>Code</th>
                    <th>Site Name</th>
                    <th>Location</th>
                    <th>Plot Number</th>
                    <th>Address</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>

<!-- Site Modal -->
<div class="modal fade" id="siteModal" tabindex="-1" aria-labelledby="siteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="siteForm" class="needs-validation" novalidate>
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title w-100 text-center" id="tenderModalLabel">Tender</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="siteId" value="0" />

                    <div class="row g-3">
                        <!-- Site Name -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Site Name</label>
                            <input type="text" id="siteName" class="form-control" placeholder="Enter site name" required />
                            <div class="invalid-feedback">Site name is required.</div>
                        </div>

                        <!-- Project Location Dropdown -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Project Location</label>
                            <select id="projectLocation" class="form-select" required>
                                <option value="">Select project location</option>
                                <!-- Dynamically populated -->
                            </select>
                            <div class="invalid-feedback">Please select a project location.</div>
                        </div>

                        <!-- Plot Number -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Plot Number</label>
                            <input type="text" id="plotNumber" class="form-control" placeholder="Enter plot number" required />
                            <div class="invalid-feedback">Plot number is required.</div>
                        </div>

                        <!-- Address -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Address</label>
                            <textarea id="address" class="form-control" rows="2" placeholder="Enter address"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

        $(document).ready(function () {


            function loadProjectSites() {
            $.ajax({
                url: '/Construction/GetProjectSites',
                type: 'GET',
                success: function (res) {
                    if (!res.status) {
                        toastr.error("Failed to load project sites");
                        return;
                    }
                    console.log(res);

                    // Destroy existing DataTable if already initialized
                    if ($.fn.DataTable.isDataTable("#projectSiteTable")) {
                        $("#projectSiteTable").DataTable().destroy();
                    }

                    const tbody = $("#projectSiteTable tbody");
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, site) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${site.code ?? ""}</td>
                                    <td>${site.name ?? ""}</td>
                                    <td>${site.location ?? ""}</td>
                                    <td>${site.plotNumber ?? ""}</td>
                                    <td>${site.address ?? ""}</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-primary editSiteBtn"
                                                data-site='${JSON.stringify(site)}'
                                                title="Edit Project Site">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger deleteSiteBtn"
                                                data-id='${site.id}'
                                                title="Delete Project Site">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable
                        $("#projectSiteTable").DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: { columns: ':not(:last-child)' }
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: { columns: ':not(:last-child)' }
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 25
                        });
                    } else {
                        tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error("Failed to load project sites");
                }
            });
        }

            loadProjectSites();
        
            function loadCityDropdown() {
            $.ajax({
                url: '/Construction/GetCities',
                type: 'GET',
                success: function (res) {
                    
                    if (res.status && res.data.length > 0) {
                        let options = '<option value="">Select location</option>';
                        $.each(res.data, function (i, city) {
                            options += `<option value="${city.id}">${city.name}</option>`;
                        });
                        $('#projectLocation').html(options);
                    } else {
                        toastr.warning('No cities found');
                    }
                },
                error: function (xhr) {
                    toastr.error('Error loading city list');
                }
            });
        }

            loadCityDropdown();

             $(document).on("click", ".editSiteBtn", function () {
            const site = $(this).data("site");
            if (!site) return;

            $("#siteId").val(site.id || 0);
            $("#siteName").val(site.name || "");
            $("#projectLocation").val(site.locationId || "");
            $("#plotNumber").val(site.plotNumber || "");
            $("#address").val(site.address || "");

            $("#tenderModalLabel").text("Edit Site");
            $("#siteModal").modal("show");
        });

             $("#siteForm").on("submit", function (e) {
            e.preventDefault();
            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const siteData = {
                Id: parseInt($("#siteId").val()) || 0,
                Name: $("#siteName").val().trim(),
                LocationId: parseInt($("#projectLocation").val()) || null,
                PlotNumber: $("#plotNumber").val().trim(),
                Address: $("#address").val().trim()
            };

            $.ajax({
                url: '/Construction/SaveSite',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(siteData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(siteData.Id > 0 ? 'Site updated successfully' : 'Site added successfully');
                        $("#siteModal").modal("hide");
                           setTimeout(function () {
                                        location.reload();
                                     }, 1500); // Optional delay before redirect
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to save site");
                }
            });
        });

              $(document).on('click', '.deleteSiteBtn', function() {
            const id = $(this).data('id');
            if (!confirm('Are you sure you want to delete this site?')) return;

            $.ajax({
                url: `/Construction/DeleteProjectSite/${id}`,
                type: 'DELETE',
                success: function(res) {
                    if (res.status) {
                        toastr.success('Project site deleted successfully');
                        loadProjectSites();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to delete site");
                }
            });
        });


        });

    </script>
}
