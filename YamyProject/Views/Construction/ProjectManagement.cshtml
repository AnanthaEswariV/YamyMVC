
@{
    ViewData["Title"] = "ProjectManagement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }

    .modal-xl {
        max-width: 1200px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 500;
    }

    .form-control-sm,
    .form-select-sm {
        font-size: 13px;
    }
</style>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Project Center</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="addCategoryBtn" data-bs-toggle="modal" data-bs-target="#projectModal">
                <i class="bi bi-plus-circle me-2"></i>Add Project
            </button>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="projectTable">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th>EndDate</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Project Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-labelledby="projectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title w-100 text-center" id="projectModalLabel">Project</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body">
                <input type="hidden" id="projectId" value="0">

                <!-- TABS NAV -->
                <ul class="nav nav-tabs mb-3" id="projectTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="tab-projects" data-bs-toggle="tab"
                                data-bs-target="#pane-projects" type="button" role="tab">
                            Projects
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-accounts" data-bs-toggle="tab"
                                data-bs-target="#pane-accounts" type="button" role="tab">
                            Accounts
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-attachments" data-bs-toggle="tab"
                                data-bs-target="#pane-attachments" type="button" role="tab">
                            Attachments
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-subcontractors" data-bs-toggle="tab"
                                data-bs-target="#pane-subcontractors" type="button" role="tab">
                            Sub Contractors
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-engineers" data-bs-toggle="tab"
                                data-bs-target="#pane-engineers" type="button" role="tab">
                            Project Engineers
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-location" data-bs-toggle="tab"
                                data-bs-target="#pane-location" type="button" role="tab">
                            Location
                        </button>
                    </li>
                </ul>

                <!-- TAB PANES -->
                <div class="tab-content" id="projectTabsContent">

                    <!-- ========== TAB 1: PROJECTS ========== -->
                    <div class="tab-pane fade show active" id="pane-projects" role="tabpanel">
                        <form id="projectForm" class="needs-validation" novalidate>

                            <!-- TOP ROW -->
                            <div class="row g-2 mb-2">
                                <div class="col-md-2">
                                    <label class="form-label">Code</label>
                                    <input type="text" id="projectCode" class="form-control form-control-sm" disabled>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Emirate</label>
                                    <select id="emirateDropdown" class="form-select form-select-sm">
                                        <option>Dubai</option>
                                        <option>Abu Dhabi</option>
                                        <option>Ajman</option>
                                        <option>Fujairah</option>
                                        <option>Ras Al Khaimah</option>
                                        <option>Sharjah</option>
                                        <option>Umm Al Quwain</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Status</label>
                                    <select id="statusDropdown" class="form-select form-select-sm">
                                        <option>Approved</option>
                                        <option>No-Action</option>
                                        <option>Closed</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Type</label>
                                    <select id="typeDropdown" class="form-select form-select-sm">
                                        <option>Project</option>
                                        <option>Cost Center (Job)</option>
                                    </select>
                                </div>
                            </div>

                            <!-- PROJECT NAMES -->
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label">Project Name (English)</label>
                                    <input type="text" id="projectName" class="form-control form-control-sm" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Project Name (Arabic)</label>
                                    <input type="text" id="projectNameArabic" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Category</label>
                                    <input type="text" id="projectCategory" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Description</label>
                                    <input type="text" id="projectDescription" class="form-control form-control-sm">
                                </div>
                            </div>

                            <!-- DATES -->
                            <div class="row g-2 mb-2">
                                <div class="col-md-3">
                                    <label class="form-label">Start Date</label>
                                    <input type="date" id="projectStart" class="form-control form-control-sm" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">End Date</label>
                                    <input type="date" id="projectEnd" class="form-control form-control-sm" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Extend / Delay</label>
                                    <input type="date" id="extendDelay" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Execution Period (Months)</label>
                                    <input type="number" id="executionPeriod" class="form-control form-control-sm">
                                </div>
                            </div>

                            <!-- CUSTOMER / CONTRACTOR / CONSULTANT -->
                            <div class="row g-2 mb-2">
                                <div class="col-md-4">
                                    <label class="form-label">Customer</label>
                                    <select class="form-select form-select-sm" id="customer">
                                        <option value="">-- Select Customer --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Contractor</label>
                                    <input type="text" id="contractor" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Consultant</label>
                                    <input type="text" id="consultant" class="form-control form-control-sm">
                                </div>
                            </div>

                            <!-- LOCATION & DETAILS -->
                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Location</label>
                                    <textarea id="location" class="form-control form-control-sm" rows="2"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Details</label>
                                    <textarea id="details" class="form-control form-control-sm" rows="2"></textarea>
                                </div>
                            </div>

                            <hr>

                            <!-- PROJECT VALUE -->
                            <div class="border rounded p-3 mb-3 bg-light">
                                <h6 class="fw-bold">Project Value</h6>
                                <div class="row g-2">
                                    <div class="col-md-3">
                                        <label class="form-label">Contract Value</label>
                                        <input type="number" id="contractValue" class="form-control form-control-sm" value="0">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Additional Value</label>
                                        <input type="number" id="additionalValue" class="form-control form-control-sm" value="0">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Deduction Value</label>
                                        <input type="number" id="deductionValue" class="form-control form-control-sm" value="0">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Total Value</label>
                                        <input type="number" id="totalValue" class="form-control form-control-sm" readonly>
                                    </div>
                                </div>
                            </div>

                            <!-- SUMMARY -->
                            <div class="border rounded p-3 bg-light">
                                <h6 class="fw-bold">Summary</h6>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Billed To Date</label>
                                        <input type="number" id="billedToDate" class="form-control form-control-sm" value="0">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Expenses</label>
                                        <input type="number" id="expenses" class="form-control form-control-sm" value="0">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Balance</label>
                                        <input type="number" id="balance" class="form-control form-control-sm" readonly>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-3 d-flex justify-content-end gap-2">
                                <button type="submit" class="btn btn-primary">Save</button>
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                            </div>

                        </form>
                    </div>
                    <!-- END TAB 1 -->
                    <!-- ========== TAB 2: ACCOUNTS ========== -->
                    <div class="tab-pane fade" id="pane-accounts" role="tabpanel">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Project</label>
                            <input type="text" id="accountProjectName" class="form-control form-control-sm" readonly>
                        </div>
                        <table class="table table-bordered table-sm" id="accountsTable">
                            <thead class="table-primary">
                                <tr>
                                    <th><input type="checkbox" id="checkAllAccounts"></th>
                                    <th></th>
                                    <th>Main Account</th>
                                    <th>Code</th>
                                    <th>Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck" checked></td>
                                    <td>IncomeAccount</td>
                                    <td>
                                        <select id="accountNameIncome" class="form-select form-select-sm" required>
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck" checked></td>
                                    <td>ExpensesAccount</td>
                                    <td>
                                        <select id="accountNameExpenses" class="form-select form-select-sm" required>
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck" checked></td>
                                    <td>RetentionAccount</td>
                                    <td>
                                        <select id="accountNameretentions" class="form-select form-select-sm" required>
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck" checked></td>
                                    <td>DownpaymentAccount</td>
                                    <td>
                                        <select id="accountNameDownpayments" class="form-select form-select-sm" required>
                                            <option value="">-- Select --</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck"></td>
                                    <td>Other1</td>
                                    <td>
                                        <select id="other1" class="form-select form-select-sm">
                                            <option value="">Please select</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                                <tr>
                                    <td><input type="checkbox" class="accountCheck"></td>
                                    <td>Other2</td>
                                    <td>
                                        <select id="other2" class="form-select form-select-sm">
                                            <option value="">Please select</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control form-control-sm accCode"></td>
                                    <td><input type="text" class="form-control form-control-sm accName"></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="mt-2">
                            <button type="button" class="btn btn-primary btn-sm" id="createAccountsBtn">Create Accounts</button>
                        </div>
                    </div>
                    <!-- END TAB 2 -->
                    <!-- ========== TAB 3: ATTACHMENTS ========== -->
                    <div class="tab-pane fade" id="pane-attachments" role="tabpanel">
                        <div class="mb-3 d-flex justify-content-end">
                            <button type="button" class="btn btn-primary btn-sm" id="addAttachmentBtn">
                                <i class="fas fa-plus me-1"></i> Add Attachment
                            </button>
                        </div>
                        <table class="table table-bordered table-sm" id="attachmentsTable">
                            <thead class="table-primary">
                                <tr>
                                    <th>#</th>
                                    <th>File Name</th>
                                    <th>Description</th>
                                    <th>Uploaded By</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td colspan="6" class="text-center text-muted py-3">No attachments found</td></tr>
                            </tbody>
                        </table>
                        <input type="file" id="attachmentFileInput" class="d-none" multiple>
                    </div>
                    <!-- END TAB 3 -->
                    <!-- ========== TAB 4: SUB CONTRACTORS ========== -->
                    <div class="tab-pane fade" id="pane-subcontractors" role="tabpanel">
                        <div class="mb-3 d-flex justify-content-end">
                            <button type="button" class="btn btn-primary btn-sm" id="addSubContractorBtn">
                                <i class="fas fa-plus me-1"></i> Add Sub Contractor
                            </button>
                        </div>
                        <table class="table table-bordered table-sm" id="subContractorsTable">
                            <thead class="table-primary">
                                <tr>
                                    <th>#</th>
                                    <th>Sub Contractor Name</th>
                                    <th>Trade</th>
                                    <th>Contract Value</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td colspan="7" class="text-center text-muted py-3">No sub contractors found</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- END TAB 4 -->
                    <!-- ========== TAB 5: PROJECT ENGINEERS ========== -->
                    <div class="tab-pane fade" id="pane-engineers" role="tabpanel">
                        <div class="mb-3 d-flex justify-content-end">
                            <button type="button" class="btn btn-primary btn-sm" id="addEngineerBtn">
                                <i class="fas fa-plus me-1"></i> Add Engineer
                            </button>
                        </div>
                        <table class="table table-bordered table-sm" id="engineersTable">
                            <thead class="table-primary">
                                <tr>
                                    <th>#</th>
                                    <th>Engineer Name</th>
                                    <th>Role</th>
                                    <th>Phone</th>
                                    <th>Email</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td colspan="6" class="text-center text-muted py-3">No engineers found</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- END TAB 5 -->
                    <!-- ========== TAB 6: LOCATION ========== -->
                    <div class="tab-pane fade" id="pane-location" role="tabpanel">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Address</label>
                                <textarea id="locAddress" class="form-control form-control-sm" rows="3"></textarea>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Latitude</label>
                                <input type="text" id="locLatitude" class="form-control form-control-sm" placeholder="e.g. 25.2048">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Longitude</label>
                                <input type="text" id="locLongitude" class="form-control form-control-sm" placeholder="e.g. 55.2708">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Map Link</label>
                                <input type="text" id="locMapLink" class="form-control form-control-sm" placeholder="https://maps.google.com/...">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Notes</label>
                                <textarea id="locNotes" class="form-control form-control-sm" rows="2"></textarea>
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="button" class="btn btn-primary btn-sm" id="saveLocationBtn">Save Location</button>
                            </div>
                        </div>
                    </div>
                    <!-- END TAB 6 -->

                </div>
                <!-- END TAB CONTENT -->
            </div>
            <!-- END MODAL BODY -->

        </div>
    </div>
</div>



@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

         function setOtherTabsState(disabled) {
            $('#projectTabs button:not(#tab-projects)').prop('disabled', disabled);
        }

        function calculateTotal() {
            const contract = parseFloat($('#contractValue').val()) || 0;
            const add = parseFloat($('#additionalValue').val()) || 0;
            const deduct = parseFloat($('#deductionValue').val()) || 0;
            const total = contract + add - deduct;
            $('#totalValue').val(total);

            const billed = parseFloat($('#billedToDate').val()) || 0;
            const expenses = parseFloat($('#expenses').val()) || 0;
            const balance = total - billed - expenses;
            $('#balance').val(balance);
        }

        $('#contractValue, #additionalValue, #deductionValue, #billedToDate, #expenses').on('input', calculateTotal);

        $(document).on("click", ".editProjectBtn", function () {
            const project = $(this).data("project");
            if (!project) return;

            console.log(project);

            // 🔹 Fill hidden ID and code
            $("#projectId").val(project.id ?? 0);
            $("#projectCode").val(project.code ?? "");

            // 🔹 Fill basic project info
            $("#projectName").val(project.name ?? "");
            $("#projectNameArabic").val(project.nameArabic ?? "");
            $("#projectCategory").val(project.category ?? "");
            $("#projectDescription").val(project.description ?? "");
            $("#emirateDropdown").val(project.emirate ?? "");
            $("#statusDropdown").val(project.status ?? "");
            $("#typeDropdown").val(project.type ?? "");

            // 🔹 Dates
            $("#projectStart").val(project.startDate ?? "");
            $("#projectEnd").val(project.endDate ?? "");
            $("#extendDelay").val(project.extendDelay ?? "");
            $("#executionPeriod").val(project.executionPeriodMonths ?? "");

            // 🔹 Customer / Contractor / Consultant
            $("#customer").val(project.customer ?? "");
            $("#contractor").val(project.contractor ?? "");
            $("#consultant").val(project.consultant ?? "");

            // 🔹 Location & Details
            $("#location").val(project.location ?? "");
            $("#details").val(project.details ?? "");

            // 🔹 Project values
            $("#contractValue").val(project.contractValue ?? 0);
            $("#additionalValue").val(project.additionalValue ?? 0);
            $("#deductionValue").val(project.deductionValue ?? 0);
            $("#totalValue").val(project.totalValue ?? 0);
            $("#billedToDate").val(project.billedToDate ?? 0);
            $("#expenses").val(project.expenses ?? 0);
            $("#balance").val(project.balance ?? 0);

            // 🔹 Update modal title
            $("#projectModalLabel").text("Edit Project");

            // 🔹 Show modal
            $("#projectModal").modal("show");
        });

        $('#projectForm').on('submit', function(e) {
            e.preventDefault();
            const form = this;
            if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

        const startDate = $('#projectStart').val();
        const endDate = $('#projectEnd').val();
        const extendDelay = $('#extendDelay').val();

            if (extendDelay) {
            const end = new Date(endDate);
            const extend = new Date(extendDelay);

            if (extend < end) {
                toastr.error("'Extend/Delay Date' cannot be less than 'End Date'");
                return;
            }
        }
            const projectData = {
                Id: parseInt($('#projectId').val()) || 0,
                Code: $('#projectCode').val(),
                Name: $('#projectName').val()?.trim() || '',
                NameArabic: $('#projectNameArabic').val()?.trim() || '',
                Category: $('#projectCategory').val()?.trim() || '',
                Description: $('#projectDescription').val()?.trim() || '',
                Emirate: $('#emirateDropdown').val(),
                Status: $('#statusDropdown').val(),
                Type: $('#typeDropdown').val(),
                StartDate: $('#projectStart').val(),
                EndDate: $('#projectEnd').val(),
                ExtendDelay: $('#extendDelay').val(),
                ExecutionPeriodMonths: parseInt($('#executionPeriod').val()) || null,
                Customer: $('#customer').val(),
                Contractor: $('#contractor').val(),
                Consultant: $('#consultant').val(),
                Location: $('#location').val(),
                Details: $('#details').val(),
                ContractValue: parseFloat($('#contractValue').val()) || 0,
                AdditionalValue: parseFloat($('#additionalValue').val()) || 0,
                DeductionValue: parseFloat($('#deductionValue').val()) || 0,
                TotalValue: parseFloat($('#totalValue').val()) || 0,
                BilledToDate: parseFloat($('#billedToDate').val()) || 0,
                Expenses: parseFloat($('#expenses').val()) || 0,
                Balance: parseFloat($('#balance').val()) || 0
            };

            $.ajax({
                url: '/Construction/SaveProject', // Your controller action
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(projectData),
                success: function(res) {
                    if(res.status){
                        toastr.success(projectData.Id>0 ? 'Project updated' : 'Project added');
                        $('#projectModal').modal('hide');
                        setTimeout(()=>location.reload(), 1500);
                    } else toastr.error(res.message);
                },
                error: function(xhr){
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

        function loadCustomers() {
            $.ajax({
                url: '@Url.Action("GetCustomers", "Customer")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const customerDdl = $("#customer");

                        customerDdl.empty().append('<option value="">-- Select Customer --</option>');

                        res.data.forEach(c => {
                            const option = `<option value="${c.id}">${c.name}</option>`;
                            customerDdl.append(option);
                        });
                    } else {
                        toastr.error('Failed to load customers.');
                    }
                },
                error: function () {
                    toastr.error('Error loading customers.');
                }
            });
        }

        function loadProjects() {
            $.ajax({
               url: '@Url.Action("GetProjectManagement", "Construction")',
                type: "GET",
                success: function(res) {
                    if (!res.status) {
                        toastr.error("Failed to load projects");
                        return;
                    }
                    // Destroy existing DataTable if exists
                    if ($.fn.DataTable.isDataTable("#projectTable")) {
                        $("#projectTable").DataTable().destroy();
                    }

                    let tbody = $("#projectTable tbody");
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function(i, row) {
                            const startDate = row.startDate ?? "";
                            const endDate = row.endDate ?? "";
                            let duration = 0;

                            if (startDate && endDate) {
                                const start = new Date(startDate);
                                const end = new Date(endDate);
                                duration = Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1;
                            }

                            const tr = `
                                <tr>
                                    <td>${row.sn}</td>
                                    <td>${row.code ?? ""}</td>
                                    <td>${row.name ?? ""}</td>
                                    <td>${row.customer ?? ""}</td>
                                    <td>${row.status}</td>
                                    <td>${endDate}</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary editProjectBtn" data-project='${JSON.stringify(row)}' title="Edit Project">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger deleteCardBtn"
                    data-id='${row.id}'>
                <i class="fas fa-prescription-bottle-alt"></i>
            </button>
                                    </td>
                                </tr>
                            `;
                            tbody.append(tr);
                        });

                        // Initialize DataTable
                                $("#projectTable").DataTable({
            dom: 'Bfrtip',
            buttons: [
                {
                    extend: 'excelHtml5',
                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                    className: 'btn btn-primary btn-sm',
                    exportOptions: {
                        columns: ':not(:last-child)' // Exclude the last column (Actions)
                    }
                },
                {
                    extend: 'pdfHtml5',
                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                    className: 'btn btn-primary btn-sm',
                    exportOptions: {
                        columns: ':not(:last-child)' // Exclude the last column (Actions)
                    }
                }
            ],
            order: [[0, 'asc']],
            pageLength: 25
        });
                    } else {
                        tbody.append(`<tr><td colspan="8" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function() {
                    toastr.error("Failed to load projects");
                }
            });
        }

        $(document).on("click", ".deleteCardBtn", function () {
            const projectId = $(this).data("id");
            if (!projectId) return;

            if (!confirm("Are you sure you want to delete this project?")) return;

            $.ajax({
             url: `@Url.Action("DeleteProject", "Construction")?projectId=${projectId}`,
        type: "DELETE",
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message);
                         setTimeout(function () {
                            location.reload();
                        }, 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to delete project");
                }
            });
        });

           function loadAllAccounts() {
            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function(accounts) {

                    // 1️⃣ Predefined account types with default selection
                    const predefinedDropdowns = {
                        "IncomeAccount": $("#accountNameIncome"),
                        "ExpensesAccount": $("#accountNameExpenses"),
                        "RetentionAccount": $("#accountNameretentions"),
                        "DownpaymentAccount": $("#accountNameDownpayments")
                    };

                    $.each(predefinedDropdowns, function(type, $ddl) {
                        $ddl.empty().append('<option value="">-- Select --</option>');
                        $.each(accounts, function(i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name,
                                    'data-code': item.code
                                })
                            );
                        });

                        // Fetch and set selected value
                        $.ajax({
                            url: '/Construction/GetPaymentMethodInfo',
                            type: 'GET',
                            data: { method: type },
                            success: function(res) {
                                if (res.status) {
                                    $ddl.val(res.accountId);
                                }
                            },
                            error: function(xhr, status, error) {
                                console.error("❌ Error fetching selected account ID for " + type + ":", error);
                            }
                        });
                    });

                    // 2️⃣ Other dropdowns (Other1, Other2) – just show accounts
                    const otherDropdowns = ["#other1", "#other2"];
                    $.each(otherDropdowns, function(index, selector) {
                        const $ddl = $(selector);
                        $ddl.empty().append('<option value="">-- Select --</option>');
                        $.each(accounts, function(i, item) {
                            $ddl.append(
                                $('<option>', {
                                    value: item.id,
                                    text: item.code + ' - ' + item.name
                                })
                            );
                        });
                    });

                },
                error: function(xhr, status, error) {
                    console.error("❌ Error loading accounts:", error);
                }
            });
        }

        // Call on document ready
        $(document).ready(function() {
            loadCustomers();
            loadProjects();
            loadAllAccounts();
        });
    </script>
}