        function loadEngineers(projectId) {
            const $tbody = $('#engineersBody');
            $tbody.empty();

            if (!projectId || projectId === 0) {
                addEmptyEngineerRow();
                return;
            }

            $.ajax({
                url: '/Construction/GetProjectEngineers',
                type: 'GET',
                data: { projectId: projectId },
                success: function (res) {
                    if (!res.status) {
                        toastr.error("Failed to load engineers");
                        addEmptyEngineerRow();
                        return;
                    }

                    const engineers = res.data;

                    if (!engineers || engineers.length === 0) {
                        addEmptyEngineerRow();
                        return;
                    }

                    engineers.forEach(function (eng, i) {
                        const row = `
                            <tr data-id="${eng.id}">
                                <td>${i + 1}</td>
                                <td><input type="text" class="form-control form-control-sm engineer-code" value="${eng.engineerCode}" readonly></td>
                                <td><input type="text" class="form-control form-control-sm engineer-name" value="${eng.engineerName}" placeholder="Enter name"></td>
                                <td><input type="text" class="form-control form-control-sm engineer-phone" value="${eng.phone}" placeholder="Enter phone"></td>
                                <td><input type="date" class="form-control form-control-sm engineer-contract-date" value="${formatDate(eng.contractDate)}"></td>
                                <td><a href="#" class="text-danger deleteEngineerRow"><i class="fas fa-trash"></i></a></td>
                            </tr>`;
                        $tbody.append(row);
                    });

                    addEmptyEngineerRow();
                },
                error: function () {
                    toastr.error("Error loading engineers");
                    appendBlankEngineerRow();
                }
            });
        }

        $(document).on('click', '.deleteEngineerRow', function(e) {
            e.preventDefault();

            const row = $(this).closest('tr');
            const id = row.data('id');

            if (!confirm('Are you sure you want to delete this engineer?')) return;

            if (!id || id === 0) {
                row.remove();
                return;
            }

            $.ajax({
                url: `/Construction/DeleteProjectEngineer?engineerId=${id}`,
                type: 'DELETE',
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message || 'Engineer deleted successfully');
                        row.remove();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function() {
                    toastr.error('Error deleting engineer');
                }
            });
        });

        function loadCityDropdown() {
            $.ajax({
               url: '@Url.Action("GetCities", "Construction")',
                type: 'GET',
                success: function (res) {

                    if (res.status && res.data.length > 0) {
                        let options = '<option value="">Select location</option>';
                        $.each(res.data, function (i, city) {
                            options += `<option value="${city.id}">${city.name}</option>`;
                        });
                        $('#projectLocation').html(options);
                    } else {
                        toastr.warning('No cities found');
                    }
                },
                error: function (xhr) {
                    toastr.error('Error loading city list');
                }
            });
        }

        $("#saveSiteBtn").click(function () {

            const projectId = parseInt($("#projectId").val()) || 0;

            if (projectId === 0) {
                toastr.error("Invalid project");
                return;
            }

            const siteData = {
                Id: Number($("#siteId").val()) || 0,
                ProjectId: projectId,   // ADD THIS
                Name: $("#siteName").val().trim(),
                LocationId: $("#projectLocation").val() ? Number($("#projectLocation").val()) : null,
                PlotNumber: $("#plotNumber").val().trim(),
                Address: $("#address").val().trim()
            };

            $.ajax({
                url: '@Url.Action("SaveSite", "Construction")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(siteData),

                success: function (res) {

                    if (res.status) {

                        toastr.success(
                            siteData.Id > 0
                                ? "Site updated successfully"
                                : "Site added successfully"
                        );

                        $("#siteModal").modal("hide");

                        setTimeout(function () {
                            location.reload();
                        }, 1200);

                    } else {
                        toastr.error(res.message);
                    }
                },

                error: function () {
                    toastr.error("Failed to save site");
                }
            });

        });

         function loadProjectSites(projectId) {

            // Clear fields first
            $('#siteId').val(0);
            $('#siteName').val('');
            $('#projectLocation').val('');
            $('#plotNumber').val('');
            $('#address').val('');

            if (!projectId || projectId === 0) return;

            $.ajax({
                url: '@Url.Action("GetProjectSites", "Construction")',
                type: 'GET',
                data: { projectId: projectId },

                success: function (res) {
                    if (!res.status || !res.data || res.data.length === 0) return;

                    // Populate form with the first site record
                    const site = res.data[0];
                    $('#siteId').val(site.id ?? 0);
                    $('#siteName').val(site.name ?? '');
                    $('#projectLocation').val(site.locationId ?? '');
                    $('#plotNumber').val(site.plotNumber ?? '');
                    $('#address').val(site.address ?? '');
                },
                error: function () {
                    toastr.error('Failed to load site data');
                }
            });
        }

        $(document).ready(function () {
            loadCustomers();
            loadProjects();
            loadAllAccounts();
            loadSubcontractors();
            loadCityDropdown();
        });

    </script>
}
