        function populateSubcontractorRow($row, data) {
            const subDdl  = $row.find('.subcontractor');
            const codeDdl = $row.find('.code');

            subDdl.empty().append('<option value="">-- Select --</option>');
            codeDdl.empty().append('<option value="">-- Select --</option>');

            data.forEach(c => {
                subDdl.append(`<option value="${c.id}" data-code="${c.code}">${c.name}</option>`);
                codeDdl.append(`<option value="${c.code}">${c.code}</option>`);
            });
        }

        $(document).on('change', '.subcontractor', function () {

            const row = $(this).closest('tr');
            const code = $(this).find(':selected').data('code');

            row.find('.code').val(code);

        });

        function formatDate(dateStr) {
            if (!dateStr) return '';

            const d = new Date(dateStr);
            return d.toISOString().split('T')[0];
        }

        function loadSubcontractorss(projectId) {
            const $tbody = $('#subContractorBody');
            $tbody.empty();

            if (!projectId || projectId === 0) {
                appendBlankSubRow();
                return;
            }

            $.ajax({
                url: '@Url.Action("GetProjectSubcontractors", "Construction")',
                type: 'GET',
                data: { projectId: projectId },
                success: function (res) {
                    if (!res.status) { toastr.error("Failed to load subcontractors"); return; }

                    const projects = res.data;

                    if (!projects || projects.length === 0 || !projects[0].subcontractors.length) {
                        appendBlankSubRow(); 
                        return;
                    }

                    projects[0].subcontractors.forEach(function (sub) {
                        const row = `
                            <tr class="sub-row" data-id="${sub.id}">
                                <td><select class="form-select code"><option value="">Select</option></select></td>
                                <td><select class="form-select subcontractor"><option value="">Select</option></select></td>
                                <td><input type="text" class="form-control contractNo" value="${sub.contractNo ?? ''}"></td>
                                <td><input type="number" class="form-control contractValue" value="${sub.contractValue ?? 0}"></td>
                                <td><input type="date" class="form-control contractDate" value="${formatDate(sub.contractDate)}"></td>
                                <td><input type="text" class="form-control contractPeriod" value="${sub.contractPeriod ?? ''}"></td>
                                <td><input type="text" class="form-control works" value="${sub.works ?? ''}"></td>
                                <td><input type="text" class="form-control worksEn" value="${sub.worksEn ?? ''}"></td>
                                <td><a href="#" class="text-danger deleteRow"><i class="fas fa-trash"></i></a></td>
                            </tr>`;

                        $tbody.append(row);

                        const $newRow = $tbody.find('tr:last');
                        populateSubcontractorRow($newRow, subcontractorList);
                        $newRow.find('.subcontractor').val(sub.subcontractorId);
                        $newRow.find('.code').val(sub.codeId);
                    });

                    appendBlankSubRow(); 
                },
                error: function () { toastr.error("Error loading subcontractors"); }
            });
        }

        function appendBlankSubRow() {
            const $tbody = $('#subContractorBody');
            const $blankRow = $(`
                <tr class="sub-row" data-id="0">
                    <td><select class="form-select code"><option value="">Select</option></select></td>
                    <td><select class="form-select subcontractor"><option value="">Select</option></select></td>
                    <td><input type="text" class="form-control contractNo"></td>
                    <td><input type="number" class="form-control contractValue"></td>
                    <td><input type="date" class="form-control contractDate"></td>
                    <td><input type="text" class="form-control contractPeriod"></td>
                    <td><input type="text" class="form-control works"></td>
                    <td><input type="text" class="form-control worksEn"></td>
                    <td><a href="#" class="text-danger deleteRow"><i class="fas fa-trash"></i></a></td>
                </tr>`);

            populateSubcontractorRow($blankRow, subcontractorList); 
            $tbody.append($blankRow);
        }

