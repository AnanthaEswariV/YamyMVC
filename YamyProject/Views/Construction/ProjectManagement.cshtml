        $('#addAttachmentBtn').on('click', function () {
            const projectId = parseInt($('#projectId').val()) || 0;
            if (projectId === 0) { toastr.error('Please save project first'); return; }
            $('#attachmentFileInput').click();
        });

        $('#attachmentFileInput').on('change', function () {
            const projectId = parseInt($('#projectId').val()) || 0;
            if (projectId === 0) { toastr.error('Invalid project'); return; }

            const files = this.files;
            if (!files.length) return;

            let uploaded = 0;
            for (let i = 0; i < files.length; i++) {
                const formData = new FormData();
                formData.append('ProjectId',   projectId);
                formData.append('File',        files[i]);
                formData.append('Description', files[i].name);

                $.ajax({
                    url:         '/Construction/SaveProjectAttachment',
                    type:        'POST',
                    data:        formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.status) {
                            toastr.success(res.message);
                            uploaded++;
                           loadAttachments(projectId);

                        } else {
                            toastr.error(res.message);
                        }
                    },
                    error: function () { toastr.error('Error uploading attachment'); }
                });
            }

            $(this).val(''); 
        });

        function loadAttachments(projectId) {
            const $tbody = $('#attachmentsTable tbody');
            $tbody.empty();

            if (!projectId || projectId === 0) {
                $tbody.html('<tr><td colspan="5" class="text-center text-muted py-3">No attachments found</td></tr>');
                return;
            }

            $.ajax({
                url: '@Url.Action("GetProjectAttachments", "Construction")',
                type: 'GET',
                data: { projectId: projectId },
                success: function (res) {
                    if (!res.status) {
                        toastr.error('Failed to load attachments');
                        return;
                    }

                    const projects = res.data;

                    if (!projects || projects.length === 0 || !projects[0].attachments || projects[0].attachments.length === 0) {
                        $tbody.html('<tr><td colspan="5" class="text-center text-muted py-3">No attachments found</td></tr>');
                        return;
                    }

                    // Loop through attachments
                    projects[0].attachments.forEach((att, i) => {
                        const tr = `
                            <tr data-id="${att.id}">
                                <td>${i + 1}</td>
                                <td>${projects[0].name ?? ''}</td>
                                <td>
                                    <a href="${att.filePath}" target="_blank">${att.fileName}</a>
                                </td>
                                <td>
                                    <input type="text"
                                           class="form-control form-control-sm attachmentDescription"
                                           value="${att.description ?? ''}"
                                           data-id="${att.id}" disabled>
                                </td>
                                <td>
                                    <a href="${att.filePath}" download
                                       class="btn btn-sm btn-success me-1" title="Download">
                                        <i class="fas fa-download"></i>
                                    </a>
                                    <button class="btn btn-sm btn-danger deleteAttachment"
                                            data-id="${att.id}" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
                        $tbody.append(tr);
                    });
                },
                error: function () {
                    toastr.error('Failed to load attachments');
                }
            });
        }

