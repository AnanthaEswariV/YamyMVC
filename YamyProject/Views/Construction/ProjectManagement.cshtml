        function loadSubcontractors() {
            $.ajax({
                url: '@Url.Action("GetSubContractors", "Subcontractor")',
                type: 'GET',
                success: function (res) {
                    if (!res.status) { toastr.error('Failed to load Vendors.'); return; }

                    subcontractorList = res.data; 

                    $('.sub-row').each(function () {
                        populateSubcontractorRow($(this), res.data);
