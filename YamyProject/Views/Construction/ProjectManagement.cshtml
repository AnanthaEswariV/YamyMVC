            let rows = [];

            $('#subContractorBody tr').each(function () {

                const row = $(this);

                const data = {
                    Id: parseInt(row.data('id')) || 0,
                    ProjectId: projectId,
                    CodeId: row.find('.code').val(),
                    SubcontractorId: row.find('.subcontractor').val(),
                    ContractNo: row.find('td:eq(2) input').val(),
                    ContractValue: row.find('td:eq(3) input').val(),
                    ContractDate: row.find('td:eq(4) input').val(),
                    ContractPeriod: row.find('td:eq(5) input').val(),
                    Works: row.find('td:eq(6) input').val(),
