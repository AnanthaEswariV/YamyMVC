        function loadAllAccounts() {
            $.ajax({
                url:  '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function (accounts) {
                    const predefinedDropdowns = {
                        'IncomeAccount':      $('#accountNameIncome'),
                        'ExpensesAccount':    $('#accountNameExpenses'),
                        'RetentionAccount':   $('#accountNameretentions'),
                        'DownpaymentAccount': $('#accountNameDownpayments')
                    };

                    $.each(predefinedDropdowns, function (type, $ddl) {
                        $ddl.empty().append('<option value="">-- Select --</option>');
