                            $ddl.append($('<option>', { value: item.id, text: item.code + ' - ' + item.name, 'data-code': item.code }));
                        });

                        $.ajax({
                            url:  '/Construction/GetPaymentMethodInfo',
                            type: 'GET',
                            data: { method: type },
                            success: function (res) { if (res.status) $ddl.val(res.accountId); },
                            error:   function (xhr, s, err) { console.error('Error fetching account for ' + type + ':', err); }
                        });
                    });

                    ['#other1', '#other2'].forEach(function (sel) {
                        const $ddl = $(sel).empty().append('<option value="">-- Select --</option>');
                        $.each(accounts, function (i, item) {
                            $ddl.append($('<option>', { value: item.id, text: item.code + ' - ' + item.name, 'data-code': item.code }));
                        });
