
@{
    ViewData["Title"] = "ProjectWorkDone";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <bold> <strong>Project Work Done</strong></bold>
    </div>
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Reported By -->
            <div style="min-width: 250px;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0">Reported By</h6>
                    <input type="checkbox" class="form-check-input autoLock" id="chkReportedBy" checked>
                </div>
                <select class="form-select" id="projectName" disabled>
                    <option value="">-- Select Project Name --</option>
                </select>
            </div>


            <!-- Add Tender Button -->
            <div class="text-center">
                <button class="btn btn-primary rounded-3" id="addPlanningBtn" data-bs-toggle="modal" data-bs-target="#newItemsModal">
                    <i class="fas fa-plus me-2"></i> Add
                </button>
            </div>

        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>V No</th>
                    <th>Project Name</th>
                    <th>Tender Name</th>
                    <th>Total QtyP</th>
                    <th>Total QtyWD</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Work Done Items Modal -->
<div class="modal fade" id="itemsModal" tabindex="-1" aria-labelledby="itemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title">Work Done Items</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered" id="itemsTable">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Unit</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rows will be appended dynamically -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<!-- Project Work Done Modal -->
<div class="modal fade" id="newItemsModal" tabindex="-1" aria-labelledby="newItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title" id="projectWorkDoneLabel">Project - New WorkDone</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <input type="hidden" id="workDoneId" value="0">
                <!-- Top Section -->
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label>Date</label>
                        <input type="date" class="form-control" >
                    </div>
                    <div class="col-md-3">
                        <label>Project Name</label>
                        <select class="form-select" id="projectNames">
                            <option value="">-- Select Project Name --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label>Project Site</label>
                        <select class="form-select" id="projectSite" style="max-width: 85%;">
                            <option value="">-- Select Site --</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Tender Name</label>
                        <select class="form-select" id="tenderDropdown">
                            <option value="">-- Select Tender --</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Account Name</label>
                        <select class="form-select" id="debitAccount">
                            <option value="">-- Select Account --</option>
                        </select>
                    </div>
                </div>

                <!-- Work Done Table -->
                <table class="table table-bordered" id="workDoneTable">
                    <thead>
                        <tr>
                            <th>P Id</th>
                            <th>Date</th>
                            <th>Sr</th>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Unit</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rows will be dynamically added -->
                    </tbody>
                </table>





            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="btnSaveWorkDone">Save</button>
                <button type="button" class="btn btn-secondary">Save & New</button>
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


 @section Scripts {

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>


    <script>
               $(document).ready(function () {
            // Global variable to track the current selected planning ID
            let selectedPlanningId = 0;

            loadProjects();

            $('#chkReportedBy').change(function () {
                if ($(this).is(':checked')) {
                    $('#projectName').prop('disabled', true);
                    loadProjectWorkDone();
                } else {
                    $('#projectName').prop('disabled', false);
                    loadProjects();
                }
            });

            $('#projectName').change(function () {
                const selectedProjectId = $(this).val() || null;
                loadProjectWorkDone(selectedProjectId);
            });

            function loadProjects() {
                $.ajax({
                   url: '@Url.Action("GetProjectManagement", "Construction")',
                    type: 'GET',
                    success: function (result) {
                        if (result.status) {
                            const $dropdown = $('#projectName');
                            const $dropdowns = $('#projectNames');
                            $dropdown.empty();
                            $dropdowns.empty();
                            $dropdown.append('<option value="">-- Select Project Name --</option>');
                            $dropdowns.append('<option value="">-- Select Project Name --</option>');

                            $.each(result.data, function (index, project) {
                                $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                                $dropdowns.append('<option value="' + project.id + '">' + project.name + '</option>');
                            });
                        } else {
                            toastr.error('Failed to load projects');
                        }
                    },
                    error: function () {
                        toastr.error('Error loading projects');
                    }
                });
            }

            loadProjectWorkDone();

            function loadProjectWorkDone(projectId = null, tenderId = null) {
                $.ajax({
                   url: '@Url.Action("GetProjectWorkDone", "Construction")',
                    type: 'GET',
                    data: { projectId: projectId, tenderId: tenderId },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error('Failed to load project work done');
                            return;
                        }
                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().clear().destroy();
                        }

                        const tbody = $('#table1 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                const tr = `
                                    <tr data-id="${row.vNo}" style="cursor:pointer;">
                                        <td>${row.sn}</td>
                                        <td>${row.date ?? ''}</td>
                                        <td>${row.vNo}</td>
                                        <td>${row.projectName ?? ''}</td>
                                        <td>${row.tenderName ?? ''}</td>
                                        <td>${row.totalQtyP ?? 0}</td>
                                        <td>${row.totalQtyWD ?? 0}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary viewItemsBtn" data-id="${row.id}" title="View Items">
                                                <i class="fas fa-book"></i>
                                            </button>
                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $('#table1').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    { extend: 'excelHtml5', text: '<i class="fas fa-file-excel me-1"></i> Excel', className: 'btn btn-primary btn-sm' },
                                    { extend: 'pdfHtml5', text: '<i class="fas fa-file-pdf me-1"></i> PDF', className: 'btn btn-primary btn-sm' }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 25
                            });
                        } else {
                            tbody.append(`<tr><td colspan="8" class="text-center text-muted py-4">No records found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading project work done');
                    }
                });
            }

            $('#table1').on('click', '.viewItemsBtn', function () {
                const workDoneId = $(this).data('id');
                $('#itemsModal').modal('show');

                const tbody = $('#itemsTable tbody');
                tbody.empty();

                $.ajax({
                  url: '@Url.Action("GetProjectWorkDoneItems", "Construction")',
                    type: 'GET',
                    data: { id: workDoneId },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error('Failed to load items');
                            return;
                        }

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, item) {
                                const tr = `
                                    <tr>
                                        <td>${item.itemName}</td>
                                        <td>${item.qty}</td>
                                        <td>${item.rate}</td>
                                        <td>${item.unit}</td>
                                        <td>${item.amount}</td>
                                    </tr>`;
                                tbody.append(tr);
                            });
                        } else {
                            tbody.append(`<tr><td colspan="5" class="text-center text-muted py-2">No items found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading items');
                    }
                });
            });

            // Load Project Sites
            $.ajax({
                url: '@Url.Action("GetProjectSites", "Construction")',
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    if (response.status) {
                        var dropdown = $('#projectSite');
                        response.data.forEach(function(site) {
                            dropdown.append($('<option>', {
                                value: site.id,
                                text: site.name
                            }));
                        });
                    } else {
                        console.error('Failed to load sites:', response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching sites:', error);
                }
            });

            // Load Tenders
            $.ajax({
               url: '@Url.Action("GetTenders", "Construction")',
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    if (response.status) {
                        var dropdown = $('#tenderDropdown');
                        response.data.forEach(function(tender) {
                            dropdown.append($('<option>', {
                                value: tender.id,
                                text: tender.name
                            }));
                        });
                    } else {
                        console.error('Failed to load tenders:', response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching tenders:', error);
                }
            });

            // Load Accounts
            $.ajax({
              url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function(res) {
                    const data = Array.isArray(res) ? res : res.data || [];
                    if (!data.length) return;

                    const accountSelectors = ['#debitAccount'];
                    accountSelectors.forEach(function(selector) {
                        const $select = $(selector);
                        const selectedId = $select.data('selected-id');
                        $select.empty().append('<option value="">-- Select --</option>');

                        $.each(data, function(i, item) {
                            const $option = $('<option>', {
                                value: item.id,
                                text: `${item.code} - ${item.name}`,
                                selected: String(item.id) === String(selectedId)
                            });
                            $select.append($option);
                        });
                    });
                },
                error: function(err) {
                    console.error('Failed to fetch accounts:', err);
                }
            });

            // When Project/Site/Tender changes, load planning dates
            $('#projectNames, #projectSite, #tenderDropdown').change(function () {
                const projectId = $('#projectNames').val();
                const siteId = $('#projectSite').val();
                const tenderId = $('#tenderDropdown').val();

                // Reset the selected planning ID
                selectedPlanningId = 0;
                $('#workDoneTable tbody').empty();
                $('.work-assembly-container').remove();

                if (projectId && siteId && tenderId) {
                    loadWorkDoneItems(projectId, siteId, tenderId);
                }
            });

            function loadWorkDoneItems(projectId, siteId, tenderId) {
                const tbody = $('#workDoneTable tbody');
                tbody.empty();

                $.ajax({
                  url: '@Url.Action("GetProjectWorkDoneDetails", "Construction")',
                    type: 'GET',
                    data: { projectId, siteId, tenderId },
                    success: function (res) {
                        if (!res.status || !res.data || res.data.length === 0) {
                            tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No planning dates found</td></tr>`);
                            toastr.warning(res.message || 'No items found for this selection.');
                            return;
                        }

                       
                        const planningList = res.data;

                        $.each(planningList, function (i, item) {
                            // Store the planning ID - convert to integer
                            const planId = parseInt(item.id) || 0;

                            const tr = `
                                <tr class="planning-row" data-planning-id="${planId}" style="cursor:pointer; background-color: #f8f9fa;">
                                    <td>${planId}</td>
                                    <td class="text-primary fw-bold">${item.date || ''}</td>
                                    <td>${i + 1}</td>
                                    <td colspan="3" class="text-muted fst-italic">Click to expand BOQ items</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        toastr.success('Planning dates loaded. Click a date to view BOQ items.');
                    },
                    error: function (xhr) {
                        toastr.error('Error loading planning dates.');
                        console.error(xhr);
                    }
                });
            }

            // Click planning row to expand BOQ items
            $('#workDoneTable tbody').on('click', 'tr.planning-row', function () {
                const tr = $(this);
                const planningId = parseInt(tr.data('planning-id')) || 0;

                if (!planningId) {
                    toastr.error('Invalid planning ID');
                    return;
                }

                // Update the global selected planning ID
                selectedPlanningId = planningId;

                // Collapse if already expanded
                if (tr.hasClass('expanded')) {
                    tr.removeClass('expanded');
                    $(`tr.boq-row[data-parent-id="${planningId}"]`).remove();
                    $('.work-assembly-container').remove();
                    return;
                }

                // Collapse other planning rows
                $('tr.planning-row').removeClass('expanded');
                $('tr.boq-row').remove();
                $('.work-assembly-container').remove();

                // Insert loading row
                tr.after(`<tr class="boq-row temp-row" data-parent-id="${planningId}">
                            <td colspan="6" class="text-center text-muted">Loading BOQ items...</td>
                          </tr>`);

                // Fetch BOQ items
                $.ajax({
                  url: '@Url.Action("GetBoqItems", "Construction")',
                    type: 'GET',
                    data: { planningId },
                    success: function (res) {
                        $(`tr.temp-row[data-parent-id="${planningId}"]`).remove();

                        if (!res.status || !res.data || res.data.length === 0) {
                            toastr.warning(res.message || 'No BOQ items found');
                            return;
                        }

                        let boqRowsHtml = '';
                        res.data.forEach(item => {
                            boqRowsHtml += `
                                <tr class="boq-row" data-item-id="${item.id}" data-parent-id="${planningId}">
                                    <td></td>
                                    <td></td>
                                    <td>${item.sr || ''}</td>
                                    <td class="name-cell text-primary" style="cursor:pointer; padding-left: 20px;">
                                        <i class="fas fa-arrow-right me-2"></i>${item.name || ''}
                                    </td>
                                    <td>${item.qty || ''}</td>
                                    <td>${item.unit || ''}</td>
                                </tr>`;
                        });

                        $(boqRowsHtml).insertAfter(tr);
                        tr.addClass('expanded');
                        toastr.info('Click on a BOQ item name to view assembly details');
                    },
                    error: function () {
                        $(`tr.temp-row[data-parent-id="${planningId}"]`).remove();
                        toastr.error('Error fetching BOQ items.');
                    }
                });
            });

            // Click BOQ item name to view assembly
            $('#workDoneTable tbody').on('click', 'td.name-cell', function (e) {
                e.stopPropagation();
                const tr = $(this).closest('tr');
                const itemId = tr.data('item-id');

                if (!itemId) return;

                fetchAssemblyData(itemId);
            });

            function fetchAssemblyData(itemId) {
                $.ajax({
                  url: '@Url.Action("GetAssemblyData", "Construction")',
                    type: 'GET',
                    data: { itemId },
                    success: function (res) {
                        if (!res.status || !res.data || res.data.length === 0) {
                            toastr.warning(res.message || 'No assembly data found');
                            return;
                        }

                        let html = `
                            <div class="mt-3 work-assembly-container">
                                <div class="alert alert-info">
                                    <strong>Assembly Details for Planning ID: ${selectedPlanningId}</strong><br>
                                    <small>Click on any row to add it to your work done record</small>
                                </div>
                                <div class="table-responsive">
                                <table class="table table-sm table-bordered table-hover mb-0" id="assemblyTable" data-planning-id="${selectedPlanningId}">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Code</th>
                                            <th>Name</th>
                                            <th>BOQ Qty</th>
                                            <th>Unit</th>
                                            <th>Requested Qty</th>
                                            <th>Issued Qty</th>
                                            <th>Received Qty</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                        res.data.forEach(a => {
                            const code = a.code ?? "";
                            const name = a.name ?? "";
                            const boqqty = a.boqQty ?? "";
                            const unit = a.unit ?? "";
                            const requested = a.requestedQty ?? "";
                            const issued = a.issuedQty ?? "";
                            const received = a.receivedQty ?? "";
                            const sr = a.sr ?? "";

                            html += `
                                <tr class="assembly-detail-row" style="cursor:pointer;"
                                    data-boqqty="${boqqty}"
                                    data-requestedqty="${requested}"
                                    data-issuedqty="${issued}"
                                    data-receivedqty="${received}"
                                    data-usedqty="${a.usedQty ?? ''}"
                                    data-code="${code}"
                                    data-name="${name}"
                                    data-unit="${unit}"
                                    data-sr="${sr}"
                                    data-itemid="${a.id ?? ''}"
                                    data-mainid="${a.mainId ?? 0}">
                                    <td>${code}</td>
                                    <td>${name}</td>
                                    <td>${boqqty}</td>
                                    <td>${unit}</td>
                                    <td>${requested}</td>
                                    <td>${issued}</td>
                                    <td>${received}</td>
                                </tr>`;
                        });

                        html += '</tbody></table></div></div>';

                        $('#newItemsModal .work-assembly-container').remove();
                        $("#workDoneTable").after(html);

                        const $assembly = $("#newItemsModal #assemblyTable").closest('.work-assembly-container');
                        if ($assembly.length) {
                            $assembly[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }

                        toastr.success('Assembly items loaded! Click rows to select items.');
                    },
                    error: function () {
                        toastr.error('Error loading assembly data.');
                    }
                });
            }

            function ensureWorkDoneDate() {
                let $date = $("#workDoneDate");
                if ($date.length === 0) {
                    $date = $("#newItemsModal input[type='date']").first();
                    $date.attr("id", "workDoneDate");
                }
                if (!$date.val()) {
                    const today = new Date().toISOString().split("T")[0];
                    $date.val(today);
                }
                return $date.val();
            }

            // Save Work Done
            $("#btnSaveWorkDone").off('click').on("click", function () {
                ensureWorkDoneDate();

                const rawDate = $("#workDoneDate").val();
                let formattedDate = null;
                if (rawDate) {
                    const dateObj = new Date(rawDate);
                    formattedDate = dateObj.toISOString();
                }

                // Get planning ID from assembly table or global variable
                const planningId = parseInt($("#assemblyTable").data("planning-id")) || selectedPlanningId;

                const model = {
                    Id: parseInt($("#workDoneId").val()) || 0,
                    Date: formattedDate,
                    ProjectId: parseInt($("#projectNames").val()) || 0,
                    SiteId: parseInt($("#projectSite").val()) || 0,
                    TenderId: parseInt($("#tenderDropdown").val()) || 0,
                    PlanningId: planningId,
                    AccountId: parseInt($("#debitAccount").val()) || 0,
                    WarehouseId: 1,
                    Items: []
                };

                // Collect Assembly items
                $("#assemblyTable tbody tr.assembly-detail-row").each(function () {
                    const $tr = $(this);
                    const qty = parseFloat($tr.data("usedqty")) ||
                                parseFloat($tr.data("receivedqty")) ||
                                parseFloat($tr.data("boqqty")) || 0;

                    if (qty > 0) {
                        model.Items.push({
                            ItemId: parseInt($tr.data("itemid")) || 0,
                            MainItemId: parseInt($tr.data("mainid")) || 0,
                            Code: ($tr.data("code") || "").toString(),
                            QtyTotal: qty,
                            Unit: ($tr.data("unit") || "").toString(),
                            QtyUsed: qty
                        });
                    }
                });

             

                // Validation
                if (!model.ProjectId) return toastr.warning("Please select a Project.");
                if (!model.SiteId) return toastr.warning("Please select a Project Site.");
                if (!model.TenderId) return toastr.warning("Please select a Tender.");
                if (!model.PlanningId || model.PlanningId === 0) {
                    return toastr.warning("Please select a Planning by clicking a planning date row.");
                }
                if (!model.AccountId) return toastr.warning("Please select an Account.");
                if (model.Items.length === 0) {
                    return toastr.warning("Please add at least one item from assembly details.");
                }

                // API call
                $.ajax({
                   url: '@Url.Action("SaveOrUpdateProjectWorkDone", "Construction")',
                    type: 'POST',
                    data: JSON.stringify(model),
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    beforeSend: function () {
                        $("#btnSaveWorkDone").prop("disabled", true).text("Saving...");
                    },
                    success: function (response) {
                        if (response.status) {
                            toastr.success(response.message || "Work Done saved successfully!");
                            $("#newItemsModal").modal("hide");
                            loadProjectWorkDone();
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            toastr.warning(response.message || "Save failed!");
                        }
                    },
                    error: function (xhr) {
                        console.error("Error details:", xhr);
                        let errorMsg = "Unexpected error";
                        try {
                            const response = JSON.parse(xhr.responseText);
                            errorMsg = response.message || errorMsg;
                        } catch (e) {
                            errorMsg = xhr.responseText || errorMsg;
                        }
                        toastr.error("Error: " + errorMsg);
                    },
                    complete: function () {
                        $("#btnSaveWorkDone").prop("disabled", false).text("Save");
                    }
                });
            });

            // Reset when modal closes
            $('#newItemsModal').on('hidden.bs.modal', function () {
                selectedPlanningId = 0;
                $('#workDoneId').val(0);
                $('#workDoneTable tbody').empty();
                $('.work-assembly-container').remove();
                $('#projectNames, #projectSite, #tenderDropdown, #debitAccount').val('');
            });

            // Reset when modal opens (for new entry)
            $('#addPlanningBtn').on('click', function() {
                selectedPlanningId = 0;
                $('#workDoneId').val(0);
                $('#workDoneTable tbody').empty();
                $('.work-assembly-container').remove();
                ensureWorkDoneDate();
            });
        });
    </script>


    }