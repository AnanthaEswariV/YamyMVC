                        $.ajax({
                            url: `/Construction/GetItemsByTenderId?tenderId=${tenderId}`,
                            type: 'GET',
                            success: function (response) {
                                if (response.status) {
                                    const items = response.data;

                                    // If specific dropdown passed → populate only that
                                    const dropdowns = targetDropdown ? targetDropdown : $('.materialDescription');

                                    dropdowns.each(function () {
                                        const dropdown = $(this);
                                        const selectedValue = dropdown.val();

                                        dropdown.empty();
                                        dropdown.append('<option value="">Select Item</option>');
                                        items.forEach(item => {
                                            dropdown.append(`<option value="${item.id}" data-unit="${item.unit}" data-qty="${item.qty}">${item.name}</option>`);
                                        });

                                        // Restore previous value if reloading all
                                        if (selectedValue && !targetDropdown) {
                                            dropdown.val(selectedValue);
                                        }
                                    });
                                } else {
                                    alert('Error loading items');
                                }
                            },
                            error: function () {
                                alert('An error occurred while fetching items.');
