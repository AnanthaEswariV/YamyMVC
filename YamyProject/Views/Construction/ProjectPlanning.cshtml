                                    </td>
                                </tr>`;
                            tbody.append(row);
                        });
                    } else {
                        $('#assignResourceModal tbody').html(`<tr><td colspan="7" class="text-center text-muted">No resources found</td></tr>`);
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                    $('#assignResourceModal tbody').html(`<tr><td colspan="7" class="text-center text-danger">Failed to load resources</td></tr>`);
                }
            });
        }


        });


             // Function to toggle employee dropdown
        function toggleEmployeeDropdown() {
            const selectedType = $('input[name="type"]:checked').val();
            if (selectedType === "Labour") {
                $('#employeeSection').show();
            } else {
                $('#employeeSection').hide();
            }
        }

        // Initial check on page load
        toggleEmployeeDropdown();

        // When type changes
        $('input[name="type"]').change(function() {
            toggleEmployeeDropdown();
        });



                // 🟩 Open modal for new role
        $("#addRoleBtn").on("click", function () {
            $("#roleId").val(0);
            $("#roleCode").val(""); // Auto-generate in API
            $("#roleName").val("");
            $("#newRoleModalLabel").text("New Role");
            $("#newRoleModal").modal("show");
        });

        // 🟦 Submit form (Add/Edit)
        $("#newRoleForm").on("submit", function (e) {
            e.preventDefault();
            const form = this;

            if (!form.checkValidity()) {
                form.classList.add("was-validated");
                return;
            }

            const roleData = {
                Id: parseInt($("#roleId").val()) || 0,
                Code: $("#roleCode").val().trim() || null,
                Name: $("#roleName").val().trim()
            };

            $.ajax({
                url: "/Construction/SaveOrUpdateRole",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(roleData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(roleData.Id > 0 ? "Role updated successfully" : "Role added successfully");
                        $("#newRoleModal").modal("hide");
                          // 🔹 After save, go back to previous tab (Issue tab)
        setTimeout(() => {
            const prevTab = document.querySelector('#resource-tab');
            if (prevTab) {
                const tab = new bootstrap.Tab(prevTab);
                tab.show();
            }
        }, 500); // slight delay to ensure modal fully closes
                    } else {
                        toastr.error(res.message || "Something went wrong");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to save role");
                }
            });
        });


                function loadRoles() {
            $.ajax({
                url: "/Construction/GetRoles",
                type: "GET",
                success: function (res) {
                    const $dropdown = $("#roleDropdown");
                    $dropdown.empty().append(`<option value="">-- Select Role --</option>`);

                    if (res.status && res.data?.length > 0) {
                        res.data.forEach(role => {
                            $dropdown.append(`<option value="${role.id}">${role.name}</option>`);
                        });
                    } else {
                        $dropdown.append(`<option value="">No roles found</option>`);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to load roles");
                }
            });
        }


        loadRoles();


            $("#saveResourceBtn").on("click", function (e) {
            e.preventDefault();

            const form = $("#projectResourceForm")[0];
            if (!form.checkValidity()) {
                form.classList.add("was-validated");
                return;
            }

            const resourceData = {
                Id: parseInt($("#resourceId").val()) || 0,
                Code: $("#resourceCode").val().trim(),
                Date: $("#resourceDate").val(),
                Name: $("#resourceName").val().trim(),
                Phone: $("#resourcePhone").val().trim(),
                Role: $("#roleDropdown").val(),
                Type: $("input[name='type']:checked").val(),
                EmployeeId: parseInt($("#employeeDropdown").val()) || null,
                PriceUnit: parseFloat($("#priceUnit").val()) || 0,
                UnitTime: parseFloat($("#unitTime").val()) || 8,
                MaxUnitTime: parseFloat($("#maxUnitTime").val()) || 8
            };

            if (!resourceData.Role) return toastr.warning("Role is required");
            if (!resourceData.Name) return toastr.warning("Name is required");

            $.ajax({
                url: "/Construction/SaveOrUpdateProjectResource",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(resourceData),
                beforeSend: function () {
                    $("#saveResourceBtn").prop("disabled", true).text("Saving...");
                },
                success: function (res) {
                    if (res.status) {
                        toastr.success(resourceData.Id > 0 ? "Resource updated successfully" : "Resource added successfully");
                        // 🔹 Wait until Project Resource modal fully hidden
                $("#projectResourceModal").one('hidden.bs.modal', function () {

                    // Refresh Assign Resource modal
                    $("#assignResourceForm")[0].reset();
                    $("#assignResourceForm").removeClass("was-validated");
                    loadRoles(); // reload roles if needed
                    loadManagersDropdown(); // reload employees if needed

                    // Show Assign Resource modal
                    $("#assignResourceModal").modal("show");
                });

                // Now hide Project Resource modal (triggers hidden.bs.modal)
                $("#projectResourceModal").modal("hide");
                        if (typeof loadProjectResources === "function") loadProjectResources();
                    } else {
                        toastr.error(res.message || "Something went wrong");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to save resource");
                },
                complete: function () {
                    $("#saveResourceBtn").prop("disabled", false).text("Save");
                }
            });
        });

              function loadManagersDropdown(selectedId = null) {
            $.getJSON('/Inventory/GetAllEmployees', function(employees) {
                const $manager = $('#employeeDropdown');
                $manager.empty().append('<option value="">Select Manager</option>');

                employees.forEach(emp => {
                    const selected = selectedId && emp.id === selectedId ? 'selected' : '';
                    $manager.append(`<option value="${emp.id}" ${selected}>${emp.name}</option>`);
                });
            });
        }

            loadManagersDropdown();


        // 🟦 Submit Assign Resource form
        $('#saveAssignResourceBtn').on('click', function (e) {
            e.preventDefault();

            const selectedResources = [];
            const planningId = parseInt($('#currentPlanningId').val()) || 0;

            // Collect selected resources from the table
                    $('#assignResourceForm tbody tr').each(function () {
            const $row = $(this);
            const isChecked = $row.find('input[type="checkbox"]').is(':checked');
            if (isChecked) {
                const resourceId = parseInt($row.data('resource-id'));
                if (resourceId) selectedResources.push(resourceId);
            }
        });


            if (selectedResources.length === 0) {
                return toastr.warning("Please select at least one resource");
            }

            const requestData = {
                PlanningId: planningId,
                ResourceIds: selectedResources
            };

            $.ajax({
                url: '/Construction/AssignResources',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(requestData),
                beforeSend: function () {
                    $('#saveAssignResourceBtn').prop('disabled', true).text('Saving...');
                },
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message || 'Resources assigned successfully');
                        $('#assignResourceModal').modal('hide');

                        // Optional: reload table of resources
                        if (typeof loadAssignedResources === 'function') loadAssignedResources();

                        // Reset the form
                        $('#assignResourceForm')[0].reset();
                    } else {
                        toastr.error(res.message || "Something went wrong");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to assign resources");
                },
                complete: function () {
                    $('#saveAssignResourceBtn').prop('disabled', false).text('Save');
                }
            });
        });




                });



    </script>

