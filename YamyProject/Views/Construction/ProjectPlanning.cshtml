    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
   

    <script>
         let currentTenderId = null;
         let currentPlanningId = null;

        $(document).ready(function () {

            $(document).on('change', '.autoLock', function () {
                const selectId = $(this).attr('id').replace('chk', ''); 
                const select = $('#' + selectId.charAt(0).toLowerCase() + selectId.slice(1));

                select.prop('disabled', $(this).is(':checked'));

                if (selectId === 'ReportedBy' && !$(this).is(':checked')) {
                    loadProjects();  
                }

                loadProjectPlanning();
            });

            loadProjects();
            loadProjectPlanning();

            $('#projectName, #projectType, #projectStatus').on('change', function () {
                loadProjectPlanning();
            });

            $.ajax({
            url: '/Construction/GetTenders',
            type: 'GET',
            dataType: 'json',
            success: function(response) {
                if (response.status) {
                    var dropdown = $('#tenderDropdown');
                    response.data.forEach(function(tender) {
                        dropdown.append(
                            $('<option>', {
                                value: tender.id,
                                text: tender.name
                            })
                        );
                    });
                } else {
                    console.error('Failed to load tenders:', response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error fetching tenders:', error);
            }
        });

            $.ajax({
            url: '/Construction/GetProjectSites',
            type: 'GET',
            dataType: 'json',
            success: function(response) {
                if (response.status) {
                    var dropdown = $('#projectSite');
                    response.data.forEach(function(site) {
                        dropdown.append(
                            $('<option>', {
                                value: site.id,
                                text: site.name
                            })
                        );
                    });
                } else {
                    console.error('Failed to load tenders:', response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error fetching tenders:', error);
            }
        });

            function populateBankAccounts() {
            $.ajax({
                url: '/HR/GetAccruedSalaries',
                type: 'GET',
                success: function(res) {
                    const data = Array.isArray(res) ? res : res.data || [];

                    if (!data.length) return;

                    const accountSelectors = ['#debitAccount'];

                    accountSelectors.forEach(function(selector) {
                        const $select = $(selector);
                        const selectedId = $select.data('selected-id');

                        $select.empty().append('<option value="">-- Select --</option>');

                        $.each(data, function(i, item) {
                            const $option = $('<option>', {
                                value: item.id,
                                text: `${item.code} - ${item.name}`,
                                selected: String(item.id) === String(selectedId)
                            });

                            $select.append($option);
                        });
                    });
                },
                error: function(err) {
                    console.error('Failed to fetch bank accounts:', err);
                }
            });
        }

            populateBankAccounts();

            $('#showTendersBtn').on('click', function () {
            // Get the selected project ID
            const projectId = $('#projectNames').val();

            if (projectId) {
                loadProjectTenders(projectId);
            } else {
                toastr.error('Please select a project first.');
            }

           });

            function loadProjectTenders(projectId) {
            $.ajax({
                url: '/Construction/GetProjectTenders',
                type: 'GET',
                data: { projectId: projectId },
                success: function (res) {
                    if (!res.status) {
                        toastr.error('Failed to load project tenders');
                        return;
                    }

                    // Destroy DataTable if already initialized
                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tbody = $('#table2 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            const tr = `
                                <tr data-id="${row.id}" style="cursor:pointer;">
                                    <td>${i + 1}</td>
                                    <td>${row.date ?? ''}</td>
                                    <td>${row.projectName ?? ''}</td>
                                    <td>${row.tenderName ?? ''}</td>
                                    <td>${row.submitDate ?? ''}</td>
                                    <td>${row.fees ?? 0}</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary viewItemsBtn" data-id="${row.id}" title="View Items">
                                            <i class="fas fa-book"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable
                        $('#table2').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 25
                        });
                    } else {
                        tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading project tenders');
                }
            });
        }

            $(document).on('click', '.viewItemsBtn', function () {
            const tenderId = $(this).data('id');
            if (!tenderId) return;

            $('#tenderItemsModal').modal('show');
            loadTenderItems(tenderId);
        });

            function loadTenderItems(tenderId) {
            $.ajax({
                url: '/Construction/GetTenderItems',
                type: 'GET',
                data: { tenderId: tenderId },
                success: function (res) {
                    // Destroy DataTable if already exists
                    if ($.fn.DataTable.isDataTable('#table3')) {
                        $('#table3').DataTable().clear().destroy();
                    }

                    const tbody = $('#table3 tbody');
                    tbody.empty();

                    if (res.status && res.data && res.data.length > 0) {
                        $.each(res.data, function (i, item) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${item.itemName ?? ''}</td>
                                    <td>${item.qty ?? 0}</td>
                                    <td>${item.rate ?? 0}</td>
                                    <td>${item.unit ?? ''}</td>
                                    <td>${item.amount ?? 0}</td>
                                    <td>${item.margin_Percentage ?? 0}</td>
                                    <td>${item.margin_Amount ?? 0}</td>
                                    <td>${item.total ?? 0}</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable with export buttons
                        $('#table3').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 10
                        });
                    } else {
                        tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>`);
                    }
                      // ✅ Calculate BOQ Total
                        calculateBoqTotal();
        
                },
                error: function () {
                    toastr.error('Failed to load tender items');
                }

                      
            });
        }

            function calculateBoqTotal() {
            let boqTotal = 0;

            $("#table3 tbody tr").each(function () {
                const total = parseFloat($(this).find("td:eq(8)").text()) || 0; // 9th column = Total
                boqTotal += total;
            });

            $("#boqTotal").val(boqTotal.toFixed(2));
        }

             $("#projectNames").on("change", function () {
            const projectId = $(this).val();
            if (projectId) {
                // Reload tender items for the selected project
                loadTenderItems(projectId);
            } else {
                // Clear table & BOQ total if no project selected
                $("#table3 tbody").empty().append(`<tr><td colspan="9" class="text-center text-muted py-3">No items found</td></tr>`);
                $("#boqTotal").val(0);
            }
        });

             $('#planningForm').on('submit', function (e) {
            e.preventDefault();
        });
      
        });

        function loadProjects() {
            $.ajax({
                url: '/Construction/GetProjects',
                type: 'GET',
                success: function (result) {
                    if (result.status) {
                        const $dropdown = $('#projectName');  
                        const $dropdowns = $('#projectNames'); 
                        $dropdown.empty();
                        $dropdowns.empty();

                        // Append default options
                        $dropdown.append('<option value="">-- Select Reported By --</option>');
                        $dropdowns.append('<option value="">-- Select Project --</option>');

                        // Populate both dropdowns with project names
                        $.each(result.data, function (index, project) {
                            $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                            $dropdowns.append('<option value="' + project.id + '">' + project.name + '</option>');
                        });

                     
                        if ($('#chkReportedBy').is(':checked')) {
                            $dropdown.prop('disabled', true);  
                        } else {
                            $dropdown.prop('disabled', false); 
                        }
                    } else {
                        toastr.error('Failed to load projects');
                    }
                },
                error: function () {
                    toastr.error('Error loading projects');
                }
            });
        }

        function loadProjectPlanning() {
            const reportedBy = $('#chkReportedBy').is(':checked') ? null : $('#projectName').val();
            const projectType = $('#chkProjectType').is(':checked') ? null : $('#projectType').val();
            const projectStatus = $('#chkProjectStatus').is(':checked') ? null : $('#projectStatus').val();

            $.ajax({
                url: '/Construction/GetProjectPlanning', 
                type: 'GET',
                data: {
                    projectId: reportedBy,
                    projectType: projectType,
                    projectStatus: projectStatus
                },
                beforeSend: function () {
                    $('#table1 tbody').html(
                        `<tr><td colspan="10" class="text-center text-muted py-4">
                            <div class="spinner-border text-primary me-2"></div>Loading...
                        </td></tr>`
                    );
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error('Failed to load project planning');
                        return;
                    }
                    // Destroy the existing DataTable if it is initialized
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            const tr = `
                                <tr data-id="${row.projectNo}" style="cursor:pointer;">
                                    <td>${i + 1}</td>
                                    <td>${row.date ?? ''}</td>
                                    <td>${row.projectName ?? ''}</td>
                                    <td>${row.startDate ?? ''}</td>
                                    <td>${row.endDate ?? ''}</td>
                                    <td>${row.status ?? ''}</td>
                                    <td>${row.projectType ?? ''}</td>
                                    <td>${row.estBudget ?? 0}</td>
                                    <td>${row.progress ?? ''}</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary editPlanningBtn"
                                                data-planning='${JSON.stringify(row)}'
                                                title="Edit Planning">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger deletePlanningBtn"
                                                data-id='${row.projectNo}'
                                                title="Delete Planning">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable with export buttons
                        $('#table1').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {
                                        columns: ':not(:last-child)'
                                    }
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {
                                        columns: ':not(:last-child)'
                                    },
                                    orientation: 'landscape',
                                    pageSize: 'A4'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 25
                        });
                    } else {
                        tbody.append(`<tr><td colspan="10" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading project planning');
                }
            });
        }

        $("#addPlanningBtn").on("click", () => $("#pettyCashSection").hide());

        $(document).on("click", ".editPlanningBtn", () => $("#pettyCashSection").slideDown());

        $("#btnSavePlanning").on("click", function () {

            // Collect form values
            const model = {
                Id: parseInt($("#planningId").val()) || 0,
                Date: $("#date").val(),
                ProjectId: parseInt($("#projectNames").val()) || 0,
                SiteId: parseInt($("#projectSite").val()) || 0,
                TenderId: parseInt($("#tenderDropdown").val()) || 0,
                TenderNameId: parseInt($("#tenderDropdown").val()) || 0,
                AccountId: parseInt($("#debitAccount").val()) || 0,
                CashAccountId: parseInt($("#cashAccount").val()) || 0,
                EstimatedBudget: parseFloat($("#estimatedBudget").val()) || 0,
                Status: $("#projectStatuss").val(),
                ProjectType: $("#projectTypee").val(),
                StartDate: $("#startDate").val(),
                EndDate: $("#endDate").val()
            };

            // --- Validation ---
            if (!model.ProjectId) {
                toastr.warning("Please select a Project.");
                return;
            }
            if (!model.SiteId) {
                toastr.warning("Please select a Site.");
                return;
            }
            if (!model.TenderId || !model.TenderNameId) {
                toastr.warning("Please select a Tender and Tender Name.");
                return;
            }
            if (!model.AccountId) {
                toastr.warning("Please select a Fund Management Account.");
                return;
            }
            if (model.EstimatedBudget <= 0) {
                toastr.warning("Estimated Budget must be greater than zero.");
                return;
            }
            if (!model.Status) {
                toastr.warning("Please select Project Status.");
                return;
            }
            if (!model.ProjectType) {
                toastr.warning("Please select Project Type.");
                return;
            }
            if (!model.Date) {
                toastr.warning("Please select a Date.");
                return;
            }
            if (!model.StartDate) {
                toastr.warning("Please select a Start Date.");
                return;
            }
            if (!model.EndDate) {
                toastr.warning("Please select an End Date.");
                return;
            }

            if (new Date(model.EndDate) < new Date(model.StartDate)) {
                toastr.warning("End Date cannot be earlier than Start Date.");
                return;
            }

            $.ajax({
                url: '/Construction/SaveOrUpdateProjectPlanning',
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify(model),
                beforeSend: function () {
                    $("#btnSavePlanning").prop("disabled", true).text("Saving...");
                },
                success: function (response) {
                    if (response.status) {
                        toastr.success(response.message || "Saved successfully!");
                        $("#planningModal").modal("hide");
                        loadProjectPlanning();
                    } else {
                        toastr.warning(response.message || "Save failed!");
                    }
                },
                error: function (xhr) {
                    toastr.error("Error: " + (xhr.responseText || "Unexpected error"));
                },
                complete: function () {
                    $("#btnSavePlanning").prop("disabled", false).text("Save");
                }
            });
        });

        $(document).on("click", ".editPlanningBtn", function () {
            const planning = $(this).data("planning");
            if (!planning) return;

            // Save tender ID globally
            currentTenderId = planning.tender_Name_Id;
            currentPlanningId = planning.id;
            // Fill modal fields
            $("#planningId").val(planning.id ?? 0);
            $("#date").val(planning.date ? planning.date.split('T')[0] : "");
            $("#projectNames").val(planning.project_Id ?? 0).trigger("change");
            $("#projectSite").val(planning.site ?? 0).trigger("change");
            $("#tenderDropdown").val(planning.tender_Name_Id ?? 0).trigger("change");
            $("#debitAccount").val(planning.fund_Account_Id ?? 0).trigger("change");
            $("#cashAccount").val(planning.fund_Account_Id ?? 0).trigger("change");
            $("#estimatedBudget").val(planning.estBudget ?? 0);
            $("#projectStatuss").val(planning.status ?? "").trigger("change");
            $("#projectTypee").val(planning.projectType ?? "").trigger("change");
            $("#startDate").val(planning.startDate ? planning.startDate.split('T')[0] : "");
            $("#endDate").val(planning.endDate ? planning.endDate.split('T')[0] : "");

            $("#planningModalLabel").text("Edit Project Planning");
            $("#btnSavePlanning").text("Update Planning");

            $("#planningModal").modal("show");

            // Show petty cash section & activity tab
            $('#pettyCashSection').slideDown();
            $('#activity-tab').tab('show');
                             // ✅ Load activity planning for the same tenderId
            loadActivityPlanning(currentTenderId);
           loadRequestMaterial(currentPlanningId);
           loadIssuedMaterial(currentPlanningId);
           loadReceivedMaterial(currentPlanningId);
            loadResourceList(currentPlanningId);
        });

        $("#addPlanningBtn").on("click", function () {
            currentTenderId = null;
            $("#planningModalLabel").text("Planning - New");
            $("#btnSavePlanning").text("Save");
            $("#pettyCashSection").hide();
            $("#planningId").val(0);
            $("#planningForm")[0].reset();
        });

        function loadActivityPlanning(tenderId) {
          

            $.ajax({
                url: '/Construction/GetProjectTenderDetails',
                type: 'GET',
                data: { tenderId: tenderId },
                success: function (res) {
                    const tbody = $('#activityTable tbody').empty();
                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="6" class="text-center">No records found</td></tr>');
                        return;
                    }

                    $.each(res.data, function (i, r) {
                        tbody.append(`
                            <tr>
                                <td>${r.SNo ?? i + 1}</td>
                                <td>${r.sr ?? ''}</td>
                                <td>${r.name ?? ''}</td>
                                <td>${r.startDate ?? ''}</td>
                                <td>${r.endDate ?? ''}</td>
                                <td>${r.progress ?? '0'}%</td>
                            </tr>
                        `);
                    });
                },
                error: function (xhr) {
                    console.error("API error:", xhr.status, xhr.responseText);
                    toastr.error('Failed to load activity planning');
                }
            });
        }

        function loadRequestMaterial(planningId) {
            $.ajax({
                url: '/Construction/GetRequestedMaterial',
                type: 'GET',
                data: { planningId: planningId },
                success: function (res) {
                    const tbody = $('#requestTable tbody').empty();
                    console.log(res);

                    // ✅ Check the correct structure
                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="7" class="text-center">No records found</td></tr>');
                        return;
                    }

                    // ✅ Loop through `res.data`
                    $.each(res.data, function (i, r) {
                        tbody.append(`
                            <tr>
                                <td>${r.sNo ?? i + 1}</td>
                                <td>${r.id ?? ''}</td>
                                <td>${r.date ?? ''}</td>
                                <td>${r.name ?? ''}</td>
                                <td>${r.unit ?? ''}</td>
                                <td>${r.qty ?? '0.00'}</td>
                                <td>${r.status ?? ''}</td>
                            </tr>
                        `);
                    });
                },
                error: function (xhr) {
                    console.error("API error:", xhr.status, xhr.responseText);
                    toastr.error('Failed to load request material');
                }
            });
        }

                // 🔹 Load Issued Material
        function loadIssuedMaterial(planningId) {
            $.ajax({
                url: '/Construction/GetIssuedMaterial',
                type: 'GET',
                data: { planningId: planningId },
                success: function (res) {
                    const tbody = $('#issueTable tbody').empty();
                    console.log("Issued:", res);

                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="6" class="text-center">No records found</td></tr>');
                        return;
                    }

                    $.each(res.data, function (i, r) {
                        tbody.append(`
                            <tr>
                                <td>${r.sNo ?? i + 1}</td>
                                <td>${r.id ?? ''}</td>
                                <td>${r.date ?? ''}</td>
                                <td>${r.name ?? ''}</td>
                                <td>${r.qty ?? '0.00'}</td>
                                <td>${r.status ?? ''}</td>
                            </tr>
                        `);
                    });
                },
                error: function (xhr) {
                    console.error("Issued API error:", xhr.status, xhr.responseText);
                    toastr.error('Failed to load issued materials');
                }
            });
        }

        // 🔹 Load Received Material
        function loadReceivedMaterial(planningId) {
            $.ajax({
                url: '/Construction/GetReceivedMaterial',
                type: 'GET',
                data: { planningId: planningId },
                success: function (res) {
                    const tbody = $('#receiveTable tbody').empty();
                    console.log("Received:", res);

                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="7" class="text-center">No records found</td></tr>');
                        return;
                    }

                    $.each(res.data, function (i, r) {
                        tbody.append(`
                            <tr>
                                <td>${r.sNo ?? i + 1}</td>
                                <td>${r.id ?? ''}</td>
                                <td>${r.date ?? ''}</td>
                                <td>${r.name ?? ''}</td>
                                <td>${r.qty ?? '0.00'}</td>
                                <td>${r.unit ?? ''}</td>
                                <td>${r.status ?? ''}</td>
                            </tr>
                        `);
                    });
                },
                error: function (xhr) {
                    console.error("Received API error:", xhr.status, xhr.responseText);
                    toastr.error('Failed to load received materials');
                }
            });
        }

        // 🔹 Load Resource List
        function loadResourceList(planningId) {
            $.ajax({
                url: '/Construction/GetResourceData',
                type: 'GET',
                data: { planningId: planningId },
                success: function (res) {
                    const tbody = $('#resourceTable tbody').empty();
                    console.log("Resources:", res);

                    if (!res.status || !res.data || res.data.length === 0) {
                        tbody.html('<tr><td colspan="6" class="text-center">No records found</td></tr>');
                        return;
                    }

                    $.each(res.data, function (i, r) {
                        tbody.append(`
                            <tr>
                                <td>${r.sNo ?? i + 1}</td>
                                <td>${r.code ?? ''}</td>
                                <td>${r.name ?? ''}</td>
                                <td>${r.type ?? ''}</td>
                                <td>${r.roleName ?? ''}</td>
                                <td>${r.priceUnit ?? '0.00'}</td>
                            </tr>
                        `);
                    });
                },
                error: function (xhr) {
                    console.error("Resource API error:", xhr.status, xhr.responseText);
                    toastr.error('Failed to load resource data');
                }
            });
        }

        $('.editPlanningBtn').on('click', function () {
            const tender = $(this).data('planning');
            $('#pettyCashSection').show();
            $('#activity-tab').tab('show');
            loadActivityPlanning(tender.tenderId);
        });

        $('#activity-tab').on('shown.bs.tab', function () {
            if (currentTenderId) {
                loadActivityPlanning(currentTenderId);
            }
        });

        $('#request-tab').on('shown.bs.tab', function () {
            if(currentPlanningId){
                loadRequestMaterial(currentPlanningId);
            }   
        });

                $('#issue-tab').on('shown.bs.tab', function () {
            if (currentPlanningId) {
                loadIssuedMaterial(currentPlanningId);
            }
        });

        $('#receive-tab').on('shown.bs.tab', function () {
            if (currentPlanningId) {
                loadReceivedMaterial(currentPlanningId);
            }
        });

        $('#resource-tab').on('shown.bs.tab', function () {
            if (currentPlanningId) {
                loadResourceList(currentPlanningId);
            }
        });

        $(document).ready(function() {
            $('#activityTable tbody').on('dblclick', 'tr', function() {
                // Get row data
                var rowData = $(this).children('td').map(function() {
                    return $(this).text();
                }).get();

                // Fill modal inputs
                $('#activityName').val(rowData[2]); 
                $('#startDate').val(formatDate(rowData[3])); 
                $('#endDate').val(formatDate(rowData[4]));  
                $('#progress').val(rowData[5]); 

                // Open modal
                var modal = new bootstrap.Modal(document.getElementById('activityModal'));
                modal.show();
            });
        });

        // Helper to format date if needed
        function formatDate(dateStr) {
            // Convert DD/MM/YYYY to YYYY-MM-DD for input[type=date]
            var parts = dateStr.split('/');
            return parts[2] + '-' + parts[1] + '-' + parts[0];
        }


            document.addEventListener('DOMContentLoaded', function() {
            const activityInput = document.getElementById('activitys');

            activityInput.addEventListener('click', function() {
                // Open Sub-Activity modal
                var subActivityModal = new bootstrap.Modal(document.getElementById('subActivityModal'));
                subActivityModal.show();
            });
        });


   </script>

