
@{
    ViewData["Title"] = "ProjectSiteWork";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header text-center">
        <strong>Project Site Daily Work</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-3">
            <button type="button" class="btn btn-primary" id="addSiteBtn" data-bs-toggle="modal" data-bs-target="#siteModal">
                <i class="bi bi-plus-circle me-2"></i>Add Site
            </button>
        </div>

        <table id="projectSiteTable" class="table table-striped table-bordered align-middle">
            <thead class="table-primary text-center">
                <tr>
                    <th>SN</th>
                    <th>Work Date</th>
                    <th>Project Name</th>
                    <th>Site Name</th>
                    <th>BOQ Item</th>
                    <th>Today Qty</th>
                    <th>Cum Qty</th>
                    <th>Progress %</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

    </div>
</div>


<div class="modal fade" id="siteModal" tabindex="-1" aria-labelledby="siteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <form id="siteForm" class="needs-validation" novalidate>
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title w-100 text-center" id="siteModalLabel">Site Setup</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="siteId" value="0" />
                    <input type="hidden" id="tenderId" value="0" />
                    <!-- Form Inputs -->
                    <div class="row g-3 align-items-center">
                        <!-- Date -->
                        <div class="col-md-4">
                            <label for="date" class="form-label fw-bold">Date</label>
                            <input type="date" id="date" class="form-control" required />
                            <div class="invalid-feedback">Date is required.</div>
                        </div>

                        <!-- Project Name -->
                        <div class="col-md-4">
                            <label for="projectName" class="form-label fw-bold">Project Name</label>
                            <select class="form-select" id="projectName" required>
                                <option value="">-- Select Project --</option>
                            </select>
                            <div class="invalid-feedback">Project name is required.</div>
                        </div>

                        <!-- Project Site -->
                        <div class="col-md-4">
                            <label for="projectSite" class="form-label fw-bold">Project Site</label>
                            <select id="projectSite" class="form-select" required>
                                <option value="">-- Select Site --</option>
                            </select>
                            <div class="invalid-feedback">Please select a project site.</div>
                        </div>

                    </div>

                    <!-- Table section -->
                    <div class="mt-4">
                        <div class="table-responsive" style="max-height: 300px; overflow-y: auto; border: 1px solid #ddd; border-radius: 4px;">
                            <table class="table table-bordered table-hover table-sm mb-0" id="boqTable">
                                <thead class="table-light" style="position: sticky; top: 0; z-index: 10;">
                                    <tr>
                                        <th style="width: 40px;">Sr</th>
                                        <th>BOQ Item</th>
                                        <th style="width: 80px;">Unit</th>
                                        <th style="width: 100px;">BOQ Qty</th>
                                        <th style="width: 110px;">Prev Done Qty</th>
                                        <th style="width: 100px;">Today Qty</th>
                                        <th style="width: 100px;">Cum Qty</th>
                                        <th style="width: 110px;">Balance Qty</th>
                                        <th style="width: 110px;">Progress %</th>
                                    </tr>
                                </thead>
                                <tbody id="boqTableBody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="modal-footer justify-content-between">
                    <div>
                        <span class="me-3"><strong>Total Today Qty:</strong> <span id="totalTodayQty">0</span></span>
                        <span><strong>Overall Progress:</strong> <span id="overallProgress">0</span></span>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary px-4">Save</button>
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        $(document).ready(function () {

            loadProjects();
            loadDailyWorks();
            $.ajax({
                 url: '@Url.Action("GetProjectSites", "Construction")',
                    type: 'GET',
                    dataType: 'json',
                    success: function(response) {
                        if (response.status) {
                            var dropdown = $('#projectSite');
                            response.data.forEach(function(site) {
                                dropdown.append(
                                    $('<option>', {
                                        value: site.id,
                                        text: site.name
                                    })
                                );
                            });
                        } else {
                            console.error('Failed to load tenders:', response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error fetching tenders:', error);
                    }
                });

            function getTodayDate() {
                const today = new Date();
                const year = today.getFullYear();
                const month = String(today.getMonth() + 1).padStart(2, '0');
                const day = String(today.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            document.getElementById('siteModal').addEventListener('shown.bs.modal', function () {
                const todayDate = getTodayDate();

                // Fill all date fields
                const dateFields = [
                    'date'
                ];

                dateFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (field && !field.value) {
                        field.value = todayDate;
                    }
                });
            });

        });

          function loadProjects() {
                $.ajax({
                    url: '@Url.Action("GetProjectManagement", "Construction")',
                    type: 'GET',
                    success: function (result) {
                        if (result.status) {
                            const $dropdown = $('#projectName');
                            $dropdown.empty();
                            $dropdown.append('<option value="">-- Select Project --</option>');

                            $.each(result.data, function (index, project) {
                                $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                            });
                        } else {
                            toastr.error('Failed to load projects');
                        }
                    },
                    error: function () {
                        toastr.error('Error loading projects');
                    }
                });
            }




          function addNewRow() {
            const rowCount = $('#boqTableBody tr').length + 1;
            const newRow = `
                <tr>
                    <td>${rowCount}</td>
                    <td>
                        <select class="form-select form-select-sm boqItemSelect">
                            <option value="">-- Select BOQ Item --</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control form-control-sm unit" readonly></td>
                    <td><input type="number" class="form-control form-control-sm boqQty" readonly></td>
                    <td><input type="number" class="form-control form-control-sm prevDoneQty" readonly></td>
                    <td><input type="number" class="form-control form-control-sm todayQty" step="0.01" min="0"></td>
                    <td><input type="number" class="form-control form-control-sm cumQty" readonly></td>
                    <td><input type="number" class="form-control form-control-sm balanceQty" readonly></td>
                    <td><input type="number" class="form-control form-control-sm progressPercent" readonly></td>
                </tr>
            `;
            $('#boqTableBody').append(newRow);

            const $lastRow = $('#boqTableBody tr:last');
            fillBoqItems($lastRow.find('select.boqItemSelect')); 
            setupRowListeners($lastRow);
        }

          function fillBoqItems($select) {
            $select.empty().append('<option value="">-- Select BOQ Item --</option>');
            allBoqItems.forEach(item => {
                $select.append(`<option value="${item.id}"
                    data-unit="${item.unit}"
                    data-boqqty="${item.boqQty}"
                    data-prevdoneqty="${item.prevDoneQty}">
                    ${item.name}
                </option>`);
            });
        }


          function setupRowListeners($row) {
           const $boqSelect = $row.find('select.boqItemSelect');
           const $unit = $row.find('input.unit');
           const $boqQty = $row.find('input.boqQty');
           const $prevDone = $row.find('input.prevDoneQty');
           const $todayQty = $row.find('input.todayQty');
           const $cumQty = $row.find('input.cumQty');
           const $balanceQty = $row.find('input.balanceQty');
           const $progress = $row.find('input.progressPercent');

           $boqSelect.on('change', function () {
             const selectedOption = $(this).find('option:selected');
             if (selectedOption.val() === '') {
               $unit.val('');
               $boqQty.val('');
               $prevDone.val('');
               $todayQty.val('');
               $cumQty.val('');
               $balanceQty.val('');
               $progress.val('');
             } else {
               $unit.val(selectedOption.data('unit'));
               $boqQty.val(selectedOption.data('boqqty'));
               $prevDone.val(selectedOption.data('prevdoneqty'));
               $todayQty.val('');
               $cumQty.val('');
               $balanceQty.val('');
               $progress.val('');
             }
             checkAddRow();
           });

           $todayQty.on('input', function () {
             const boqQtyVal = parseFloat($boqQty.val()) || 0;
             const prevDoneVal = parseFloat($prevDone.val()) || 0;
             const todayQtyVal = parseFloat($(this).val()) || 0;

             const cumQtyVal = prevDoneVal + todayQtyVal;
             $cumQty.val(cumQtyVal.toFixed(3));

             const balanceQtyVal = boqQtyVal - cumQtyVal;
             $balanceQty.val(balanceQtyVal.toFixed(3));

             const progressVal = boqQtyVal > 0 ? (cumQtyVal / boqQtyVal) * 100 : 0;
             $progress.val(progressVal.toFixed(2));

             checkAddRow();
           });
         }

          function checkAddRow() {
           const $rows = $('#boqTableBody tr');
           if ($rows.length === 0) return;

           const $lastRow = $rows.last();
           const boqSelected = $lastRow.find('select.boqItemSelect').val();
           const todayQtyVal = $lastRow.find('input.todayQty').val();

           if (boqSelected !== '' || (todayQtyVal !== '' && !isNaN(parseFloat(todayQtyVal)))) {
             addNewRow();
           }
         }

          $('#siteModal').on('shown.bs.modal', function () {
           $('#boqTableBody').empty();
           addNewRow();
         });

          let allBoqItems = [];

          $('#projectName, #projectSite').on('change', async function () {
            const projectId = $('#projectName').val();
            const site = $('#projectSite').val();

            $('#tenderId').val(0); 

            if (!projectId || !site) {
                $('#boqTableBody').empty();
                return;
            }

            try {
                const tenderUrl = '@Url.Action("GetTenderByProjectSite", "Construction")';
                const tenderResponse = await fetch(`${tenderUrl}?projectId=${projectId}&site=${encodeURIComponent(site)}`);
                const tenderData = await tenderResponse.json();

                if (!tenderData.status || tenderData.data.tenderId === 0) {
                    toastr.warning("No Tender found for this Project + Site");
                    $('#boqTableBody').empty();
                    return;
                }

                const tenderId = tenderData.data.tenderId;
                $('#tenderId').val(tenderId); // ✅ store tender ID here

                const boqUrl = '@Url.Action("GetBOQItemsByTender", "Construction")';
                const boqResponse = await fetch(`${boqUrl}?tenderId=${tenderId}`);
                const boqData = await boqResponse.json();

                if (!boqData.status || !boqData.data.length) {
                    toastr.warning("No BOQ items found for this Tender");
                    $('#boqTableBody').empty();
                    return;
                }

                allBoqItems = boqData.data;
                $('#boqTableBody').empty();
                addNewRow();

            } catch (error) {
                console.error("Error:", error);
                toastr.error("Failed to load BOQ data.");
            }
        });

          function updateBoqTotals() {
            let totalToday = 0, totalCum = 0, totalBoq = 0;
            $('#boqTableBody tr').each(function () {
                totalBoq   += parseFloat($(this).find('.boqQty').val()) || 0;
                totalCum   += parseFloat($(this).find('.cumQty').val()) || 0;
                totalToday += parseFloat($(this).find('.todayQty').val()) || 0;
            });
            $('#totalTodayQty').text(totalToday.toFixed(2));
            $('#overallProgress').text(totalBoq > 0 ? ((totalCum / totalBoq) * 100).toFixed(2) + '%' : '0%');
        }

          $("#siteForm").on("submit", function (e) {
            e.preventDefault();

            // ✅ Remove empty rows before validation
            $('#boqTableBody tr').each(function () {
                const boqVal = $(this).find('.boqItemSelect').val();
                const todayVal = $(this).find('.todayQty').val();
                if (!boqVal && (!todayVal || parseFloat(todayVal) === 0)) {
                    $(this).remove();
                }
            });

            if (!this.checkValidity()) {
                e.stopPropagation();
                $(this).addClass('was-validated');
                return;
            }

            const model = {
                ProjectId: parseInt($("#projectName").val()) || 0,
                SiteId:    parseInt($("#projectSite").val()) || 0,
                TenderId:  parseInt($("#tenderId").val()) || 0,
                WorkDate:  $("#date").val(),
                DailyWorks: []
            };

            if (!model.ProjectId) { toastr.warning("Please select a Project."); return; }
            if (!model.SiteId)    { toastr.warning("Please select a Site.");    return; }
            if (!model.TenderId)  { toastr.warning("Tender not found.");        return; }
            if (!model.WorkDate)  { toastr.warning("Please select a Date.");    return; }

            let hasError = false;

            $("#boqTableBody tr").each(function () {
                const $row      = $(this);
                const boqItemId = parseInt($row.find(".boqItemSelect").val()) || 0;
                const boqQty    = parseFloat($row.find(".boqQty").val()) || 0;
                const prevDone  = parseFloat($row.find(".prevDoneQty").val()) || 0;
                const todayQty  = parseFloat($row.find(".todayQty").val()) || 0;
                const cumQty    = parseFloat($row.find(".cumQty").val()) || 0;
                const progress  = parseFloat($row.find(".progressPercent").val()) || 0;

                if (todayQty <= 0) return; // skip empty rows

                if (!boqItemId) {
                    toastr.warning("BOQ Item is missing in one or more rows.");
                    hasError = true;
                    return false;
                }
                if (cumQty > boqQty) {
                    toastr.warning("Cumulative Qty cannot exceed BOQ Qty.");
                    hasError = true;
                    return false;
                }

                model.DailyWorks.push({
                    BoqItemId:   boqItemId,
                    BoqQty:      boqQty,
                    PrevDoneQty: prevDone,
                    TodayQty:    todayQty,
                    CumQty:      cumQty,
                    Progress:    progress,
                    Remarks:     ""
                });
            });

            if (hasError) return;

            if (model.DailyWorks.length === 0) {
                toastr.warning("Please enter at least one row with Today Qty greater than zero.");
                return;
            }

            const $btnSave = $("#siteForm button[type='submit']");
            $btnSave.prop("disabled", true).text("Saving...");

            $.ajax({
                url: '@Url.Action("SaveDailyWork", "Construction")',
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify(model),
                success: function (response) {
                    if (response.status) {
                        toastr.success(response.message || "Saved successfully!");
                        $("#siteModal").modal("hide");
                         setTimeout(function () {
                            location.reload();
                        }, 1500);
                    } else {
                        toastr.warning(response.message || "Save failed!");
                    }
                },
                error: function (xhr) {
                    toastr.error("Error: " + (xhr.responseText || "Unexpected error"));
                },
                complete: function () {
                    $btnSave.prop("disabled", false).text("Save");
                }
            });
        });

          function loadDailyWorks() {
            $.ajax({
                url: '@Url.Action("GetDailyWorks", "Construction")',
                type: 'GET',
                success: function (result) {
                    const $tbody = $('#projectSiteTable tbody');
                    $tbody.empty();

                    if (result.status && result.data.length > 0) {

                        $.each(result.data, function (index, item) {
                            let row = `
                                <tr class="text-center">
                                    <td>${item.sn}</td>
                                    <td style="direction:ltr;">${item.workDate}</td>
                                    <td>${item.projectName || ''}</td>
                                    <td>${item.siteName || ''}</td>
                                    <td>${item.boqItemName || ''}</td>
                                    <td>${parseFloat(item.todayQty).toFixed(2)}</td>
                                    <td>${parseFloat(item.cumQty).toFixed(2)}</td>
                                    <td>
                                        <span class="badge bg-success">
                                            ${parseFloat(item.progress).toFixed(2)}%
                                        </span>
                                    </td>
                                </tr>
                            `;
                            $tbody.append(row);
                        });

                    } else {
                        $tbody.append(`
                            <tr>
                                <td colspan="9" class="text-center text-muted">
                                    No data found
                                </td>
                            </tr>
                        `);
                    }
                },
                error: function () {
                    toastr.error('Error loading daily works');
                }
            });
        }

    </script>
}
