
@{
    ViewData["Title"] = "ProjectTender";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Project Tender</strong>
    </div>
    <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <!-- Left: Project Dropdown -->
                <div style="min-width: 300px;">
                    <h6 class="fw-bold mb-2">Project Name</h6>
                    <select class="form-select" id="projectName">
                        <option value="">-- Select Project --</option>
                    </select>
                </div>

                <!-- Right: Add Button -->
                <div>
                <button class="btn btn-primary rounded-3" id="addTenderBtn" data-bs-toggle="modal" data-bs-target="#tenderModal">
                        <i class="fas fa-plus me-2"></i> Add Tender
                    </button>
                <button type="button" class="btn btn-success recycleCardBtn ms-2" data-bs-toggle="modal" data-bs-target="#recycleTenderModal">
                    <i class="fas fa-recycle me-2"></i>Recycle
                </button>
                </div>
            </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Project Name</th>
                    <th>Tender Name</th>
                    <th>Submit Date</th>
                    <th>Fees</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Tender Items Modal -->
<div class="modal fade" id="tenderItemsModal" tabindex="-1" aria-labelledby="tenderItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white shadow-sm">
                <h5 class="modal-title fw-semibold d-flex align-items-center" id="tenderItemsModalLabel">
                    <i class="fas fa-list-alt me-2"></i> Tender Items
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="table2" style="font-size:13px; width:100%;">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Unit</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Tender Modal -->
<div class="modal fade" id="tenderModal" tabindex="-1" aria-labelledby="tenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content rounded-4 shadow-lg border-0">

            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="tenderModalLabel">Project - New Tender</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="tenderForm">
                    <input type="hidden" id="TenderId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" class="form-control" id="tenderDate">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project</label>
                            <div class="input-group">
                                <select class="form-select" id="projectDropdown">
                                    <option value="">-- Select Project --</option>
                                </select>
                                <a href="/Construction/ProjectCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project Code</label>
                            <input type="text" class="form-control" id="projectCode" placeholder="Account Code" readonly>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <select class="form-select" id="debitAccount">
                                <option value="">-- Select Account --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Tender Name</label>
                            <div class="input-group">
                                <select class="form-select" id="tenderDropdown">
                                    <option value="">-- Select Tender --</option>
                                </select>
                                <a href="/Construction/TenderCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Submission Date</label>
                            <input type="date" class="form-control" id="submissionDate">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold">Fees</label>
                            <input type="text" class="form-control" id="fees" placeholder="Fees">
                        </div>

                        <!-- Step 1: Download Sample PDF -->
                        <div class="col-md-2 d-flex align-items-end">
                            <a href="~/BOQ.xlsx"
                               class="btn btn-outline-primary w-100 mb-0"
                               id="downloadSampleBtn"
                               download>
                                Download Sample
                            </a>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-primary w-100 mb-0" type="button" id="importBoqBtn">
                                Import BOQ
                            </button>
                        </div>

                    </div>

                    <!-- Status Message -->
                    <div class="row">
                        <div class="col-md-12 mt-2">
                            <small id="boqStatusMessage" class="text-muted">
                                🔹 Please download the sample before importing your BOQ file.
                            </small>
                        </div>
                    </div>



                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" class="form-control" id="tenderDescription" placeholder="Description">
                        </div>

                        <div class="col-md-6">
                            <label for="warehouseDropdown" class="form-label fw-semibold">Warehouse</label>
                            <select id="warehouseDropdown" class="form-select">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>

                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>Sr</th>
                                    <th>Description of Work</th>
                                    <th>Qty</th>
                                    <th>Unit</th>
                                    <th>Length</th>
                                    <th>Width</th>
                                    <th>Thick</th>
                                    <th>Rate</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody id="tenderTableBody">
                                <tr>
                                    <td><input type="text" class="form-control sr" value="A" readonly></td>
                                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                                    <td><input type="number" class="form-control qty"></td>
                                    <td><input type="text" class="form-control unit"></td>
                                    <td><input type="text" class="form-control length"></td>
                                    <td><input type="text" class="form-control width"></td>
                                    <td><input type="text" class="form-control thick"></td>
                                    <td><input type="text" class="form-control rate" disabled></td>
                                    <td><input type="text" class="form-control amount" disabled></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveTenderBtn">Save Tender</button>
            </div>

        </div>
    </div>
</div>

<!-- ♻️ Recycle Bin Modal -->
<div class="modal fade" id="recycleTenderModal" tabindex="-1" aria-labelledby="recycleTenderLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4 shadow-lg border-0">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title" id="recycleTenderLabel">Recycle Bin - Deleted Project Tenders</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="recycleTenderTable">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Date</th>
                            <th>Project Name</th>
                            <th>Tender Name</th>
                            <th>Submit Date</th>
                            <th>Fees</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        <tr><td colspan="7" class="text-muted py-4">No deleted tenders found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title" id="importModalLabel">📋 BOQ Import</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="boqImportForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Data Start Row Number</label>
                        <input type="number" class="form-control" id="cellStartIndex" value="2" placeholder="e.g., 2">
                        <small class="text-muted">
                            Enter the Excel row number where your data starts<br>
                            (Usually row 2 if row 1 contains headers)
                        </small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Data End Row Number (Optional)</label>
                        <input type="number" class="form-control" id="cellEndIndex" placeholder="Leave blank for all rows">
                        <small class="text-muted">Leave empty to import all data rows</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Upload Excel File</label>
                        <input type="file" class="form-control" id="excelFileInput" accept=".xls, .xlsx">
                        <small class="text-success">✅ Columns will be auto-detected</small>
                    </div>

                    <div class="alert alert-info mb-0">
                        <strong>📌 Excel Format:</strong><br>
                        <small>
                            Row 1 (Header): S.No | Description | Qty | Unit | Rate | Amount<br>
                            Row 2+ (Data): Your BOQ items
                        </small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="okBtn">
                    <i class="fas fa-upload me-1"></i> Import Data
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
     <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        function detectColumns(headers) {
            const map = {};

            console.log("Detecting columns from headers:", headers);

            headers.forEach((header, index) => {
                if (!header) return;

                const h = String(header).toLowerCase().trim();

                // More flexible matching patterns
                if (h.match(/s\.?n\.?o?|serial|sr\.?/i)) {
                    map.sn = index;
                    console.log(`Found S.No at column ${index}: "${header}"`);
                }
                else if (h.match(/desc|work|item|particular/i)) {
                    map.description = index;
                    console.log(`Found Description at column ${index}: "${header}"`);
                }
                else if (h.match(/qty|quantity|quan/i)) {
                    map.qty = index;
                    console.log(`Found Qty at column ${index}: "${header}"`);
                }
                else if (h.match(/unit/i)) {
                    map.unit = index;
                    console.log(`Found Unit at column ${index}: "${header}"`);
                }
                else if (h.match(/length|len/i)) {
                    map.length = index;
                    console.log(`Found Length at column ${index}: "${header}"`);
                }
                else if (h.match(/width|wid/i)) {
                    map.width = index;
                    console.log(`Found Width at column ${index}: "${header}"`);
                }
                else if (h.match(/thick/i)) {
                    map.thickness = index;
                    console.log(`Found Thickness at column ${index}: "${header}"`);
                }
                else if (h.match(/rate|price|unit.*price/i)) {
                    map.rate = index;
                    console.log(`Found Rate at column ${index}: "${header}"`);
                }
                else if (h.match(/amount|total|value/i)) {
                    map.amount = index;
                    console.log(`Found Amount at column ${index}: "${header}"`);
                }
            });

            console.log("Final column mapping:", map);
            return map;
        }

        document.addEventListener("DOMContentLoaded", function () {
            const downloadBtn = document.getElementById("downloadSampleBtn");
            const importBoqBtn = document.getElementById("importBoqBtn");
            const statusMessage = document.getElementById("boqStatusMessage");
            const importModal = new bootstrap.Modal(document.getElementById("importModal"));

            // Enable Import BOQ after sample download
            downloadBtn.addEventListener("click", function () {
                setTimeout(() => {
                    importBoqBtn.classList.remove("disabled");
                    importBoqBtn.removeAttribute("disabled");
                    statusMessage.textContent = "✅ You can now import your BOQ file.";
                    statusMessage.classList.remove("text-muted");
                    statusMessage.classList.add("text-success");
                }, 1000);
            });

            // Show modal when Import BOQ clicked
            importBoqBtn.addEventListener("click", function () {
                if (importBoqBtn.disabled) return;
                importModal.show();
            });

       
        document.getElementById("okBtn").addEventListener("click", function () {
            const fileInput = document.getElementById("excelFileInput");
            const startIndex = parseInt(document.getElementById("cellStartIndex").value);
            const endIndex = parseInt(document.getElementById("cellEndIndex").value);

            if (!fileInput.files.length) {
                toastr.warning("Please upload an Excel file");
                return;
            }

            if (!startIndex || startIndex < 1) {
                toastr.warning("Please enter a valid start row number");
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: "array" });
                    const sheet = workbook.Sheets[workbook.SheetNames[0]];
                    const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

                    if (!rows || rows.length < 2) {
                        toastr.error("Excel file is empty or invalid");
                        return;
                    }

                    console.log("Total rows in Excel:", rows.length);
                    console.log("First few rows:", rows.slice(0, 5));

                    // Header row is always one row before data starts
                    const headerRowIndex = startIndex - 2; // If data starts at row 2, header is at index 0
                    const headerRow = rows[headerRowIndex];

                    if (!headerRow || headerRow.length === 0) {
                        toastr.error("Could not find header row. Please check your start index.");
                        return;
                    }

                    console.log("Header row:", headerRow);

                    // Auto-detect columns from header row
                    const colMap = detectColumns(headerRow);
                    console.log("Detected column mapping:", colMap);

                    const tbody = document.getElementById("tenderTableBody");
                    tbody.innerHTML = "";

                    // Calculate actual array indices (Excel row numbers start at 1, array starts at 0)
                    const startRowIndex = startIndex - 1; // Convert Excel row to array index
                    const endRowIndex = endIndex ? endIndex : rows.length;

                    let importedCount = 0;

                    console.log(`Processing rows from index ${startRowIndex} to ${endRowIndex}`);

                    for (let i = startRowIndex; i < endRowIndex && i < rows.length; i++) {
                        const row = rows[i];

                        if (!row || row.length === 0) {
                            console.log(`Skipping empty row at index ${i}`);
                            continue;
                        }

                        // Skip if all cells are empty
                        const hasData = row.some(cell => cell !== null && cell !== undefined && String(cell).trim() !== '');
                        if (!hasData) {
                            console.log(`Skipping row ${i} - no data`);
                            continue;
                        }

                        // Extract values using detected column indices
                        const srValue = colMap.sn !== undefined ? (row[colMap.sn] || (importedCount + 1)) : (importedCount + 1);
                        const description = colMap.description !== undefined ? (row[colMap.description] || "") : "";
                        const qty = colMap.qty !== undefined ? (row[colMap.qty] || "") : "";
                        const unit = colMap.unit !== undefined ? (row[colMap.unit] || "") : "";
                        const length = colMap.length !== undefined ? (row[colMap.length] || "") : "";
                        const width = colMap.width !== undefined ? (row[colMap.width] || "") : "";
                        const thickness = colMap.thickness !== undefined ? (row[colMap.thickness] || "") : "";
                        const rate = colMap.rate !== undefined ? (row[colMap.rate] || "") : "";
                        const amount = colMap.amount !== undefined ? (row[colMap.amount] || "") : "";

                        console.log(`Row ${i} data:`, {
                            sr: srValue,
                            description,
                            qty,
                            unit,
                            rate,
                            amount
                        });

                        const tr = document.createElement("tr");
                        tr.innerHTML = `
                            <td><input class="form-control sr" value="${srValue}" readonly></td>
                            <td><input class="form-control description" value="${description}"></td>
                            <td><input class="form-control qty" value="${qty}"></td>
                            <td><input class="form-control unit" value="${unit}"></td>
                            <td><input class="form-control length" value="${length}"></td>
                            <td><input class="form-control width" value="${width}"></td>
                            <td><input class="form-control thick" value="${thickness}"></td>
                            <td><input class="form-control rate" value="${rate}" disabled></td>
                            <td><input class="form-control amount" value="${amount}" disabled></td>
                        `;
                        tbody.appendChild(tr);
                        importedCount++;
                    }

                    if (importedCount === 0) {
                        toastr.warning("No data found in the specified range. Please check your start/end row numbers.");
                        addEmptyRow();
                    } else {
                        toastr.success(`✅ Successfully imported ${importedCount} items!`);
                        console.log(`Total imported: ${importedCount} rows`);
                    }

                    // Close import modal
                    $("#importModal").modal("hide");

                } catch (error) {
                    console.error("Import error:", error);
                    toastr.error("Failed to import Excel file: " + error.message);
                }
            };

            reader.readAsArrayBuffer(fileInput.files[0]);
        });
        });

        function loadWarehouses() {
            $.ajax({
                url: '@Url.Action("GetWarehouses", "Inventory")',
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        if (result.data && result.data.length > 0) {
                            result.data.forEach(w => {
                                dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                            });
                        } else {
                            dropdown.append('<option value="">No warehouses available</option>');
                        }
                    } else {
                        alert(result.message || 'Error loading warehouses');
                    }
                },
                error: function(err) {
                    console.error('Error fetching data:', err);
                    alert('Failed to load warehouse data. Please try again later.');
                }
            });
        }

        function getSrForRow(rowIndex) {
            const groupIndex = Math.floor(rowIndex / 4);
            const posInGroup = rowIndex % 4;
            const letter = String.fromCharCode(65 + groupIndex);
            if (posInGroup === 0) return letter;
            return posInGroup;
        }

        function addRow() {
            const rowIndex = $('#tenderTableBody tr').length;
            const srValue = getSrForRow(rowIndex);

            const newRow = `
                <tr>
                    <td class="sr-cell text-center">${srValue}</td>
                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                    <td><input type="number" class="form-control qty"></td>
                    <td><input type="text" class="form-control unit"></td>
                    <td><input type="text" class="form-control length"></td>
                    <td><input type="text" class="form-control width"></td>
                    <td><input type="text" class="form-control thick"></td>
                    <td><input type="text" class="form-control rate" disabled></td>
                    <td><input type="text" class="form-control amount" disabled></td>
                </tr>`;

            $('#tenderTableBody').append(newRow);
        }

        function addEmptyRow() {
            $("#tenderTableBody").append(`
                <tr>
                    <td><input type="text" class="form-control sr" value="A" readonly></td>
                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                    <td><input type="number" class="form-control qty"></td>
                    <td><input type="text" class="form-control unit"></td>
                    <td><input type="text" class="form-control length"></td>
                    <td><input type="text" class="form-control width"></td>
                    <td><input type="text" class="form-control thick"></td>
                    <td><input type="text" class="form-control rate" disabled></td>
                    <td><input type="text" class="form-control amount" disabled></td>
                </tr>
            `);
        }

        $(document).ready(function () {
            loadProjectTenders();
            loadWarehouses();

            if ($('#tenderTableBody tr').length === 0) addRow();

            $('#tenderTableBody').on('input', 'tr:last-child input', function () {
                const $lastRow = $(this).closest('tr');
                const filled = $lastRow.find('input').toArray().some(i => $(i).val().trim() !== '');
                if (filled) addRow();
            });

            function loadProjects() {
                $.ajax({
                    url: '@Url.Action("GetProjectManagement", "Construction")',
                    type: 'GET',
                    success: function (result) {
                        if (result.status) {
                            const $dropdown = $('#projectName');
                            $dropdown.empty();
                            $dropdown.append('<option value="">-- Select Project --</option>');

                            $.each(result.data, function (index, project) {
                                $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                            });
                        } else {
                            toastr.error('Failed to load projects');
                        }
                    },
                    error: function () {
                        toastr.error('Error loading projects');
                    }
                });
            }

            loadProjects();

            function loadProjectTenders(projectId) {
                $.ajax({
                    url: '@Url.Action("GetProjectTenders", "Construction")',
                    type: 'GET',
                    data: { projectId: projectId },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error('Failed to load project tenders');
                            return;
                        }

                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().clear().destroy();
                        }

                        const tbody = $('#table1 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                const tr = `
                                    <tr data-id="${row.id}" style="cursor:pointer;">
                                        <td>${i + 1}</td>
                                        <td>${row.date ?? ''}</td>
                                        <td>${row.projectName ?? ''}</td>
                                        <td>${row.tenderName ?? ''}</td>
                                        <td>${row.submitDate ?? ''}</td>
                                        <td>${row.fees ?? 0}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary editTenderBtn" data-tender='${JSON.stringify(row)}' title="Edit Tender">
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-primary viewItemsBtn" data-id="${row.id}" title="View Items">
                                                <i class="fas fa-book"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger deleteTenderBtn" data-id='${row.id}' title="Delete Tender">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $('#table1').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                      extend: 'print',
                                      text: '<i class="fas fa-print me-1"></i> Print',
                                      className: 'btn btn-primary btn-sm',
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 25
                            });
                        } else {
                            tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading project tenders');
                    }
                });
            }

            $('#projectName').on('change', function () {
                const projectId = $(this).val();
                if (projectId) {
                    loadProjectTenders(projectId);
                } else {
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }
                    $('#table1 tbody').html(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                }
            });

            $(document).on('click', '.viewItemsBtn', function () {
                const tenderId = $(this).data('id');
                if (!tenderId) return;

                $('#tenderItemsModal').modal('show');
                loadTenderItems(tenderId);
            });

            function loadTenderItems(tenderId) {
                $.ajax({
                    url: '@Url.Action("GetTenderItems", "Construction")',
                    type: 'GET',
                    data: { tenderId: tenderId },
                    success: function (res) {
                        if ($.fn.DataTable.isDataTable('#table2')) {
                            $('#table2').DataTable().clear().destroy();
                        }

                        const tbody = $('#table2 tbody');
                        tbody.empty();

                        if (res.status && res.data && res.data.length > 0) {
                            $.each(res.data, function (i, item) {
                                const tr = `
                                    <tr>
                                        <td>${i + 1}</td>
                                        <td>${item.Y ?? ''}</td>
                                        <td>${item.qty ?? 0}</td>
                                        <td>${item.rate ?? 0}</td>
                                        <td>${item.unit ?? ''}</td>
                                        <td>${item.amount ?? 0}</td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $('#table2').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                       extend: 'print',
                                       text: '<i class="fas fa-print me-1"></i> Print',
                                       className: 'btn btn-primary btn-sm',
                                     }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 10
                            });
                        } else {
                            tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load tender items');
                    }
                });
            }

            function populateBankAccounts() {
                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function(res) {
                        const data = Array.isArray(res) ? res : res.data || [];

                        if (!data.length) return;

                        const accountSelectors = ['#debitAccount'];

                        accountSelectors.forEach(function(selector) {
                            const $select = $(selector);
                            const selectedId = $select.data('selected-id');

                            $select.empty().append('<option value="">-- Select --</option>');

                            $.each(data, function(i, item) {
                                const $option = $('<option>', {
                                    value: item.id,
                                    text: `${item.code} - ${item.name}`,
                                    selected: String(item.id) === String(selectedId)
                                });

                                $select.append($option);
                            });
                        });
                    },
                    error: function(err) {
                        console.error('Failed to fetch bank accounts:', err);
                    }
                });
            }

            populateBankAccounts();

            $.ajax({
                url: '@Url.Action("GetProjectManagement", "Construction")',
                type: 'GET',
                dataType: 'json',
                success: function (response) {
                    if (response.status) {
                        var dropdown = $('#projectDropdown');
                        dropdown.empty().append('<option value="">-- Select Project --</option>');
                        response.data.forEach(function (project) {
                            dropdown.append(
                                $('<option>', {
                                    value: project.id,
                                    text: project.name,
                                    'data-code': project.code
                                })
                            );
                        });
                    } else {
                        console.error('Failed to load projects:', response.message);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching projects:', error);
                }
            });

            $('#projectDropdown').on('change', function () {
                var selectedOption = $(this).find('option:selected');
                var projectCode = selectedOption.data('code') || '';
                $('input[placeholder="Account Code"]').val(projectCode);
            });

            $.ajax({
                url: '@Url.Action("GetTenders", "Construction")',
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    if (response.status) {
                        var dropdown = $('#tenderDropdown');
                        response.data.forEach(function(tender) {
                            dropdown.append(
                                $('<option>', {
                                    value: tender.id,
                                    text: tender.name
                                })
                            );
                        });
                    } else {
                        console.error('Failed to load tenders:', response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching tenders:', error);
                }
            });

            $(document).on("click", ".editTenderBtn", function () {
                const tenderStr = $(this).attr("data-tender");
                const tender = tenderStr ? JSON.parse(tenderStr) : null;
                if (!tender) {
                    console.warn("No tender data found!");
                    return;
                }
                console.log(tender);

                $("#TenderId").val(tender.id ?? 0);
                $("#tenderDate").val(tender.date ?? new Date().toISOString().slice(0,10));
                $("#projectDropdown").val(tender.project_Id ?? 0);
                $("#projectCode").val(tender.code ?? "");
                $("#debitAccount").val(tender.account_Id ?? 0);
                $("#warehouseDropdown").val(tender.warehouse_Id ?? 0);
                $("#tenderDropdown").val(tender.tender_Name_Id ?? 0);
                $("#submissionDate").val(tender.submitDate ?? new Date().toISOString().slice(0,10));
                $("#fees").val(tender.fees ?? 0);
                $("#tenderDescription").val(tender.description ?? "");

                $("#tenderTableBody").empty();

                $.ajax({
                    url: '@Url.Action("GetTenderItems", "Construction")',
                    type: 'GET',
                    data: { tenderId: tender.id },
                    success: function(res) {
                        if (!res || !res.status) {
                            toastr.warning("No BOQ items found");
                            addEmptyRow();
                            return;
                        }
                        const items = res.data;

                        if (items.length > 0) {
                            items.forEach((item, index) => {
                                const sr = item.sr ?? String.fromCharCode(65 + index);
                                $("#tenderTableBody").append(`
                                    <tr>
                                        <td><input type="text" class="form-control sr" value="${sr}" readonly></td>
                                        <td><input type="text" class="form-control description" value="${item.name ?? ''}" placeholder="Description of work"></td>
                                        <td><input type="number" class="form-control qty" value="${item.qty ?? 0}"></td>
                                        <td><input type="text" class="form-control unit" value="${item.unit_Name ?? ''}"></td>
                                        <td><input type="text" class="form-control length" value="${item.length ?? 0}"></td>
                                        <td><input type="text" class="form-control width" value="${item.width ?? 0}"></td>
                                        <td><input type="text" class="form-control thick" value="${item.thickness ?? 0}"></td>
                                        <td><input type="text" class="form-control rate" value="${item.rate ?? 0}" disabled></td>
                                        <td><input type="text" class="form-control amount" value="${item.amount ?? 0}" disabled></td>
                                    </tr>
                                `);
                            });
                        } else {
                            addEmptyRow();
                        }
                    },
                    error: function() {
                        toastr.error("Failed to load BOQ items");
                        addEmptyRow();
                    }
                });

                $("#tenderModalLabel").text("Edit Project Tender");
                $("#tenderModal").modal("show");
            });

            $('#saveTenderBtn').on('click', function () {
                const idVal = $('#TenderId').val();
                const isEdit = idVal && parseInt(idVal) > 0;

                const items = [];
                $('#tenderTableBody tr').each(function () {
                    const $r = $(this);
                    const desc = ($r.find('.description').val() || '').trim();
                    if (!desc) return;

                    items.push({
                        Sr: (items.length + 1).toString(),
                        Description: desc,
                        Qty: parseFloat($r.find('.qty').val()) || 0,
                        Unit: $r.find('.unit').val() || '',
                        Length: parseFloat($r.find('.length').val()) || 0,
                        Width: parseFloat($r.find('.width').val()) || 0,
                        Thick: parseFloat($r.find('.thick').val()) || 0,
                        Rate: parseFloat($r.find('.rate').val()) || 0,
                        Amount: parseFloat($r.find('.amount').val()) || 0,
                        Note: ''
                    });
                });

                const todayStr = new Date().toISOString().split('T')[0];
                const tenderData = {
                    Id: isEdit ? parseInt(idVal) : 0,
                    Date: $('#tenderDate').val() || todayStr,
                    ProjectId: parseInt($('#projectDropdown').val()) || 0,
                    TenderNameId: parseInt($('#tenderDropdown').val()) || 0,
                    AccountId: parseInt($('#debitAccount').val()) || 0,
                    WarehouseId: parseInt($('#warehouseDropdown').val()) || 0,
                    Fees: parseFloat($('#fees').val()) || 0,
                    SubmissionDate: $('#submissionDate').val() || todayStr,
                    Description: $('#tenderDescription').val() || '',
                    Items: items
                };

                if (!tenderData.ProjectId || !tenderData.TenderNameId) {
                    toastr.warning('Please select project and tender name');
                    return;
                }

                if (items.length === 0) {
                    toastr.warning('Please add at least one BOQ item');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("SaveOrUpdateTender", "Construction")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(tenderData),
                    success: res => {
                        toastr[res.status ? 'success' : 'error'](res.message);
                        if (res.status) {
                            $('#tenderModal').modal('hide');
                            setTimeout(() => location.reload(), 1500);
                        }
                    },
                    error: xhr => {
                        let msg = xhr.responseJSON?.message || (() => { try { return JSON.parse(xhr.responseText).message; } catch { return 'Error saving tender'; } })();
                        toastr.error(msg);
                    }
                });
            });

            $('#tenderModal').on('hidden.bs.modal', function () {
                $('#tenderForm')[0].reset();
                $('#tenderForm').removeClass('was-validated');
                $('#TenderId').val(0);
                $('#tenderModalLabel').text("Project - New Tender");

                $('#tenderTableBody').empty();

                $('#tenderTableBody').append(`
                    <tr>
                        <td><input type="text" class="form-control sr" value="A" readonly></td>
                        <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                        <td><input type="number" class="form-control qty"></td>
                        <td><input type="text" class="form-control unit"></td>
                        <td><input type="text" class="form-control length"></td>
                        <td><input type="text" class="form-control width"></td>
                        <td><input type="text" class="form-control thick"></td>
                        <td><input type="text" class="form-control rate" disabled></td>
                        <td><input type="text" class="form-control amount" disabled></td>
                    </tr>
                `);

                const projectId = $('#projectName').val();
                if (projectId) loadProjectTenders(projectId);
            });

            $(document).on('click', '.deleteTenderBtn', function () {
                const tenderId = $(this).data('id');
                if (!tenderId) return;

                if (!confirm('Are you sure you want to delete this tender?')) return;

                $.ajax({
                    url: '@Url.Action("DeleteTenders", "Construction")' + '?tenderId=' + tenderId,
                    type: 'DELETE',
                    success: function (res) {
                        toastr[res.status ? 'success' : 'error'](res.message);
                        if (res.status && $('#projectName').val()) {
                            loadProjectTenders($('#projectName').val());
                        }
                    },
                    error: function (xhr) {
                        const msg = xhr.responseJSON?.message || 'Error deleting tender';
                        toastr.error(msg);
                    }
                });
            });

            $(document).on('click', '.recycleCardBtn', function (e) {
                loadDeletedTenders();
            });

            $('#recycleTenderModal').on('shown.bs.modal', function () {
                loadDeletedTenders();
            });

            function loadDeletedTenders() {
                $.ajax({
                    url: '@Url.Action("GetDeletedTenders", "Construction")',
                    type: 'GET',
                    dataType: 'json',
                    cache: false,
                    success: function (res) {
                        if (!res || res.status !== true) {
                            toastr.error(res?.message || 'Failed to load deleted tenders');
                            return;
                        }

                        if ($.fn.DataTable.isDataTable('#recycleTenderTable')) {
                            try { $('#recycleTenderTable').DataTable().clear().destroy(); } catch (err) { console.warn(err); }
                        }

                        const $tbody = $('#recycleTenderTable tbody');
                        $tbody.empty();

                        if (Array.isArray(res.data) && res.data.length > 0) {
                            res.data.forEach(function (row, i) {
                                $tbody.append(`
                                    <tr data-id="${row.id}">
                                        <td>${i + 1}</td>
                                        <td>${row.date ?? ''}</td>
                                        <td>${row.projectName ?? ''}</td>
                                        <td>${row.tenderName ?? ''}</td>
                                        <td>${row.submitDate ?? ''}</td>
                                        <td>${row.fees ?? 0}</td>
                                        <td>
                                            <button class="btn btn-sm btn-success restoreTenderBtn" data-id="${row.id}" title="Restore Tender">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                        </td>
                                    </tr>
                                `);
                            });
                        } else {
                            $tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No deleted tenders found</td></tr>`);
                        }
                    },
                    error: function (xhr, status, err) {
                        console.error('GetDeletedTenders error:', status, err, xhr.responseText);
                        const msg = xhr.responseJSON?.message || xhr.responseText || 'Error loading deleted tenders';
                        toastr.error(msg);
                    }
                });
            }

            $(document).on('click', '.restoreTenderBtn', function () {
                const id = $(this).data('id');
                if (!id) return;

                Swal.fire({
                    title: 'Restore Tender?',
                    text: 'Are you sure you want to restore this tender?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Restore',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#28a745'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("RestoreTender", "Construction")',
                            type: 'POST',
                            data: { id: id },
                            success: function (res) {
                                if (res.status) {
                                    toastr.success(res.message);
                                    loadDeletedTenders();
                                } else {
                                    toastr.error(res.message || 'Restore failed');
                                }
                            },
                            error: function (xhr) {
                                toastr.error(xhr.responseJSON?.message || 'Error restoring tender');
                            }
                        });
                    }
                });
            });
        });
    </script>
}