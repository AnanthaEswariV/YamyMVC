
@{
    ViewData["Title"] = "ProjectTender";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Project Tender</strong>
    </div>
    <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <!-- Left: Project Dropdown -->
                <div style="min-width: 300px;">
                    <h6 class="fw-bold mb-2">Project Name</h6>
                    <select class="form-select" id="projectName">
                        <option value="">-- Select Project --</option>
                    </select>
                </div>

                <!-- Right: Add Button -->
                <div>
                <button class="btn btn-primary rounded-3" id="addTenderBtn" data-bs-toggle="modal" data-bs-target="#tenderModal">
                        <i class="fas fa-plus me-2"></i> Add Tender
                    </button>
                <button type="button" class="btn btn-success recycleCardBtn ms-2" data-bs-toggle="modal" data-bs-target="#recycleTenderModal">
                    <i class="fas fa-recycle me-2"></i>Recycle
                </button>
                </div>
            </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Project Name</th>
                    <th>Tender Name</th>
                    <th>Submit Date</th>
                    <th>Fees</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Tender Items Modal -->
<div class="modal fade" id="tenderItemsModal" tabindex="-1" aria-labelledby="tenderItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white shadow-sm">
                <h5 class="modal-title fw-semibold d-flex align-items-center" id="tenderItemsModalLabel">
                    <i class="fas fa-list-alt me-2"></i> Tender Items
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="table2" style="font-size:13px; width:100%;">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Item Name</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Unit</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Tender Modal -->
<div class="modal fade" id="tenderModal" tabindex="-1" aria-labelledby="tenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content rounded-4 shadow-lg border-0">

            <!-- Header -->
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-semibold" id="tenderModalLabel">Project - New Tender</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="tenderForm">
                    <input type="hidden" id="TenderId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" class="form-control" id="tenderDate">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project</label>
                            <div class="input-group">
                                <select class="form-select" id="projectDropdown">
                                    <option value="">-- Select Project --</option>
                                </select>
                                <a href="/Construction/ProjectCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Project Code</label>
                            <input type="text" class="form-control" id="projectCode" placeholder="Account Code" readonly>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <select class="form-select" id="debitAccount">
                                <option value="">-- Select Account --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Tender Name</label>
                            <div class="input-group">
                                <select class="form-select" id="tenderDropdown">
                                    <option value="">-- Select Tender --</option>
                                </select>
                                <a href="/Construction/TenderCenter" class="btn btn-primary">+</a>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Submission Date</label>
                            <input type="date" class="form-control" id="submissionDate">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold">Fees</label>
                            <input type="text" class="form-control" id="fees" placeholder="Fees">
                        </div>

                        <!-- Step 1: Download Sample PDF -->
                        <div class="col-md-2 d-flex align-items-end">
                            <a href="~/BOQ.xlsx"
                               class="btn btn-outline-primary w-100 mb-0"
                               id="downloadSampleBtn"
                               download>
                                Download Sample
                            </a>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-primary w-100 mb-0 disabled" type="button" id="importBoqBtn" disabled>
                                Import BOQ
                            </button>
                        </div>

                    </div>

                    <!-- Status Message -->
                    <div class="row">
                        <div class="col-md-12 mt-2">
                            <small id="boqStatusMessage" class="text-muted">
                                🔹 Please download the sample before importing your BOQ file.
                            </small>
                        </div>
                    </div>



                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" class="form-control" id="tenderDescription" placeholder="Description">
                        </div>

                        <div class="col-md-6">
                            <label for="warehouseDropdown" class="form-label fw-semibold">Warehouse</label>
                            <select id="warehouseDropdown" class="form-select">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>

                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>Sr</th>
                                    <th>Description of Work</th>
                                    <th>Qty</th>
                                    <th>Unit</th>
                                    <th>Length</th>
                                    <th>Width</th>
                                    <th>Thick</th>
                                    <th>Rate</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody id="tenderTableBody">
                                <tr>
                                    <td><input type="text" class="form-control sr" value="A" readonly></td>
                                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                                    <td><input type="number" class="form-control qty"></td>
                                    <td><input type="text" class="form-control unit"></td>
                                    <td><input type="text" class="form-control length"></td>
                                    <td><input type="text" class="form-control width"></td>
                                    <td><input type="text" class="form-control thick"></td>
                                    <td><input type="text" class="form-control rate" disabled></td>
                                    <td><input type="text" class="form-control amount" disabled></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveTenderBtn">Save Tender</button>
            </div>

        </div>
    </div>
</div>

<!-- ♻️ Recycle Bin Modal -->
<div class="modal fade" id="recycleTenderModal" tabindex="-1" aria-labelledby="recycleTenderLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4 shadow-lg border-0">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title" id="recycleTenderLabel">Recycle Bin - Deleted Project Tenders</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-striped table-bordered align-middle" id="recycleTenderTable">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Date</th>
                            <th>Project Name</th>
                            <th>Tender Name</th>
                            <th>Submit Date</th>
                            <th>Fees</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        <tr><td colspan="7" class="text-muted py-4">No deleted tenders found</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="importModal" tabindex="-1" role="dialog" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title" id="importModalLabel">BOQ Import</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="boqImportForm">
                    <div class="mb-3">
                        <label for="cellStartIndex" class="form-label">Cell Starting Index</label>
                        <input type="text" class="form-control" id="cellStartIndex" placeholder="Enter start index">
                    </div>

                    <div class="mb-3">
                        <label for="cellEndIndex" class="form-label">Cell Ending Index</label>
                        <input type="text" class="form-control" id="cellEndIndex" placeholder="Enter end index">
                    </div>

                    <div class="mb-3">
                        <label for="excelFileInput" class="form-label">Upload Excel File</label>
                        <input type="file" class="form-control" id="excelFileInput" accept=".xls, .xlsx">
                        <small class="text-muted">Only .xls or .xlsx files are allowed</small>
                    </div>
                    <div class="form-group">
                        <label for="sn">Sn</label>
                        <select class="form-control" id="sn">
                            <option value="">-- Select --</option>
                            <!-- A–Z options -->
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="description">Description of work</label>
                        <select class="form-control" id="description">
                            <option value="">-- Select --</option>
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="qty">Quantity</label>
                        <select class="form-control" id="qty">
                            <option value="">-- Select --</option>
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="rate">Rate</label>
                        <select class="form-control" id="rate">
                            <option value="">-- Select --</option>
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="unit">Unit</label>
                        <select class="form-control" id="unit">
                            <option value="">-- Select --</option>
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="amount">Amount</label>
                        <select class="form-control" id="amount">
                            <option value="">-- Select --</option>
                            <script>
                                for (let i = 65; i <= 90; i++) {
                                    document.write(`<option value="${String.fromCharCode(i)}">${String.fromCharCode(i)}</option>`);
                                }
                            </script>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="note">Note</label>
                        <input type="text" class="form-control" id="note">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="okBtn">Ok</button>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        document.addEventListener("DOMContentLoaded", function () {
            const downloadBtn = document.getElementById("downloadSampleBtn");
            const importBoqBtn = document.getElementById("importBoqBtn");
            const statusMessage = document.getElementById("boqStatusMessage");
            const importModal = new bootstrap.Modal(document.getElementById("importModal"));

            // Step 1: Enable Import BOQ after sample download
            downloadBtn.addEventListener("click", function () {
                // Simulate short delay for file download
                setTimeout(() => {
                    importBoqBtn.classList.remove("disabled");
                    importBoqBtn.removeAttribute("disabled");
                    statusMessage.textContent = "✅ You can now import your BOQ file.";
                    statusMessage.classList.remove("text-muted");
                    statusMessage.classList.add("text-success");
                }, 1000);
            });

            // Step 2: Show modal when Import BOQ clicked
            importBoqBtn.addEventListener("click", function () {
                if (importBoqBtn.disabled) return;
                importModal.show();
            });

            // 

            document.getElementById("okBtn").addEventListener("click", function () {
                const start = document.getElementById("cellStartIndex").value.trim();
                const end = document.getElementById("cellEndIndex").value.trim();
                const fileInput = document.getElementById("excelFileInput");

                if (!start || !end) {
                    alert("Please enter both Cell Start and End Index.");
                    return;
                }

                if (!fileInput.files.length) {
                    alert("Please upload an Excel file (.xls or .xlsx).");
                    return;
                }

                const file = fileInput.files[0];
                const allowedExtensions = /(\.xls|\.xlsx)$/i;
                if (!allowedExtensions.exec(file.name)) {
                    alert("Invalid file type. Only .xls or .xlsx files are allowed.");
                    fileInput.value = "";
                    return;
                }

                console.log("Start:", start, "End:", end, "File:", file.name);

                // TODO: Add your upload logic here (AJAX or fetch)

                importModal.hide();
            });
        });

               
        document.getElementById("okBtn").addEventListener("click", async function () {
            const fileInput = document.getElementById("excelFileInput");
            const startIndex = parseInt(document.getElementById("cellStartIndex").value);
            const endIndex = parseInt(document.getElementById("cellEndIndex").value);

            if (!fileInput.files.length) {
                alert("Please upload an Excel file first.");
                return;
            }

            const file = fileInput.files[0];
            const reader = new FileReader();

            reader.onload = function (e) {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, { type: "array" });
                const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                const sheetData = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });

                // Get column selections (A–Z)
                const snCol = document.getElementById("sn").value.charCodeAt(0) - 65;
                const descCol = document.getElementById("description").value.charCodeAt(0) - 65;
                const qtyCol = document.getElementById("qty").value.charCodeAt(0) - 65;
                const rateCol = document.getElementById("rate").value.charCodeAt(0) - 65;
                const unitCol = document.getElementById("unit").value.charCodeAt(0) - 65;
                const amountCol = document.getElementById("amount").value.charCodeAt(0) - 65;

                // Validate
                if (isNaN(startIndex) || isNaN(endIndex)) {
                    alert("Please enter valid start and end index numbers.");
                    return;
                }

                const tbody = document.getElementById("tenderTableBody");
                tbody.innerHTML = ""; // clear old rows

                for (let i = startIndex - 1; i < endIndex && i < sheetData.length; i++) {
                    const row = sheetData[i];
                    if (!row) continue;

                    const sn = row[snCol] ?? "";
                    const desc = row[descCol] ?? "";
                    const qty = row[qtyCol] ?? "";
                    const unit = row[unitCol] ?? "";
                    const rate = row[rateCol] ?? "";
                    const amount = row[amountCol] ?? "";

                    const newRow = `
                        <tr>
                            <td><input type="text" class="form-control sr" value="${sn}" readonly></td>
                            <td><input type="text" class="form-control description" value="${desc}"></td>
                            <td><input type="number" class="form-control qty" value="${qty}"></td>
                            <td><input type="text" class="form-control unit" value="${unit}"></td>
                            <td><input type="text" class="form-control length"></td>
                            <td><input type="text" class="form-control width"></td>
                            <td><input type="text" class="form-control thick"></td>
                            <td><input type="text" class="form-control rate" value="${rate}"></td>
                            <td><input type="text" class="form-control amount" value="${amount}"></td>
                        </tr>`;
                    tbody.insertAdjacentHTML("beforeend", newRow);
                }

                // Close import modal and show tender modal
                const importModal = bootstrap.Modal.getInstance(document.getElementById("importModal"));
                importModal.hide();
                const tenderModal = new bootstrap.Modal(document.getElementById("tenderModal"));
                tenderModal.show();
            };

            reader.readAsArrayBuffer(file);
        });
   


         function loadWarehouses() {
            $.ajax({
              url: '@Url.Action("GetWarehouses", "Inventory")',
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        // Check if there are warehouses to display
                        if (result.data && result.data.length > 0) {
                            result.data.forEach(w => {
                                dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                            });
                        } else {
                            dropdown.append('<option value="">No warehouses available</option>');
                        }
                    } else {
                        alert(result.message || 'Error loading warehouses');
                    }
                },
                error: function(err) {
                    console.error('Error fetching data:', err);
                    alert('Failed to load warehouse data. Please try again later.');
                }
            });
        }

        $(document).ready(function () {
            loadProjectTenders();
            loadWarehouses();

            function loadProjects() {
                $.ajax({
                    url: '@Url.Action("GetProjects", "Construction")',
                    type: 'GET',
                    success: function (result) {
                        if (result.status) {
                            const $dropdown = $('#projectName');
                            $dropdown.empty();
                            $dropdown.append('<option value="">-- Select Project --</option>');

                            $.each(result.data, function (index, project) {
                                $dropdown.append('<option value="' + project.id + '">' + project.name + '</option>');
                            });
                        } else {
                            toastr.error('Failed to load projects');
                        }
                    },
                    error: function () {
                        toastr.error('Error loading projects');
                    }
                });
            }

            loadProjects(); 

            function loadProjectTenders(projectId) {
                $.ajax({
                   url: '@Url.Action("GetProjectTenders", "Construction")',
                    type: 'GET',
                    data: { projectId: projectId },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error('Failed to load project tenders');
                            return;
                        }
                        
                        // Destroy DataTable if already initialized
                        if ($.fn.DataTable.isDataTable('#table1')) {
                            $('#table1').DataTable().clear().destroy();
                        }

                        const tbody = $('#table1 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                const tr = `
                                    <tr data-id="${row.id}" style="cursor:pointer;">
                                        <td>${i + 1}</td>
                                        <td>${row.date ?? ''}</td>
                                        <td>${row.projectName ?? ''}</td>
                                        <td>${row.tenderName ?? ''}</td>
                                        <td>${row.submitDate ?? ''}</td>
                                        <td>${row.fees ?? 0}</td>
                                        <td>
                                                        <button class="btn btn-sm btn-primary editTenderBtn" data-tender='${JSON.stringify(row)}' title="Edit Tender">
            <i class="fas fa-pen"></i>
        </button>

                                            <button class="btn btn-sm btn-primary viewItemsBtn" data-id="${row.id}" title="View Items"> 
                                                <i class="fas fa-book"></i> 
                                            </button>
                                              <button class="btn btn-sm btn-danger deleteTenderBtn" data-id='${row.id}' title="Delete Tender">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            // Initialize DataTable
                            $('#table1').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                        extend: 'pdfHtml5',
                                        text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                        className: 'btn btn-primary btn-sm'
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 25
                            });
                        } else {
                            tbody.append(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading project tenders');
                    }
                });
            }

            $('#projectName').on('change', function () {
                const projectId = $(this).val();
                if (projectId) {
                    loadProjectTenders(projectId);
                } else {
                    // Clear table if nothing selected
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }
                    $('#table1 tbody').html(`<tr><td colspan="7" class="text-center text-muted py-4">No records found</td></tr>`);
                }
            });

            $(document).on('click', '.viewItemsBtn', function () {
            const tenderId = $(this).data('id');
            if (!tenderId) return;

            $('#tenderItemsModal').modal('show');
            loadTenderItems(tenderId);

        });

            function loadTenderItems(tenderId) {
            $.ajax({
               url: '@Url.Action("GetTenderItems", "Construction")',
                type: 'GET',
                data: { tenderId: tenderId },
                success: function (res) {
                    // Destroy DataTable if already exists
                    if ($.fn.DataTable.isDataTable('#table2')) {
                        $('#table2').DataTable().clear().destroy();
                    }

                    const tbody = $('#table2 tbody');
                    tbody.empty();

                    if (res.status && res.data && res.data.length > 0) {
                        $.each(res.data, function (i, item) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${item.Y ?? ''}</td>
                                    <td>${item.qty ?? 0}</td>
                                    <td>${item.rate ?? 0}</td>
                                    <td>${item.unit ?? ''}</td>
                                    <td>${item.amount ?? 0}</td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        // Initialize DataTable with export buttons
                        $('#table2').DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm'
                                },
                                {
                                    extend: 'pdfHtml5',
                                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                    className: 'btn btn-primary btn-sm'
                                }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 10
                        });
                    } else {
                        tbody.append(`<tr><td colspan="6" class="text-center text-muted py-3">No items found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Failed to load tender items');
                }
            });
        }

            function populateBankAccounts() {
            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function(res) {
                    const data = Array.isArray(res) ? res : res.data || [];

                    if (!data.length) return;

                    // Target both debit and credit selects
                    const accountSelectors = ['#debitAccount'];

                    accountSelectors.forEach(function(selector) {
                        const $select = $(selector);
                        const selectedId = $select.data('selected-id'); // optional pre-selected ID

                        // Clear existing options and add default
                        $select.empty().append('<option value="">-- Select --</option>');

                        // Append new options
                        $.each(data, function(i, item) {
                            const $option = $('<option>', {
                                value: item.id,
                                text: `${item.code} - ${item.name}`,
                                selected: String(item.id) === String(selectedId)
                            });

                            $select.append($option);
                        });
                    });
                },
                error: function(err) {
                    console.error('Failed to fetch bank accounts:', err);
                }
            });
        }

            populateBankAccounts();

            $.ajax({
         url: '@Url.Action("GetProjects", "Construction")',
            type: 'GET',
            dataType: 'json',
            success: function (response) {
                if (response.status) {
                    var dropdown = $('#projectDropdown');
                    dropdown.empty().append('<option value="">-- Select Project --</option>');
                    response.data.forEach(function (project) {
