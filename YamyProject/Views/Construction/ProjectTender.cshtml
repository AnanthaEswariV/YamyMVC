            function getSrForRow(rowIndex) {
            // Each group = 4 rows: 0 -> A, 1 -> 1, 2 -> 2, 3 -> 3, 4 -> B, 5 -> 1...
            const groupIndex = Math.floor(rowIndex / 4);
            const posInGroup = rowIndex % 4;

            const letter = String.fromCharCode(65 + groupIndex); // 65 = 'A'
            if (posInGroup === 0) return letter;
            return posInGroup; // 1,2,3
        }

            function addRow() {
            const rowIndex = $('#tenderTableBody tr').length;
            const srValue = getSrForRow(rowIndex);

            const newRow = `
                <tr>
                    <td class="sr-cell text-center">${srValue}</td>
                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                    <td><input type="number" class="form-control qty"></td>
                    <td><input type="text" class="form-control unit"></td>
                    <td><input type="text" class="form-control length"></td>
                    <td><input type="text" class="form-control width"></td>
                    <td><input type="text" class="form-control thick"></td>
                    <td><input type="text" class="form-control rate" disabled></td>
                    <td><input type="text" class="form-control amount" disabled></td>
                </tr>`;

            $('#tenderTableBody').append(newRow);
        }

            $(document).ready(function () {
            if ($('#tenderTableBody tr').length === 0) addRow();
        });

            $('#tenderTableBody').on('input', 'tr:last-child input', function () {
            const $lastRow = $(this).closest('tr');
            const filled = $lastRow.find('input').toArray().some(i => $(i).val().trim() !== '');
            if (filled) addRow();
        });

            $(document).on("click", ".editTenderBtn", function () {
            const tenderStr = $(this).attr("data-tender");
            const tender = tenderStr ? JSON.parse(tenderStr) : null;
            if (!tender) {
                console.warn("No tender data found!");
                return;
            }
            console.log(tender);
            // Fill main tender info
            $("#TenderId").val(tender.id ?? 0);
            $("#tenderDate").val(tender.date ?? new Date().toISOString().slice(0,10));
            $("#projectDropdown").val(tender.project_Id ?? 0);
            $("#projectCode").val(tender.code ?? "");
            $("#debitAccount").val(tender.account_Id ?? 0);
            $("#warehouseDropdown").val(tender.warehouse_Id ?? 0);
            $("#tenderDropdown").val(tender.tender_Name_Id ?? 0);
            $("#submissionDate").val(tender.submitDate ?? new Date().toISOString().slice(0,10));
            $("#fees").val(tender.fees ?? 0);
            $("#tenderDescription").val(tender.description ?? "");

            // Clear existing BOQ rows
            $("#tenderTableBody").empty();

            // 🔹 Fetch tender items from another API
            $.ajax({
                url: '@Url.Action("GetTenderItems", "Construction")',
                type: 'GET',
                data: { tenderId: tender.id },
                success: function(res) {
                    if (!res || !res.status) {
                        toastr.warning("No BOQ items found");
                        addEmptyRow(); 
                        return;
                    }
                    const items = res.data;

                    if (items.length > 0) {
                        items.forEach((item, index) => {
                            const sr = item.sr ?? String.fromCharCode(65 + index); // 'A', 'B', ...
                            $("#tenderTableBody").append(`
                                <tr>
                                    <td><input type="text" class="form-control sr" value="${sr}" readonly></td>
                                    <td><input type="text" class="form-control description" value="${item.name ?? ''}" placeholder="Description of work"></td>
                                    <td><input type="number" class="form-control qty" value="${item.qty ?? 0}"></td>
                                    <td><input type="text" class="form-control unit" value="${item.unit_Name ?? ''}"></td>
                                    <td><input type="text" class="form-control length" value="${item.length ?? 0}"></td>
                                    <td><input type="text" class="form-control width" value="${item.width ?? 0}"></td>
                                    <td><input type="text" class="form-control thick" value="${item.thickness ?? 0}"></td>
                                    <td><input type="text" class="form-control rate" value="${item.rate ?? 0}" disabled></td>
                                    <td><input type="text" class="form-control amount" value="${item.amount ?? 0}" disabled></td>
                                </tr>
                            `);
                        });
                    } else {
                        addEmptyRow(); // fallback if no items
                    }
                },
                error: function() {
                    toastr.error("Failed to load BOQ items");
                    addEmptyRow();
                }
            });

            $("#tenderModalLabel").text("Edit Project Tender");
            $("#tenderModal").modal("show");
        });

            function addEmptyRow() {
            $("#tenderTableBody").append(`
                <tr>
                    <td><input type="text" class="form-control sr" value="A" readonly></td>
                    <td><input type="text" class="form-control description" placeholder="Description of work"></td>
                    <td><input type="number" class="form-control qty"></td>
                    <td><input type="text" class="form-control unit"></td>
                    <td><input type="text" class="form-control length"></td>
                    <td><input type="text" class="form-control width"></td>
                    <td><input type="text" class="form-control thick"></td>
                    <td><input type="text" class="form-control rate" disabled></td>
                    <td><input type="text" class="form-control amount" disabled></td>
                </tr>
            `);
        }

            $('#saveTenderBtn').on('click', function () {
             const idVal = $('#TenderId').val();
             const isEdit = idVal && parseInt(idVal) > 0;

             const items = [];
             $('#tenderTableBody tr').each(function () {
                 const $r = $(this);
                 const desc = ($r.find('.description').val() || '').trim();
                 if (!desc) return; // skip empty rows

                 items.push({
                     Sr: (items.length + 1).toString(),
                     Description: desc,
                     Qty: parseFloat($r.find('.qty').val()) || 0,
                     Unit: $r.find('.unit').val() || '',
                     Length: parseFloat($r.find('.length').val()) || 0,
                     Width: parseFloat($r.find('.width').val()) || 0,
                     Thick: parseFloat($r.find('.thick').val()) || 0,
                     Rate: parseFloat($r.find('.rate').val()) || 0,
                     Amount: parseFloat($r.find('.amount').val()) || 0,
                     Note: ''
                 });
             });

              const todayStr = new Date().toISOString().split('T')[0];
             const tenderData = {
                 Id: isEdit ? parseInt(idVal) : 0,
                Date: $('#tenderDate').val() || todayStr,
                 ProjectId: parseInt($('#projectDropdown').val()) || 0,
                 TenderNameId: parseInt($('#tenderDropdown').val()) || 0,
                 AccountId: parseInt($('#debitAccount').val()) || 0,
                 // WarehouseId: 1,
                  WarehouseId: parseInt($('#warehouseDropdown').val()) || 0,
                 Fees: parseFloat($('#fees').val()) || 0,
                 SubmissionDate: $('#submissionDate').val() || todayStr,
                 Description: $('#tenderDescription').val() || '',
                 Items: items
             };

             if (!tenderData.ProjectId || !tenderData.TenderNameId) {
                 toastr.warning('Please select project and tender name');
                 return;
             }

                   if (items.length === 0) {
            toastr.warning('Please add at least one BOQ item');
            return;
        }


                 $.ajax({
            url: '@Url.Action("SaveOrUpdateTender", "Construction")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(tenderData),
            success: res => {
                toastr[res.status ? 'success' : 'error'](res.message);
                if (res.status) {
                    $('#tenderModal').modal('hide');
                     setTimeout(() => location.reload(), 1500);
                }
            },
            error: xhr => {
                let msg = xhr.responseJSON?.message || (() => { try { return JSON.parse(xhr.responseText).message; } catch { return 'Error saving tender'; } })();
                toastr.error(msg);
            }
        });

         });

            $('#tenderModal').on('hidden.bs.modal', function () {
            const projectId = $('#projectName').val();
            if (projectId) loadProjectTenders(projectId);
