@{
    ViewData["Title"] = "ProjectCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Project Center</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="addCategoryBtn" data-bs-toggle="modal" data-bs-target="#projectModal">
                <i class="bi bi-plus-circle me-2"></i>Add Project
            </button>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="projectTable">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>StartDate</th>
                    <th>EndDate</th>
                    <th>Duration</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Project Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-labelledby="projectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="projectForm" class="needs-validation" novalidate>
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title w-100 text-center" id="projectModalLabel">Project</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Modal Body -->
                <div class="modal-body">
                    <input type="hidden" id="projectId" value="0">

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Project Name</label>
                        <div class="col-sm-9">
                            <input type="text" id="projectName" class="form-control" placeholder="Enter project name" required>
                            <div class="invalid-feedback">Project Name is required</div>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Category</label>
                        <div class="col-sm-9">
                            <input type="text" id="projectCategory" class="form-control" placeholder="Enter category" required>
                            <div class="invalid-feedback">Category is required</div>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Estimate Start Date</label>
                        <div class="col-sm-3">
                            <input type="date" id="projectStart" class="form-control" required>
                            <div class="invalid-feedback">Start Date is required</div>
                        </div>
                        <label class="col-sm-3 col-form-label">Estimate End Date</label>
                        <div class="col-sm-3">
                            <input type="date" id="projectEnd" class="form-control" required>
                            <div class="invalid-feedback">End Date is required</div>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Country</label>
                        <div class="col-sm-3">
                            <select id="countryDropdown" class="form-select form-select-sm" required>
                                <option value="">-- Select --</option>
                            </select>
                            <div class="invalid-feedback">Country is required</div>
                        </div>
                        <label class="col-sm-3 col-form-label">City</label>
                        <div class="col-sm-3">
                            <select id="cityDropdown" class="form-select form-select-sm" required>
                                <option value="">-- Select --</option>
                            </select>
                            <div class="invalid-feedback">City is required</div>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <div class="col-sm-3">
                            <a href="#" class="link-primary">Cost Center</a>
                        </div>
                        <div class="col-sm-3">
                            <a href="#" class="link-primary">Vendor</a>
                        </div>
                        <div class="col-sm-3">
                            <a href="#" class="link-primary">Customer</a>
                        </div> <div class="col-sm-3">
                            <a href="#" class="link-primary">Subcontractor</a>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="projectDescription" class="form-control" rows="3" placeholder="Enter description"></textarea>
                    </div>


                </div>

                <!-- Modal Footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

        $(document).ready(function() {

         function loadProjects() {
            $.ajax({
               url: '@Url.Action("GetProjects", "Construction")',
                type: "GET",
                success: function(res) {
                    if (!res.status) {
                        toastr.error("Failed to load projects");
                        return;
                    }
                   
                    // Destroy existing DataTable if exists
                    if ($.fn.DataTable.isDataTable("#projectTable")) {
                        $("#projectTable").DataTable().destroy();
                    }

                    let tbody = $("#projectTable tbody");
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function(i, row) {
                            const startDate = row.startDate ?? "";
                            const endDate = row.endDate ?? "";
                            let duration = 0;

                            if (startDate && endDate) {
                                const start = new Date(startDate);
                                const end = new Date(endDate);
                                duration = Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1;
                            }

                            const tr = `
                                <tr>
                                    <td>${row.sn}</td>
                                    <td>${row.code ?? ""}</td>
                                    <td>${row.name ?? ""}</td>
                                    <td>${row.category ?? ""}</td>
                                    <td>${startDate}</td>
                                    <td>${endDate}</td>
                                    <td>${duration}</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary editProjectBtn" data-project='${JSON.stringify(row)}' title="Edit Project">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger deleteCardBtn"
                    data-id='${row.id}'>
                <i class="fas fa-prescription-bottle-alt"></i>
            </button>
                                    </td>
                                </tr>
                            `;
                            tbody.append(tr);
                        });

                        // Initialize DataTable
                                $("#projectTable").DataTable({
            dom: 'Bfrtip',
            buttons: [
                {
                    extend: 'excelHtml5',
                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                    className: 'btn btn-primary btn-sm',
                    exportOptions: {
                        columns: ':not(:last-child)' // Exclude the last column (Actions)
                    }
                },
                {
                    extend: 'pdfHtml5',
                    text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                    className: 'btn btn-primary btn-sm',
                    exportOptions: {
                        columns: ':not(:last-child)' // Exclude the last column (Actions)
                    }
                }
            ],
            order: [[0, 'asc']],
            pageLength: 25
        });
                    } else {
                        tbody.append(`<tr><td colspan="8" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function() {
                    toastr.error("Failed to load projects");
                }
            });
        }

         loadProjects();

         let countryCities = [];

         function loadCountryCityDropdowns(apiUrl, countryIdSelector, cityIdSelector) {
                const $country = $(countryIdSelector);
                const $city = $(cityIdSelector);

                $.getJSON(apiUrl, function (data) {
                    countryCities = data; // store globally

                    // Populate country dropdown
                    $country.append(data.map(c => `<option value="${c.id}">${c.name}</option>`));
                });

                // Event: When country changes, populate cities
                $country.on('change', function () {
                    const selectedCountryId = $(this).val();

                    // Reset city dropdown
                    $city.html('<option value="">-- Select --</option>');

                    if (selectedCountryId) {
                        const cities = countryCities.find(c => c.id == selectedCountryId)?.cities || [];
                        $city.append(cities.map(city => `<option value="${city.id}">${city.name}</option>`));
                    }
                });
            }

         loadCountryCityDropdowns('@Url.Action("GetCountryCities", "HR")', '#countryDropdown', '#cityDropdown');

         $(document).on("click", ".editProjectBtn", function () {
            const project = $(this).data("project");
            if (!project) return;

            console.log(project);

            // 🔹 Fill basic fields
            $("#projectId").val(project.id ?? 0);
            $("#projectCode").val(project.code ?? "");
            $("#projectName").val(project.name ?? "");
            $("#projectCategory").val(project.category ?? "");
            $("#projectDescription").val(project.description ?? "");
            $("#projectStart").val(project.startDate ?? "");
            $("#projectEnd").val(project.endDate ?? "");
            $("#countryDropdown").val(project.countryId ?? "").trigger('change'); 

            setTimeout(function () {
                $("#cityDropdown").val(project.cityId ?? "");
            }, 100); // delay ensures the city dropdown has options

            // 🔹 Calculate total days
            if (project.startDate && project.endDate) {
                const start = new Date(project.startDate);
                const end = new Date(project.endDate);
                const days = Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1;
                $("#totalDays").val(days);
            }

            // 🔹 Update modal title
            $("#projectModalLabel").text("Edit Project");

            // 🔹 Show modal
            $("#projectModal").modal("show");
        });

        $('#projectForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const projectData = {
                Id: parseInt($('#projectId').val()) || 0,
                Code: '', // Generate code in backend or assign if needed
                Name: $('#projectName').val().trim(),
                Category: $('#projectCategory').val().trim(),
                Description: $('#projectDescription').val().trim(),
                StartDate: $('#projectStart').val(),
                EndDate: $('#projectEnd').val(),
                CountryId: parseInt($('#countryDropdown').val()) || null,
                CityId: parseInt($('#cityDropdown').val()) || null,
                IsProjectOption: $('#isProjectOption').is(':checked')
            };

            $.ajax({
              url: '@Url.Action("SaveProject", "Construction")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(projectData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(projectData.Id > 0 ? 'Project updated successfully' : 'Project added successfully');
                        $('#projectModal').modal('hide');
                        setTimeout(function () {
                            location.reload();
                        }, 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

        $(document).on("click", ".deleteCardBtn", function () {
            const projectId = $(this).data("id");
            if (!projectId) return;

            if (!confirm("Are you sure you want to delete this project?")) return;

            $.ajax({
             url: `@Url.Action("DeleteProject", "Construction")?projectId=${projectId}`,
        type: "DELETE",
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message);
                         setTimeout(function () {
                            location.reload();
                        }, 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to delete project");
                }
            });
        });


        });



    </script>
}

