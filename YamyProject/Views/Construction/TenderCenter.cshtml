@{
    ViewData["Title"] = "TenderCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Tender Center</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="addTenderBtn" data-bs-toggle="modal" data-bs-target="#tenderModal">
                <i class="bi bi-plus-circle me-2"></i>Add Tender
            </button>
        </div>

        <!-- Tender Table -->
        <table class="table table-striped" id="tenderTable">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Tender Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Tender Modal -->
<div class="modal fade" id="tenderModal" tabindex="-1" aria-labelledby="tenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="tenderForm" class="needs-validation" novalidate>
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title w-100 text-center" id="tenderModalLabel">Tender</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Modal Body -->
                <div class="modal-body">
                    <input type="hidden" id="tenderId" value="0">

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Tender Name</label>
                        <div class="col-sm-9">
                            <input type="text" id="tenderName" class="form-control" placeholder="Enter tender name" required>
                            <div class="invalid-feedback">Tender Name is required</div>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        // Initialize Tender DataTable
        function loadTenders() {
            $.ajax({
              url: '@Url.Action("GetTenders", "Construction")',
                type: 'GET',
                success: function(res) {
                    if (!res.status) {
                        toastr.error("Failed to load tenders");
                        return;
                    }

                    if ($.fn.DataTable.isDataTable("#tenderTable")) {
                        $("#tenderTable").DataTable().destroy();
                    }

                    let tbody = $("#tenderTable tbody");
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function(i, tender) {
                            const tr = `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${tender.name ?? ""}</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary editTenderBtn" data-tender='${JSON.stringify(tender)}' title="Edit Tender">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger deleteTenderBtn" data-id='${tender.id}' title="Delete Tender">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>`;
                            tbody.append(tr);
                        });

                        $("#tenderTable").DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: { columns: ':not(:last-child)' }
                                },
                                {
                                    extend: 'print',
                                    text: '<i class="fas fa-print me-1"></i> Print',
                                    className: 'btn btn-primary btn-sm',
                                    exportOptions: {  columns: ':not(:last-child)'}
                                 }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 25
                        });
                    } else {
                        tbody.append(`<tr><td colspan="3" class="text-center text-muted py-4">No records found</td></tr>`);
                    }
                },
                error: function() {
                    toastr.error("Failed to load tenders");
                }
            });
        }

        loadTenders();

        // Edit Tender Button
        $(document).on("click", ".editTenderBtn", function () {
            const tender = $(this).data("tender");
            if (!tender) return;

            $("#tenderId").val(tender.id ?? 0);
            $("#tenderName").val(tender.name ?? "");

            $("#tenderModalLabel").text("Edit Tender");
            $("#tenderModal").modal("show");
        });

        // Delete Tender Button
        $(document).on("click", ".deleteTenderBtn", function () {
            const tenderId = $(this).data("id");
            if (!tenderId) return;

            if (!confirm("Are you sure you want to delete this tender?")) return;

            $.ajax({
               url: `@Url.Action("DeleteTender", "Construction")?tenderId=${tenderId}`,
                type: "DELETE",
                success: function(res) {
                    if (res.status) {
                        toastr.success(res.message);
                        loadTenders();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to delete tender");
                }
            });
        });

        // Save Tender (Add/Edit)
        $("#tenderForm").on("submit", function(e) {
            e.preventDefault();
            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const tenderData = {
                Id: parseInt($("#tenderId").val()) || 0,
                Name: $("#tenderName").val().trim()
            };

            $.ajax({
              url: '@Url.Action("SaveTender", "Construction")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(tenderData),
                success: function(res) {
                    if (res.status) {
                        toastr.success(tenderData.Id > 0 ? 'Tender updated successfully' : 'Tender added successfully');
                        $("#tenderModal").modal("hide");
                        loadTenders();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || "Failed to save tender");
                }
            });
        });
    </script>
}
