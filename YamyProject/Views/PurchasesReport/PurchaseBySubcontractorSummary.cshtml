@model SalesByCustomerSummaryViewModel
@{
    ViewData["Title"] = "Purchase By Subcontractor Summary";
    }

@* <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
 *@
<style>
    body {
        background: #f5f6f8;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .report-wrap {
        padding: 12px 18px;
    }

    .toolbar button {
        font-size: .8rem;
    }

    .filters-row label {
        font-size: .8rem;
        font-weight: 600;
    }

    .filters-row .form-select,
    .filters-row .form-control {
        font-size: .8rem;
        height: calc(1.5rem + 6px);
        padding: 2px 6px;
    }

    .report-surface {
        margin-top: 18px;
        background: #ffffff;
        min-height: 480px;
        padding: 32px 0;
    }

    .company-title {
        font-size: .9rem;
        font-weight: 600;
    }

    .report-title {
        font-size: 1.05rem;
        font-weight: 700;
    }

    .report-subtitle {
        font-size: .85rem;
        font-weight: 600;
    }

    .center-panel {
        max-width: 520px;
        margin: 0 auto;
    }

    .summary-table {
        border: 1px solid #d0d5dd;
        background: #f5f5f5;
    }

        .summary-table thead th {
            background: #e6e7ea;
            font-size: .8rem;
            padding: 6px 8px;
        }

        .summary-table tbody td {
            font-size: .8rem;
            padding: 6px 8px;
        }

        .summary-table tbody tr:nth-child(odd) td {
            background: #f9f9ff;
        }

        .summary-table tfoot td {
            background: #e3e3e3;
            font-weight: 700;
        }

    .left-time {
        font-size: .7rem;
        color: #555;
        position: absolute;
        left: 10px;
        top: 90px;
    }
</style>

<div class="container-fluid report-wrap">

    <!-- TOP TOOLBAR (no Customize / Comment / Memorize / Hide Header / Refresh) -->
    <div class="toolbar d-flex flex-wrap gap-2 mb-2">
        <button type="button" class="btn btn-sm btn-outline-secondary">Print ▼</button>
        <button type="button" class="btn btn-sm btn-outline-secondary">Excel</button>
    </div>

    <!-- FILTERS -->
    <form method="get">
        <div class="row g-2 align-items-end mb-2 filters-row">
            <div class="col-auto">
                <label class="form-label mb-0">Dates</label>
                <select class="form-select form-select-sm" asp-for="DateFilter">
                    <option value="All">All</option>
                    <option value="Today">Today</option>
                    <option value="ThisWeek">This Week</option>
                    <option value="ThisWeekToDate">This Week-To-Date</option>
                    <option value="ThisMonth">This Month</option>
                    <option value="ThisMonthToDate">This Month-to-Date</option>
                    <option value="ThisFiscalQuarter">This Fiscal Quarter</option>
                    <option value="ThisFiscalQuarterToDate">This Fiscal Quarter-To-Date</option>
                    <option value="ThisFiscalQuarterYear">This Fiscal Quarter Year</option>
                    <option value="ThisFiscalQuarterYearToLastMonth">This Fiscal Quarter Year-To-Last Month</option>
                    <option value="ThisFiscalQuarterYearToDate">This Fiscal Quarter Year-To-Date</option>
                    <option value="Yesterday">Yesterday</option>
                </select>
            </div>

            <div class="col-auto">
                <label class="form-label mb-0">From</label>
                <input type="date" class="form-control form-control-sm"
                       asp-for="DateFrom" />
            </div>

            <div class="col-auto">
                <label class="form-label mb-0">To</label>
                <input type="date" class="form-control form-control-sm"
                       asp-for="DateTo" />
            </div>

            <div class="col-auto">
                <label class="form-label mb-0">Invoice Type</label>
                <select class="form-select form-select-sm" asp-for="InvoiceType">
                    <option value="Sales">Purchase</option>
                    <option value="Quotation">Quotation</option>
                    <option value="Performa">Performa</option>
                    <option value="Order">Order</option>
                    <option value="Return">Return</option>
                </select>
            </div>

            @* 
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Run Report</button>
            </div>*@  
       </div>
    </form>

    <!-- LEFT TIME / DATE (like screenshot) -->
    @*   <div class="left-time">
        @DateTime.Now.ToString("hh:mm tt")<br />
        @DateTime.Now.ToString("dd/MM/yyyy")
    </div> *@

    <!-- REPORT BODY -->
    <div class="report-surface position-relative">
        <div class="center-panel">

            <div class="text-center mb-3">
                <div class="company-title">ARC MASTER CONTRACTING L.L.C.</div>
                <div class="report-title">Purchase By Subcontractor Summary</div>
                <div class="report-subtitle">All Transaction</div>
            </div>

            <div class="summary-table">
                <table id="reportTable" class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width: 60px;">Sn</th>
                            <th>Name</th>
                            <th class="text-end">Net Purchase</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Rows != null && Model.Rows.Any())
                            {
                            var i = 1;
                            foreach (var row in Model.Rows)
                                {
                                <tr data-id="@row.CustomerId">
                                    <td>@i</td>
                                    <td>@row.Name</td>
                                    <td class="text-end">@row.NetSales.ToString("N2")</td>
                                </tr>
                                i++;
                                }
                            }
                        else
                            {
                            <tr>
                                <td colspan="3" class="text-center text-muted">No data to display.</td>
                            </tr>
                            }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td>TOTAL</td>
                            <td class="text-end">
                                @Model?.TotalNetSales.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

        </div>
    </div>
</div>
    @section Scripts {
    <script>
        $(document).ready(function () {
            $('#reportTable tbody').on('dblclick', 'tr', function () {
                const id = $(this).data('id');
                if (!id) return;

                const url = '@Url.Action("PurchaseBySubcontractorSummaryDetails", "PurchasesReport")' + '?Id=' + id;
                window.location.href = url;
            });
        });
    </script>
    }
