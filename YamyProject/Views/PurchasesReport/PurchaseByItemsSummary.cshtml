@model ItemSalesReportViewModel
@{
    ViewData["Title"] = "Purchase By Item Summary";
    }

<style>
    body {
        background: #f5f6f8;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .report-wrap {
        padding: 16px 24px;
    }

    .report-card {
        background: #ffffff;
        border-radius: 4px;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, .06);
        padding: 12px 18px 24px;
    }

    .toolbar {
        margin-bottom: 8px;
    }

        .toolbar .btn {
            font-size: .8rem;
            padding: 4px 10px;
        }

    .filters-row label {
        font-size: .8rem;
        font-weight: 600;
        margin-right: 4px;
    }

    .filters-row .form-select,
    .filters-row .form-control {
        font-size: .8rem;
        height: calc(1.5rem + 6px);
        padding: 2px 6px;
    }

    .filters-row .input-group-text {
        padding: 2px 6px;
        font-size: .75rem;
    }

    .report-title h6 {
        font-size: .8rem;
        letter-spacing: .05em;
    }

    .report-title h5 {
        font-size: 1rem;
        margin-bottom: 2px;
    }

    .report-title span {
        font-size: .85rem;
        font-weight: 600;
    }

    .report-table-wrapper {
        margin-top: 16px;
        border: 1px solid #e5e7eb;
        background: #fafafa;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .78rem;
    }

        .report-table thead th {
            background: #e5e7eb;
            padding: 6px 8px;
            text-align: right;
            border-bottom: 1px solid #e5e7eb;
            font-weight: 600;
            white-space: nowrap;
        }

            .report-table thead th:first-child {
                text-align: left;
                width: 32%;
            }

        .report-table tbody td {
            padding: 4px 8px;
            border-bottom: 1px solid #f1f1f1;
            white-space: nowrap;
        }

        .report-table tbody tr:last-child td {
            border-bottom: none;
        }

        .report-table tbody td.text-end {
            text-align: right;
        }

    .group-row {
        background: #dde4f1;
        font-weight: 600;
        cursor: pointer;
    }

        .group-row.level-2 {
            background: #c9d7f0;
        }

        .group-row td {
            border-bottom-color: #dde4f1;
        }

    .group-arrow {
        display: inline-block;
        width: 14px;
        text-align: center;
        margin-right: 4px;
        font-size: .6rem;
    }

    .indent-1 {
        padding-left: 28px !important;
    }

    .indent-2 {
        padding-left: 44px !important;
    }

    .hidden-row {
        display: none;
    }
</style>

<div class="report-wrap">
    <div class="report-card">
        <!-- Top toolbar (Print / Excel only) -->
        <div class="d-flex justify-content-between align-items-center toolbar">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-secondary btn-sm">
                    Print
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm ms-1">
                    Excel
                </button>
            </div>
        </div>

        <!-- Filters row (GET form is best practice) -->
        <form asp-action="ItemSummary" asp-controller="PurchasesReport" method="get" class="mb-2">
            <div class="row g-2 align-items-center filters-row">
                <div class="col-auto d-flex align-items-center">
                    <label for="dateFilter">Dates</label>
                    <select id="dateFilter" name="dateFilter" class="form-select form-select-sm ms-2">
                            @{
                            string df = Model.DateFilter ?? "All";
                            }
                        <option value="All" selected="@(df == "All")">All</option>
                        <option value="Today" selected="@(df == "Today")">Today</option>
                        <option value="This Week" selected="@(df == "This Week")">This Week</option>
                        <option value="This Month" selected="@(df == "This Month")">This Month</option>
                        <option value="This Year" selected="@(df == "This Year")">This Year</option>
                        <option value="Custom" selected="@(df == "Custom")">Custom</option>
                    </select>
                </div>

                <div class="col-auto d-flex align-items-center">
                    <label for="dateFrom">From</label>
                    <div class="input-group input-group-sm ms-2">
                        <input type="date"
                               id="dateFrom"
                               name="fromDate"
                               class="form-control form-control-sm"
                               value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>
                </div>

                <div class="col-auto d-flex align-items-center">
                    <label for="dateTo">To</label>
                    <div class="input-group input-group-sm ms-2">
                        <input type="date"
                               id="dateTo"
                               name="toDate"
                               class="form-control form-control-sm"
                               value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>
                </div>

                <div class="col-auto d-flex align-items-center">
                    <label for="showColumns">Show_Columns</label>
                    <select id="showColumns" name="showColumns" class="form-select form-select-sm ms-2">
                        <option value="Default" selected="@(Model.ShowColumns == "Default")">Default</option>
                        <option value="All Columns" selected="@(Model.ShowColumns == "All Columns")">All Columns</option>
                        <option value="Compact" selected="@(Model.ShowColumns == "Compact")">Compact</option>
                    </select>
                </div>

                <div class="col-auto d-flex align-items-center">
                    <label for="sortBy">Sort By</label>
                    <select id="sortBy" name="sortBy" class="form-select form-select-sm ms-2">
                        <option value="Item Name" selected="@(Model.SortBy == "Item Name")">Item Name</option>
                        <option value="Amount" selected="@(Model.SortBy == "Amount")">Amount</option>
                        <option value="QTY" selected="@(Model.SortBy == "QTY")">QTY</option>
                        <option value="Gross Margin" selected="@(Model.SortBy == "Gross Margin")">Gross Margin</option>
                    </select>
                </div>

                @*      <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">
                        Run Report
                    </button>
                </div> *@
            </div>
        </form>

        <!-- Header (time / date / title) -->
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div style="width:120px;"></div>

            <div class="report-title text-center flex-grow-1">
                <h6 class="mb-1 text-uppercase">ARC MASTER CONTRACTING L.L.C.</h6>
                <h5 class="mb-0 fw-bold">Purchases By Item Summary</h5>
                <span>All Transactions</span>
            </div>

            <div style="width:120px;"></div>
        </div>

        <!-- Table -->
        <div class="report-table-wrapper">
            <table class="report-table" id="salesTable">
                <thead>
                    <tr>
                        <th>Item / Category</th>
                        <th>QTY</th>
                        <th>Amount</th>
                        <th>% of Sales</th>
                        <th>AVG Price</th>
                        <th>COGS</th>
                        <th>AVG COGS</th>
                        <th>Gross Margin</th>
                        <th>Margin %</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ItemRows == null || !Model.ItemRows.Any())
                        {
                        <tr>
                            <td colspan="9" class="text-center text-muted">
                                No data available for the selected filters.
                            </td>
                        </tr>
                        }
                    else
                        {
                        foreach (var row in Model.ItemRows)
                            {
                            var isGroup = row.Level == 1 || row.Level == 2;
                            var rowClass = isGroup ? "detail-row" : "group-row";
                            if (row.Level == 2) rowClass += " level-2";

                            var indentClass = row.Level == 1
                            ? ""
                            : row.Level == 2 ? "indent-1" : "indent-2";

                            <tr class="@rowClass"
                                data-level="@row.Level"
                                data-key="@row.Key"
                                data-state="@row.State"
                                data-load-state="@row.LoadState">
                                <td class="@indentClass">
                                    @if (row.State == "e")
                                        {
                                        <span class="group-arrow">▼</span>
                                        }
                                    @row.Name
                                </td>

                                @if (row.Level == 3)
                                    {
                                    <td class="text-end">@((row.Qty ?? 0m).ToString("N3"))</td>
                                    <td class="text-end">@((row.Amount ?? 0m).ToString("N3"))</td>
                                    <td class="text-end">@((row.PercentOfSales ?? 0m).ToString("0.0"))%</td>
                                    <td class="text-end">@((row.AvgPrice ?? 0m).ToString("N2"))</td>
                                    <td class="text-end">@((row.Cogs ?? 0m).ToString("N2"))</td>
                                    <td class="text-end">@((row.AvgCogs ?? 0m).ToString("N2"))</td>
                                    <td class="text-end">@((row.GrossMargin ?? 0m).ToString("N2"))</td>
                                    <td class="text-end">@((row.GrossMarginPercent ?? 0m).ToString("0.0"))%</td>
                                    }
                                else
                                    {
                                    <td colspan="8"></td>
                                    }
                            </tr>
                            }
                        }
                </tbody>
            </table>
        </div>
    </div>
</div>

    @section Scripts {
    <script>
        (function () {
            const table = document.getElementById('salesTable');
            if (!table) return;

            const dateFromInput = document.getElementById('dateFrom');
            const dateToInput = document.getElementById('dateTo');
            const dateFilterSelect = document.getElementById('dateFilter'); // NEW

            const loadUrl = '@Url.Action("LoadRows", "PurchasesReport")';
            const detailsUrl = '@Url.Action("PurchaseByItemsSummaryDetails", "PurchasesReport")'; // NEW

            // ================================
            // NEW: Double-click on level 3 row → go to details
            // ================================
            table.addEventListener('dblclick', function (e) {
                // only level 3 rows
                const tr = e.target.closest('tr[data-level="3"]');
                if (!tr) return;

                // we assume data-key holds the Item Id
                const id = tr.dataset.key;
                if (!id) return;

                const dateFilter = dateFilterSelect ? dateFilterSelect.value : '';
                const dateFrom = dateFromInput && dateFromInput.value ? dateFromInput.value : '';
                const dateTo = dateToInput && dateToInput.value ? dateToInput.value : '';

                // Build query string:
                // /SalesSummary/SalesByItemsSummaryDetails?id=...&dateFilter=...&dateFrom=...&dateTo=...
                const url = detailsUrl
                    + '?id=' + encodeURIComponent(id)
                    + '&dateFilter=' + encodeURIComponent(dateFilter || '')
                    + '&dateFrom=' + encodeURIComponent(dateFrom)
                    + '&dateTo=' + encodeURIComponent(dateTo);

                // Navigate to details page
                window.location.href = url;
            });
            // ================================

            // 🔽 Your existing click handler for expand/collapse
            table.addEventListener('click', async function (e) {
                const tr = e.target.closest('tr[data-level]');
                if (!tr) return;

                const state = tr.dataset.state;
                if (state !== 'e') return; // only expandable rows

                const level = parseInt(tr.dataset.level || '0');
                const key = tr.dataset.key;
                if (!key) return;

                const arrow = tr.querySelector('.group-arrow');

                // toggle collapsed flag
                debugger
                const isCollapsedNow = tr.classList.toggle('collapsed');
                if (arrow) arrow.textContent = isCollapsedNow ? '►' : '▼';

                if (isCollapsedNow) {
                    hideDescendants(tr);
                    return;
                }

                // expanded
                if (tr.dataset.loadState === 'u') {
                    // first time: load children via AJAX
                    const from = dateFromInput.value || '@(Model.FromDate?.ToString("yyyy-MM-dd") ?? "")';
                    const to = dateToInput.value || '@(Model.ToDate?.ToString("yyyy-MM-dd") ?? "")';

                    const url = `${loadUrl}?level=${level}&key=${encodeURIComponent(key)}&fromDate=${from}&toDate=${to}`;

                    try {
                        const resp = await fetch(url);
                        if (!resp.ok) {
                            console.error('Failed to load rows', resp.status);
                            return;
                        }
                        const rows = await resp.json();
                        insertRowsAfter(tr, rows);
                        tr.dataset.loadState = 'l';
                    } catch (err) {
                        console.error('Error loading rows', err);
                    }
                } else {
                    // already loaded: just show children
                    showDirectChildren(tr);
                }
            });

            function insertRowsAfter(parentRow, rows) {
                const parentKey = parentRow.dataset.key;
                let current = parentRow;

                rows.forEach(row => {
                    const tr = document.createElement('tr');
                    const isGroup = row.level === 1 || row.level === 2;

                    tr.dataset.level = row.level;
                    tr.dataset.key = row.key;
                    tr.dataset.state = row.state;
                    tr.dataset.loadState = row.loadState;
                    tr.dataset.parent = parentKey;

                    let rowClass = isGroup ? 'group-row' : 'detail-row';
                    if (row.level === 2) rowClass += ' level-2';
                    tr.className = rowClass;

                    // first cell
                    const tdName = document.createElement('td');
                    if (row.level === 2) tdName.classList.add('indent-1');
                    if (row.level === 3) tdName.classList.add('indent-2');

                    if (row.state === 'e') {
                        const arrow = document.createElement('span');
                        arrow.className = 'group-arrow';
                        arrow.textContent = '▼';
                        tdName.appendChild(arrow);
                        tdName.appendChild(document.createTextNode(' '));
                    }

                    tdName.appendChild(document.createTextNode(row.name));
                    tr.appendChild(tdName);

                    if (row.level === 3) {
                        tr.appendChild(createNumberCell(row.qty, 3));
                        tr.appendChild(createNumberCell(row.amount, 3));
                        tr.appendChild(createPercentCell(row.percentOfSales, 1));
                        tr.appendChild(createNumberCell(row.avgPrice, 2));
                        tr.appendChild(createNumberCell(row.cogs, 2));
                        tr.appendChild(createNumberCell(row.avgCogs, 2));
                        tr.appendChild(createNumberCell(row.grossMargin, 2));
                        tr.appendChild(createPercentCell(row.grossMarginPercent, 1));
                    } else {
                        for (let i = 0; i < 8; i++) {
                            tr.appendChild(document.createElement('td'));
                        }
                    }

                    current.insertAdjacentElement('afterend', tr);
                    current = tr;
                });
            }

            function hideDescendants(parentRow) {
                const parentKey = parentRow.dataset.key;
                const children = table.querySelectorAll('tr[data-parent="' + parentKey + '"]');

                children.forEach(child => {
                    child.classList.add('hidden-row');

                    if (child.classList.contains('group-row')) {
                        child.classList.add('collapsed');
                        const arrow = child.querySelector('.group-arrow');
                        if (arrow) arrow.textContent = '►';
                        hideDescendants(child);
                    }
                });
            }

            function showDirectChildren(parentRow) {
                const parentKey = parentRow.dataset.key;
                const children = table.querySelectorAll('tr[data-parent="' + parentKey + '"]');

                children.forEach(child => {
                    child.classList.remove('hidden-row');

                    if (child.classList.contains('group-row') && !child.classList.contains('collapsed')) {
                        showDirectChildren(child);
                    }
                });
            }

            function createNumberCell(value, decimals) {
                const td = document.createElement('td');
                td.className = 'text-end';
                if (value != null) {
                    td.textContent = Number(value)
                        .toLocaleString(undefined, {
                            minimumFractionDigits: decimals,
                            maximumFractionDigits: decimals
                        });
                }
                return td;
            }

            function createPercentCell(value, decimals) {
                const td = createNumberCell(value, decimals);
                if (td.textContent) td.textContent += '%';
                return td;
            }
        })();
    </script>
    }
