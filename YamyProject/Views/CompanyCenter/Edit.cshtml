<form method="post" asp-controller="CompanyCenterController" enctype="multipart/form-data" id="form">
    @if (Model.Id > 0)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div class="tab-content" id="profileTabContent">
        <!-- General Info Tab -->
        <div class="tab-pane fade show active" id="general" role="tabpanel">
            <div class="row mb-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label">Company Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="col-md-4 text-center">
                    <div class="border mb-2" style="height: 120px; background-color: #f8f9fa;">
                        <!-- Optional preview for image -->
                    </div>
           @*          <label asp-for="LogoComp" class="form-label">Upload Logo</label>
                    <input asp-for="LogoComp" type="file" class="form-control" />
               *@  </div>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address 1</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Phone1" class="form-label">Phone 1</label>
                    <input asp-for="Phone1" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone2" class="form-label">Phone 2</label>
                    <input asp-for="Phone2" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Phone1" class="form-label">Mobile</label>
                    <input asp-for="Phone2" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Gmail" class="form-label">Gmail</label>
                    <input asp-for="Gmail" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Website" class="form-label">Website</label>
                <input asp-for="Website" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address 2</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="TrnNo" class="form-label">TRN No</label>
                <input asp-for="TrnNo" class="form-control" />
            </div>

           @*  <div class="mb-4">
                <label asp-for="CountryId" class="form-label">Country</label>
                <select asp-for="CountryId" class="form-select" data-placeholder="Select Country" asp-item="">
                    <option value="">Select Country</option>

                </select>
            </div> *@
        </div>

        <!-- VAT Tab (empty placeholder) -->
        <div class="tab-pane fade" id="vat" role="tabpanel">
            <p class="text-muted">VAT Configuration section coming soon.</p>
        </div>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Close</a>
    </div>
</form>
</div>
</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success mt-3">@ViewBag.Message</div>
}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

