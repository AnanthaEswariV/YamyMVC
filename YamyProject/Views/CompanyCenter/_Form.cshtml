@model CompanyViewModels

<form id="companyProfileForm"
      asp-controller="CompanyCenter"
@*       asp-action="SaveProfile"   *@      
      method="post"
      enctype="multipart/form-data"
      data-ajax="true"
      data-ajax-method="post"
      data-ajax-begin="onModalBegin"
      data-ajax-success="onModalSuccess"
      data-ajax-failure="showErrorMessage"
      data-ajax-complete="onModalComplete">

    @Html.AntiForgeryToken()

    @if (Model?.Id > 0)
    {
        <input type="hidden" asp-for="Id" />
    }

    <div class="card shadow-sm">
        <!-- header -->
        <div class="card-header py-2" style="background-color:#0d3b70;color:white;">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Company Profile</h5>
              @*   <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>*@
            </div> 
        </div>

        <div class="card-body">

            <!-- tabs -->
            <ul class="nav nav-tabs mb-3" id="profileTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="general-tab"
                            data-bs-toggle="tab" data-bs-target="#general"
                            type="button" role="tab">
                        General Information
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="vat-tab"
                            data-bs-toggle="tab" data-bs-target="#vat"
                            type="button" role="tab">
                        VAT Configuration
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="profileTabContent">
                <!-- GENERAL INFORMATION TAB -->
                <div class="tab-pane fade show active" id="general" role="tabpanel">

                    <div class="row mb-3">
                        <!-- left column -->
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label">Company Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Descriptions" class="form-label">Address 1</label>
                                <input asp-for="Descriptions" class="form-control" />
                                <span asp-validation-for="Descriptions" class="text-danger"></span>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="Phone1" class="form-label">Phone 1</label>
                                    <input asp-for="Phone1" class="form-control" />
                                    <span asp-validation-for="Phone1" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Phone2" class="form-label">Phone 2</label>
                                    <input asp-for="Phone2" class="form-control" />
                                    <span asp-validation-for="Phone2" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="Mobile" class="form-label">Mobile</label>
                                    <input asp-for="Mobile" class="form-control" />
                                    <span asp-validation-for="Mobile" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Gmail" class="form-label">Gmail</label>
                                    <input asp-for="Gmail" class="form-control" />
                                    <span asp-validation-for="Gmail" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Website" class="form-label">Website</label>
                                <input asp-for="Website" class="form-control" />
                                <span asp-validation-for="Website" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Address" class="form-label">Address 2</label>
                                <input asp-for="Address" class="form-control" />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="TrnNo" class="form-label">TRN No</label>
                                <input asp-for="TrnNo" class="form-control" />
                                <span asp-validation-for="TrnNo" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="CountryId" class="form-label">Country</label>
                                <select asp-for="CountryId"
                                        class="form-select"
                                        asp-items="ViewBag.Countries">
                                    <option value="">Select Country</option>
                                </select>
                                <span asp-validation-for="CountryId" class="text-danger"></span>
                            </div>

                            <div class="form-check mb-2">
                                <input asp-for="IsMainCompany" class="form-check-input" />
                                <label asp-for="IsMainCompany" class="form-check-label">
                                    Make This Company Main Account
                                </label>
                            </div>
                        </div>

                        <!-- right column: logo + stamp -->
                        <div class="col-md-4">
                            <!-- Logo -->
                            <div class="mb-3 text-center">
                                <div class="border rounded mb-2 d-flex align-items-center justify-content-center"
                                     style="height:140px;background-color:#f8f9fa;">
                                    @* show existing logo if you have a Url property *@
                                    @if (!string.IsNullOrEmpty(Model?.logoComp))
                                    {
                                        <img src="@Model.logoComp" class="img-fluid" alt="Logo" />
                                    }
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Logo</span>
                                    <label class="btn btn-outline-primary btn-sm mb-0">
                                        Browse
                                        <input asp-for="LogoFile" type="file" class="d-none" />
                                    </label>
                                </div>
                                <span asp-validation-for="LogoFile" class="text-danger"></span>
                            </div>

                            <!-- Stamp -->
                            <div class="mb-3 text-center">
                                <div class="border rounded mb-2 d-flex align-items-center justify-content-center"
                                     style="height:140px;background-color:#f8f9fa;">
                                    @if (!string.IsNullOrEmpty(Model?.stampComp))
                                    {
                                        <img src="@Model.stampComp" class="img-fluid" alt="Stamp" />
                                    }
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Stamp</span>
                                    <label class="btn btn-outline-primary btn-sm mb-0">
                                        Browse
                                        <input asp-for="StampFile" type="file" class="d-none" />
                                    </label>
                                </div>
                                <span asp-validation-for="StampFile" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- VAT CONFIGURATION TAB -->
                <div class="tab-pane fade" id="vat" role="tabpanel" aria-labelledby="vat-tab">

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="TaxRegistrationNo" class="form-label">TAX Registration No</label>
                            <input asp-for="TaxRegistrationNo" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TrnIssueDate" class="form-label">TRN Issue Date</label>
                            <input asp-for="TrnIssueDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <h6 class="fw-bold mt-3 mb-2">Quarter Dates</h6>

                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Quarter</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Due Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 1; i <= 4; i++)
                                {
                                    <tr>
                                        <td>Quarter No. @i</td>
                                        <td><input name="Quarter[@i].StartDate" type="date" class="form-control" /></td>
                                        <td><input name="Quarter[@i].EndDate" type="date" class="form-control" /></td>
                                        <td><input name="Quarter[@i].DueDate" type="date" class="form-control" /></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <h6 class="fw-bold mt-3 mb-2">Corporate TAX</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="CorporateTaxNo" class="form-label">Corporate TAX No</label>
                            <input asp-for="CorporateTaxNo" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CorporateIssueDate" class="form-label">TRN Issue Date</label>
                            <input asp-for="CorporateIssueDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Quarter</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Due Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Yearly</td>
                                    <td><input name="CorporateYearly.StartDate" type="date" class="form-control" /></td>
                                    <td><input name="CorporateYearly.EndDate" type="date" class="form-control" /></td>
                                    <td><input name="CorporateYearly.DueDate" type="date" class="form-control" /></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary px-4">Save</button>
            <button type="button" class="btn btn-outline-secondary px-4"
                    data-bs-dismiss="modal">Close</button>
        </div>
    </div>
</form>
    @section script {
    <script>
        $(document).on('submit', '#companyProfileForm', function (e) {
            e.preventDefault();

            var $form = $(this);
            
            $.ajax({
                url: $form.attr('action'),
                type: $form.attr('method'),
                data: $form.serialize(),
                success: function (res) {
                    if (res && res.success) {
                        // ✅ Bootstrap 5 way
                        var modalEl = $form.closest('.modal')[0];
                        var modal = bootstrap.Modal.getInstance(modalEl)
                                    || new bootstrap.Modal(modalEl);
                        modal.hide();
                    }
                }
            });
        });
    </script>

}
