                <div class="tab-pane fade" id="vat" role="tabpanel" aria-labelledby="vat-tab">
                  <form method="post" asp-controller="CompanyCenterController" enctype="multipart/form-data" id="form">
                      <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="txtRegistrationNo">TAX Registration No</label>
                                    <input type="text" class="form-control" id="txtRegistrationNo" name="txtRegistrationNo" />
                                </div>
                                <div class="col-md-6">
                                    <label for="dtpTRNIssueDate">TRN Issue Date</label>
                                    <input type="date" class="form-control" id="dtpTRNIssueDate" name="dtpTRNIssueDate" />
                                </div>
                            </div>

                                  <div class="section-header">Quarter Dates</div>
                                  <div class="row">
                                <div class="col-md-12">
                                    <table class="table quarter-table">
                                        <thead>
                                            <tr>
                                                <th>Quarter</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Due Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 1; i <= 4; i++)
                                            {
                                                <tr>
                                                    <td class="quarter-label">Quarter No. @i</td>
                                                    <td><input type="date" class="form-control" name="StartDate_Q@i" /></td>
                                                    <td><input type="date" class="form-control" name="EndDate_Q@i" /></td>
                                                    <td><input type="date" class="form-control" name="DueDate_Q@i" /></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                                  <div class="section-header">Corporate TAX</div>
                                  <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="txtCorporateTaxNo">Corporate TAX No</label>
                                    <input type="text" class="form-control" id="txtCorporateTaxNo" name="txtCorporateTaxNo" />
                                </div>
                                <div class="col-md-6">
                                    <label for="dtpCorporateTRNIssueDate">TRN Issue Date</label>
                                    <input type="date" class="form-control" id="dtpCorporateTRNIssueDate" name="dtpCorporateTRNIssueDate" />
                                </div>
                            </div>
                                  <div class="row">
                                <div class="col-md-12">
                                    <table class="table quarter-table">
                                        <thead>
                                            <tr>
                                                <th>Quarter</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Due Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="quarter-label">Yearly</td>
                                                <td><input type="date" class="form-control" name="StartDate_Yearly" /></td>
                                                <td><input type="date" class="form-control" name="EndDate_Yearly" /></td>
                                                <td><input type="date" class="form-control" name="DueDate_Yearly" /></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                                  <div class="text-end">
                                      <button type="submit" class="btn btn-primary">Save</button>
                                  </div>
                  </form>
            </div>
        </div>
    </div>

</div>

