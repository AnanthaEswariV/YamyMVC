@model CompanyViewModels

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4 mb-5">
       
    <div class="card-body">
            <ul class="nav nav-tabs mb-4" id="profileTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">
                        General Information
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="vat-tab" data-bs-toggle="tab" data-bs-target="#vat" type="button" role="tab">
                        VAT Configuration
                    </button>
                </li>
            </ul>
        <div class="tab-content" id="profileTabContent">
                <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">

                <form method="post" asp-controller="CompanyCenterController" @* asp-action="Edit" *@ id="form">
              @*  @if(Model.Id>0)
                    {
                        <input type="hidden" asp-for="Id"/>                  
                     } *@
                   
                    <!-- General Info Tab -->
                        <div class="row">
                            <div class="col-md-6">
                                 <label asp-for="Name" class="form-label">Company Name</label>
                                 <input asp-for="Name" class="form-control" />
                                 <label asp-for="TrnNo" class="form-label">TRN No</label>
                                 <input asp-for="TrnNo" class="form-control" />
                                 <label asp-for="Website" class="form-label">Website</label>
                                 <input asp-for="Website" class="form-control" />
                            </div>
                            <div class="col-md-6 text-center">
                                 <div class="border mb-2" style="height: 164px;width:350px; background-color: #f8f9fa;">
                                  <!-- Optional preview for image -->
                                </div>
                                 <input asp-for="LogoComp" type="file" class="form-control" />
                            </div>
                        </div>                       

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Phone1" class="form-label">Phone 1</label>
                                <input asp-for="Phone1" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone2" class="form-label">Phone 2</label>
                                <input asp-for="Phone2" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                    <label asp-for="Phone1" class="form-label">Mobile</label>
                                    <input asp-for="Phone2" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Gmail" class="form-label">Gmail</label>
                                <input asp-for="Gmail" class="form-control" />
                            </div>
                        </div>
                    <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Address" class="form-label">Address 1</label>
                                <input asp-for="Address" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Address" class="form-label">Address 2</label>
                                <input asp-for="Address" class="form-control" />
                            </div>
                        </div>

                 @*    <div class="row mb-3">
                        <div class="col-md-6">

                            <label asp-for="CountryId" class="form-label">Country</label>
                            <select asp-for="CountryId" class="form-select" data-placeholder="Select Country" asp-item="">
                                <option value="">Select Country</option>
                               
                            </select>
                            </div>
                        </div> *@
                
                         <div class="text-end">
                              <button type="submit" class="btn btn-primary">Save</button>
                              <!--<a asp-action="Index" class="btn btn-secondary ms-2">Close</a>-->
                         </div>

              </form>
          </div>   
                <div class="tab-pane fade" id="vat" role="tabpanel" aria-labelledby="vat-tab">
                  <form method="post" asp-controller="CompanyCenterController" enctype="multipart/form-data" id="form">
                      <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="txtRegistrationNo">TAX Registration No</label>
                                    <input type="text" class="form-control" id="txtRegistrationNo" name="txtRegistrationNo" />
                                </div>
                                <div class="col-md-6">
                                    <label for="dtpTRNIssueDate">TRN Issue Date</label>
                                    <input type="date" class="form-control" id="dtpTRNIssueDate" name="dtpTRNIssueDate" />
                                </div>
                            </div>

                                  <div class="section-header">Quarter Dates</div>
                                  <div class="row">
                                <div class="col-md-12">
                                    <table class="table quarter-table">
                                        <thead>
                                            <tr>
                                                <th>Quarter</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Due Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 1; i <= 4; i++)
                                            {
                                                <tr>
                                                    <td class="quarter-label">Quarter No. @i</td>
                                                    <td><input type="date" class="form-control" name="StartDate_Q@i" /></td>
                                                    <td><input type="date" class="form-control" name="EndDate_Q@i" /></td>
                                                    <td><input type="date" class="form-control" name="DueDate_Q@i" /></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                                  <div class="section-header">Corporate TAX</div>
                                  <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="txtCorporateTaxNo">Corporate TAX No</label>
                                    <input type="text" class="form-control" id="txtCorporateTaxNo" name="txtCorporateTaxNo" />
                                </div>
                                <div class="col-md-6">
                                    <label for="dtpCorporateTRNIssueDate">TRN Issue Date</label>
                                    <input type="date" class="form-control" id="dtpCorporateTRNIssueDate" name="dtpCorporateTRNIssueDate" />
                                </div>
                            </div>
                                  <div class="row">
                                <div class="col-md-12">
                                    <table class="table quarter-table">
                                        <thead>
                                            <tr>
                                                <th>Quarter</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Due Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="quarter-label">Yearly</td>
                                                <td><input type="date" class="form-control" name="StartDate_Yearly" /></td>
                                                <td><input type="date" class="form-control" name="EndDate_Yearly" /></td>
                                                <td><input type="date" class="form-control" name="DueDate_Yearly" /></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                                  <div class="text-end">
                                      <button type="submit" class="btn btn-primary">Save</button>
                                  </div>
                  </form>
            </div>
        </div>
    </div>

</div>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success mt-3">@ViewBag.Message</div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

