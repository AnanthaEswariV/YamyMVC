<select id="tpl-vat" class="d-none" asp-items="@(new SelectList(Model.Accounts, "Value", "Text"))"></select>

    <script>
        // --- simple account master data
        const ACCOUNTS = [
          { code:'1201003', name:'Cars & Buses' },
          { code:'1101001', name:'Cash on Hand' },
          { code:'1302001', name:'Office Supplies' },
          { code:'2101001', name:'Accounts Payable' }
        ];
        const parseDec = (v) => { const n = parseFloat((v||'').toString().replace(/,/g,'')); return isNaN(n)?0:n; };
        function renumber(){
          document.querySelectorAll('#linesTable tbody tr').forEach((tr,i)=>{
            tr.querySelector('td[data-col="idx"]').textContent = i+1;
          });
        }
        function enforceRowRule(tr){
          const dInput = tr.querySelector('input.debit');
          const cInput = tr.querySelector('input.credit');
          const d = parseDec(dInput.value);
          const c = parseDec(cInput.value);
          if (d>0) { cInput.value = ''; }
          if (c>0) { dInput.value = ''; }
        }
        function recalcTotals(){
          let td=0, tc=0;
          document.querySelectorAll('#linesTable tbody tr').forEach(tr=>{
            const d = parseDec(tr.querySelector('input.debit').value);
            const c = parseDec(tr.querySelector('input.credit').value);
            if (d>0) td += d; if (c>0) tc += c;
          });
          document.getElementById('totalDebit').value = td.toFixed(2);
          document.getElementById('totalCredit').value = tc.toFixed(2);
        }
        function showError(msg){
          const el = document.getElementById('alertBox');
          el.textContent = msg; el.classList.remove('d-none');
          setTimeout(()=>el.classList.add('d-none'), 3000);
        }
        function accountOptionsHTML(){
          return ACCOUNTS.map(a=>`<option value="${a.code}">${a.name}</option>`).join('');
        }
        function makeRow(i){
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td data-col="idx" class="text-muted">${i+1}</td>
            <td><input class="form-control form-control-sm" name="Lines[${i}].AcCode" readonly/></td>
            <td>
              <div class="input-group input-group-sm">
                <select class="form-select form-select-sm account-select" name="Lines[${i}].AccountName">
                  <option value="" selected>Select account...</option>
                  ${accountOptionsHTML()}
                </select>
              </div>
            </td>
            <td><input class="form-control form-control-sm number debit" name="Lines[${i}].Debit" inputmode="decimal"></td>
            <td><input class="form-control form-control-sm number credit" name="Lines[${i}].Credit" inputmode="decimal"></td>
            <td><input class="form-control form-control-sm" name="Lines[${i}].Description" /></td>
            <td><input class="form-control form-control-sm" name="Lines[${i}].Partner" /></td>
            <td class="text-center"><button class="btn btn-outline-danger btn-sm del-row"><i class="fa fa-trash"></i></button></td>`;
          return tr;
        }
        function addRow(){
          const tbody = document.querySelector('#linesTable tbody');
          const i = tbody.querySelectorAll('tr').length;
          const tr = makeRow(i);
          tbody.appendChild(tr);
          return tr;
        }
        function ensureTrailingBlankRow(changedTr){
          const tbody = document.querySelector('#linesTable tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));
          const last = rows[rows.length-1];
          // if the last row now has an account selected, append a new blank one
          const lastSelect = last.querySelector('select.account-select');
          if (lastSelect && lastSelect.value){
            const newTr = addRow();
            renumber();
            // focus the new row's account select
            newTr.querySelector('select.account-select').focus();
          }}
        // --- events ---
        document.getElementById('linesTable').addEventListener('input', (e)=>{
          if(e.target.matches('input.debit, input.credit')){
            enforceRowRule(e.target.closest('tr'));
            recalcTotals();
          }});
        document.getElementById('linesTable').addEventListener('change', (e)=>{
          // When account is selected, set AC Code, and if it's the last row, auto-add a new one
          if(e.target.matches('select.account-select')){
            const tr = e.target.closest('tr');
            const selCode = e.target.value;
            const acc = ACCOUNTS.find(a=>a.code===selCode);
            tr.querySelector('input[name*=".AcCode"]').value = acc ? acc.code : '';
            ensureTrailingBlankRow(tr);
          }});
        document.getElementById('linesTable').addEventListener('click', (e)=>{
          if(e.target.closest('.del-row')){
            e.target.closest('tr').remove();
            renumber(); recalcTotals();
          }});
        document.getElementById('addRow').addEventListener('click', ()=>{
          addRow(); renumber();
        });
        document.getElementById('saveBtn').addEventListener('click', ()=>{
          // client rules
          let hasDebit=false, hasCredit=false;
          let bad=false, msg="";
          document.querySelectorAll('#linesTable tbody tr').forEach(tr=>{
            const d = parseDec(tr.querySelector('input.debit').value);
            const c = parseDec(tr.querySelector('input.credit').value);
            const ac = (tr.querySelector('input[name*=".AcCode"]').value||"").trim();
            const sel = tr.querySelector('select.account-select');
            const accSelected = sel && sel.value;
            if(d>0) hasDebit=true; if(c>0) hasCredit=true;
            if (d>0 && c>0){ bad=true; msg="Enter either Debit OR Credit per row."; }
            if ((d===0 && c>0) || (c===0 && d>0)){ bad=true; msg="Amounts must be greater than 0."; }
            if (!d && !c && (accSelected || ac)){ bad=true; msg="Enter a Debit or Credit for each account row."; }
          });
          const td = parseDec(document.getElementById('totalDebit').value);
          const tc = parseDec(document.getElementById('totalCredit').value);
          if (!hasDebit || !hasCredit){ bad=true; msg="Add at least one debit and one credit line."; }
          if (td !== tc){ bad=true; msg="Dr Amount must equal Cr Amount."; }
          if (bad){ showError(msg); return; }
          showError('Looks good! (Preview only)');
        });
        // init
        document.getElementById('jvDate').valueAsDate = new Date();
        // seed one initial row and one example to mimic screenshot flow
        addRow();
        renumber();
        recalcTotals();
    </script>