
@{
    ViewData["Title"] = "Loan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>Employee Loan Details</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end align-items-center mb-4">
            <button type="button" class="btn btn-primary" id="addCategoryBtn" data-bs-toggle="modal" data-bs-target="#bankModal">
                <i class="bi bi-plus-circle me-2"></i>Add Loan
            </button>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Employee Code</th>
                    <th>Employee Name</th>
                    <th>Email</th>
                    <th>Phone No</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>


