@{
    ViewData["Title"] = "Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<style>
    .employee-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
    }

    .employee-toolbar {
        background: #e7e6e6;
        margin: 0 -15px;
        padding: 5px 15px;
        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .employee-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .employee-main {
        margin: 0 -15px -15px -15px;
        display: flex;
        height: calc(100vh - 200px);
        background: #f8f9fa;
    }

    .employee-sidebar {
        width: 380px;
        background: white;
        border-right: 1px solid #ddd;
        display: flex;
        flex-direction: column;
    }

    .sidebar-controls {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

        .sidebar-controls select,
        .sidebar-controls input {
            font-size: 11px;
            padding: 3px 6px;
            border: 1px solid #ccc;
        }

    .employee-list {
        flex: 1;
        overflow-y: auto;
    }

    .employee-list-header {
        background: #f8f9fa;
        padding: 6px 12px;
        border-bottom: 1px solid #ddd;
        font-weight: bold;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
    }

    .employee-item {
        padding: 6px 12px;
        border-bottom: 1px solid #eee;
        cursor: pointer;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
    }

        .employee-item:hover {
            background: #f5f5f5;
        }

        .employee-item.active {
            background: #c8e6c9;
        }

    .employee-content {
        flex: 1;
        padding: 15px;
        background: white;
        position: relative;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 15px;
    }

    .content-title {
        font-size: 18px;
        color: #666;
        font-weight: normal;
        margin: 0;
    }

    .note-section {
        text-align: right;
        font-size: 11px;
        color: #666;
    }

    .note-icons {
        margin-bottom: 8px;
    }

    .employee-code {
        font-size: 12px;
        margin-bottom: 20px;
        color: #333;
    }

    .transactions-header {
        font-size: 12px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #333;
    }

    .transactions-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
    }

        .transactions-table th {
            background: #f8f9fa;
            padding: 6px 8px;
            text-align: left;
            border: 1px solid #ddd;
            font-weight: normal;
            color: #666;
        }

        .transactions-table td {
            padding: 6px 8px;
            border: 1px solid #ddd;
        }

    #main {
        margin-left: 250px;
    }

    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<div class="employee-header">
    <center> Employee Center</center>
</div>

<div class="employee-toolbar">
    <ul class="nav nav-pills mb-0">
        <li class="nav-item dropdown me-3">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                <i class="bi bi-gear-fill me-1"></i> Employee Operations
            </a>
            <ul class="dropdown-menu">
                <li>
                    <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newEmployeeModal">
                        <i class="bi bi-plus-circle me-2"></i> New Employee
                    </a>
                </li>
            </ul>
        </li>
        <li class="nav-item dropdown me-3">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                <i class="bi bi-printer me-1"></i> Print
            </a>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Print List</a></li>
                <li><a class="dropdown-item" href="#">Print Details</a></li>
            </ul>
        </li>
        <li class="nav-item dropdown me-3">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel
            </a>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Export to Excel</a></li>
            </ul>
        </li>
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                <i class="bi bi-file-earmark-word me-1"></i> Word
            </a>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Export to Word</a></li>
            </ul>
        </li>
    </ul>
</div>

<div class="employee-main">

    <div class="employee-sidebar p-3 border rounded">
        <!-- Controls -->
        <div class="sidebar-controls mb-3">
            <select id="employeeFilter" class="form-select form-select-sm mb-2">
                <option value="active" selected>Active Employee</option>
                <option value="all">All Employees</option>
                <option value="inactive">Inactive Employee</option>
            </select>
            <input type="text" id="searchEmployee" class="form-control form-control-sm" placeholder="Search By Name or Code">
        </div>

        <!-- Employee Table -->
        <div class="employee-list">
            <div class="table-responsive">
                <table class="table table-striped table-sm" id="employeeTable">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Total Salary</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Employee rows injected here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="employee-content">
        <div class="content-header">
            <h2 class="content-title">Employee Information</h2>
            <div class="note-section">
            </div>
        </div>

        <div>
            <div class="transactions-header">Transactions</div>

            <div class="table-responsive">
                <table class="table table-striped" id="transactionsTable">
                    <thead class="table-light">
                        <tr>
                            <th>SN#</th>
                            <th>No</th>
                            <th>Date</th>
                            <th>Account Name</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Paid Amt</th>
                            <th>Balance</th>
                        </tr>
                    </thead>
                    <tbody id="transactionsBody">
                        <!-- Populated dynamically -->
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>


<!-- 🔽 Modal Partial View goes here -->
@Html.Partial("_Employee")


<!-- Add/Edit Position Modal -->
<div class="modal fade" id="addPositionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Position</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="positionId">
                <div class="mb-3">
                    <label for="departmentSelectforpos" class="form-label">Department</label>
                    <select id="departmentSelectforpos" class="form-select"></select>
                </div>
                <div class="mb-3">
                    <label for="positionName" class="form-label">Position Name</label>
                    <input type="text" id="positionName" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-primary" onclick="savePosition()">Save</button>
            </div>
        </div>
    </div>
</div>


<!-- Add Department Modal -->
<div class="modal fade" id="addDepartmentModal" tabindex="-1" aria-labelledby="addDepartmentLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addDepartmentLabel">Add New Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addDepartmentForm">
                    <div class="mb-3">
                        <label for="addDepartmentName" class="col-form-label">Department Name</label>
                        <input type="text" class="form-control" id="addDepartmentName" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveDepartment()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <!-- Buttons extension -->
    <link href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <!-- Export dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script>


               $(document).on('click', '#employeeTable tbody tr', function (e) {
            // Ignore button clicks inside the row
            if ($(e.target).closest('button').length) return;

            const employeeId = $(this).data('id');
            if (!employeeId) {
                toastr.warning('No employee ID found.');
                return;
            }


            // Optional: highlight
            $('#employeeTable tbody tr').removeClass('table-active');
            $(this).addClass('table-active');

            loadEmployeeTransactions(employeeId);
        });


          function loadEmployeeTransactions(employeeId) {
            $.ajax({
           url: '@Url.Action("GetInvoiceByCustomerId", "HR")',
                type: 'GET',
                data: { id: employeeId },
                beforeSend: function () {
                    $('#transactionsBody').html(`
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
               

                    // Destroy DataTable if exists
                    if ($.fn.DataTable.isDataTable('#transactionsTable')) {
                        $('#transactionsTable').DataTable().clear().destroy();
                    }

                    const tbody = $('#transactionsBody');
                    tbody.empty();

                    // 🔹 Handle no data or error message
                    if (!res.status || !res.data || res.data.length === 0) {
                        const message = res.message || "No transactions found";
                        tbody.html(`
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">${message}</td>
                            </tr>
                        `);
                        return;
                    }

                    // 🔹 Render transaction rows
                    $.each(res.data, function (i, row) {
                        tbody.append(`
                            <tr>
                                <td>${row.sn ?? ''}</td>
                                <td>${row.voucherNo ?? ''}</td>
                                <td>${row.date ?? ''}</td>
                                <td>${row.accountName ?? ''}</td>
                                <td>${row.type ?? ''}</td>
                                <td class="text-end">${(row.amount ?? 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>
                                <td class="text-end">${(row.paidAmt ?? 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>
                                <td class="text-end">${(row.balance ?? 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>
                            </tr>
                        `);
                    });

                    // ✅ Initialize DataTable with export buttons
                    $('#transactionsTable').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                className: 'btn btn-primary btn-sm'
                            },
                            {
                                extend: 'pdfHtml5',
                                text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                className: 'btn btn-primary btn-sm',
                                orientation: 'landscape',
                                pageSize: 'A4'
                            }
                        ],
                        order: [[0, 'asc']],
                        pageLength: 5
                    });
                },
                error: function () {
                    $('#transactionsBody').html(`
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">Error loading data</td>
                        </tr>
                    `);
                }
            });
        }



        $(document).ready(function() {

                    $('#saveEmployeeBtn').click(function() {
                saveEmployee();
            });


                               if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    } else {
                        event.preventDefault();
                        saveEmployee();
                    }

            // Employee selection
            $('.employee-item').click(function() {
                $('.employee-item').removeClass('active');
                $(this).addClass('active');

                var employeeCode = $(this).data('employee-code');
                $('#selectedEmployeeCode').text(employeeCode);

                // Load employee transactions here
                loadEmployeeTransactions(employeeCode);

                         });
            // Search functionality
            $('#searchEmployee').on('input', function() {
                var searchTerm = $(this).val().toLowerCase();

                $('.employee-item').each(function() {
                    var employeeName = $(this).find('span:first').text().toLowerCase();
                    var employeeCode = $(this).data('employee-code').toLowerCase();

                    if (employeeName.includes(searchTerm) || employeeCode.includes(searchTerm)) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });
                  // AJAX form submit
            $('#newEmployeeForm').on('submit', function (e) {
                e.preventDefault();

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.status) {
                            alert(res.message);
                            $('#newEmployeeModal').modal('hide');
                            // TODO: reload employee list dynamically instead of full reload
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function () {
                        alert("Error while saving employee.");
                    }
                });
            });

            // --- Account Code Update ---
            window.updateCode = function(dropdown, inputId){
                let code = $(dropdown).val().split(" - ")[0];
                $('#'+inputId).val(code);
            };





        });

        $(document).ready(function () {

             toastr.options = {
                         "closeButton": true,
                         "debug": false,
                         "newestOnTop": false,
                         "progressBar": true,
                         "positionClass": "toast-top-right",
                         "preventDuplicates": false,
                         "onclick": null,
                         "showDuration": "300",
                         "hideDuration": "1000",
                         "timeOut": "5000",
                         "extendedTimeOut": "1000",
                         "showEasing": "swing",
                         "hideEasing": "linear",
                         "showMethod": "fadeIn",
                         "hideMethod": "fadeOut"
                     };

             function calculateTotalSalary() {
                let basic = parseFloat($("#basicSalary").val()) || 0;
                let house = parseFloat($("#houseAllowance").val()) || 0;
                let transport = parseFloat($("#transportAllowance").val()) || 0;
                let other = parseFloat($("#otherAllowance").val()) || 0;

                let total = basic + house + transport + other;
                $("#totalSalary").val(total.toFixed(2));
            }

             $("#basicSalary, #houseAllowance, #transportAllowance, #otherAllowance")
             .on("input", calculateTotalSalary);


              // Form submit handler
            $('#newEmployeeForm').on('submit', function (e) {
                e.preventDefault();

                const form = this;                      // <<--- fix for "form is not defined"
                if (!form.checkValidity()) {
                    form.classList.add('was-validated');
                    return;
                }

                // Decide create vs update by EmployeeId presence (robust)
                const idVal = $('#EmployeeId').val();
                const isEdit = idVal && parseInt(idVal) > 0;
                 const url = isEdit
        ? '@Url.Action("EditEmployee", "HR")'
        : '@Url.Action("SaveEmployee", "HR")';

                // Build payload - prefer explicit IDs. Keep this list in sync with your modal IDs.
                const employeeData = {
                    Id: isEdit ? parseInt(idVal) : 0,
                    Name: $('input[name="EmployeeName"]').val() || '',
                    BirthDay: $('#BirthDay').val() || null,
                    SocialStatus: $('#SocialStatus').val() || '',
                    CountryId: $('#countryDropdown').val() ? parseInt($('#countryDropdown').val()) : null,
                    CityId: $('#cityDropdown').val() ? parseInt($('#cityDropdown').val()) : null,
                    CountryOfIssue: $('#countryOfIssue').val() ? parseInt($('#countryOfIssue').val()) : null,
                    Address: $('#Address').val() || '',
                    Phone: $('#Phone').val() || '',
                    Email: $('#Email').val() || '',
                    SocialInsuranceNumber: $('#SocialInsuranceNumber').val() || '',
                    EmergencyName: $('#EmergencyName').val() || '',
                    EmergencyAddress: $('#EmergencyAddress').val() || '',
                    EmergencyPhone: $('#EmergencyPhone').val() || '',
                    Relation: $('#Relation').val() || '',
                    PassportNumber: $('#PassportNumber').val() || '',
                    PassportIssueDate: $('#PassportIssueDate').val() || null,
                    PassportExpiryDate: $('#PassportExpiryDate').val() || null,
                    WorkContractNumber: $('#ContractNumber').val() || '',
                    PositionId: $('#positionSelect').val() ? parseInt($('#positionSelect').val()) : null,
                    DepartmentId: $('#departmentSelect').val() ? parseInt($('#departmentSelect').val()) : null,
                    WorkContractType: $('#ContractType').val() || '',
                    WorkDays: $('input[name="WorkDays"]').val() || '',
                    WorkingHours: $('input[name="WorkingHours"]').val() || '',
                    ContractIssueDate: $('#ContractIssueDate').val() || null,
                    ContractExpiryDate: $('#ContractExpiryDate').val() || null,
                    ResidencyFileNumber: $('#ResidencyFileNumber').val() || '',
                    ResidencyIssuingAuthority: $('#ResidencyIssuingAuthority').val() || '',
                    ResidencyIssueDate: $('#ResidencyIssueDate').val() || null,
                    ResidencyExpiryDate: $('#ResidencyExpiryDate').val() || null,
                    EmiratesIdfileNumber: $('#EmiratesIdFileNumber').val() || '',
                    EmiratesIdissuingAuthority: $('#EmiratesIdIssuingAuthority').val() || '',
                    EmiratesIdissueDate: $('#EmiratesIdIssueDate').val() || null,
                    EmiratesIdexpiryDate: $('#EmiratesIdExpiryDate').val() || null,
                    BasicSalary: parseFloat($('#basicSalary').val()) || 0,
                    HousingAllowance: parseFloat($('#houseAllowance').val()) || 0,
                    TransportationAllowance: parseFloat($('#transportAllowance').val()) || 0,
                    Other: parseFloat($('#otherAllowance').val()) || 0,
                    AccountId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                    BankId: $('#BankId').val() ? parseInt($('#BankId').val()) : null,
                    IbanNumber: $('#IbanNumber').val() || '',
                    BankAccountNumber: $('#BankAccountNumber').val() || '',
                    EmployeeRecivableId: $('#code2').val() ? parseInt($('#code2').val()) : null,
                    AccruedSalariesId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                    AcroalLeaveSalaryId: $('#code3').val() ? parseInt($('#code3').val()) : null,
                    GratuitId: $('#code4').val() ? parseInt($('#code4').val()) : null,
                    PettyCashId: 0,
                    Active: $('#employeeActive').is(':checked') ? 1 : 0
                };

                

                $.ajax({
                    url: url,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(employeeData),
                    success: function (res) {
                        if (res.status) {
                            toastr.success(isEdit ? 'Employee updated successfully' : 'Employee saved successfully');
                                $('#newEmployeeModal').modal('hide'); // Optional: reload page or table
                                setTimeout(function () {
                                    location.reload(); // or call a function to reload table/dropdown
                                }, 1500);
                        } else {
                            toastr.error(res.message || 'Operation failed');
                        }
                    },
                    error: function (xhr) {
                        toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Something went wrong');
                    }
                });
            });

             // Optional: remove validation styles on modal hide
             $('#newEmployeeModal').on('hidden.bs.modal', function () {
                 let form = $('#newEmployeeForm')[0];
                 form.classList.remove('was-validated');
                 form.reset();
             });

                 function renderEmployeeTable(employees) {
            const tbody = $("#employeeTable tbody");
            tbody.empty();

            if (employees.length === 0) {
                tbody.append('<tr><td colspan="3" class="text-center">No employees found</td></tr>');
                return;
            }

            employees.forEach(emp => {
                const totalSalary =
                    (emp.basicSalary || 0) +
                    (emp.housingAllowance || 0) +
                    (emp.transportationAllowance || 0) +
                    (emp.other || 0);

                tbody.append(`
                    <tr data-id="${emp.id}">
                        <td>${emp.name || ""}</td>
                        <td>${totalSalary.toFixed(2)}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-primary edit-btn me-2"
                                    data-id="${emp.id}" title="Edit Employee">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger delete-btn"
                                    data-id="${emp.id}" title="Delete Employee">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `);
            });
        }


            // Fetch employees from API
            function fetchEmployees(filter = "active", search = ""){
                $.ajax({
                  url: '@Url.Action("GetEmployees", "HR")' + '?filter=' + filter,
                    method: "GET",
                    success: function(res){
                        if(res.status){
                            let data = res.data;
                          

                            // Apply search filter
                            if(search){
                                data = data.filter(emp =>
                                    (emp.name && emp.name.toLowerCase().includes(search.toLowerCase())) ||
                                    (emp.code && emp.code.toString().includes(search))
                                );
                              
                            }

                            renderEmployeeTable(data);
                        } else {
                            console.log("API Error:", res.message);
                        }
                    },
                    error: function(xhr){
                        console.log("AJAX Error:", xhr);
                    }
                });
            }

            // Dropdown change event
            $("#employeeFilter").on("change", function(){
                let filter = $(this).val();
                let search = $("#searchEmployee").val();
                fetchEmployees(filter, search);
            });

            // Search input event
            $("#searchEmployee").on("input", function(){
                let filter = $("#employeeFilter").val();
                let search = $(this).val();
                fetchEmployees(filter, search);
            });

            // Initial load
            fetchEmployees();


              let countryCities = []; // global storage for countries and cities

            // Function to load country & city dropdowns
            function loadCountryCityDropdowns(apiUrl, countryIdSelector, cityIdSelector) {
                const $country = $(countryIdSelector);
                const $city = $(cityIdSelector);

                $.getJSON(apiUrl, function (data) {
                    countryCities = data; // store globally

                    // Populate country dropdown
                    $country.append(data.map(c => `<option value="${c.id}">${c.name}</option>`));
                });

                // Event: When country changes, populate cities
                $country.on('change', function () {
                    const selectedCountryId = $(this).val();

                    // Reset city dropdown
                    $city.html('<option value="">-- Select --</option>');

                    if (selectedCountryId) {
                        const cities = countryCities.find(c => c.id == selectedCountryId)?.cities || [];
                        $city.append(cities.map(city => `<option value="${city.id}">${city.name}</option>`));
                    }
                });
            }


