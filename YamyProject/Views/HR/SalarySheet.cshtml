@{
    ViewData["Title"] = "SalarySheet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <i class="bi bi-cash-coin text-danger fs-1 mb-3"></i>
        <h5 class="card-title fw-bold">Payroll</h5>
    </div>
    @* <div class="dropdown position-absolute top-0 end-0 mt-2 me-2">
        <button class="btn btn-light btn-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-three-dots-vertical fw-bold"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/HR/LeaveSalary"><i class="bi bi-calendar-x me-2"></i>Leave Salary</a></li>
            <li><a class="dropdown-item" href="/HR/EndOfService"><i class="bi bi-person-x me-2"></i>End Of Service</a></li>
        </ul>
    </div> *@
    <div class="card-body">
        <div class="row mb-4 align-items-center border-bottom pb-3">
            <!-- Left Side: Date & REF -->
            <div class="col-md-3">
                <div>
                    @* <strong>Date:</strong> <span id="currentDate"></span> *@
                </div>
            </div>

            <!-- Center: Month & Year Selection -->
            <div class="col-md-6 text-center">
                <div class="row justify-content-center">
                    <div class="col-auto">
                        <label class="form-label fw-bold mb-1">Month</label>
                        <select id="cmbMonth" class="form-select"></select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label fw-bold mb-1">Year</label>
                        <select id="cmbYear" class="form-select"></select>
                    </div>
                    <div class="col-auto d-flex align-items-end">
                        <button class="btn btn-primary" onclick="loadSalarySheet()">
                            <i class="bi bi-search me-1"></i> Load
                        </button>
                    </div>
                </div>
            </div>

        </div>

        <!-- Table Sections -->
        <div class="table-responsive">
            <table class="table table-striped align-middle w-100" id="table1">
                <thead class="table-light">
                    <tr>
                        <th>S.No</th>
                        <th>Employee</th>
                        <th>Basic Salary</th>
                        <th>Total Additions</th>
                        <th>Total Deductions</th>
                        <th>Net Salary</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<!-- Payslip Modal -->
<div class="modal fade" id="payslipModal" tabindex="-1" aria-labelledby="payslipModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="payslipModalLabel">Salary Slip</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="payslipContent">
                <!-- Payslip details will be appended here dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        function updateDate() {
            const year = $('#cmbYear').val();
            const month = $('#cmbMonth').val();

            if (year && month) {
                // Get last day of the selected month
                const lastDay = new Date(year, month, 0).getDate();
                const dateStr = `${lastDay}-${month}-${year}`;
                $('#currentDate').text(dateStr);
            }
        }
        // Load Salary Sheet 
        function loadSalarySheet() {
            const year = $('#cmbYear').val();
            const month = $('#cmbMonth').val();

            if (!year || !month) {
                toastr.warning('Please select both Month and Year');
                return;
            }

            $.ajax({
              url: '@Url.Action("GetSalarySheet", "HR")',
                type: 'GET',
                data: { year: year, month: month },

                beforeSend: function () {
                    $('#table1 tbody').html(`
                        <tr>
                            <td colspan="19" class="text-center text-muted py-4">
                                <div class="spinner-border text-primary me-2"></div>Loading...
                            </td>
                        </tr>
                    `);
                },
                success: function (res) {
                    if (!res.status) {
                        toastr.error(res.message || 'Failed to load salary data');
                        return;
                    }
                    console.log(res);
                    // Destroy existing DataTable
                    if ($.fn.DataTable.isDataTable('#table1')) {
                        $('#table1').DataTable().clear().destroy();
                    }

                    const tbody = $('#table1 tbody');
                    tbody.empty();

                    if (res.data && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                   const tr = `
        <tr>
            <td>${i + 1}</td>
            <td>${row.EmployeeName || ''}</td>
            <td class="text-end">${cleanNumber(row.BasicSalary).toFixed(2)}</td>
            <td class="text-end">${cleanNumber(row.Additions).toFixed(2)}</td>
            <td class="text-end">${cleanNumber(row.TotalDeductions).toFixed(2)}</td>
            <td class="text-end fw-bold">${cleanNumber(row.NetSalary).toFixed(2)}</td>
            <td class="text-center">
                <button class="btn btn-sm btn-primary" onclick='viewPayslip(${JSON.stringify(row)})'>
                    <i class="bi bi-eye"></i> View
                </button>
            </td>
        </tr>`;

                            tbody.append(tr);
                        });

                           $('#table1').DataTable({
            dom: 'Bfrtip',
            scrollX: true, 
            autoWidth: false, 
            responsive: false, 
            buttons: [
                {
                    extend: 'excelHtml5',
                    text: '<i class="fas fa-file-excel me-1"></i> Excel',
                    className: 'btn btn-primary btn-sm'
                },
                {
                  extend: 'print',
                  text: '<i class="fas fa-print me-1"></i> Print',
                  className: 'btn btn-primary btn-sm',
                }
            ],
            order: [[0, 'asc']],
            pageLength: 15,
            drawCallback: function () {
                // Adjust columns when table fully drawn
                $($.fn.dataTable.tables(true)).DataTable().columns.adjust();
            }
        });

                    } else {
                        tbody.append(`<tr><td colspan="19" class="text-center text-muted py-4">No salary records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error('Error loading salary data');
                }
            });
        }

                      function cleanNumber(val) {
            if (!val) return 0;

            return parseFloat(
                val
                    .toString()
                    .replace(/٬/g, '')  
                    .replace(/٫/g, '.')  
                    .replace(/,/g, '')  
            ) || 0;
        }

                function viewPayslip(row) {
            const payslipHtml = `
            <div class="text-center mb-3">
                <h5 class="fw-bold">Company Name</h5>
                <p>Salary Slip for ${$('#cmbMonth option:selected').text()} ${$('#cmbYear').val()}</p>
            </div>
            <table class="table table-bordered">
                <tr>
                    <td><strong>Name</strong></td><td>${row.EmployeeName || ''}</td>
                    <td><strong>Department</strong></td><td>${row.Department || ''}</td>
                </tr>
                <tr>
                    <td><strong>Emp. No</strong></td><td>${row.EmployeeCode || ''}</td>
                    <td><strong>Designation</strong></td><td>${row.Position || ''}</td>
                </tr>
            </table>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th colspan="2" class="text-center text-primary">Earnings</th>
                        <th colspan="2" class="text-center text-danger">Deductions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Basic Salary</td><td>${row.BasicSalary || 0}</td>
                        <td>Loan</td><td>${row.EmployeeAdvance || 0}</td>
                    </tr>
                    <tr>
                        <td>Allowances</td><td>${row.Allowance || 0}</td>
                        <td>Work Absence</td><td>${row.WorkAbsence || 0}</td>
                    </tr>
                    <tr>
                        <td>Other</td><td>${row.Other || 0}</td>
                        <td>Fines & Salik</td><td>${row.Salik || 0}</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Total Earnings</td><td class="fw-bold">${row.TotalEarnings || 0}</td>
                        <td class="fw-bold">Total Deductions</td><td class="fw-bold">${row.TotalDeductions || 0}</td>
                    </tr>
                </tbody>
            </table>

            <div class="text-end fw-bold fs-5 mt-3">
                Net Pay: ${row.NetSalary || 0}
            </div>`;

            $('#payslipContent').html(payslipHtml);
            $('#payslipModal').modal('show');
        }

        // On page load
        $(document).ready(function () {
            const cmbMonth = $('#cmbMonth');
            const cmbYear = $('#cmbYear');
            const currentYear = new Date().getFullYear();
            const currentMonth = String(new Date().getMonth() + 1).padStart(2, '0');

            // Populate Year dropdown
            for (let y = 2000; y <= 2050; y++) {
                cmbYear.append(`<option value="${y}">${y}</option>`);
            }

            // Populate Month dropdown
            for (let m = 1; m <= 12; m++) {
                const mm = String(m).padStart(2, '0');
                cmbMonth.append(`<option value="${mm}">${mm}</option>`);
            }

            cmbYear.val(currentYear);
            cmbMonth.val(currentMonth);

            // Load salary sheet initially
            loadSalarySheet();

            // Reload when filters change
            $('#cmbMonth, #cmbYear').change(loadSalarySheet);
        });
    </script>
}