                                                class="form-select form-select-sm">
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label">PDC Receivable Hold</label>
                                        <select asp-for="DefaultAccount.PdcReceivableHoldId"
                                                asp-items="Model.Accounts"
                                                class="form-select form-select-sm">
                                        </select>
                                    </div>
                                    <div>
