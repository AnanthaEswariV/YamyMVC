@model SettingsMasterViewmodel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Setting - Master";

    bool IsActive(string key) =>
        string.Equals(Model?.ActivePrimary ?? "default", key, StringComparison.OrdinalIgnoreCase);

    bool IsSub(string key) =>
        string.Equals(Model?.ActiveSub ?? "common", key, StringComparison.OrdinalIgnoreCase);
    }

<style>
    .settings-wrapper {
        background-color: #f5f6f8;
        min-height: calc(100vh - 60px);
    }

    .settings-header-bar {
        background-color: #003b73;
        color: #fff;
        padding: 8px 24px;
        font-size: 1rem;
        font-weight: 600;
    }

        .settings-header-bar h4 {
            margin: 0;
            font-size: 1.05rem;
        }

    .settings-primary-tabs .nav-link {
        border-radius: 0;
        padding: 6px 24px;
        font-size: .9rem;
        background-color: #1f2933;
        color: #e5e7eb;
        margin-right: 2px;
    }

        .settings-primary-tabs .nav-link.active {
            background-color: #111827;
            color: #fff;
        }

    .settings-sub-tabs .btn {
        border-radius: 0;
        min-width: 140px;
        font-size: .85rem;
    }

        .settings-sub-tabs .btn.btn-primary {
            background-color: #5b5ce6;
            border-color: #5b5ce6;
        }

        .settings-sub-tabs .btn.btn-outline-primary {
            border-color: #5b5ce6;
            color: #5b5ce6;
        }

            .settings-sub-tabs .btn.btn-outline-primary:hover {
                background-color: #5b5ce6;
                color: #fff;
            }

    .settings-card {
        border-radius: 0;
    }

        .settings-card .form-label {
            font-size: .8rem;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .settings-card .form-select {
            font-size: .8rem;
            height: calc(1.8rem + 2px);
            padding-top: .15rem;
            padding-bottom: .15rem;
        }

    .settings-save-footer {
        border-top: none;
        background: transparent;
    }
</style>

<div class="settings-wrapper">
    <!-- Top blue bar -->
    <div class="settings-header-bar d-flex align-items-center justify-content-between">
        <h4 class="mb-0 fw-semibold"> Setting - Master</h4>
        @if (TempData["ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
            {
            <span class="small text-light">@ok</span>
            }
    </div>

    <div class="container-fluid py-3">

        @* Optional: Debug line – remove later *@
        <div class="small text-muted mb-2">
            Primary: @Model.ActivePrimary | Sub: @Model.ActiveSub
        </div>

        <!-- Primary Tabs (top dark row) -->
        <ul class="nav settings-primary-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link @(IsActive("default") ? "active" : "")"
                   asp-controller="MasterSettings"
                   asp-action="Index"
                   asp-route-primary="default"
                   asp-route-sub="common">
                    Default Account Config
                </a>
            </li>
         @*    <li class="nav-item">
                <a class="nav-link @(IsActive("employee") ? "active" : "")"
                   asp-controller="MasterSettings"
                   asp-action="Index"
                   asp-route-primary="employee"
                   asp-route-sub="common">
                    Employee Default Setting
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("user") ? "active" : "")"
                   asp-controller="MasterSettings"
                   asp-action="Index"
                   asp-route-primary="user"
                   asp-route-sub="common">
                    User Config
                </a>
            </li> *@
            <li class="nav-item">
                <a class="nav-link @(IsActive("general") ? "active" : "")"
                   asp-controller="MasterSettings"
                   asp-action="Index"
                   asp-route-primary="general"
                   asp-route-sub="common">
                    General Settings
                </a>
            </li>
        </ul>

        <!-- ========= DEFAULT ACCOUNT CONFIG ========= -->
        @if (IsActive("default"))
            {
            <!-- Second row: purple sub-tabs -->
            <div class="mb-3">
                <div class="btn-group settings-sub-tabs flex-wrap">
                    <a class="btn @(IsSub("common") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="common">
                        Common
                    </a>
                    <a class="btn @(IsSub("vendor") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="vendor">
                        Vendor - Purchase
                    </a>
                    <a class="btn @(IsSub("inventory") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="inventory">
                        Inventory
                    </a>
                    <a class="btn @(IsSub("customer") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="customer">
                        Customer - Sales
                    </a>
                    <a class="btn @(IsSub("employee") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="employee">
                        Employee
                    </a>
                    <a class="btn @(IsSub("bank") ? "btn-primary" : "btn-outline-primary")"
                       asp-controller="MasterSettings"
                       asp-action="Index"
                       asp-route-primary="default"
                       asp-route-sub="bank">
                        Bank &amp; Other
                    </a>
                </div>
            </div>

