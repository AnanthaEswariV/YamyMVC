                                    </div>
                                    <div>
                                        <label class="form-label">Prepaid Expense Credit Account</label>
                                        <select asp-for="DefaultAccount.PrepaidExpenseCreditAccountId"
                                                asp-items="Model.Accounts"
                                                class="form-select form-select-sm">
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label">Fixed Asset Debit Account</label>
                                        <select asp-for="DefaultAccount.FixedAssetDebitAccountId"
                                                asp-items="Model.Accounts"
                                                class="form-select form-select-sm">
