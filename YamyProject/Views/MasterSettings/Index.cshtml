                                                class="form-select form-select-sm">
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer settings-save-footer d-flex justify-content-end">
                        <button type="button" id="btnSaveDefaults" class="btn btn-primary px-4">
                            Save
                        </button>
                    </div>
                </form>
                }

