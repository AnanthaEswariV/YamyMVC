@model CustomerSummaryViewModel

@{
    ViewData["Title"] = "Customer Summary";
    }

<style>
    body {
        background: #ffffff;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
    }

    .report-wrapper {
        padding: 16px 24px;
    }

    .report-filters {
        font-size: .9rem;
        margin-bottom: 20px;
    }

        .report-filters label {
            font-weight: 600;
            margin-right: 4px;
        }

    .report-card {
        max-width: 850px;
        margin: 0 auto;
        border: 1px solid #d0d0d0;
        background: #fff;
    }

    .report-header {
        text-align: center;
        padding: 12px 16px 4px;
        font-size: .9rem;
    }

        .report-header .company {
            font-weight: 700;
            font-size: 1rem;
        }

        .report-header .title-main {
            font-weight: 600;
            margin-top: 4px;
        }

        .report-header .title-sub {
            font-weight: 700;
            margin-top: 2px;
        }

        .report-header .meta {
            margin-top: 6px;
            font-size: .75rem;
        }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .8rem;
    }

        .report-table th,
        .report-table td {
            padding: 4px 8px;
            border: 1px solid #d5d5d5;
            vertical-align: middle;
            white-space: nowrap;
        }

        .report-table th {
            background: #dcdcdc;
            font-weight: 700;
        }

        .report-table tfoot td {
            background: #e2e2e2;
            font-weight: 700;
        }

    .text-right {
        text-align: right;
    }
</style>

<div class="report-wrapper">

    <!-- Filters -->
    <form asp-action="CustomerSummary"
          method="get"
          class="report-filters d-flex align-items-center gap-2">
        <label for="FromDate">From</label>
        <input asp-for="FromDate"
               type="date"
               class="form-control form-control-sm"
               style="width: 170px;" />

        <label for="ToDate" class="ms-2">To</label>
        <input asp-for="ToDate"
               type="date"
               class="form-control form-control-sm"
               style="width: 170px;" />

        <div class="form-check ms-3">
            <input asp-for="AllDates"
                   class="form-check-input"
                   type="checkbox"
                   id="AllDates" />
            <label class="form-check-label" for="AllDates">All</label>
        </div>

       @*  <button type="submit" class="btn btn-sm btn-primary ms-3">
            Show
        </button> *@
    </form>

    <!-- Report body -->
    <div class="report-card">

        <div class="report-header">
            <div class="company">ARC MASTER CONTRCTING L.L.C.</div>
            <div class="title-main">Customer Summary</div>
            <div class="title-sub">All Transaction</div>
            <div class="meta">
                @DateTime.Now.ToString("dd/MM/yyyy")
                &nbsp;&nbsp;
                @DateTime.Now.ToString("hh\\:mm tt")
            </div>
        </div>

        <table id="reportTable" class="report-table">
            <thead>
                <tr>
                    <th style="width:50px;">Sn</th>
                    <th style="width:280px;">Name</th>
                    <th style="width:130px;" class="text-right">Debit</th>
                    <th style="width:130px;" class="text-right">Credit</th>
                    <th style="width:130px;" class="text-right">Balance</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CustomerSummaries != null && Model.CustomerSummaries.Any())
                    {
                    var sn = 1;
                    foreach (var row in Model.CustomerSummaries)
                        {
                        <tr data-id="@row.Id">
                            <td>@sn</td>
                            <td>@row.Name</td>
                            <td class="text-right">@row.Debit.ToString("N2")</td>
                            <td class="text-right">@row.Credit.ToString("N2")</td>
                            <td class="text-right">@row.Balance.ToString("N2")</td>
                        </tr>
                        sn++;
                        }
                    }
                else
                    {
                    <tr>
                        <td colspan="5" class="text-center py-3 text-muted">
                            No data for selected period.
                        </td>
                    </tr>
                    }
            </tbody>
            <tfoot>
                <tr>
                    <td></td>
                    <td>
                        <span style="text-decoration: underline;">TOTAL</span>
                    </td>
                    <td></td>
                    <td></td>
                    <td class="text-right">
                        <span style="text-decoration: underline;">
                            @((Model.CustomerSummaries ?? new List<CustomerSummaryRowViewModel>())
                                                        .Sum(x => x.Balance).ToString("N2"))
                        </span>
                    </td>
                </tr>
            </tfoot>
        </table>

    </div>
</div>

@section Scripts {

<script>
    $(document).ready(function () {

               $('#reportTable tbody').on('dblclick', 'tr', function () {
        const id = $(this).data('id');
        if (!id) return;

                const url = '@Url.Action("CustomerSummaryDetails", "CustomerAndReceivable")' + '?id=' + id;
        window.location.href = url;
    });
    });
</script>

}