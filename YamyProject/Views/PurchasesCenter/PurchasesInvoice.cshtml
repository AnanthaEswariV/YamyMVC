                            <option value="">--</option>
                            ${ccOptions}
                        </select>
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button>
                    </td>
                    <td style="display:none;">
                        <input type="hidden" name="Items[${index}].Price" class="form-control item-Price" readonly />
                    </td>
                    <td style="display:none;">
                        <input type="hidden" name="Items[${index}].Type" class="form-control item-Type" readonly />
                    </td>
                    <td style="display:none;">
                        <input type="hidden" name="Items[${index}].Method" class="form-control item-Method" readonly />
                    </td>
