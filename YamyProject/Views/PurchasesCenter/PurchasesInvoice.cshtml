                        <datalist id="itemOptions${index}"></datalist>
                    </td>
                    <td>
                        <input name="Items[${index}].ItemName" list="itemOptions${index}" placeholder="Type or select..." class="form-control item-name itemname" />
                        <datalist id="itemOptions${index}"></datalist>
                    </td>
                    <td><input name="Items[${index}].QTY" class="form-control item-QTY" /></td>
                    <td><input name="Items[${index}].CostPrice" class="form-control item-CostPrice" /></td>
                    <td><input name="Items[${index}].Disc" class="form-control item-Disc" /></td>
                    <td><input name="Items[${index}].NetPrice" class="form-control item-NetPrice" readonly /></td>
                    <td>
                        <select class="form-select item-VatPersint" name="Items[${index}].VatPersint">
                            ${vatOptions}
                        </select>
                    </td>
                    <td><input name="Items[${index}].VatAmonut" class="form-control item-VatAmonut" readonly /></td>
                    <td><input name="Items[${index}].Amount" class="form-control item-Amount" readonly /></td>
                    <td>
