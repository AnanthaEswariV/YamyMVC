        $(document).on('click', '.remove-row', function () {
            const $tr = $(this).closest('tr');
            $tr.remove();
            if ($('#itemsTable tbody tr').length === 0) {
                const $new = NewRow();
                setupAutocomplete($new);
            } else {
                updateRowIndexes();
            }
            calcTotals();
        });

        // Toolbar "Create a Copy" = new row
        $('#addRow').on('click', function () {
            const $new = NewRow();
            setupAutocomplete($new);
        });

        // ------------------------
        // Vendor selection sync
        // ------------------------
        $(function () {
            const Vendors = @Html.Raw(JsonSerializer.Serialize(
                                                                    Model.Vendors.Select(c => new { id = c.Id, code = c.Code, name = c.Name })
                                                                ));
        const byId = Object.fromEntries(Vendors.map(x => [String(x.id), x]));

            const sel = document.getElementById('filterVendor');
            const hiddenId = document.getElementById('VendorId');
            const codeInput = document.getElementById('VendorCode');
            const nameInput = document.getElementById('VendorName');

            function syncFromSelect() {
                const m = byId[sel.value];
                if (!m) {
                    if (hiddenId) hiddenId.value = '';
                    codeInput.value = '';
                    nameInput.value = '';
                    return;
                }
                if (hiddenId) hiddenId.value = String(m.id);
                codeInput.value = m.code ?? '';
                nameInput.value = m.name ?? '';
            }

            if (sel) {
                const pre = hiddenId?.value;
                if (pre && byId[pre]) sel.value = pre;
                syncFromSelect();
                sel.addEventListener('change', syncFromSelect);
            }
        });

        // ------------------------
        // Validation helpers
        // ------------------------
        function clearInvalid($el) {
            $el.removeClass('is-invalid');
            $el.siblings('.invalid-feedback').remove();
        }

        function setInvalid($el, message) {
            $el.addClass('is-invalid');
            let $fb = $el.siblings('.invalid-feedback');
            if ($fb.length === 0) {
                $fb = $('<div class="invalid-feedback"></div>');
                $el.after($fb);
            }
            $fb.text(message);
        }

        function showMessagesSpread(messages) {
            if (!messages.length) return;
            if (window.toastr) {
                toastr.options = Object.assign({}, toastr.options, {
                    positionClass: "toast-top-center",
                    closeButton: true,
                    progressBar: true,
                    timeOut: 4500
                });
                messages.forEach((m, i) => setTimeout(() => toastr.error(m), i * 200));
            } else {
                alert(messages.join('\n'));
            }
        }

        // ------------------------
        // validateForm: ignore last completely empty row
        // ------------------------
        function validateForm() {
            const $rows = $('#itemsTable tbody tr').filter((_, tr) => !isTemplateRow($(tr)));
            const messages = [];

            // Clear previous invalid states
            $rows.find('input, select').each(function () {
                clearInvalid($(this));
            });

            let validRowCount = 0;

            $rows.each(function (i) {
                const $tr = $(this);
                const rowNo = i + 1;

                const $code = $tr.find('.item-code');
                const $name = $tr.find('.item-name');
                const $qty = $tr.find('.item-QTY');
                const $price = $tr.find('.item-CostPrice');
                const $amount = $tr.find('.item-Amount');
                const $itemId = $tr.find('.item-id');

                const codeVal = ($code.val() || '').trim();
                const nameVal = ($name.val() || '').trim();
                const qtyVal = num($qty.val());
                const priceVal = num($price.val());
                const amountVal = num($amount.val());

                const isLast = (i === $rows.length - 1);
                const isCompletelyEmpty =
                    !codeVal &&
                    !nameVal &&
                    qtyVal === 0 &&
                    priceVal === 0 &&
                    amountVal === 0;

                // Ignore last empty row if there is another row
                if (isLast && isCompletelyEmpty && $rows.length > 1) {
                    return;
                }

                validRowCount++;
                $tr.removeClass('table-danger');

                if (validRowCount === 1 && $itemId.length && !$itemId.val()?.trim()) {
                    setInvalid($itemId, 'Item ID is required for the first row.');
                    messages.push('First row: Item ID is required.');
                    $tr.addClass('table-danger');
                    return;
                }

                if ($code.length && !codeVal) {
                    setInvalid($code, `Item Code is required (row ${rowNo}).`);
                    messages.push(`Row ${rowNo}: Item Code is required.`);
                    $tr.addClass('table-danger');
                    return;
                }

                if ($name.length && !nameVal) {
                    setInvalid($name, `Item Name is required (row ${rowNo}).`);
                    messages.push(`Row ${rowNo}: Item Name is required.`);
                    $tr.addClass('table-danger');
                    return;
                }

                if ($qty.length) {
                    if (qtyVal <= 0) {
                        setInvalid($qty, `QTY must be greater than 0 (row ${rowNo}).`);
                        messages.push(`Row ${rowNo}: QTY must be > 0.`);
                        $tr.addClass('table-danger');
                        return;
                    }
                }

                if ($price.length) {
                    if (priceVal < 0) {
                        setInvalid($price, `Cost Price must be positive (row ${rowNo}).`);
                        messages.push(`Row ${rowNo}: Cost Price must be ≥ 0.`);
                        $tr.addClass('table-danger');
                        return;
                    }
                }

                if ($amount.length) {
                    if (amountVal <= 0) {
                        setInvalid($amount, `Amount must be greater than 0 (row ${rowNo}).`);
                        messages.push(`Row ${rowNo}: Amount must be > 0.`);
                        $tr.addClass('table-danger');
                        return;
                    }
                }
            });

            if (validRowCount === 0) {
                messages.push('At least one item row with data is required.');
            }

            if (messages.length) {
                showMessagesSpread(messages);
                const $firstInvalid = $('.is-invalid').first();
                if ($firstInvalid.length) {
                    $firstInvalid.get(0).focus?.();
                    $firstInvalid.get(0).scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                return false;
            }

            return true;
        }

        // ------------------------
        // AJAX Save
        // ------------------------
        (function () {
            const $form = $('#invoiceForm');
            const token = $form.find('input[name="__RequestVerificationToken"]').val();

            // prevent Enter key from native submit
            $form.on('keydown', 'input,select,textarea', function (e) {
                if (e.key === 'Enter') e.preventDefault();
            });

            function getUrlFromId() {
                const idVal = Number($form.find('input[name="Id"]').val() || 0);
                return idVal > 0
                    ? '@Url.Action("Edit", controllerName)'
                    : '@Url.Action("Create", controllerName)';
            }

            function postAjax(saveAndClose) {
                calcTotals();
                const payload = $form.serialize();
                const url = getUrlFromId();

                $.ajax({
                    url,
                    type: 'POST',
                    data: payload,
                    headers: { 'RequestVerificationToken': token },
                    success: function (res) {
                        if (saveAndClose) {
                            window.location.href = (res && res.redirectUrl)
                                ?? '@Url.Action("Index", controllerName)';
                        } else {
                            showMessagesSpread([(res && res.message) || 'Saved.']);
                        }
                    },
                    error: function (xhr) {
                        try {
                            const r = JSON.parse(xhr.responseText);
                            showMessagesSpread([r.message || 'Error while saving.']);
                            console.error(r.errors || r);
                        } catch {
                            showMessagesSpread(['Error while saving.']);
                        }
                    }
                });
            }

            $('#btnAjaxSave').on('click', function () {
                if (!validateForm()) return;
                postAjax(false);
            });

            $('#btnAjaxSaveClose').on('click', function () {
                if (!validateForm()) return;
                postAjax(true);
            });
        })();

        // ------------------------
        // Initialisation
        // ------------------------
        $(function () {
            $('#itemsTable tbody tr').each(function () {
                setupAutocomplete($(this));
            });
            calcTotals();
        });

        // ------------------------
        // InvoiceType -> Default Account mapping
        // ------------------------
        $(function () {
            const $invoiceType = $('#InvoiceType, select[name="InvoiceType"]');
            const $accountSelect = $('#AccountId, select[name="AccountId"]');

            if (!$invoiceType.length || !$accountSelect.length) {
                console.error('InvoiceType or AccountId select not found.');
                return;
            }

            function loadDefaultAccount() {
                const type = ($invoiceType.val() || '').trim();
                let accountKey = null;

                if (type === 'Cash') {
                    accountKey = 'Purchase Payment Cash Method';
                } else if (type === 'Credit') {
                    accountKey = 'Vendor';
                } else {
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetDefolutAccount", "PurchasesCenter")',
                    type: 'GET',
                    data: { account: accountKey },
                    success: function (result) {
                        console.log('GetDefolutAccount result:', result);

                        if (result == null) return;

                        let accountId;

                        if (typeof result === 'number' || typeof result === 'string') {
                            accountId = String(result);
                        } else if (typeof result === 'object') {
                            accountId = String(
                                result.accountId ??
                                result.id ??
                                result.AccountId ??
                                ''
                            );
                        }

                        if (!accountId) {
                            console.warn('No accountId in result:', result);
                            return;
                        }

                        $accountSelect.val(accountId);

                        if ($accountSelect.val() !== accountId) {
                            console.warn('No option with value =', accountId,
                                'Available:', $accountSelect.find('option').map(function () {
                                    return $(this).val();
                                }).get()
                            );
                            return;
                        }

                        $accountSelect.trigger('change');
                    },
                    error: function (xhr, status, err) {
                        console.error('GetDefolutAccount AJAX error:', status, err, xhr.responseText);
                    }
                });
            }

            $invoiceType.on('change', loadDefaultAccount);
            loadDefaultAccount();
        });

        // ------------------------
        // show/hide Fixed Assets based on Purchase Type
        // ------------------------

        document.addEventListener('DOMContentLoaded', function () {
            const purchaseTypeSelect = document.getElementById('PurchaseType');
            const fixedAssetDiv = document.getElementById('fixedAssetWrapper');

            function toggleFixedAsset() {
                if (purchaseTypeSelect.value === 'Fixed Assets') {
                    fixedAssetDiv.classList.remove('d-none');
                } else {
                    fixedAssetDiv.classList.add('d-none');
                }
            }

            purchaseTypeSelect.addEventListener('change', toggleFixedAsset);
            toggleFixedAsset();
        });
    </script>
