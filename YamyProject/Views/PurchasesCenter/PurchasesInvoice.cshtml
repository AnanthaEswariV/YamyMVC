@model PurchaseInvoiceViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Purchase Invoice";

    var controllerName = string.Equals(Model?.VendorType, "Subcontractor", StringComparison.OrdinalIgnoreCase)
        ? "SubcontractorPurchasesCenter"
        : "PurchasesCenter";
    }

<style>
    body {
        background: #e6edf4;
    }

    .pi-shell {
        margin-top: 6px;
    }

    .pi-window {
        border-radius: 0;
        border: 1px solid #c4ccd7;
        overflow: hidden;
    }

    /* top blue bar  */
    .pi-titlebar {
        background: #0b3555;
        color: #fff;
        padding: 4px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .pi-titlebar-controls i {
        font-size: .8rem;
        margin-left: 10px;
        cursor: pointer;
    }

    /* toolbar (New / Save / Delete / Print / etc.)  */
    .pi-toolbar {
        background: #f4f6f9;
        border-bottom: 1px solid #d2d7e0;
        padding: 6px 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .pi-toolbar .btn {
            padding: 4px 10px;
            font-size: .8rem;
            border-radius: 0;
        }

            .pi-toolbar .btn i {
                margin-right: 4px;
            }

    .pi-toolbar-spacer {
        flex: 1 1 auto;
    }

    /* light blue band for header fields */
    .pi-header-strip {
        background: #e3edf7;
        border-bottom: 1px solid #cbd5e4;
        padding: 10px 12px 6px 12px;
    }

        .pi-header-strip .form-label {
            font-size: .75rem;
            margin-bottom: 1px;
        }

        .pi-header-strip .form-control,
        .pi-header-strip .form-select {
            height: 30px;
            padding: 2px 6px;
            font-size: .8rem;
        }

        .pi-header-strip .tiny-link {
            font-size: .7rem;
            margin-left: 4px;
            cursor: pointer;
            color: #0d6efd;
        }

        .pi-header-strip .pi-inline-row {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            align-items: flex-end;
        }

            .pi-header-strip .pi-inline-row > div {
                min-width: 130px;
            }

            .pi-header-strip .pi-inline-row .pi-grow {
                flex: 1 1 auto;
            }

    .jv-toolbar-wrap {
        background: #f7f8fb;
        border-bottom: 1px solid #c7ccd6;
        padding: 8px 16px 12px;
    }

    .jv-toolbar {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .jv-navbox {
        display: flex;
        align-items: center;
        background: #e9ecf2;
        border: 1px solid #c0c6d6;
        border-radius: 2px;
        padding: 4px 10px;
        gap: 6px;
    }

        .jv-navbox span.badge-box {
            min-width: 55px;
            text-align: center;
            background: #d2d7e2;
            border-radius: 2px;
            font-size: .85rem;
            padding: 3px 0;
        }

        .jv-navbox button {
            border: none;
            background: transparent;
            padding: 0 4px;
            font-size: 1rem;
            color: #495057;
        }

    .jv-toolgroup {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .jv-toolbtn {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: .78rem;
        color: #333;
        cursor: pointer;
        min-width: 60px;
    }

        .jv-toolbtn i {
            font-size: 1.2rem;
            margin-bottom: 2px;
        }

    .jv-checks {
        margin-left: auto;
        font-size: .8rem;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    /* grid area */
    .pi-body-inner {
        padding: 8px 12px 0 12px;
        background: #fff;
    }

    .pi-grid-wrapper {
        border: 1px solid #d2d7e0;
        border-radius: 0;
        height: calc(100vh - 360px);
        min-height: 280px;
        overflow: auto;
    }

    #itemsTable {
        margin-bottom: 0;
        font-size: .8rem;
    }

        #itemsTable thead th {
            background: #eef2f7;
            border-bottom: 1px solid #cbd5e4;
            white-space: nowrap;
        }

        #itemsTable tbody td {
            padding: 3px 4px;
        }

        #itemsTable input.form-control,
        #itemsTable select.form-select {
            font-size: .78rem;
            padding: 2px 4px;
            height: 28px;
        }

    /* notes + totals */
    .pi-footer-panel {
        padding: 6px 12px 8px 12px;
        background: #f4f6f9;
        border-top: 1px solid #cbd5e4;
    }

    .pi-notes textarea {
        resize: vertical;
        min-height: 80px;
        font-size: .82rem;
    }

    .pi-totals-box {
        background: #e3edf7;
        border: 1px solid #cbd5e4;
        border-radius: 2px;
        padding: 6px 8px;
        font-size: .78rem;
    }

        .pi-totals-box .row + .row {
            margin-top: 4px;
        }

    .pi-totals-label {
        font-weight: 600;
    }

    .pi-totals-value {
        text-align: right;
        min-width: 90px;
    }

    /* bottom buttons */
    .pi-bottom-bar {
        background: #dfe4ee;
        border-top: 1px solid #c4ccd7;
        padding: 6px 14px;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

        .pi-bottom-bar .btn {
            min-width: 110px;
            border-radius: 0;
            font-size: .82rem;
        }

        .pi-bottom-bar .btn-primary {
            background: #0b3555;
            border-color: #0b3555;
        }

        .pi-bottom-bar .btn-success {
            background: #0f6b31;
            border-color: #0f6b31;
        }
</style>

<div class="container-fluid pi-shell">
    <div class="pi-window card shadow-sm">
        <!-- Title bar -->
        <div class="pi-titlebar justify-content-between align-items-center">
            <div>Purchase Invoice</div>
        </div>

        <!-- Toolbar / navigation -->
        <div class="jv-toolbar-wrap">
            <div class="jv-toolbar">
                <!-- navigation box -->
                <div class="jv-navbox">
                    <button type="button" title="Previous"><i class="fa fa-arrow-left"></i></button>
                    <span class="badge-box">@Model.PurchaseId</span>
                    <button type="button" title="Next"><i class="fa fa-arrow-right"></i></button>
                </div>

                <!-- actions -->
                <div class="jv-toolgroup">
                    <div class="jv-toolbtn">
                        <i class="fa fa-file"></i>
                        <span>New</span>
                    </div>
                    <div class="jv-toolbtn" id="tbSave">
                        <i class="fa fa-save"></i>
                        <span>Save</span>
                    </div>
                    <div class="jv-toolbtn">
                        <i class="fa fa-trash"></i>
                        <span>Delete</span>
                    </div>
                    <div class="jv-toolbtn" id="addRow">
                        <i class="fa fa-copy"></i>
                        <span>Create a Copy</span>
                    </div>
                    <div class="jv-toolbtn">
                        <i class="fa fa-print"></i>
                        <span>Print</span>
                    </div>
                    <div class="jv-toolbtn">
                        <i class="fa fa-envelope"></i>
                        <span>Email</span>
                    </div>
                    <div class="jv-checks">
                        <label class="form-check-label">
                            <input type="checkbox" class="form-check-input me-1" /> Print Later
                        </label>
                        <label class="form-check-label">
                            <input type="checkbox" class="form-check-input me-1" /> Email Later
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <form enctype="multipart/form-data" id="invoiceForm">
            @Html.AntiForgeryToken()

            @if (Model?.Id > 0)
                {
                <input type="hidden" asp-for="Id" />
                }
            <input type="hidden" asp-for="From" />
            <input type="hidden" asp-for="IdFromOtherTybe" />

            <!-- Validation -->
            <div class="px-3 pt-2">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            </div>

            <!-- Light blue header strip: vendor + main info -->
            <div class="pi-header-strip">
                <!-- Row 1 -->
                <div class="pi-inline-row mb-1">
                    <div>
                        <label class="form-label">Code</label>
                        <input class="form-control" asp-for="VendorCode" id="VendorCode" readonly />
                        <input type="hidden" asp-for="VendorId" id="VendorId" />
                    </div>

                    <div class="pi-grow">
                        <label class="form-label">Vendor</label>
                        <div class="d-flex gap-1">
                            <select class="form-select" asp-for="VendorId"
                                    asp-items="@(new SelectList(Model.Vendors, "Id", "Name"))"
                                    id="filterVendor"></select>
                            <span class="tiny-link align-self-center">New</span>
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Bill</label>
                        <input class="form-control" asp-for="VendorName" id="VendorName" />
                    </div>

                    <div class="pi-grow">
                        <label class="form-label">Ship</label>
                        <input class="form-control" asp-for="ShipTo" id="ShipTo" />
                    </div>

                    <div>
                        <label class="form-label">Ship Date</label>
                        <input asp-for="ShipDate" type="date" class="form-control" />
                    </div>

                    <div>
                        <label class="form-label">Via</label>
                        <select asp-for="Via" class="form-select">
                            <option value="DHl">DHl</option>
                            <option value="MAIl">MAIl</option>
                            <option value="OnSite">On Site</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <!-- Row 2 -->
                <div class="pi-inline-row mt-1">
                    <div>
                        <label class="form-label">Invoice Type</label>
                        <select asp-for="InvoiceType" class="form-select" id="InvoiceType">
                            <option value="Cash">Cash</option>
                            <option value="Credit">Credit</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Warehouse</label>
                        <select class="form-select js-select2" asp-for="WarehouseId"
                                asp-items="@(new SelectList(Model.Warehouses, "Id", "Name"))"
                                id="filterWarehouse">
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Payment Terms</label>
                        <select asp-for="PaymentTermDays" class="form-select">
                            <option>30</option>
                            <option>60</option>
                            <option>90</option>
                            <option>120</option>
                            <option>150</option>
                            <option>180</option>
                            <option>210</option>
                            <option>240</option>
                            <option>270</option>
                            <option>300</option>
                            <option>330</option>
                            <option>360</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Due To</label>
                        <input asp-for="DueTo" type="date" class="form-control" />
                    </div>

                    <div>
                        <label class="form-label">P.O NO</label>
                        <input class="form-control" asp-for="PONo" id="PONo" />
                    </div>

                    <div>
                        <label class="form-label">Invoice #</label>
                        <input class="form-control" asp-for="Invoce" readonly />
                    </div>
                </div>

                <!-- Row 3 -->
                <div class="pi-inline-row mt-1">
                    <div>
                        <label class="form-label">Emirate</label>
                        <select asp-for="Emirate" class="form-select">
                            <option>Abu Dhabi</option>
                            <option>Dubai</option>
                            <option>Sharjah</option>
                            <option>Ajman</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Sales Man</label>
                        <input class="form-control" asp-for="SalesMane" id="SalesMane" />
                    </div>
                    <div>
                        <label class="form-label">Account Name</label>
                        <select class="form-select" asp-for="AccountId"
                                asp-items="@(new SelectList(Model.Accounts, "Id", "Name"))"
                                id="AccountId">
                            <option value="">-- Select Account --</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Purchase Type</label>
                        <select asp-for="PurchaseType" class="form-select" id="PurchaseType">
                            <option>Inventory</option>
                            <option>Fixed Assets</option>
                            <option>Expense</option>
                        </select>
                    </div>
                    <div id="fixedAssetWrapper" class="d-none">
                        <label class="form-label">Fixed AssetId</label>
                        <select class="form-select" asp-for="FixedAssetId"
                                asp-items="@(new SelectList(Model.FixedAssets, "Id", "CategoryName"))"
                                id="FixedAssetId">
                            <option value="">-- Select Account --</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- White body: grid -->
            <div class="pi-body-inner">
                <div class="pi-grid-wrapper table-responsive">
                    <table id="itemsTable" class="table table-bordered table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="display:none">Id</th>
                                <th>#</th>
                                <th>Item Code</th>
                                <th>Item Name</th>
                                <th>QTY</th>
                                <th>Cost Price</th>
                                <th>Disc</th>
                                <th>Net Price</th>
                                <th>Vat</th>
                                <th>Vat Amount</th>
                                <th>Amount</th>
                                <th>Cost Center</th>
                                <th>DEL</th>
                                <th style="display:none">Price</th>
                                <th style="display:none">Type</th>
                                <th style="display:none">Method</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null && Model.Items.Any())
                                {
                                for (var item = 0; item < Model.Items.Count; item++)
                                    {
                                    <tr>
                                        <td style="display:none;">
                                            <input type="hidden"
                                                   asp-for="Items[item].ItemId"
                                                   class="form-control item-id" />
                                        </td>
                                        <td>@(item + 1)</td>
                                        <td>
                                            <input type="text"
                                                   asp-for="Items[item].ItemCode"
                                                   list="itemOptions@(item)"
                                                   placeholder="Type or select..."
                                                   class="form-control item-code itemCode" />
                                            <datalist id="itemOptions@(item)"></datalist>
                                        </td>
                                        <td>
                                            <input type="text"
                                                   asp-for="Items[item].ItemName"
                                                   list="itemOptions@(item)"
                                                   placeholder="Type or select..."
                                                   class="form-control item-name itemname" />
                                            <datalist id="itemOptions@(item)"></datalist>
                                        </td>
                                        <td>
                                            <input class="form-control item-QTY"
                                                   asp-for="Items[item].QTY" />
                                        </td>
                                        <td>
                                            <input class="form-control item-CostPrice"
                                                   asp-for="Items[item].CostPrice" />
                                        </td>
                                        <td>
                                            <input class="form-control item-Disc"
                                                   asp-for="Items[item].Disc" />
                                        </td>
                                        <td>
                                            <input class="form-control item-NetPrice"
                                                   asp-for="Items[item].NetPrice"
                                                   readonly />
                                        </td>
                                        <td>
                                            <select class="form-select item-VatPersint"
                                                    asp-for="Items[item].VatPersint"
                                                    asp-items="Model.Vat">
                                            </select>
                                        </td>
                                        <td>
                                            <input class="form-control item-VatAmonut"
                                                   asp-for="Items[item].VatAmonut"
                                                   readonly />
                                        </td>
                                        <td>
                                            <input class="form-control item-Amount"
                                                   asp-for="Items[item].Amount"
                                                   readonly />
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm"
                                                    asp-for="Items[item].CostCenterId"
                                                    asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))">
                                                <option value="">--</option>
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button>
                                        </td>
                                        <td style="display:none;">
                                            <input type="hidden"
                                                   class="form-control item-Price"
                                                   asp-for="Items[item].Price" />
                                        </td>
                                        <td style="display:none;">
                                            <input type="hidden"
                                                   asp-for="Items[item].Type"
                                                   class="form-control item-Type" />
                                        </td>
                                        <td style="display:none;">
                                            <input type="hidden"
                                                   asp-for="Items[item].Method"
                                                   class="form-control item-Method" />
                                        </td>
                                    </tr>
                                    }
                                }
                            else
                                {
                                <tr>
                                    <td style="display:none;">
                                        <input type="hidden"
                                               name="Items[0].ItemId"
                                               class="form-control item-id" />
                                    </td>
                                    <td>1</td>
                                    <td>
                                        <input type="text"
                                               name="Items[0].ItemCode"
                                               list="itemOptions0"
                                               placeholder="Type or select..."
                                               class="form-control item-code itemCode" />
                                        <datalist id="itemOptions0"></datalist>
                                    </td>
                                    <td>
                                        <input type="text"
                                               name="Items[0].ItemName"
                                               list="itemOptions0"
                                               placeholder="Type or select..."
                                               class="form-control item-name itemname" />
                                        <datalist id="itemOptions0"></datalist>
                                    </td>
                                    <td><input class="form-control item-QTY" name="Items[0].QTY" /></td>
                                    <td><input class="form-control item-CostPrice" name="Items[0].CostPrice" /></td>
                                    <td><input class="form-control item-Disc" name="Items[0].Disc" /></td>
                                    <td><input class="form-control item-NetPrice" name="Items[0].NetPrice" readonly /></td>
                                    <td>
                                        <select class="form-select form-select-sm item-VatPersint"
                                                name="Items[0].VatPersint"
                                                asp-items="Model.Vat">
                                        </select>
                                    </td>
                                    <td><input class="form-control item-VatAmonut" name="Items[0].VatAmonut" readonly /></td>
                                    <td><input class="form-control item-Amount" name="Items[0].Amount" readonly /></td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                name="Items[0].CostCenterId"
                                                asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))">
                                            <option value="">--</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button>
                                    </td>
                                    <td style="display:none;">
                                        <input type="hidden" class="form-control item-Price"
                                               name="Items[0].Price" />
                                    </td>
                                    <td style="display:none;">
                                        <input type="hidden" name="Items[0].Type"
                                               class="form-control item-Type" />
                                    </td>
                                    <td style="display:none;">
                                        <input type="hidden" name="Items[0].Method"
                                               class="form-control item-Method" />
                                    </td>
                                </tr>
                                }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Notes + totals + bottom buttons -->
            <div class="pi-footer-panel">
                <div class="row g-2">
                    <div class="col-md-8 pi-notes">
                        <label class="form-label small">Notes</label>
                        <textarea asp-for="Description" class="form-control"></textarea>
                    </div>
                    <div class="col-md-4">
                        <div class="pi-totals-box">
                            <div class="row">
                                <div class="col-7 pi-totals-label">Total Before Vat</div>
                                <div class="col-5 pi-totals-value total-BeforeVat">@Model.TotalBeforeVat</div>
                            </div>
                            <div class="row">
                                <div class="col-7 pi-totals-label">Total Vat</div>
                                <div class="col-5 pi-totals-value total-Vat">@Model.TotalVat</div>
                            </div>
                            <div class="row">
                                <div class="col-7 pi-totals-label">Total Discount</div>
                                <div class="col-5 pi-totals-value tota-Discount">@Model.TotaDiscount</div>
                            </div>
                            <div class="row">
                                <div class="col-7 pi-totals-label">Net Amount</div>
                                <div class="col-5 pi-totals-value fw-bold net-Amount">@Model.TotaAmount</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hidden totals for posting -->
            <input type="hidden" asp-for="TotalBeforeVat" />
            <input type="hidden" asp-for="TotalVat" />
            <input type="hidden" asp-for="TotaDiscount" />
            <input type="hidden" asp-for="TotaAmount" />

            <div class="pi-bottom-bar">
                <button type="button" id="btnAjaxSaveClose" class="btn btn-primary">Save &amp; Close</button>
                <button type="button" id="btnAjaxSave" class="btn btn-success">Save</button>
                <a asp-action="Index" asp-controller="@controllerName" class="btn btn-secondary">Close</a>
            </div>
        </form>

        <!-- hidden templates for JS -->
        <select id="tpl-vat" class="d-none" asp-items="Model.Vat"></select>
        <select id="tpl-cc" class="d-none" asp-items="@(new SelectList(Model.CostCenters, "Id", "Code"))"></select>
    </div>
</div>

    @section Scripts {
    <script>
        // ------------------------
        // Shared helpers
        // ------------------------
        const num = v => {
            if (v == null) return 0;
            const n = parseFloat(String(v).replace(/,/g, ''));
            return Number.isFinite(n) ? n : 0;
        };

        const fmt = n => n.toLocaleString(undefined, {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        function isTemplateRow($tr) {
            return $tr.hasClass('template') || $tr.is('[data-template="true"]');
        }

        function isLastRow($row) {
            return $row.is(':last-child');
        }

        function updateRowIndexes() {
            $('#itemsTable tbody tr').each(function (i) {
                $(this).find('td').eq(1).text(i + 1);
                $(this).find('input, select').each(function () {
                    const name = $(this).attr('name');
                    if (!name) return;
                    $(this).attr('name', name.replace(/Items\[\d+\]/, `Items[${i}]`));
                });
            });
        }

        // ------------------------
        // Row calculation
        // ------------------------
        function calcRow($tr) {
            let disc = 0;
            const qty = num($tr.find('.item-QTY').val());
            const price = num($tr.find('.item-CostPrice').val());
            if (qty > 0 && price > 0) {
                disc = num($tr.find('.item-Disc').val());
            }
            const vatPct = num($tr.find('.item-VatPersint').val());

            const net = (qty * price) - disc;
            const vatAmt = net * (vatPct / 100);
            const amount = net + vatAmt;

            $tr.find('.item-NetPrice').val(fmt(net));
            $tr.find('.item-VatAmonut').val(fmt(vatAmt));
            $tr.find('.item-Amount').val(fmt(amount));
            $tr.find('.item-Disc').val(fmt(disc));

            return { net, vatAmt, amount, Discount: disc };
        }

        function calcTotals() {
            let totalNet = 0, totalVat = 0, totalAmount = 0, totalDiscount = 0;

            $('#itemsTable tbody tr').each(function () {
                const $tr = $(this);
                if (isTemplateRow($tr)) return;
                const r = calcRow($tr);
                totalNet += r.net;
                totalVat += r.vatAmt;
                totalDiscount += r.Discount;
                totalAmount += r.amount;
            });

            $('.total-BeforeVat').text(fmt(totalNet));
            $('.total-Vat').text(fmt(totalVat));
            $('.tota-Discount').text(fmt(totalDiscount));
            $('.net-Amount').text(fmt(totalAmount));

            const set = (name, val) => {
                const el = document.querySelector(`input[name="${name}"]`);
                if (el) el.value = val;
            };
            set('TotalBeforeVat', totalNet);
            set('TotalVat', totalVat);
            set('TotaDiscount', totalDiscount);
            set('TotaAmount', totalAmount);
        }

        $(document).on('input change',
            '#itemsTable .item-QTY, #itemsTable .item-CostPrice, #itemsTable .item-Disc, #itemsTable .item-VatPersint',
            function () {
                const $tr = $(this).closest('tr');
                calcRow($tr);
                calcTotals();
            });

        // ------------------------
        // Autocomplete + items
        // ------------------------
        function fillRowFromItem($row, item) {
            const get = (o, a, b) => o[a] ?? o[b];

            $row.find('.item-id').val(get(item, 'Id', 'id'));
            $row.find('.item-code').val(get(item, 'Code', 'code'));
            $row.find('.item-name').val(get(item, 'Name', 'name'));
            $row.find('.item-CostPrice').val(get(item, 'CostPrice', 'costPrice'));
            $row.find('.item-QTY').val(0);
            $row.find('.item-Disc').val(0);
            $row.find('.item-NetPrice').val(0);
            $row.find('.item-VatAmonut').val(0);
            $row.find('.item-Amount').val(0);
            $row.find('.item-Price').val(get(item, 'SalesPrice', 'salesPrice'));
            $row.find('.item-Type').val(get(item, 'Type', 'type'));
            $row.find('.item-Method').val(get(item, 'Method', 'method'));

            calcRow($row);
            calcTotals();
        }

        function setupAutocomplete($row) {
            function getDatalist($input, $scope = $(document)) {
                const el = $input[0];
                if (!el) return $();
                if (el.list) return $(el.list);
                const id = $input.attr('list');
                if (!id) return $();
                const $scoped = $scope.find('#' + id);
                return $scoped.length ? $scoped : $('#' + id);
            }

            const $code = $row.find('.item-code');
            const $name = $row.find('.item-name');
            const $codeDL = getDatalist($code, $row);
            const $nameDL = getDatalist($name, $row);

            let cacheItems = [];

            function fetchItems(term, cb) {
                $.getJSON('@Url.Action("GetItems", "PurchasesCenter")', {
                    term: term,
                    warehouseId: document.querySelector('.js-select2')?.value
                }, function (data) {
                    const itemsArray = Array.isArray(data) ? data : data?.items;
                    const arr = Array.isArray(itemsArray) ? itemsArray : [];
                    cacheItems = arr;
                    cb(arr);
                });
            }

            function populateDatalist($dl, arr, valueKey) {
                if (!$dl || !$dl.length) return;
                $dl.empty();
                arr.slice(0, 50).forEach(item => {
                    const code = item.Code ?? item.code;
                    const name = item.Name ?? item.name;
                    const value = valueKey === 'code' ? code : name;
                    $('<option />', { value: value, text: `${code} - ${name}` }).appendTo($dl);
                });
            }

            function resolveAndFill($input) {
                if (!cacheItems.length) return;

                const isCode = $input.is('.item-code');
                const val = ($input.val() || '').trim();
                if (!val) return;

                const chosen = cacheItems.find(x => {
                    const code = x.Code ?? x.code;
                    const name = x.Name ?? x.name;
                    return isCode ? code === val : name === val;
                });

                if (chosen) {
                    fillRowFromItem($row, chosen);
                    if (isLastRow($row)) {
                        const $new = NewRow();
                        setupAutocomplete($new);
                    }
                }
            }

            if ($codeDL.length) {
                $code.on('input', function () {
                    const term = this.value || '';
                    if (term.length < 1) { $codeDL.empty(); return; }
                    fetchItems(term, function (arr) {
                        populateDatalist($codeDL, arr, 'code');
                    });
                });
                $code.on('change blur', function () { resolveAndFill($code); });
            }

            if ($nameDL.length) {
                $name.on('input', function () {
                    const term = this.value || '';
                    if (term.length < 1) { $nameDL.empty(); return; }
                    fetchItems(term, function (arr) {
                        populateDatalist($nameDL, arr, 'name');
                    });
                });
                $name.on('change blur', function () { resolveAndFill($name); });
            }
        }

