@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<YamyProject.SharedResource> Localizer


@{
    ViewData["Title"] = "BankCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header text-center">
        <strong>@Localizer["Nav_BankCenter"]</strong>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <!-- Left side - Filter -->
            <div style="min-width: 300px;">
                <h6 class="fw-bold mb-2">@Localizer["Lbl_SelectionMethod"]</h6>
                <select class="form-select" id="bankSelect">
                    <option value="Register Bank">@Localizer["Bank_RegisterBank"]</option>
                    <option value="UnRegister Bank">@Localizer["Bank_UnRegisterBank"]</option>
                </select>
            </div>

            <!-- Right side - Add Bank Button -->
            <div>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#bankModal">
                    <i class="bi bi-plus-circle me-2"></i>@Localizer["Bank_AddBank"]
                </button>
            </div>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>@Localizer["Lbl_No"]</th>
                    <th>@Localizer["Lbl_Code"]</th>
                    <th>@Localizer["Bank_BankName"]</th>
                    <th>@Localizer["Bank_AbbName"]</th>
                    <th>@Localizer["Bank_EntId"]</th>
                    <th>@Localizer["Bank_RouteNo"]</th>
                    <th>@Localizer["Lbl_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                <!-- Rows will be loaded dynamically -->
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Bank Modal -->
<div class="modal fade" id="bankModal" tabindex="-1" aria-labelledby="bankModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="bankForm" class="needs-validation" novalidate>
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@Localizer["Bank_RegisterBank"]</h5>
                    <button type="button" class="btn btn-sm btn-outline-light" data-bs-dismiss="modal">✕</button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="bankId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Lbl_Code"]</label>
                            <input type="text" class="form-control" id="bankCode" placeholder="@Localizer["Lbl_Code"]" disabled>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Bank_BankName"]</label>
                            <input type="text" class="form-control" id="bankName" name="BankName" placeholder="@Localizer["Bank_BankName"]" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Bank_AbbName"]</label>
                            <input type="text" class="form-control" id="abbreviationName" name="AbbName" placeholder="@Localizer["Bank_AbbName"]" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Bank_EntId"]</label>x
                            <input type="text" class="form-control" id="entId" name="EntId" placeholder="@Localizer["Bank_EntId"]" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Bank_RouteNo"]</label>
                            <input type="text" class="form-control" id="routeNo" name="RouteNum" placeholder="@Localizer["Bank_RouteNo"]" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Lbl_Country"]</label>
                            <select class="form-select" id="country" name="CountryId" required>
                                <option value="">-- @Localizer["Lbl_Country"] --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">@Localizer["Btn_Save"]</button>
                    <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">@Localizer["Btn_Close"]</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

            var btnExcel = "@Localizer["Btn_Excel"]";
        var btnPdf   = "@Localizer["Btn_PDF"]";
        // ===== Load Banks Table =====
           function loadBanks(selectionMethod) {
            $.ajax({
               url: '@Url.Action("GetBanks", "Account")',
                type: "GET",
                data: { selectionMethod: selectionMethod },
                success: function (res) {
                    if (res.status) {
                        if ($.fn.DataTable.isDataTable("#table1")) {
                            $("#table1").DataTable().destroy();
                        }

                        let tbody = $("#table1 tbody");
                        tbody.empty();

                                   let isRegister = (selectionMethod === "Register Bank");
                                    let isUnregister = (selectionMethod === "UnRegister Bank");


                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                let rowData = JSON.stringify(row);

                                let tr = `
                                    <tr>
                                        <td>${row.sn}</td>
                                        <td>${row.code ?? ""}</td>
                                        <td>${row.bankName ?? ""}</td>
                                        <td>${row.abbName ?? ""}</td>
                                        <td>${row.entId ?? ""}</td>
                                        <td>${row.routeNo ?? ""}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary editBankBtn"
                                                    data-bank='${rowData}' ${!isRegister ? "disabled" : ""}>
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger deleteBankBtn"
                                                    data-id='${row.id}' ${!isRegister ? "disabled" : ""}>
                                                <i class="fas fa-prescription-bottle-alt"></i>
                                            </button>
                                          <button class="btn btn-sm btn-success recycleBankBtn"
        data-id='${row.id}' ${!isUnregister ? "disabled" : ""}><i class="fas fa-recycle"></i></button>

                                        </td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $("#table1").DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    { extend: 'excelHtml5', className: 'btn btn-primary btn-sm',text: '<i class="fas fa-file-excel me-1"></i> ' +btnExcel , exportOptions: { columns: ':not(:last-child)' } },
                                    { extend: 'pdfHtml5',className: 'btn btn-primary btn-sm',text: '<i class="fas fa-file-pdf me-1"></i> ' +btnPdf, exportOptions: { columns: ':not(:last-child)' } }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15
                            });
                        } else {
                            tbody.append(`<tr><td colspan="7" class="text-center" style="padding:40px; color:#6c757d; font-style:italic;">No records found</td></tr>`);
                            $('.dt-buttons').hide();
                        }
                    } else {
                        $("#table1 tbody").html(`<tr><td colspan="7" class="text-center" style="color:red; padding:40px;">Error: ${res.message || 'Failed to load data'}</td></tr>`);
                        $('.dt-buttons').hide();
                    }
                },
                error: function (xhr, status, error) {
                    if ($.fn.DataTable.isDataTable("#table1")) {
                        $("#table1").DataTable().destroy();
                    }
                    $("#table1 tbody").html(`<tr><td colspan="7" class="text-center" style="color:red; padding:40px;">Error loading data: ${error}</td></tr>`);
                    $('.dt-buttons').hide();
                }
            });
        }

        // ===== Filter banks on selection =====
        $("#bankSelect").on("change", function () {
            let selectionMethod = $(this).val();
            loadBanks(selectionMethod);
        });


               // ===== Edit Bank Button Click =====
        $(document).on("click", ".editBankBtn", function () {
            const bank = $(this).data("bank");
            if (!bank) return;
            console.log(bank);
            $("#bankId").val(bank.id);
            $("#bankCode").val(bank.code);
            $("#bankName").val(bank.bankName);
            $("#abbreviationName").val(bank.abbName);
            $("#entId").val(bank.entId);
            $("#routeNo").val(bank.routeNo);
         

            // ✅ Set country select after ensuring options are loaded
            let $country = $("#country");
            if ($country.find(`option[value='${bank.countryId}']`).length) {
                $country.val(bank.countryId);
            } else {
                // Option not found, load the country name dynamically
                $.ajax({
                    url: `@Url.Action("GetCountryById", "Account")?id=${bank.countryId}`,
                    type: 'GET',
                    success: function(country) {
                        if (country) {
                            $country.append(`<option value="${country.id}" selected>${country.name}</option>`);
                            $country.val(country.id);
                        }
                    },
                    error: function() {
                        console.warn("Failed to load country for editing.");
                    }
                });
            }

            $("#bankModalLabel").text("Edit Bank");
            $("#bankModal").modal("show");
        });


        // ===== Submit Bank Form (Create / Update) =====
        $('#bankForm').on('submit', function(e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const idVal = $('#bankId').val();
            const isEdit = idVal && parseInt(idVal) > 0;

            const bankData = {
                Id: isEdit ? parseInt(idVal) : 0,
                BankName: $('#bankName').val().trim(),
                AbbName: $('#abbreviationName').val().trim(),
                EntId: $('#entId').val().trim(),
                RouteNum: $('#routeNo').val().trim(),
                CountryId: $('#country').val() ? parseInt($('#country').val()) : null
            };

            $.ajax({
               url: '@Url.Action("SaveBank", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(bankData),
                success: function(res) {
                    if(res.status) {
                        toastr.success(isEdit ? 'Bank updated successfully' : 'Bank added successfully');
                        $('#bankModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);

                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

                // Soft Delete / Deactivate Bank
        $(document).on("click", ".deleteBankBtn", function () {
               const bankId = $(this).attr("data-id"); 
        if (!bankId) return;

            if (!confirm("Are you sure you want to deactivate this bank?")) return;

            $.ajax({
                url: '@Url.Action("DeactivateBank", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: bankId, // Send just the integer
                success: function(res) {
                    if(res.status) {
                        toastr.success("Bank has been deactivated.");
                        const selectionMethod = $('#bankSelect').val();
                        loadBanks(selectionMethod); // reload table
                    } else {
                        toastr.error(res.message || "Operation failed.");
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Something went wrong");
                }
            });
        });


        // ===== Recycle / Activate Bank =====
        $(document).on("click", ".recycleBankBtn", function () {
            const bankId = $(this).attr("data-id");
            if (!bankId) return;
            if (!confirm("Are you sure you want to reactivate this bank?")) return;

            $.ajax({
                url: '@Url.Action("ReactivateBank", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: bankId,
                success: function(res) {
                    if(res.status) {
                        toastr.success("Bank has been activated.");
                        loadBanks($('#bankSelect').val());
                    } else {
                        toastr.error(res.message || "Operation failed.");
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Something went wrong");
                }
            });
        });

        // ===== Load Countries on Page Ready =====
        $(document).ready(function () {
            $.ajax({
             url: '@Url.Action("GetCountries", "Account")',
                type: 'GET',
                success: function (countries) {
                    let $country = $("#country");
                    $country.empty();
                    $country.append(`<option value="">-- @Localizer["Lbl_Country"] --</option>`);

                    $.each(countries, function (i, country) {
                        $country.append(`<option value="${country.id}">${country.name}</option>`);
                    });
                },
                error: function () {
                    alert("Failed to load countries.");
                }
            });

            loadBanks($("#bankSelect").val());
        });
    </script>


    <button>@Localizer["Btn_Save"]</button>
    <h3>@Localizer["Nav_Customers"]</h3>




}