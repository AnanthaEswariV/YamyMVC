@{
    ViewData["Title"] = "PDC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #435EBE !important;
            color: #fff !important;
        }
</style>

<div class="card">
    <div class="card-header text-center">
        <strong>Post Date Cheque (PDC)</strong>
    </div>

    <div class="card-body">
        <!-- Dropdown -->
        <div class="d-flex justify-content-center mb-4">
            <div style="min-width: 300px;">
                <h6 class="text-center fw-bold">Selection Method</h6>
                <select class="form-select text-center" id="transactionSelect">
                    <option>Payable</option>
                    <option>Receivable</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table1">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>TRS Date</th>
                    <th>Cheque Date</th>
                    <th>TRF REF</th>
                    <th>Cheque No</th>
                    <th>Cheque Name</th>
                    <th>Bank Name</th>
                    <th>Amount</th>
                    <th>State</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Bootstrap Modal -->
<div class="modal fade" id="pdcModal" tabindex="-1" aria-labelledby="pdcModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="pdcModalLabel">Cheque Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="checkForm">
                    <input type="hidden" id="actionType" />
                    <input type="hidden" id="rowId" />

                    <div class="mb-3">
                        <label for="chequeDate" class="form-label">Cheque Date</label>
                        <input type="date" id="chequeDate" class="form-control" readonly>
                    </div>

                    <div class="mb-3">
                        <label for="actionDate" class="form-label" id="actionDateLabel">Action Date</label>
                        <input type="date" id="actionDate" class="form-control">
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="saveBtn">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function () {

            // Load table based on selection
               function loadChecks(type) {
            $.ajax({
                url: `@Url.Action("GetChecks", "Account")?type=${type}`,
                type: "GET",
                success: function (res) {
                    // Check if DataTable already exists and destroy it before re-rendering
                    if ($.fn.DataTable.isDataTable("#table1")) {
                        $("#table1").DataTable().destroy();
                    }

                    let tbody = $("#table1 tbody").empty(); // Clear the table body

                    console.log(res); // Log the response for debugging purposes

                    // Check if response contains data
                    if (res.status && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            // Prepare action buttons and check whether the cheque is payable
                            let actionButtons = `
                                <button class="btn btn-sm btn-success passBtn" data-id="${row.id}" data-date="${row.checkDate}" title="Pass"><i class="fas fa-check"></i></button>
                                <button class="btn btn-sm btn-warning returnBtn" data-id="${row.id}" data-date="${row.checkDate}" title="Return"><i class="fas fa-undo"></i></button>
                                <button class="btn btn-sm btn-info holdBtn" data-id="${row.id}" data-date="${row.checkDate}" title="Hold"><i class="fas fa-pause"></i></button>
                                <button class="btn btn-sm btn-danger cancelBtn" data-id="${row.id}" data-date="${row.checkDate}" title="Cancel"><i class="fas fa-times"></i></button>
                            `;

                            // Disable actions for non-payable checks
                            if (!row.isPayable) {
                                actionButtons = `
                                    <button class="btn btn-sm btn-secondary" disabled><i class="fas fa-ban"></i> Not Payable</button>
                                `;
                            }

                            // Append row to the table body
                            tbody.append(`
                                <tr>
                                    <td>${row.sn}</td>
                                    <td>${row.trsDate ? new Date(row.trsDate).toLocaleDateString() : ''}</td>
                                    <td>${row.checkDate ? new Date(row.checkDate).toLocaleDateString() : ''}</td>
                                    <td>${row.trsRef ?? ''}</td>
                                    <td>${row.checkNo ?? ''}</td>
                                    <td>${row.checkName ?? ''}</td>
                                    <td>${row.bankName ?? ''}</td>
                                    <td>${row.amount?.toFixed(3) ?? ''}</td>
                                    <td>${row.state ?? ''}</td>
                                    <td>${actionButtons}</td>
                                </tr>
                            `);
                        });

                        // Initialize DataTable after appending rows
                        $("#table1").DataTable({
                            dom: 'Bfrtip',
                            buttons: [
                                { extend: 'excelHtml5', className: 'btn btn-primary btn-sm', exportOptions: { columns: ':not(:last-child)' } },
                                { extend: 'print', text: '<i class="fas fa-print me-1"></i> Print', className: 'btn btn-primary btn-sm', exportOptions: { columns: ':not(:last-child)' } }
                            ],
                            order: [[0, 'asc']],
                            pageLength: 25
                        });
                    } else {
                        // If no data, show a message
                        tbody.append(`<tr><td colspan="10" class="text-center">No records found</td></tr>`);
                    }
                },
                error: function () {
                    toastr.error("Error loading data"); // Show error message if AJAX fails
                }
            });
        }
            // Initial load
            loadChecks($("#transactionSelect").val());

            $("#transactionSelect").on("change", function () {
                loadChecks($(this).val());
            });

                    // helper: produce a YYYY-MM-DD string safe for <input type="date">
        function formatForInputDate(d) {
            if (!d) return "";
            // If already "YYYY-MM-DD"
            if (/^\d{4}-\d{2}-\d{2}$/.test(d)) return d;

            // common ISO-like: "YYYY-MM-DDTHH:mm:ss" or "...T...Z"
            if (typeof d === "string" && d.indexOf("T") !== -1) {
                return d.split("T")[0];
            }

            // Microsoft JSON format: "/Date(169xx...)/"
            const msMatch = /\/Date\((\d+)(?:[+-]\d+)?\)\//.exec(d);
            if (msMatch) {
                const dt = new Date(parseInt(msMatch[1], 10));
                return dt.toISOString().split("T")[0];
            }

            // fallback: try to parse and use ISO date (may shift by timezone)
            const dt = new Date(d);
            if (!isNaN(dt.getTime())) return dt.toISOString().split("T")[0];

            return "";
        }

            // Open modal for actions
            $(document).on('click', '.passBtn, .returnBtn, .holdBtn, .cancelBtn', function () {
                let id = $(this).data("id");
                let chequeDate = $(this).data("date");
                let action = "";
                if ($(this).hasClass("passBtn")) action = "Pass";
                else if ($(this).hasClass("returnBtn")) action = "Return";
                else if ($(this).hasClass("holdBtn")) action = "Hold";
                else if ($(this).hasClass("cancelBtn")) action = "Cancel";

                $("#rowId").val(id);
                $("#actionType").val(action);
                $("#actionDateLabel").text(action + " Date");

                 $("#chequeDate").val(formatForInputDate(chequeDate));
                $("#actionDate").val("");

                new bootstrap.Modal(document.getElementById('pdcModal')).show();
            });

            // Save button click
            $("#saveBtn").on("click", function () {
            // Get values from the form
            let chequeDate = $("#chequeDate").val();
            let actionDate = $("#actionDate").val();
            let actionType = $("#actionType").val();
            let isPayable = $("#isPayable").val();  // Assuming this is correctly set as a boolean

            // Convert to boolean if necessary
            isPayable = (isPayable === "true") || isPayable === true; // Ensure `isPayable` is treated as a boolean value

            // ✅ Validation: Check if action date is selected
            if (!actionDate) {
                toastr.error("Please select " + actionType + " date.");
                return;
            }

            // ✅ Validation: Ensure action date is not before cheque date
            let chequeDateObj = new Date(chequeDate);
            let actionDateObj = new Date(actionDate);

            if (actionDateObj < chequeDateObj) {
                toastr.error(actionType + " date cannot be before Cheque Date.");
                return;
            }


            // ✅ Prepare the payload for the AJAX request
            let payload = {
                CheckDetailId: $("#rowId").val(),  // Assuming this value is set correctly
                Action: actionType,
                SelectedDate: actionDate
            };

            // ✅ AJAX request to save the data
            $.ajax({
                url: '@Url.Action("UpdateChequeState", "Account")',  // Controller action URL
                type: "POST",
                contentType: "application/json",  // Sending JSON data
                data: JSON.stringify(payload),  // Send the payload as JSON string
                success: function (response) {
                    toastr.success("Saved successfully.");
                    $("#pdcModal").modal("hide");  // Close the modal
                    loadChecks($("#transactionSelect").val()); // Refresh the grid with updated data
                },
                error: function (xhr, status, error) {
                    // Handle server error gracefully
                    let errorMessage = xhr.responseJSON?.message || "An error occurred while saving the data.";
                    toastr.error(errorMessage);
                }
            });
        });


        });
    </script>
}
