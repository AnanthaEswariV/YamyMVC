@{
    ViewData["Title"] = "PaymentVoucher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

    .dt-buttons .btn-primary:hover {
        background-color: #3b51a0 !important;
        color: #fff !important;
    }

     /* Highlight selected row */
    #table1 tbody tr.selected {
        background-color: #c7e5b4;
    }

    .modal-dialog-scrollable .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
     <div class="card-header position-relative text-center">
        <strong>Payment Voucher Center</strong>

        <button class="btn btn-primary btn-sm position-absolute end-0 top-50 translate-middle-y me-3"
                id="btnAddStock" data-bs-toggle="modal"
                data-bs-target="#paymentVoucherModal">
            <i class="fas fa-plus me-1"></i> New PV
        </button>
        <input type="file" id="excelFile" class="form-control" />
        <button type="button" id="btnImport" class="btn btn-primary">
            Import Payment Voucher
        </button>
    </div>
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Reported By -->
            <div style="min-width: 250px;">
                <select class="form-select" id="type">
                    <option value="">-- Select Type --</option>
                    <option value="Vendor" selected>Vendor</option>
                    <option value="Employee">Employee</option>
                    <option value="Petty Cash">Petty Cash</option>
                    <option value="General">General Voucher</option>
                </select>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>
            <div style="min-width: 200px;">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="enableDateFilter">
        <label class="form-check-label fw-bold">
            Enable Date Filter
        </label>
    </div>
</div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Payment Code</th>
                    <th>JV No</th>
                    <th>Amount</th>
                    <th>Debit Account</th>
                    <th>Credit Account</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="paymentVoucherModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Payment Voucher</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="paymentVoucherForm" novalidate>
            <!-- Modal Body -->
            <div class="modal-body">
                <input type="hidden" id="voucherId">
                <!-- Header Info -->
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" id="date">
                    </div>

                    <div class="col-md-3">
                      <label class="form-label">Payment Type</label>
                      <div class="d-flex align-items-center gap-2">
                                <select class="form-select" id="paymentTypeSelect">
                                    <option value="">-- Select --</option>
                                    <option value="Vendor">Vendor</option>
                                    <option value="Employee">Employee</option>
                                    <option value="Petty Cash">Petty Cash</option>
                                </select>

                     <div class="form-check mt-4">
                         <input class="form-check-input" type="checkbox" id="subContractor">
                         <label class="form-check-label" for="subContractor">
                             Subcontractors
                         </label>
                        </div>
                      </div>
                    </div>

                    <div class="col-md-3">
    <label class="form-label">Payment Method</label>
    <select class="form-select" id="paymentMethodSelect">
        <option>Cheque</option>
        <option>Cash</option>
        <option>Transfer</option>
    </select>
</div>

                </div>

                <!-- Pay To - Debit -->
                <div class="border rounded p-3 mb-3">
                    <h6 class="fw-bold mb-3">Pay To - Debit</h6>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Account Code</label>
                            <input class="form-control" id="accountCodeInput" disabled>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Account Name</label>
                            <select class="form-select" id="accountNameSelect">
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cost Center</label>
                            <select class="form-select costCenterSelect">
                            </select>
                        </div>

                    @*     <div class="col-md-3">
                            <label class="form-label">Vendor Code</label>
                            <input class="form-control" id="vendorCodeInput">
                        </div> *@

                        <div class="col-md-6">
                            <label class="form-label">Vendor Name</label>
                            <select class="form-select" id="vendorNameSelect">
                            </select>
                        </div>

                      <div class="col-md-3" id="amountInputDiv" style="display: none;">
                          <label class="form-label">Amount</label>
                          <input type="text" class="form-control" id="amountInput">
                      </div>

                    <div class="col-md-6" id="employeeNoteDiv" style="display:none;">
    <label class="form-label">Select Employees</label>

    <div id="employeeList"
         class="border rounded p-2"
         style="max-height:200px; overflow-y:auto;">
    </div>
</div>


                    </div>
                </div>

                <!-- Pay From - Credit -->
                <div class="border rounded p-3 mb-3">
                    <h6 class="fw-bold mb-3">Pay From - Credit</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Account Code</label>
                            <input class="form-control" id="creditAccountCodeInput" disabled>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Account Name</label>
                            <select class="form-select" id="creditAccountNameSelect">
                            </select>
                        </div>

                        <div class="col-md-4">
                             <label class="form-label">Cost Center</label>
    <select class="form-select creditCostCenterSelect">
    </select>
                        </div>

                    </div>
                </div>

                  <div class="border rounded p-3 mb-3">
                <div class="row g-3" id="chequeFields">
                
                    <div class="col-md-3">
        <label class="form-label">Bank Name</label>
        <select class="form-select" id="bankNameSelect"></select>
    </div>
                
  


    <div class="col-md-3">
    <label class="form-label">Cheque Book Name</label>
    <input type="text" class="form-control" id="chequeBookSelect" placeholder="Cheque Book Name">
</div>

<div class="col-md-3">
    <label class="form-label">Cheque No</label>
    <select class="form-select" id="chequeNoSelect">
        <option value="">-- Select Cheque No --</option>
    </select>
</div>

                    <div class="col-md-3">
        <label class="form-label">Cheque Date</label>
        <input type="date" class="form-control" id="chequeDate">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Bank Account Name</label>
        <select class="form-select" id="bankAccountSelect"></select>
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Book No</label>
        <select class="form-select" id="bookNoSelect"></select>
    </div>
                
                </div>
                </div>

                  <div class="border rounded p-3 mb-3">
                <div class="row g-3 d-none" id="transferFields">
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Date</label>
        <input type="date" class="form-control" id="transferDate">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Name</label>
        <input class="form-control" id="transferName">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Ref</label>
        <input class="form-control" id="transferRef">
    </div>
                
                </div>
                </div>


                <!-- Invoice Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Date</th>
                                <th>Inv No/EMP Name</th>
                                <th>Amount</th>
                                <th>Pay</th>
                                <th>Payment</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- Modal Footer -->
           <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
      <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
        $(document).ready(function () {


                    $('#btnImport').click(function () {

            var fileInput = $('#excelFile')[0];

            if (fileInput.files.length === 0) {
                toastr.warning('Please select a file');
                return;
            }

            var formData = new FormData();
            formData.append('file', fileInput.files[0]);

            $.ajax({
                  url: '@Url.Action("ImportPurchaseInvoices2", "Migration")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,

                beforeSend: function () {
                    $('#btnImport')
                        .prop('disabled', true)
                        .text('Importing...');
                },

                       success: function (res) {
            const r = res.result || {};
            console.log(r);
            if ((r.skipped || 0) > 0 || (r.failed || 0) > 0) {
                toastr.warning(`Imported ${r.success}. Skipped ${r.skipped}, failed ${r.failed}. See console.`);
                (r.errors || []).forEach(e => console.warn(e)); 
            } else {
                toastr.success(`All ${r.success} invoices imported.`);
            }
        },

                error: function (xhr) {

                    toastr.error(
                        xhr.responseJSON?.message ||
                        'Import failed'
                    );
                },

                complete: function () {

                    $('#btnImport')
                        .prop('disabled', false)
                        .text('Import Payment Voucher');
                }
            });

        });
            // ============================================================
            // HELPER
            // ============================================================
            function formatDate(dateStr) {
                if (!dateStr) return '';
                return String(dateStr).split('T')[0].split(' ')[0];
            }

            function getTodayDate() {
                const today = new Date();
                return `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
            }

            // ============================================================
            // PAGE LOAD
            // ============================================================
            loadPaymentVoucher();
            loadAccountsForPageLoad();
            loadBanks();
            loadChequeBooks();
            populateAndSelectCostCenter();

            // ============================================================
            // DATE FILTER
            // ============================================================
            $('#enableDateFilter').change(function () {
                const enabled = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', !enabled);
                if (!enabled) { $('#startDate, #endDate').val(''); loadPaymentVoucher(); }
            });
            $('#filterBtn').click(loadPaymentVoucher);
            $('#type').change(loadPaymentVoucher);

            function loadPaymentVoucher() {
                const type          = $('#type').val();
                const useDateFilter = $('#enableDateFilter').is(':checked');
                const startDate     = $('#startDate').val();
                const endDate       = $('#endDate').val();

                if (useDateFilter && (!startDate || !endDate)) {
                    toastr.warning('Please select both Start and End dates.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetPaymentVoucherReport", "Account")',
                    type: 'GET',
                    data: { type, startDate: useDateFilter ? startDate : null, endDate: useDateFilter ? endDate : null, includeAllDates: !useDateFilter },
                    beforeSend: function () {
                        $('#table2 tbody').html(`<tr><td colspan="8" class="text-center text-muted py-4"><div class="spinner-border text-primary me-2"></div>Loading...</td></tr>`);
                    },
                    success: function (res) {
                        if (!res.status) { toastr.error(res.message || 'Failed to load data'); return; }
                        if ($.fn.DataTable.isDataTable('#table2')) $('#table2').DataTable().clear().destroy();
                        const tbody = $('#table2 tbody');
                        tbody.empty();
                        if (res.data && res.data.length > 0) {
                            $.each(res.data, function (i, row) {
                                tbody.append(`
                                    <tr data-id="${row.id}">
                                        <td>${i+1}</td>
                                        <td>${row.Date ?? ''}</td>
                                        <td>${row["Payment Code"] ?? ''}</td>
                                        <td>${row["JV NO"] ?? ''}</td>
                                        <td class="text-end">${(row.Amount ?? 0).toLocaleString()}</td>
                                        <td>${row["Debit Account"] ?? ''}</td>
                                        <td>${row["Credit Account"] ?? ''}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary editPaymentVoucherBtn" data-customer='${JSON.stringify(row)}'><i class="fas fa-pen"></i></button>
                                            <button class="btn btn-sm btn-danger deleteCustomerBtn" data-id='${row.id}'><i class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>`);
                            });
                            $('#table2').DataTable({ dom: 'Bfrtip', buttons: [{ extend:'excelHtml5', className:'btn btn-primary btn-sm' }, { extend:'print', text:'<i class="fas fa-print me-1"></i> Print', className:'btn btn-primary btn-sm' }], pageLength: 15 });
                        } else {
                            tbody.append(`<tr><td colspan="8" class="text-center">No records found</td></tr>`);
                        }
                    },
                    error: function () { toastr.error('Server error while loading data'); }
                });
            }

            // ============================================================
            // MODAL OPEN — set today's dates
            // ============================================================
            document.getElementById('paymentVoucherModal').addEventListener('shown.bs.modal', function () {
                const today = getTodayDate();
                ['date','chequeDate','transferDate'].forEach(id => {
                    const f = document.getElementById(id);
                    if (f && !f.value) f.value = today;
                });
            });

            // ============================================================
            // PAYMENT TYPE CHANGE — calls GetPaymentTypeDetails (primary)
            // ============================================================
            $('#paymentTypeSelect').on('change', function () {
                const paymentType    = $(this).val();
                const isSubContractor = $('#subContractor').is(':checked');

                // Reset UI
                $('#amountInputDiv, #employeeNoteDiv').hide();
                $('#vendorNameSelect').closest('.col-md-6').hide();
                $('#accountNameSelect').empty().append('<option value="">-- Select --</option>');
                $('#accountCodeInput').val('');
                $('#vendorNameSelect').empty().append('<option value="">-- Select --</option>');
                $('#paymentVoucherModal table tbody').empty();
                $('#employeeList').empty();

                if (!paymentType) return;

                $.ajax({
                    url: '@Url.Action("GetPaymentTypeDetails", "Account")',
                    type: 'GET',
                    data: { paymentType, subContractor: isSubContractor },
                    success: function (res) {
                        if (!res.status) { toastr.error(res.message || 'Failed to fetch details'); return; }
                        const data = res.data;

                        // Load debit account
                        $.ajax({
                            url: '@Url.Action("GetAccruedSalaries", "HR")',
                            type: 'GET',
                            success: function (accounts) {
                                const $sel = $('#accountNameSelect');
                                $sel.empty().append('<option value="">-- Select --</option>');
                                accounts.forEach(item => $sel.append(`<option value="${item.id}" data-code="${item.code}">${item.code} - ${item.name}</option>`));
                                if (data.DebitAccountId) {
                                    $sel.val(data.DebitAccountId);
                                    $('#accountCodeInput').val(data.DebitAccountCode || '');
                                }
                                $sel.off('change').on('change', function () {
                                    $('#accountCodeInput').val($(this).find(':selected').data('code') || '');
                                });
                            }
                        });

                        if (paymentType === 'Vendor') {
                            $('#vendorNameSelect').closest('.col-md-6').show();
                            if (data.Vendors && data.Vendors.length > 0) {
                                const $v = $('#vendorNameSelect').empty().append('<option value="">-- Select Vendor --</option>');
                                data.Vendors.forEach(v => $v.append(`<option value="${v.Id || v.id}">${v.Name || v.name}</option>`));
                            }
                        }
                        else if (paymentType === 'Employee') {
                            $('#employeeNoteDiv').show();
                            if (data.Employees && data.Employees.length > 0) {
                                const $list = $('#employeeList').empty();
                                data.Employees.forEach(emp => {
                                    // ← KEY FIX: use data-records (not data-requests) for Employee
                                    $list.append(`
                                        <div class="form-check">
                                            <input class="form-check-input employee-checkbox"
                                                   type="checkbox"
                                                   data-employee-id="${emp.id}"
                                                   data-records='${JSON.stringify(emp.records || [])}'
                                                   id="emp_${emp.id}">
                                            <label class="form-check-label" for="emp_${emp.id}">
                                                ${emp.code} - ${emp.name}
                                            </label>
                                        </div>`);
                                });
                            }
                        }
                        else if (paymentType === 'Petty Cash') {
                            $('#employeeNoteDiv').show();
                            if (data.Employees && data.Employees.length > 0) {
                                const $list = $('#employeeList').empty();
                                data.Employees.forEach(emp => {
                                    // ← KEY FIX: use data-requests for Petty Cash
                                    $list.append(`
                                        <div class="form-check">
                                            <input class="form-check-input employee-checkbox"
                                                   type="checkbox"
                                                   data-employee-id="${emp.id}"
                                                   data-requests='${JSON.stringify(emp.requests || [])}'
                                                   id="emp_${emp.id}">
                                            <label class="form-check-label" for="emp_${emp.id}">
                                                ${emp.code} - ${emp.name}
                                            </label>
                                        </div>`);
                                });
                            }
                        }
                    },
                    error: function (xhr) { toastr.error('Error loading payment type details'); console.log(xhr.responseText); }
                });
            });

            // ============================================================
            // PAYMENT TYPE CHANGE — second handler calls GetPaymentTypeDetailss
            // ============================================================
            $('#paymentTypeSelect').on('change', function () {
                const paymentType     = $(this).val();
                const isSubContractor = $('#subContractor').is(':checked');
                if (!paymentType) return;

                $.ajax({
                    url: '@Url.Action("GetPaymentTypeDetailss", "Account")',
                    type: 'GET',
                    data: { paymentType, subContractor: isSubContractor },
                    success: function (res) {
                        if (!res.status) return;
                        const data = res.data;

                        // Set debit account
                        $.ajax({
                            url: '@Url.Action("GetAccruedSalaries", "HR")',
                            type: 'GET',
                            success: function (accounts) {
                                const $sel = $('#accountNameSelect');
                                $sel.empty().append('<option value="">-- Select --</option>');
                                accounts.forEach(item => $sel.append(`<option value="${item.id}" data-code="${item.code}">${item.code} - ${item.name}</option>`));
                                if (data.DebitAccountId) {
                                    $sel.val(data.DebitAccountId);
                                    $('#accountCodeInput').val(data.DebitAccountCode || '');
                                }
                                $sel.off('change').on('change', function () {
                                    $('#accountCodeInput').val($(this).find(':selected').data('code') || '');
                                });
                            }
                        });

                        if (paymentType === 'Vendor') {
                            $('#vendorNameSelect').closest('.col-md-6').show();
                            if (data.Vendors && data.Vendors.length > 0) {
                                const $v = $('#vendorNameSelect').empty().append('<option value="">-- Select Vendor --</option>');
                                data.Vendors.forEach(v => $v.append(`<option value="${v.id}" data-code="${v.code}">${v.code} - ${v.name}</option>`));
                            }
                        }
                        else if (paymentType === 'Employee') {
                            $('#employeeNoteDiv').show();
                            if (data.Employees && data.Employees.length > 0) {
                                const $list = $('#employeeList').empty();
                                data.Employees.forEach(emp => {
                                    $list.append(`
                                        <div class="form-check">
                                            <input class="form-check-input employee-checkbox"
                                                   type="checkbox"
                                                   data-employee-id="${emp.id}"
                                                   data-records='${JSON.stringify(emp.records || [])}'
                                                   id="emp_${emp.id}">
                                            <label class="form-check-label" for="emp_${emp.id}">
                                                ${emp.code} - ${emp.name}
                                            </label>
                                        </div>`);
                                });
                            }
                        }
                        else if (paymentType === 'Petty Cash') {
                            $('#employeeNoteDiv').show();
                            if (data.Employees && data.Employees.length > 0) {
                                const $list = $('#employeeList').empty();
                                data.Employees.forEach(emp => {
                                    $list.append(`
                                        <div class="form-check">
                                            <input class="form-check-input employee-checkbox"
                                                   type="checkbox"
                                                   data-employee-id="${emp.id}"
                                                   data-requests='${JSON.stringify(emp.requests || [])}'
                                                   id="emp_${emp.id}">
                                            <label class="form-check-label" for="emp_${emp.id}">
                                                ${emp.code} - ${emp.name}
                                            </label>
                                        </div>`);
                                });
                            }
                        }
                    },
                    error: function (xhr) { console.error('API Error:', xhr.responseJSON); }
                });
            });

            // ============================================================
            // SUBCONTRACTOR CHECKBOX
            // ============================================================
            $('#subContractor').on('change', function () {
                if ($('#paymentTypeSelect').val() === 'Vendor') $('#paymentTypeSelect').trigger('change');
            });

            // ============================================================
            // EMPLOYEE CHECKBOX HANDLER
            // ============================================================
            $(document).on('change', '.employee-checkbox', function () {
                const paymentType = $('#paymentTypeSelect').val();
                const empId       = $(this).data('employee-id');
                const empName     = $(this).closest('.form-check').find('label').text().trim();
                const tbody       = $('#paymentVoucherModal table tbody');
                const isChecked   = $(this).is(':checked');

                if (paymentType === 'Petty Cash') {
                    const requests = $(this).data('requests') || [];
                    if (isChecked) {
                        if (!requests.length) {
                            toastr.warning(`No approved petty cash requests for ${empName}`);
                            $(this).prop('checked', false);
                            return;
                        }
                        requests.forEach(req => {
                            if (req.amount > 0) {
                                const displayDate = formatDate(req.date);
                                tbody.append(`
                                    <tr data-inv-id="${req.id}" data-inv-date="${displayDate}" data-emp-id="${empId}" data-voucher-type="Petty Cash Request">
                                        <td>${tbody.find('tr').length + 1}</td>
                                        <td>${displayDate}</td>
                                        <td data-id="${req.id}">${req.id}</td>
                                        <td class="text-end">${(req.amount||0).toLocaleString()}</td>
                                        <td><input type="number" class="form-control form-control-sm pay-input"  step="0.01"></td>
                                        <td><input type="text" class="form-control form-control-sm payment-input" ></td>
                                        <td><input type="text" class="form-control form-control-sm description-input" placeholder="Description"></td>
                                    </tr>`);
                            }
                        });
                    } else {
                        tbody.find(`tr[data-emp-id="${empId}"]`).remove();
                        tbody.find('tr').each(function (i) { $(this).find('td').first().text(i+1); });
                    }
                }
                else if (paymentType === 'Employee') {
                    // ← KEY FIX: read data-records
                    const records = $(this).data('records') || [];
                    if (isChecked) {
                        if (!records.length) {
                            toastr.warning(`No salary records found for ${empName}`);
                            $(this).prop('checked', false);
                            return;
                        }
                        records.forEach(record => {
                            if (record.amount > 0) {
                                const displayDate = formatDate(record.date);
                                tbody.append(`
                                    <tr data-inv-id="${record.id}" data-inv-date="${displayDate}" data-emp-id="${empId}" data-voucher-type="Salary">
                                        <td>${tbody.find('tr').length + 1}</td>
                                        <td>${displayDate}</td>
                                        <td data-id="${record.id}">${record.id}</td>
                                        <td class="text-end">${(record.amount||0).toLocaleString()}</td>
                                        <td><input type="number" class="form-control form-control-sm pay-input" step="0.01"></td>
                                        <td><input type="text" class="form-control form-control-sm payment-input" ></td>
                                        <td><input type="text" class="form-control form-control-sm description-input" placeholder="Description"></td>
                                    </tr>`);
                            }
                        });
                    } else {
                        tbody.find(`tr[data-emp-id="${empId}"]`).remove();
                        tbody.find('tr').each(function (i) { $(this).find('td').first().text(i+1); });
                    }
                }
            });

            // ============================================================
            // PAY INPUT SYNC TO PAYMENT INPUT
            // ============================================================
            $(document).on('focus', '.pay-input', function () { $(this).data('previous-value', $(this).val()); });
            $(document).on('blur', '.pay-input', function () {
                const $this         = $(this);
                const newValue      = $this.val();
                const previousValue = $this.data('previous-value');
                const $payInput     = $this.closest('tr').find('.payment-input');
                const paymentValue  = $payInput.val().trim();
                if (!paymentValue || paymentValue === '0' || parseFloat(paymentValue) === 0 || paymentValue === previousValue)
                    $payInput.val(newValue);
            });

            // ============================================================
            // PAYMENT METHOD CHANGE
            // ============================================================
            $('#paymentMethodSelect').on('change', function () {
                const method = $(this).val();
                $('#chequeFields').addClass('d-none');
                $('#transferFields').addClass('d-none');
                if (method === 'Cheque')    $('#chequeFields').removeClass('d-none');
                if (method === 'Transfer')  $('#transferFields').removeClass('d-none');

                if (!method) return;
                $.ajax({
                    url: '@Url.Action("GetPaymentMethodDetails", "Account")',
                    type: 'GET',
                    data: { paymentMethod: method, paymentType: $('#paymentTypeSelect').val() },
                    success: function (res) {
                        if (!res.status) { alert(res.message || 'Failed to fetch data'); return; }
                        loadAccounts('#creditAccountNameSelect', '#creditAccountCodeInput', res.data.CreditAccountId, res.data.CreditAccountCode);
                    },
                    error: function () { alert('Error loading payment method details'); }
                });
            });

            // ============================================================
            // VENDOR INVOICES
            // ============================================================
            async function loadVendorInvoices() {
                if ($("#paymentVoucherModal").data("editing")) return;
                const paymentType   = $('#paymentTypeSelect').val();
                const isSubcontractor = $('#subContractor').is(':checked');
                const vendorId      = $('#vendorNameSelect').val();
                if (!vendorId || paymentType !== 'Vendor') { $('#paymentVoucherModal table tbody').empty(); return; }

                const url = '@Url.Action("GetVendorsWithInvoices", "Account")' + `?paymentType=${paymentType}&isSubcontractor=${isSubcontractor}&vendorId=${vendorId}`;
                try {
                    const res  = await fetch(url);
                    const data = await res.json();
                    if (!data.status) { toastr.error('Failed to load invoices'); return; }
                    const tbody = $('#paymentVoucherModal table tbody');
                    tbody.empty();
                    if (!data.data || data.data.length === 0) { tbody.append(`<tr><td colspan="7" class="text-center text-muted">No invoices found</td></tr>`); return; }
                    let rowIndex = 1;
                    data.data.forEach(vendor => {
                        (vendor.invoices || []).forEach(inv => {
                            tbody.append(`
                                <tr data-inv-date="${inv.date}" data-inv-id="${inv.id}">
                                    <td>${rowIndex++}</td><td>${inv.date||''}</td>
                                    <td data-id="${inv.id}">${inv.id||''}</td>
                                    <td class="text-end">${(inv.amount||0).toLocaleString()}</td>
                                    <td><input type="number" class="form-control form-control-sm pay-input" value="0" step="0.01"></td>
                                    <td><input type="text" class="form-control form-control-sm payment-input" value="0"></td>
                                    <td><input type="text" class="form-control form-control-sm description-input" placeholder="Description"></td>
                                </tr>`);
                        });
                    });
                } catch (err) { console.error(err); toastr.error('Error loading invoices'); }
            }
            $('#paymentTypeSelect, #subContractor, #vendorNameSelect').on('change', loadVendorInvoices);

            // ============================================================
            // VENDOR NAME → CHEQUE BOOK NAME
            // ============================================================
            $('#vendorNameSelect').on('change', function () {
                $('#chequeBookSelect').val($(this).find('option:selected').text().trim());
            });

            // ============================================================
            // ACCOUNTS HELPER
            // ============================================================
            function loadAccounts(selectId, codeInputId, defaultAccountId, defaultAccountCode) {
                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function (accounts) {
                        const $ddl     = $(selectId);
                        const $codeBox = $(codeInputId);
                        $ddl.empty().append('<option value="">-- Select --</option>');
                        accounts.forEach(item => {
                            $ddl.append($('<option>', { value: item.id, text: item.code+' - '+item.name, 'data-code': item.code, selected: item.id === defaultAccountId }));
                        });
                        $codeBox.val(defaultAccountCode || '');
                        $ddl.off('change').on('change', function () { $codeBox.val($(this).find(':selected').data('code')||''); });
                    }
                });
            }

            function loadAccountsForPageLoad() {
                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function (accounts) {
                        ['#accountNameSelect','#creditAccountNameSelect'].forEach((selId, idx) => {
                            const codeId = idx === 0 ? '#accountCodeInput' : '#creditAccountCodeInput';
                            const $sel   = $(selId);
                            const cur    = parseInt($sel.val()) || 0;
                            $sel.empty().append('<option value="">-- Select --</option>');
                            accounts.forEach(item => $sel.append($('<option>', { value: item.id, text: item.code+' - '+item.name, 'data-code': item.code, selected: item.id === cur })));
                            $(codeId).val($sel.find('option:selected').data('code')||'');
                            $sel.off('change').on('change', function () { $(codeId).val($(this).find(':selected').data('code')||''); });
                        });
                    }
                });
            }

            // ============================================================
            // BANK & CHEQUE BOOKS
            // ============================================================
            function loadBanks() {
                $.ajax({
                    url: '@Url.Action("GetBankss", "Account")',
                    type: 'GET',
                    success: function (res) {
                        const $sel = $('#bankNameSelect').empty().append('<option value="">-- Select Bank --</option>');
                        if (res?.status && res.data) res.data.forEach(bank => $sel.append(`<option value="${bank.id}">${bank.bankName}</option>`));
                    }
                });
            }

            let chequeBooksData = [];
            function loadChequeBooks() {
                $.ajax({
                    url: '@Url.Action("GetChequeBooks", "Account")',
                    type: 'GET',
                    success: function (res) { chequeBooksData = res.data || []; }
                });
            }

            $('#bankNameSelect').on('change', function () {
                const selectedBankId = parseInt($(this).val());
                const $cno = $('#chequeNoSelect'), $bno = $('#bookNoSelect'), $bac = $('#bankAccountSelect');
                $cno.empty().append('<option value="">-- Select Cheque No --</option>').prop('disabled', true);
                $bno.empty().append('<option value="">-- Select Book No --</option>').prop('disabled', true);
                $bac.empty().append('<option value="">-- Select Bank Account --</option>').prop('disabled', true);
                if (!selectedBankId) return;
                const books = chequeBooksData.filter(cb => cb.bank_card_id === selectedBankId);
                if (!books.length) return;
                const book = books[0];
                for (let i = parseInt(book.startFrom); i <= parseInt(book.endIn); i++) $cno.append(`<option value="${i}">${i}</option>`);
                $bno.append(`<option value="${book.chqBookNo}">${book.chqBookNo}</option>`);
                $bac.append(`<option value="${book.bank_card_id}">${book.acName}</option>`);
                $cno.prop('disabled', false); $bno.prop('disabled', false); $bac.prop('disabled', false);
            });

            // ============================================================
            // COST CENTER
            // ============================================================
            function populateAndSelectCostCenter() {
                $.ajax({
                    url: '@Url.Action("GetCostCenters", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        const data = Array.isArray(res) ? res : (res.data || []);
                        if (!data.length) return;
                        function fill($sel) {
                            const sid = String($sel.data("selected-id") || "");
                            $sel.empty().append('<option value="">-- Select --</option>');
                            data.forEach(item => $sel.append(`<option value="${item.id}">${item.code} - ${item.name}</option>`));
                            if (sid) $sel.val(sid);
                        }
                        $(".costCenterSelect").each(function () { fill($(this)); });
                        $(".creditCostCenterSelect").each(function () { fill($(this)); });
                    }
                });
            }

            // ============================================================
            // NEW PV BUTTON
            // ============================================================
            $('#btnAddStock').on('click', function () {
                $("#paymentVoucherModal").removeData("editing");
                $("#paymentVoucherModal form")[0].reset();
                $("#voucherId").val(0);
                $("#paymentVoucherModal table tbody").empty();
                $("#paymentVoucherModal .modal-title").text("New Payment Voucher");
                $("#accountNameSelect, #creditAccountNameSelect, .costCenterSelect, .creditCostCenterSelect, #vendorNameSelect").empty().append('<option value="">-- Select --</option>');
                $('#amountInputDiv, #employeeNoteDiv').hide();
                $('#vendorNameSelect').closest('.col-md-6').hide();
                $('#chequeFields').removeClass('d-none');
                $('#transferFields').addClass('d-none');
                loadAccountsForPageLoad();
                populateAndSelectCostCenter();
                const today = getTodayDate();
                $("#date").val(today); $("#chequeDate").val(today); $("#transferDate").val(today);
            });

            $('#paymentVoucherModal').on('hidden.bs.modal', function () {
                $(this).removeData("editing");
                $(".costCenterSelect, .creditCostCenterSelect").removeData("selected-id").empty();
            });

            // ============================================================
            // EDIT BUTTON
            // ============================================================
            $(document).on("click", ".editPaymentVoucherBtn", function () {
                const voucher = $(this).data("customer");
                if (!voucher) return;
                const modal = $("#paymentVoucherModal");
                modal.find("form")[0].reset();
                modal.find("select").val("");
                modal.find("tbody").empty();
                modal.data("editing", true);

                $("#voucherId").val(voucher.id || 0);
                $("#date").val(formatDate(voucher.Date));
                $("#paymentTypeSelect").val(voucher.Type || "");
                $("#subContractor").prop('checked', voucher.IsSubContractor || false);
                $("#paymentMethodSelect").val(voucher.Method || "");

                $('#amountInputDiv, #employeeNoteDiv').hide();
                $('#vendorNameSelect').closest('.col-md-6').hide();
                if (voucher.Type === 'Vendor')       $('#vendorNameSelect').closest('.col-md-6').show();
                else if (voucher.Type === 'Employee') $('#employeeNoteDiv').show();
                else if (voucher.Type === 'Petty Cash') $('#employeeNoteDiv').show();

                // Accounts
                $.ajax({
                    url: '@Url.Action("GetAccruedSalaries", "HR")',
                    type: 'GET',
                    success: function (accounts) {
                        ['#accountNameSelect','#creditAccountNameSelect'].forEach((selId, idx) => {
                            const codeId  = idx === 0 ? '#accountCodeInput' : '#creditAccountCodeInput';
                            const acctId  = idx === 0 ? voucher.DebitAccountId : voucher.CreditAccountId;
                            const acctCode = idx === 0 ? voucher["Debit Account"] : voucher["Credit Account"];
                            const $sel    = $(selId).empty().append('<option value="">-- Select --</option>');
                            accounts.forEach(item => $sel.append(`<option value="${item.id}" data-code="${item.code}">${item.code} - ${item.name}</option>`));
                            $sel.val(acctId || "");
                            $(codeId).val(acctCode || "");
                            $sel.off('change').on('change', function () { $(codeId).val($(this).find(':selected').data('code')||''); });
                        });
                    }
                });

                // Cost Centers
                $.ajax({
                    url: '@Url.Action("GetCostCenters", "Lists")',
                    type: 'GET',
                    success: function (res) {
                        const data = Array.isArray(res) ? res : (res.data || []);
                        if (!data.length) return;
                        ['.costCenterSelect', '.creditCostCenterSelect'].forEach((cls, idx) => {
                            const val = idx === 0 ? voucher.DebitCostCenterID : voucher.CreditCostCenterID;
                            $(cls).empty().append('<option value="">-- Select --</option>');
                            data.forEach(item => $(cls).append(`<option value="${item.id}">${item.code} - ${item.name}</option>`));
                            $(cls).val(val || "");
                        });
                    }
                });

                // Type-specific
                if (voucher.Type === 'Vendor') {
                    const vendorType = (voucher.IsSubContractor) ? 'Subcontractor' : 'Vendor';
                    $.ajax({
                        url: '@Url.Action("GetVendors", "Account")',
                        type: 'GET',
                        data: { type: vendorType },
                        success: function (res) {
                            if (!res.status || !res.data) return;
                            const $v = $('#vendorNameSelect').empty().append('<option value="">-- Select --</option>');
                            res.data.forEach(v => $v.append(`<option value="${v.id}" data-code="${v.code}">${v.code} - ${v.name}</option>`));
                            const vendorId = voucher.InvoiceDetails?.[0]?.HumId || "";
                            if (vendorId) { $v.val(vendorId); $('#chequeBookSelect').val($v.find('option:selected').text().trim()); }
                        }
                    });
                }
                else if (voucher.Type === 'Employee' || voucher.Type === 'Petty Cash') {
                    $.ajax({
                        url: '@Url.Action("GetEmployees", "HR")',
                        type: 'GET',
                        success: function (res) {
                            if (!res.status || !res.data) return;
                            const $list = $('#employeeList').empty();
                            const selectedIds = (voucher.employees || []).map(e => e.id);
                            res.data.forEach(emp => {
                                $list.append(`
                                    <div class="form-check">
                                        <input class="form-check-input employee-checkbox"
                                               type="checkbox"
                                               data-employee-id="${emp.id}"
                                               id="emp_${emp.id}"
                                               ${selectedIds.includes(emp.id) ? 'checked' : ''}>
                                        <label class="form-check-label" for="emp_${emp.id}">${emp.code} - ${emp.name}</label>
                                    </div>`);
                            });
                        }
                    });
                }

                // Payment method fields
                $("#chequeFields, #transferFields").addClass("d-none");
                if (voucher.Method === "Cheque") {
                    $("#chequeFields").removeClass("d-none");
                    $.ajax({
                        url: '@Url.Action("GetBankss", "Account")',
                        type: 'GET',
                        success: function (res) {
                            if (!res.status || !res.data) return;
                            const $b = $('#bankNameSelect').empty().append('<option value="">-- Select Bank --</option>');
                            res.data.forEach(bank => $b.append(`<option value="${bank.id}">${bank.bankName}</option>`));
                            $b.val(voucher.BankId || "");
                            $.ajax({
                                url: '@Url.Action("GetChequeBooks", "Account")',
                                type: 'GET',
                                success: function (cbRes) {
                                    chequeBooksData = cbRes.data || [];
                                    const selectedBankId = parseInt(voucher.BankId);
                                    const $cno = $('#chequeNoSelect'), $bno = $('#bookNoSelect'), $bac = $('#bankAccountSelect');
                                    $cno.empty().append('<option value="">-- Select Cheque No --</option>').prop('disabled', true);
                                    $bno.empty().append('<option value="">-- Select Book No --</option>').prop('disabled', true);
                                    $bac.empty().append('<option value="">-- Select Bank Account --</option>').prop('disabled', true);
                                    if (!selectedBankId) return;
                                    const books = chequeBooksData.filter(cb => cb.bank_card_id === selectedBankId);
                                    if (!books.length) return;
                                    const book = books[0];
                                    for (let i = parseInt(book.startFrom); i <= parseInt(book.endIn); i++) $cno.append(`<option value="${i}">${i}</option>`);
                                    $bno.append(`<option value="${book.chqBookNo}">${book.chqBookNo}</option>`);
                                    $bac.append(`<option value="${book.bank_card_id}">${book.acName}</option>`);
                                    $cno.prop('disabled', false); $bno.prop('disabled', false); $bac.prop('disabled', false);
                                    $("#chequeBookSelect").val(voucher.CheckName || "");
                                    $("#chequeNoSelect").val(voucher.CheckNo || "");
                                    $("#bookNoSelect").val(voucher.BookNo || "");
                                    $("#bankAccountSelect").val(voucher.BankAccountId || "");
                                    $("#chequeDate").val(formatDate(voucher.CheckDate));
                                }
                            });
                        }
                    });
                }
                if (voucher.Method === "Transfer") {
                    $("#transferFields").removeClass("d-none");
                    $("#transferDate").val(formatDate(voucher.TransDate));
                    $("#transferName").val(voucher.TransName || "");
                    $("#transferRef").val(voucher.TransRef || "");
                }

                // Invoice table
                const tbody = $("#paymentVoucherModal table tbody").empty();
                (voucher.InvoiceDetails || []).forEach((inv, index) => {
                    const payValue     = inv.Pay     != null ? inv.Pay     : inv.Total;
                    const paymentValue = inv.Payment != null ? inv.Payment : payValue;
                    tbody.append(`
                        <tr data-inv-date="${formatDate(inv.InvDate)}" data-inv-id="${inv.InvId||''}" data-emp-id="${inv.HumId||''}">
                            <td>${index+1}</td>
                            <td>${formatDate(inv.InvDate)}</td>
                            <td data-id="${inv.InvId||''}">${inv.InvCode||""}</td>
                            <td class="text-end">${(inv.Total??0).toLocaleString()}</td>
                            <td><input type="number" class="form-control form-control-sm pay-input" value="${payValue}" step="0.01"></td>
                            <td><input type="text" class="form-control form-control-sm payment-input" value="${paymentValue}"></td>
                            <td><input type="text" class="form-control form-control-sm description-input" value="${inv.Description||''}" placeholder="Description"></td>
                        </tr>`);
                });

                setTimeout(() => modal.removeData("editing"), 500);
                modal.find(".modal-title").text("Edit Payment Voucher");
                modal.modal("show");
            });

            // ============================================================
            // SUBMIT
            // ============================================================
                   $("#paymentVoucherForm").on("submit", function (e) {
            e.preventDefault();
            if (!this.checkValidity()) { this.classList.add("was-validated"); return; }

                  const formatDate = d => {
            if (!d) return null; 
            const date = new Date(d);
            if (isNaN(date.getTime())) return null;
            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        };
            const getTodayDate = () => formatDate(new Date());

            let tableAmount = 0;
            const firstRow = $("#paymentVoucherModal table tbody tr").first();
            if (firstRow.length) tableAmount = Number(firstRow.find("td").eq(4).find("input").val()) || 0;
            const amount = Number($("#amountInput").val()) || tableAmount || 0;
            const paymentMethod = $("#paymentMethodSelect").val();

            const voucherData = {
                Id: Number($("#voucherId").val()) || 0,
                Date: formatDate($("#date").val()),
                PaymentType: $("#paymentTypeSelect").val(),
                IsSubContractor: $("#subContractor").is(":checked"),
                Method: paymentMethod,
                DebitAccountId: Number($("#accountNameSelect").val()) || 0,
                DebitCostCenterId: Number($(".costCenterSelect").val()) || null,
                VendorId: Number($("#vendorNameSelect").val()) || null,
                CreditAccountId: Number($("#creditAccountNameSelect").val()) || 0,
                CreditCostCenterId: Number($(".creditCostCenterSelect").val()) || null,
                Amount: amount,
                Description: "",
                BankId: null, BankAccountId: null, BookNo: null, CheckName: null, CheckNo: null, CheckDate: null,
                TransDate: null, TransName: null, TransRef: null,
                Employees: [], InvoiceDetails: []
            };

            if (paymentMethod === "Cheque") {
                voucherData.BankId = Number($("#bankNameSelect").val()) || null;
                voucherData.BankAccountId = Number($("#bankAccountSelect").val()) || null;
                voucherData.BookNo = Number($("#bookNoSelect").val()) || null;
                voucherData.CheckName = $("#chequeBookSelect").val() || null;
                voucherData.CheckNo = $("#chequeNoSelect").val() || null;
                voucherData.CheckDate = formatDate($("#chequeDate").val());
            }

            if (paymentMethod === "Transfer") {
                voucherData.TransDate = formatDate($("#transferDate").val());
                voucherData.TransName = $("#transferName").val() || null;
                voucherData.TransRef = $("#transferRef").val() || null;
            }

            $("#employeeList input[type=checkbox]:checked").each(function () {
                voucherData.Employees.push({ EmployeeId: Number($(this).data("employee-id")) || 0 });
            });

            $("#paymentVoucherModal table tbody tr").each(function () {
                const $row = $(this);
                const tds = $row.find("td");
                const payAmount = Number(tds.eq(4).find("input").val()) || 0;
                if (payAmount === 0) return;

                let invId = Number($row.data("inv-id")) || 0;
                let humId = Number($row.data("hum-id")) || 0;
                const pType = voucherData.PaymentType;

                if (humId === 0) {
                    if (pType === "Vendor") humId = voucherData.VendorId || 0;
                    else if (pType === "Employee") humId = Number($row.data("emp-id")) || 0;
                    else if (pType === "Petty Cash") humId = Number($row.data("emp-id")) || 0;
                }

                let voucherType = $row.data("voucher-type") || "";
                if (!voucherType) {
                    if (pType === "Employee") voucherType = "Salary";
                    else if (pType === "Vendor") voucherType = "Vendor Invoice";
                    else if (pType === "Petty Cash") voucherType = "Petty Cash Request";
                }

                const rawDate = $row.data("inv-date") || "";
                const invDate = rawDate ? formatDate(rawDate) : getTodayDate();

                voucherData.InvoiceDetails.push({
                    InvId: invId,
                    InvCode: tds.eq(2).text().trim() || "",
                    InvDate: invDate,
                    Total: Number(tds.eq(3).text().replace(/,/g, '')) || 0,
                    Pay: payAmount,
                    Payment: tds.eq(5).find("input").val()?.trim() || "",
                    Description: tds.eq(6).find("input").val()?.trim() || "",
                    VendorId: humId,
                    VoucherType: voucherType
                });
            });

            console.log(voucherData);

            $.ajax({
                url: '@Url.Action("SavePaymentVoucher", "Account")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(voucherData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(voucherData.Id ? "Payment voucher updated successfully" : "Payment voucher saved successfully");
                        $("#paymentVoucherModal").modal("hide");
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    console.error("Error:", xhr);
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });
        });
    </script>
}
