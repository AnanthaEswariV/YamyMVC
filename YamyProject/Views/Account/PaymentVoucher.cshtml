    loadChequeBooks();

// Auto-copy Pay value to Payment field when Pay input changes
$(document).on('input change', '.pay-input', function() {
    const payValue = $(this).val();
    const $row = $(this).closest('tr');
    const $paymentInput = $row.find('.payment-input');
    
    // Get current payment value
    const currentPaymentValue = $paymentInput.val().trim();
    
    // Auto-fill Payment if it's empty, 0, or matches the previous Pay value
    if (currentPaymentValue === '' || 
        currentPaymentValue === '0' || 
        parseFloat(currentPaymentValue) === 0) {
        $paymentInput.val(payValue);
    }
});

// Also handle when user focuses on Pay field and it has a value
$(document).on('focus', '.pay-input', function() {
    const $this = $(this);
    // Store the current value
    $this.data('previous-value', $this.val());
});

// When Pay input loses focus, check if Payment should be updated
$(document).on('blur', '.pay-input', function() {
    const $this = $(this);
    const newValue = $this.val();
    const previousValue = $this.data('previous-value');
    const $row = $this.closest('tr');
    const $paymentInput = $row.find('.payment-input');
    const paymentValue = $paymentInput.val().trim();
    
    // If Payment equals the previous Pay value or is 0, update it
    if (paymentValue === previousValue || 
        paymentValue === '0' || 
        paymentValue === '' ||
        parseFloat(paymentValue) === 0) {
        $paymentInput.val(newValue);
    }
});

async function loadVendorInvoices() {
    // ✅ CHECK IF WE'RE IN EDIT MODE - DON'T RELOAD INVOICES
    if ($("#paymentVoucherModal").data("editing")) {
        console.log("Edit mode active - skipping invoice reload");
        return;
    }

    const paymentType = $('#paymentTypeSelect').val();
    const isSubcontractor = $('#subContractor').is(':checked');
    const vendorId = $('#vendorNameSelect').val();

    if (!vendorId || paymentType !== 'Vendor') {
        $('#paymentVoucherModal table tbody').empty();
        return;
    }

    const url = '@Url.Action("GetVendorsWithInvoices", "Account")' + 
                `?paymentType=${paymentType}&isSubcontractor=${isSubcontractor}&vendorId=${vendorId}`;

    try {
        const res = await fetch(url);
        const data = await res.json();
        console.log(data);
        
        if (!data.status) {
            toastr.error('Failed to load invoices');
            return;
        }

        const tbody = $('#paymentVoucherModal table tbody');
        tbody.empty();

        if (!data.data || data.data.length === 0) {
            tbody.append(`
                <tr>
                    <td colspan="7" class="text-center text-muted">No invoices found</td>
                </tr>
            `);
            return;
        }

        let rowIndex = 1;
        data.data.forEach(vendor => {
            if (vendor.invoices && vendor.invoices.length > 0) {
                vendor.invoices.forEach(inv => {
                    tbody.append(`
                        <tr data-inv-date="${inv.date}" data-inv-id="${inv.invoiceId}">
                            <td>${rowIndex++}</td>
                            <td>${inv.date || ''}</td>
                            <td data-id="${inv.invoiceId}">${inv.invoiceId || ''}</td>
                            <td class="text-end">${(inv.amount || 0).toLocaleString()}</td>
                            <td>
                                <input type="number" 
                                       class="form-control form-control-sm pay-input" 
                                       value="0"
                                       step="0.01">
                            </td>
                            <td>
                                <input type="text" 
                                       class="form-control form-control-sm payment-input" 
                                       value="0">
                            </td>
                            <td>
                                <input type="text" 
                                       class="form-control form-control-sm description-input" 
                                       placeholder="Description">
                            </td>
                        </tr>
                    `);
                });
            }
        });

        if (tbody.find('tr').length === 0) {
            tbody.append(`
                <tr>
                    <td colspan="7" class="text-center text-muted">No invoices found</td>
                </tr>
            `);
        }

    } catch (err) {
        console.error(err);
        toastr.error('Error loading invoices');
    }
}

