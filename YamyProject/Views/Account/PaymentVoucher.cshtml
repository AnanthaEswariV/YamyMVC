    let chequeBooksData = [];
    
    function loadChequeBooks() {
    $.ajax({
        url: '@Url.Action("GetChequeBooks", "Account")',
        type: 'GET',
        success: function (res) {
            chequeBooksData = res.data || [];
        },
        error: function () {
            alert('Failed to load cheque books');
        }
    });
}
    
    $('#bankNameSelect').on('change', function () {
    const selectedBankId = parseInt($(this).val());

    const $chequeNoSelect = $('#chequeNoSelect');
    const $bankAccountSelect = $('#bankAccountSelect');
    const $bookNoSelect = $('#bookNoSelect');

    // Reset dropdowns
    $chequeNoSelect.empty().append('<option value="">-- Select Cheque No --</option>').prop('disabled', true);
    $bookNoSelect.empty().append('<option value="">-- Select Book No --</option>').prop('disabled', true);
    $bankAccountSelect.empty().append('<option value="">-- Select Bank Account --</option>').prop('disabled', true);

    if (!selectedBankId) return;

    // Use bank_card_id instead of bank_id
    const bankChequeBooks = chequeBooksData.filter(cb => cb.bank_card_id === selectedBankId);

    if (bankChequeBooks.length === 0) return;

    const book = bankChequeBooks[0];

    // Populate cheque numbers
    for (let i = parseInt(book.startFrom); i <= parseInt(book.endIn); i++) {
        $chequeNoSelect.append(`<option value="${i}">${i}</option>`);
    }

    // Populate book no
    $bookNoSelect.append(`<option value="${book.chqBookNo}">${book.chqBookNo}</option>`);

    // Populate bank account
    $bankAccountSelect.append(`<option value="${book.bank_card_id}">${book.acName}</option>`);

    // Enable
    $chequeNoSelect.prop('disabled', false);
    $bookNoSelect.prop('disabled', false);
    $bankAccountSelect.prop('disabled', false);
});

    function loadAccountsForPageLoad() {
    $.ajax({
        url: '@Url.Action("GetAccruedSalaries", "HR")',
        type: 'GET',
        success: function (accounts) {
            // Handle Debit Account (accountNameSelect, accountCodeInput)
            const $debitAccountSelect = $("#accountNameSelect");
            const $debitAccountCodeInput = $("#accountCodeInput");
            const currentDebitAccountId = parseInt($debitAccountSelect.val()) || 0;

            $debitAccountSelect.empty().append('<option value="">-- Select --</option>');

            accounts.forEach(item => {
                const isSelected = item.id === currentDebitAccountId;
                $debitAccountSelect.append(
                    $('<option>', {
                        value: item.id,
                        text: item.code + ' - ' + item.name,
                        'data-code': item.code,
                        selected: isSelected
                    })
                );
            });

            // Set the code input based on the selected account
            const selectedDebit = $debitAccountSelect.find('option:selected');
            $debitAccountCodeInput.val(selectedDebit.data('code') || '');

            // Update the code input when the selection changes
            $debitAccountSelect.off('change').on('change', function () {
                const selectedOption = $(this).find(':selected');
                $debitAccountCodeInput.val(selectedOption.data('code') || '');
            });

            // Handle Credit Account (creditAccountNameSelect, creditAccountCodeInput)
            const $creditAccountSelect = $("#creditAccountNameSelect");
            const $creditAccountCodeInput = $("#creditAccountCodeInput");
            const currentCreditAccountId = parseInt($creditAccountSelect.val()) || 0;

            $creditAccountSelect.empty().append('<option value="">-- Select --</option>');

            accounts.forEach(item => {
                const isSelected = item.id === currentCreditAccountId;
                $creditAccountSelect.append(
                    $('<option>', {
                        value: item.id,
                        text: item.code + ' - ' + item.name,
                        'data-code': item.code,
                        selected: isSelected
                    })
                );
            });

            // Set the code input based on the selected account
            const selectedCredit = $creditAccountSelect.find('option:selected');
            $creditAccountCodeInput.val(selectedCredit.data('code') || '');

            // Update the code input when the selection changes
            $creditAccountSelect.off('change').on('change', function () {
                const selectedOption = $(this).find(':selected');
                $creditAccountCodeInput.val(selectedOption.data('code') || '');
            });
        },
        error: function (xhr, status, error) {
            console.error("❌ Error loading accounts:", status, error);
        }
    });
}


