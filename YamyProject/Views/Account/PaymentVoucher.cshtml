@{
    ViewData["Title"] = "PaymentVoucher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

    .dt-buttons .btn-primary:hover {
        background-color: #3b51a0 !important;
        color: #fff !important;
    }

     /* Highlight selected row */
    #table1 tbody tr.selected {
        background-color: #c7e5b4;
    }

    .modal-dialog-scrollable .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
     <div class="card-header position-relative text-center">
        <strong>Payment Voucher Center</strong>

        <button class="btn btn-primary btn-sm position-absolute end-0 top-50 translate-middle-y me-3"
                id="btnAddStock" data-bs-toggle="modal"
                data-bs-target="#paymentVoucherModal">
            <i class="fas fa-plus me-1"></i> New PV
        </button>
    </div
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Reported By -->
            <div style="min-width: 250px;">
                <select class="form-select" id="type">
                    <option value="">-- Select Type --</option>
                    <option value="Vendor" selected>Vendor</option>
                    <option value="Employee">Employee</option>
                    <option value="General">General</option>
                </select>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>
            <div style="min-width: 200px;">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="enableDateFilter">
        <label class="form-check-label fw-bold">
            Enable Date Filter
        </label>
    </div>
</div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>

        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>Payment Code</th>
                    <th>JV No</th>
                    <th>Amount</th>
                    <th>Debit Account</th>
                    <th>Credit Account</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="paymentVoucherModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Modal Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Payment Voucher</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="paymentVoucherForm" novalidate>
            <!-- Modal Body -->
            <div class="modal-body">
                <input type="hidden" id="voucherId">
                <!-- Header Info -->
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" id="date">
                    </div>

                    <div class="col-md-3">
                      <label class="form-label">Payment Type</label>
                      <div class="d-flex align-items-center gap-2">
                      <select class="form-select" id="paymentTypeSelect">
                          <option value="">-- Select --</option>
                          <option value="Vendor">Vendor</option>
                          <option value="Employee">Employee</option>
                          <option value="General">General</option>
                      </select>

                     <div class="form-check mt-4">
                         <input class="form-check-input" type="checkbox" id="subContractor">
                         <label class="form-check-label" for="subContractor">
                             Subcontractors
                         </label>
                        </div>
                      </div>
                    </div>

                    <div class="col-md-3">
    <label class="form-label">Payment Method</label>
    <select class="form-select" id="paymentMethodSelect">
        <option>Cheque</option>
        <option>Cash</option>
        <option>Transfer</option>
    </select>
</div>

                </div>

                <!-- Pay To - Debit -->
                <div class="border rounded p-3 mb-3">
                    <h6 class="fw-bold mb-3">Pay To - Debit</h6>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Account Code</label>
                            <input class="form-control" id="accountCodeInput" disabled>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Account Name</label>
                            <select class="form-select" id="accountNameSelect">
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cost Center</label>
                            <select class="form-select costCenterSelect" data-selected-id="2">
                            </select>
                        </div>

                    @*     <div class="col-md-3">
                            <label class="form-label">Vendor Code</label>
                            <input class="form-control" id="vendorCodeInput">
                        </div> *@

                        <div class="col-md-6">
                            <label class="form-label">Vendor Name</label>
                            <select class="form-select" id="vendorNameSelect">
                            </select>
                        </div>

                      <div class="col-md-3" id="amountInputDiv" style="display: none;">
                          <label class="form-label">Amount</label>
                          <input type="text" class="form-control" id="amountInput">
                      </div>

                    <div class="col-md-6" id="employeeNoteDiv" style="display:none;">
    <label class="form-label">Select Employees</label>

    <div id="employeeList"
         class="border rounded p-2"
         style="max-height:200px; overflow-y:auto;">
    </div>
</div>


                    </div>
                </div>

                <!-- Pay From - Credit -->
                <div class="border rounded p-3 mb-3">
                    <h6 class="fw-bold mb-3">Pay From - Credit</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Account Code</label>
                            <input class="form-control" id="creditAccountCodeInput" disabled>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Account Name</label>
                            <select class="form-select" id="creditAccountNameSelect">
                            </select>
                        </div>

                        <div class="col-md-4">
                             <label class="form-label">Cost Center</label>
    <select class="form-select creditCostCenterSelect" data-selected-id="5">
    </select>
                        </div>

                    </div>
                </div>

                  <div class="border rounded p-3 mb-3">
                <div class="row g-3" id="chequeFields">
                
                    <div class="col-md-3">
        <label class="form-label">Bank Name</label>
        <select class="form-select" id="bankNameSelect"></select>
    </div>
                
  


    <div class="col-md-3">
    <label class="form-label">Cheque Book Name</label>
    <input type="text" class="form-control" id="chequeBookSelect" placeholder="Cheque Book Name">
</div>

<div class="col-md-3">
    <label class="form-label">Cheque No</label>
    <select class="form-select" id="chequeNoSelect">
        <option value="">-- Select Cheque No --</option>
    </select>
</div>

                    <div class="col-md-3">
        <label class="form-label">Cheque Date</label>
        <input type="date" class="form-control" id="chequeDate">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Bank Account Name</label>
        <select class="form-select" id="bankAccountSelect"></select>
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Book No</label>
        <select class="form-select" id="bookNoSelect"></select>
    </div>
                
                </div>
                </div>

                  <div class="border rounded p-3 mb-3">
                <div class="row g-3 d-none" id="transferFields">
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Date</label>
        <input type="date" class="form-control" id="transferDate">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Name</label>
        <input class="form-control" id="transferName">
    </div>
                
                    <div class="col-md-3">
        <label class="form-label">Transfer Ref</label>
        <input class="form-control" id="transferRef">
    </div>
                
                </div>
                </div>


                <!-- Invoice Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Date</th>
                                <th>Inv No/EMP Name</th>
                                <th>Amount</th>
                                <th>Pay</th>
                                <th>Payment</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- Modal Footer -->
           <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script>
    $(document).ready(function () {

    loadPaymentVoucher();
    loadAccountsForPageLoad();
    $('#enableDateFilter').change(function () {
        const enabled = $(this).is(':checked');
        $('#startDate, #endDate').prop('disabled', !enabled);

        if (!enabled) {
            $('#startDate, #endDate').val('');
            loadPaymentVoucher(); 
        }
    });

    $('#filterBtn').click(function () {
        loadPaymentVoucher();
    });

    $('#type').change(function () {
        loadPaymentVoucher();
    });

    function loadPaymentVoucher() {

        const type = $('#type').val();
        const useDateFilter = $('#enableDateFilter').is(':checked');
        const startDate = $('#startDate').val();
        const endDate = $('#endDate').val();

        // Validate only if date filter is enabled
        if (useDateFilter && (!startDate || !endDate)) {
            toastr.warning('Please select both Start and End dates.');
            return;
        }

        $.ajax({
            url: '@Url.Action("GetPaymentVoucherReport", "Account")',
            type: 'GET',
            data: {
                type: type,
                startDate: useDateFilter ? startDate : null,
                endDate: useDateFilter ? endDate : null,
                includeAllDates: !useDateFilter
            },
            beforeSend: function () {
                $('#table2 tbody').html(`
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <div class="spinner-border text-primary me-2"></div>Loading...
                        </td>

                    </tr>
                `);
            },
            success: function (res) {
                console.log(res);
                if (!res.status) {
                    toastr.error(res.message || 'Failed to load data');
                    return;
                }

                if ($.fn.DataTable.isDataTable('#table2')) {
                    $('#table2').DataTable().clear().destroy();
                }

                const tbody = $('#table2 tbody');
                tbody.empty();

                if (res.data && res.data.length > 0) {

                    $.each(res.data, function (i, row) {
                        tbody.append(`
                            <tr data-id="${row.id}">
                                <td>${i + 1}</td>
                                <td>${row.Date ?? ''}</td>
                                <td>${row["Payment Code"] ?? ''}</td>
                                <td>${row["JV NO"] ?? ''}</td>
                                <td class="text-end">${(row.Amount ?? 0).toLocaleString()}</td>
                                <td>${row["Debit Account"] ?? ''}</td>
                                <td>${row["Credit Account"] ?? ''}</td>
                                 <td>
                                    <button class="btn btn-sm btn-primary editPaymentVoucherBtn"
                                        data-customer='${JSON.stringify(row)}'>
                                        <i class="fas fa-pen"></i>
                                    </button>
                                
                                    <button class="btn btn-sm btn-danger deleteCustomerBtn"
                                        data-id='${row.id}'>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        `);
                    });

                    $('#table2').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                className: 'btn btn-primary btn-sm'
                            },
                            {
                                extend: 'pdfHtml5',
                                className: 'btn btn-primary btn-sm',
                                orientation: 'landscape',
                                pageSize: 'A4'
                            }
                        ],
                        pageLength: 15
                    });

                } else {
                    tbody.append(`<tr><td colspan="8" class="text-center">No records found</td></tr>`);
                }
            },
            error: function () {
                toastr.error('Server error while loading data');
            }
        });
    }

    function getTodayDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

    document.getElementById('paymentVoucherModal').addEventListener('shown.bs.modal', function () {
            const todayDate = getTodayDate();

            // Fill all date fields
            const dateFields = [
                'date',
                'chequeDate',
                'transferDate'
            ];

            dateFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !field.value) {
                    field.value = todayDate;
                }
            });
        });

    $('#paymentTypeSelect').change(function() {
        const paymentType = $(this).val();

        if (!paymentType) return;

        $.ajax({
            url: '@Url.Action("GetPaymentTypeDetails", "Account")',
            type: 'GET',
            data: { paymentType: paymentType },
            success: function(res) {
                if (!res.status) {
                    alert(res.message || 'Failed to fetch data');
                    return;
                }

                const data = res.data;

                // Enable/disable amount input
                $('#amountInput').prop('disabled', !data.AmountEnabled);

                // Populate Pay To - Debit
                loadAccounts('#accountNameSelect', '#accountCodeInput', data.DebitAccountId, data.DebitAccountCode);
            },
            error: function() {
                alert('Error loading payment type details');
            }
        });
    });

    $('#paymentTypeSelect').change(function() {
    const paymentType = $(this).val();

    // Hide all dynamic fields first
    $('#amountInputDiv').hide();
    $('#employeeNoteDiv').hide();
    $('#vendorCodeInput').closest('.col-md-3').hide(); // Hide Vendor Code input and label
    $('#vendorNameSelect').closest('.col-md-6').hide(); // Hide Vendor Name select and label

    // Reset the account name select and account code input
    $('#accountNameSelect').empty().append('<option value="">-- Select --</option>');
    $('#accountCodeInput').val('');

    // Handle different payment types
    if (paymentType === 'Vendor') {
        // For Vendor: Show Vendor fields (Account Code, Account Name, Vendor Code, Vendor Name)
        loadAccounts('#accountNameSelect', '#accountCodeInput', null, null);
        // Show Vendor Code and Name related fields
        $('#vendorCodeInput').closest('.col-md-3').show();  // Show Vendor Code
        $('#vendorNameSelect').closest('.col-md-6').show(); // Show Vendor Name
        $('#employeeNoteDiv').hide(); // Hide the note textarea
        $('#amountInputDiv').hide(); // Hide the amount input
    } 
    else if (paymentType === 'Employee') {
        // For Employee: Show Note textarea
        $('#employeeNoteDiv').show();
        $('#amountInputDiv').hide(); // Hide amount input
        $('#vendorCodeInput').closest('.col-md-3').hide(); // Hide Vendor Code input
        $('#vendorNameSelect').closest('.col-md-6').hide(); // Hide Vendor Name select
    } 
    else if (paymentType === 'General') {
        // For General: Show Amount input
        $('#amountInputDiv').show();
        $('#employeeNoteDiv').hide(); // Hide note textarea
        $('#vendorCodeInput').closest('.col-md-3').hide(); // Hide Vendor Code input
        $('#vendorNameSelect').closest('.col-md-6').hide(); // Hide Vendor Name select
    }
    
    if (!paymentType) {
        // Reset everything if no payment type is selected
        $('#accountNameSelect').prop('disabled', false);
        $('#vendorCodeInput').closest('.col-md-3').hide(); // Hide Vendor Code input and label
        $('#vendorNameSelect').closest('.col-md-6').hide(); // Hide Vendor Name select and label
    }
});

    $('#paymentMethodSelect').change(function() {
        const paymentMethod = $(this).val();

        if (!paymentMethod) return;

        $.ajax({
            url: '@Url.Action("GetPaymentMethodDetails", "Account")',
            type: 'GET',
            data: { paymentMethod: paymentMethod, paymentType: $('#paymentTypeSelect').val() },
            success: function(res) {
                if (!res.status) {
                    alert(res.message || 'Failed to fetch data');
                    return;
                }

                const data = res.data;

                // Populate Pay From - Credit
                loadAccounts('#creditAccountNameSelect', '#creditAccountCodeInput', data.CreditAccountId, data.CreditAccountCode);
            },
            error: function() {
                alert('Error loading payment method details');
            }
        });
    });

    $('#paymentMethodSelect').on('change', function () {

    const method = $(this).val();

    // Hide all method-based sections first
    $('#chequeFields').addClass('d-none');
    $('#transferFields').addClass('d-none');

    if (method === 'Cheque') {
        $('#chequeFields').removeClass('d-none');
    }

    if (method === 'Transfer') {
        $('#transferFields').removeClass('d-none');
    }

    // Cash → nothing extra shown
});

    $('#subContractor').on('change', function() {
    if ($('#paymentTypeSelect').val() === 'Subcontractor') {
        loadVendors();
    }
});

    function loadAccounts(selectId, codeInputId, defaultAccountId, defaultAccountCode) {
        $.ajax({
            url: '@Url.Action("GetAccruedSalaries", "HR")',
            type: 'GET',
            success: function(accounts) {
                const $ddl = $(selectId);
                const $codeBox = $(codeInputId);

                $ddl.empty().append('<option value="">-- Select --</option>');

                accounts.forEach(item => {
                    const isSelected = item.id === defaultAccountId;
                    $ddl.append(
                        $('<option>', {
                            value: item.id,
                            text: item.code + ' - ' + item.name,
                            'data-code': item.code,
                            selected: isSelected
                        })
                    );
                });

                $codeBox.val(defaultAccountCode || '');

                $ddl.off('change').on('change', function() {
                    const selected = $(this).find(':selected');
                    $codeBox.val(selected.data('code') || '');
                });
            },
            error: function(xhr, status, error) {
                console.error("❌ Error loading accounts:", status, error);
            }
        });
    }

    populateAndSelectCostCenter();

    loadEmployees();
    loadVendors();
    loadBanks();
    loadChequeBooks();

    async function loadVendorInvoices() {
    const paymentType = $('#paymentTypeSelect').val();
    const isSubcontractor = $('#subContractor').is(':checked');
    const vendorId = $('#vendorNameSelect').val();

    if (!vendorId) {
        $('#paymentVoucherModal table tbody').empty(); // Clear table if no vendor
        return;
    }

    const url = '@Url.Action("GetVendorsWithInvoices", "Account")' + 
                `?paymentType=${paymentType}&isSubcontractor=${isSubcontractor}&vendorId=${vendorId}`;

    try {
        const res = await fetch(url);
        const data = await res.json();

        if (!data.status) return;

        const tbody = $('#paymentVoucherModal table tbody');
        tbody.empty();

        data.data.forEach(vendor => {
            vendor.invoices.forEach(inv => {
                tbody.append(`
                    <tr>
                        <td>${inv.sn}</td>
                        <td>${inv.date}</td>
                        <td>${inv.invoiceId}</td>
                        <td>${inv.amount}</td>
                        <td><input type="number" class="form-control form-control-sm" value="0"></td>
                        <td></td>
                        <td></td>
                    </tr>
                `);
            });
        });

    } catch (err) {
        console.error(err);
    }
}
    
    $('#paymentTypeSelect, #subContractor, #vendorNameSelect').on('change', loadVendorInvoices);


 
    $(document).on("click", ".editPaymentVoucherBtn", function () {
    const voucher = $(this).data("customer"); // Matches your table row
    if (!voucher) return;

    console.log("Voucher Data: ", voucher); // Log the entire voucher object for debugging

    // Fill hidden ID
    $("#voucherId").val(voucher.id || 0);
    console.log("Voucher ID: ", voucher.id || 0);

    // Fill header info
    $("#date").val(voucher.Date?.split('T')[0] || '');  // Date
    console.log("Voucher Date: ", voucher.Date?.split('T')[0] || '');

    $("#paymentTypeSelect").val(voucher.Type || '');  // Payment Type
    console.log("Payment Type: ", voucher.Type || '');

    $("#paymentMethodSelect").val(voucher.Method || '');  // Payment Method
    console.log("Payment Method: ", voucher.Method || '');

    // Employee section (only if Type = Employee)
    if (voucher.Type === "Employee") {
        $("#employeeNoteDiv").show();
        const employeeListDiv = $("#employeeList");
        employeeListDiv.empty();
        voucher.employees?.forEach(emp => {
            employeeListDiv.append(`
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="${emp.id}" id="emp${emp.id}" ${emp.selected ? 'checked' : ''}>
                    <label class="form-check-label" for="emp${emp.id}">${emp.name}</label>
                </div>
            `);
            console.log("Employee: ", emp.name, "Selected: ", emp.selected); 
        });
    } else {
        $("#employeeNoteDiv").hide();
    }

    // Pay To - Debit Section
    $("#accountCodeInput").val(voucher.DebitAccountCode || '');  
    console.log("Debit Account Code: ", voucher.DebitAccountCode || '');

    $("#accountNameSelect").val(voucher.DebitAccountId || '');  // Account Name
    console.log("Debit Account Name: ", voucher.DebitAccountId || '');

    $("#costCenterSelect").val(voucher.DebitCostCenterID || '');  // Cost Center
    console.log("Debit Cost Center ID: ", voucher.DebitCostCenterID || '');

    $("#vendorNameSelect").val(voucher.VendorId || '');  // Vendor Name
    console.log("Vendor ID: ", voucher.VendorId || '');

    $("#amountInput").val(voucher.Amount || 0);  // Amount
    console.log("Amount: ", voucher.Amount || 0);

    // Pay From - Credit Section
    $("#creditAccountCodeInput").val(voucher.CreditAccountCode || '');  // Credit Account Code
    console.log("Credit Account Code: ", voucher.CreditAccountCode || '');

    $("#creditAccountNameSelect").val(voucher.CreditAccountId || '');  // Credit Account Name
    console.log("Credit Account Name: ", voucher.CreditAccountId || '');

    // Credit Cost Center: Populate dropdown dynamically and set the value
    const creditCostCenterSelect = $("#creditCostCenterSelect");
    creditCostCenterSelect.empty(); // Clear previous options

    // Check if cost centers are available (either from voucher.costCenters or another source)
    if (voucher.costCenters && voucher.costCenters.length > 0) {
        voucher.costCenters.forEach(center => {
            // Create an option for each cost center
            const option = $("<option>").val(center.id).text(center.name);
            creditCostCenterSelect.append(option);
        });
        console.log("Available Credit Cost Centers: ", voucher.costCenters); // Log the available cost centers
    } else {
        console.log("No cost centers available.");
    }

    // Set selected value for Credit Cost Center ID
    if (voucher.CreditCostCenterID) {
        creditCostCenterSelect.val(voucher.CreditCostCenterID); // Set the value for the Credit Cost Center
        console.log("Setting Credit Cost Center ID: ", voucher.CreditCostCenterID); // Log the selected cost center ID
    } else {
        console.log("Credit Cost Center ID not found or not selected");
    }

    // Payment Method specific fields (Cheque/Transfer/Cash)
    if (voucher.Method === "Cheque") {
        $("#chequeFields").removeClass("d-none");
        $("#transferFields").addClass("d-none");

        $("#bankNameSelect").val(voucher.BankId || '');  // Bank Name
        console.log("Bank ID: ", voucher.BankId || '');

        $("#chequeBookSelect").val(voucher.CheckName || '');  // Cheque Book Name
        console.log("Cheque Book Name: ", voucher.CheckName || '');

        $("#chequeNoSelect").val(voucher.CheckNo || '');  // Cheque Number
        console.log("Cheque No: ", voucher.CheckNo || '');

        $("#chequeDate").val(voucher.CheckDate?.split('T')[0] || '');  // Cheque Date
        console.log("Cheque Date: ", voucher.CheckDate?.split('T')[0] || '');

        $("#bankAccountSelect").val(voucher.BankAccountId || '');  // Bank Account Name
        console.log("Bank Account ID: ", voucher.BankAccountId || '');

        $("#bookNoSelect").val(voucher.BookNo || '');  // Book No
        console.log("Book No: ", voucher.BookNo || '');
    } else if (voucher.Method === "Transfer") {
        $("#transferFields").removeClass("d-none");
        $("#chequeFields").addClass("d-none");

        $("#transferDate").val(voucher.TransDate?.split('T')[0] || '');  // Transfer Date
        console.log("Transfer Date: ", voucher.TransDate?.split('T')[0] || '');

        $("#transferName").val(voucher.TransName || '');  // Transfer Name
        console.log("Transfer Name: ", voucher.TransName || '');

        $("#transferRef").val(voucher.TransRef || '');  // Transfer Reference
        console.log("Transfer Ref: ", voucher.TransRef || '');
    } else {  // Cash
        $("#chequeFields").addClass("d-none");
        $("#transferFields").addClass("d-none");
    }

    // Populate Invoice Table (if applicable)
    const tbody = $("#paymentVoucherModal table tbody");
    tbody.empty();
    if (voucher.InvoiceDetails && voucher.InvoiceDetails.length > 0) {
        voucher.InvoiceDetails.forEach((inv, index) => {
            tbody.append(`
                <tr>
                    <td>${index + 1}</td>
                    <td>${inv.InvDate?.split('T')[0] || ''}</td>
                    <td>${inv.InvCode || ''}</td>
                    <td class="text-end">${inv.Total?.toLocaleString() || 0}</td>
                    <td><input type="number" class="form-control form-control-sm" value="${inv.Pay || 0}"></td>
                    <td>${inv.Description || ''}</td>
                </tr>
            `);
            console.log("Invoice: ", inv.InvCode, "Amount: ", inv.Total || 0); // Log each invoice's code and total amount
        });
    }

    // Update modal title
    $("#paymentVoucherModal .modal-title").text(voucher.id ? "Edit Payment Voucher" : "New Payment Voucher");

    // Show modal
    $("#paymentVoucherModal").modal("show");
});

    



    $("#paymentVoucherForm").on("submit", function(e) {
    e.preventDefault();

    const form = this;
    if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
    }

    // 1️⃣ Create main voucher object
    const voucherData = {
        Id: parseInt($("#voucherId").val() || 0),
        Date: $("#date").val(),
        PaymentType: $("#paymentTypeSelect").val(),
        Method: $("#paymentMethodSelect").val(),
        DebitAccountId: parseInt($("#accountNameSelect").val() || 0),
        DebitCostCenterId: parseInt($(".costCenterSelect").first().val() || 0),
        CreditAccountId: parseInt($("#creditAccountNameSelect").val() || 0),
        CreditCostCenterId: parseInt($(".costCenterSelect").last().val() || 0),
        Amount: parseFloat($("#amountInput").val() || 0),
        BankId: $("#bankNameSelect").val() ? parseInt($("#bankNameSelect").val()) : null,
        BankAccountId: $("#bankAccountSelect").val() ? parseInt($("#bankAccountSelect").val()) : null,
        BookNo: $("#bookNoSelect").val() ? parseInt($("#bookNoSelect").val()) : null,
        CheckName: $("#chequeBookSelect").val() || "",
        CheckNo: $("#chequeNoSelect").val() || "",
        CheckDate: $("#chequeDate").val() || null,
        TransDate: $("#transferDate").val() || null,
        TransName: $("#transferName").val() || "",
        TransRef: $("#transferRef").val() || ""
    };

    // 2️⃣ Add InvoiceDetails from table
    voucherData.InvoiceDetails = [];
    $("#paymentVoucherModal table tbody tr").each(function() {
        const $td = $(this).find("td");
        voucherData.InvoiceDetails.push({
            InvId: parseInt($td.eq(2).text()) || 0,
            InvCode: $td.eq(2).text(),
            Total: parseFloat($td.eq(3).text()) || 0,
            Pay: parseFloat($td.eq(4).find("input").val()) || 0,
            Description: $td.eq(6).text()
        });
    });

    // 3️⃣ Send AJAX
    $.ajax({
        url: '@Url.Action("SavePaymentVoucher", "Account")', 
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(voucherData),
        success: function(res) {
            if(res.status) {
                toastr.success(voucherData.Id ? 'Payment voucher updated successfully' : 'Payment voucher created successfully');
                $("#paymentVoucherModal").modal("hide");
                setTimeout(() => location.reload(), 1500);
            } else {
                toastr.error(res.message);
            }
        },
        error: function(xhr) {
            toastr.error(xhr.responseJSON?.message || xhr.statusText);
        }
    });
});

});

function populateAndSelectCostCenter() {
    $.ajax({
        url: '@Url.Action("GetCostCenters", "Lists")',
        type: 'GET',
        success: function (res) {
            const data = Array.isArray(res) ? res : (res.data || []);
            if (!data.length) return;

            // Populate all cost center dropdowns with class `.costCenterSelect`
            $('.costCenterSelect').each(function () {
                const $select = $(this);
                const selectedId = $select.data('selected-id');

                $select.empty().append('<option value="">-- Select --</option>');

                $.each(data, function (i, item) {
                    const isSelected = String(item.id) === String(selectedId);
                    const option = `<option value="${item.id}" ${isSelected ? 'selected' : ''}>${item.code} - ${item.name}</option>`;
                    $select.append(option);
                });
            });

            // Specifically target the Credit Cost Center dropdown by class `.creditCostCenterSelect`
            $('.creditCostCenterSelect').each(function () {
                const $select = $(this);
                const selectedId = $select.data('selected-id');
                $select.empty().append('<option value="">-- Select --</option>');
                
                $.each(data, function (i, item) {
                    const isSelected = String(item.id) === String(selectedId);
                    const option = `<option value="${item.id}" ${isSelected ? 'selected' : ''}>${item.code} - ${item.name}</option>`;
                    $select.append(option);
                });
                console.log('Credit Cost Center populated and selected:', selectedId);
            });
        },
        error: function (xhr, status, error) {
            console.error("❌ Error loading cost centers:", status, error);
        }
    });
}



    function loadEmployees() {
    $.ajax({
        url: '@Url.Action("GetEmployees", "HR")',
        type: 'GET',
        success: function (res) {
        

            const $list = $('#employeeList'); 
            $list.empty();

            if (!res.status || !res.data || res.data.length === 0) {
                $list.append('<div class="text-muted">No employees found</div>');
                return;
            }

            res.data.forEach(emp => {
                const checkbox = `
                    <div class="form-check">
                        <input class="form-check-input employee-checkbox"
                               type="checkbox"
                               value="${emp.id}"
                               id="emp_${emp.id}">
                        <label class="form-check-label" for="emp_${emp.id}">
                            ${emp.code} - ${emp.name}
                        </label>
                    </div>
                `;
                $list.append(checkbox);
            });
        },
        error: function () {
            alert('Failed to load employees');
        }
    });
}

    function loadVendors() {
    // Determine type to load
    let type = 'Vendor';
    if ($('#subContractor').is(':checked')) {
        type = 'Subcontractor';
    }

    $.ajax({
        url: '@Url.Action("GetVendors", "Account")',
        type: 'GET',
        data: { type: type },
        success: function(res) {
            if (!res.status) return;

            const $vendorSelect = $('#vendorNameSelect');
            const $vendorCode = $('#vendorCodeInput');

            // Clear previous options
            $vendorSelect.empty().append('<option value="">-- Select --</option>');
            $vendorCode.val('');

            // Fill new data
            res.data.forEach(v => {
                $vendorSelect.append(
                    `<option value="${v.id}" data-code="${v.code}">
                        ${v.code} - ${v.name}
                    </option>`
                );
            });
        }
    });
}

