    function loadEmployees() {
    $.ajax({
        url: '@Url.Action("GetEmployees", "HR")',
        type: 'GET',
        success: function (res) {
        

            const $list = $('#employeeList'); 
            $list.empty();

            if (!res.status || !res.data || res.data.length === 0) {
                $list.append('<div class="text-muted">No employees found</div>');
                return;
            }

            res.data.forEach(emp => {
                const checkbox = `
                    <div class="form-check">
                        <input class="form-check-input employee-checkbox"
                               type="checkbox"
                               value="${emp.id}"
                               id="emp_${emp.id}">
                        <label class="form-check-label" for="emp_${emp.id}">
                            ${emp.code} - ${emp.name}
                        </label>
                    </div>
                `;
                $list.append(checkbox);
            });
        },
        error: function () {
            alert('Failed to load employees');
        }
    });
}


    function loadBanks() {
    $.ajax({
         url: '@Url.Action("GetBankss", "Account")',
        type: 'GET',
        success: function (res) {
            const $bankSelect = $('#bankNameSelect');
            $bankSelect.empty();
            $bankSelect.append('<option value="">-- Select Bank --</option>');

            if (!res || !res.status || !res.data || res.data.length === 0) {
                $bankSelect.append('<option value="">No banks found</option>');
                return;
            }

            res.data.forEach(bank => {
                $bankSelect.append(`
                    <option value="${bank.id}">${bank.bankName}</option>
                `);
            });
        },
        error: function () {
            alert('Failed to load banks');
        }
    });
}

