@{
    ViewData["Title"] = "User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #f5f6f8;
    }

    .access-header-bar {
        background-color: #003b73;
        color: #fff;
        padding: 4px 12px;
        font-size: .95rem;
    }

    .access-card {
        border-radius: 2px;
        box-shadow: 0 0 0 1px rgba(0,0,0,.08);
    }

    /* left user list */
    #UserList table {
        font-size: .8rem;
    }

    #UserList thead {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    /* right side */
    .user-info-title {
        font-size: 1.6rem;
        font-weight: 300;
        color: #666;
        margin-bottom: 10px;
    }

    .user-info-small-label {
        font-size: .8rem;
        color: #666;
    }

    .user-info-small-value {
        font-size: .8rem;
        font-weight: 600;
        margin-left: .25rem;
    }

    .permissions-wrapper {
        background-color: #f8f8f8;
        border-top: 1px solid #e5e5e5;
        padding: 8px 12px;
    }

    .permission-row {
        font-size: .8rem;
        padding: 4px 0;
    }

        .permission-row + .permission-row {
            border-top: 1px solid #f0f0f0;
        }

    .permission-category-label {
        white-space: nowrap;
        font-weight: 500;
        color: #555;
    }

    .permission-arrow-btn {
        border: none;
        background: transparent;
        padding: 0 4px 0 0;
        line-height: 1;
    }

        .permission-arrow-btn i {
            font-size: .75rem;
        }

    .permission-select-all {
        font-size: .75rem;
    }

    .permission-items-panel {
        background-color: #f9f9f9;
        border-radius: 2px;
        padding: 4px 10px;
    }

    .permission-items-table td {
        padding: 2px 4px;
        vertical-align: middle;
        font-size: .75rem;
    }

    .permission-items-table .form-check {
        margin-bottom: 0;
    }

    .permission-items-table .form-check-label {
        font-size: .75rem;
    }

    .permission-items-table .text-danger {
        font-weight: 500;
    }

    .project-access-title {
        font-size: .8rem;
        font-weight: 600;
        margin-top: 10px;
        margin-bottom: 4px;
    }
</style>

<div class="container-fluid py-1">
    <!-- top blue bar -->
    <div class="row mb-2">
        <div class="col">
            <div class="access-header-bar d-flex justify-content-center">
                <strong>Access User Control</strong>
            </div>
        </div>
    </div>

    <form>
        <div class="row g-2">
            <!-- LEFT: user list -->
            <div class="col-3">
                <div class="card access-card h-100">
                    <div class="card-header py-1">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-1">
                                <!-- NEW USER BUTTON -->
                                <button type="button"
                                        id="btnNewUser"
                                        class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newUserModal">
                                    <i class="bi bi-person-plus"></i>
                                </button>
                                <span class="small fw-semibold">Add New User</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-body border-top pt-2 pb-1">
                        <!-- status filter -->
                        <div class="mb-1">
                            <select id="statusFilter" name="StatusFilter" class="form-select form-select-sm">
                                <option value="all">All</option>
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>

                        </div>


                        <!-- users -->
                        <div class="table-responsive" style="max-height: 70vh;" id="UserList">
                            <table id="table1"  class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>SN</th>
                                        <th>Name</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: info + permissions -->
            <div class="col-9">
                <div class="card access-card h-100">
                    <div class="card-body p-2">
                        <!-- hidden selected user for POST -->
                        <input type="hidden" name="SelectedUserId" id="SelectedUserId" />
                        <input type="hidden" id="targetUserId" name="SelectedUserId" />

                        <!-- big title -->
                        <div class="mb-2 border-bottom pb-1">
                            <div class="user-info-title">
                                <h4>User Information</h4>
                            </div>
                        </div>

                        <!-- User information (will be dynamically updated) -->
                        <div class="row g-4 small">
                            <div class="col-md-3">
                                <span class="user-info-small-label">User Code</span>
                                <span class="user-info-small-value" id="userCode">- </span> <!-- Initially empty -->
                            </div>
                            <div class="col-md-3">
                                <span class="user-info-small-label">User Name</span>
                                <span class="user-info-small-value" id="userName">- </span> <!-- Initially empty -->
                            </div>
                            <div class="col-md-3">
                                <span class="user-info-small-label">Name</span>
                                <span class="user-info-small-value" id="userFullName">- </span> <!-- Initially empty -->
                            </div>
                            <div class="col-md-3">
                                <span class="user-info-small-label">Status</span>
                                <span class="user-info-small-value" id="userStatus">- </span> <!-- Initially empty -->
                            </div>
                        </div>


