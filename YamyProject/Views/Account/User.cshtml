@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>

    <script>

        document.querySelectorAll('.password-toggle').forEach(button => {
          button.addEventListener('click', () => {
            const input = button.previousElementSibling;
            if (input.type === "password") {
              input.type = "text";
              button.innerHTML = '<i class="bi bi-eye-slash"></i>';
            } else {
              input.type = "password";
              button.innerHTML = '<i class="bi bi-eye"></i>';
            }
          });
        });

               function loadUsers(state = "all") {
            $.ajax({
                url: '@Url.Action("GetUsers", "Account")' + '?state=' + state,
                type: "GET",
                success: function (res) {
                    console.log(res);

                    if ($.fn.DataTable.isDataTable("#table1")) {
                        $("#table1").DataTable().destroy();
                    }

                    let table = $("#table1");

                    if (table.find("tbody").length === 0) {
                        table.append("<tbody></tbody>");
                    }

                    let tbody = table.find("tbody");
                    tbody.empty();

                    if (res.status && res.data.length > 0) {
                        $.each(res.data, function (i, row) {
                            tbody.append(`
                                <tr data-user-id="${row.id}" data-user-name="${row.userName}"
                                    data-user-fullname="${row.firstName} ${row.lastName}"
                                    data-user-status="${row.active}"
                                    data-user-code="${row.sn}">
                                    <td>${row.sn}</td>
                                    <td>${row.userName}</td>
                                </tr>
                            `);
                        });

                        // Add click event to each row - UPDATED TO SET TARGET USER ID
                        table.find("tbody tr").on("click", function () {
                            // Remove highlight from other rows
                            table.find("tbody tr").removeClass("table-active");
                            $(this).addClass("table-active");

                            const userId = $(this).data("user-id");
                            const userCode = $(this).data("user-code");
                            const userName = $(this).data("user-name");
                            const userFullName = $(this).data("user-fullname");
                            const userStatus = $(this).data("user-status");

                            // SET THE TARGET USER ID - THIS WAS MISSING!
                            $('#targetUserId').val(userId);
                            $('#SelectedUserId').val(userId);


                            // Dynamically update the user info section
                            $('#userCode').text('- ' + userCode);
                            $('#userName').text('- ' + userName);
                            $('#userFullName').text('- ' + userFullName);
                            $('#userStatus').text('- ' + (userStatus === "Active" ? "Active" : "Inactive"));

                            // Optional: Load permissions for this user
                            loadUserPermissions(userId);
                        });
                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="2" class="text-center">No records found</td>
                            </tr>
                        `);
                    }
                }
            });
        }


                function loadUserPermissions(targetUserId) {
            $.ajax({
                url: '@Url.Action("GetUserPermissions", "Account")',
                type: 'GET',
                data: { targetUserId: targetUserId },
                success: function(res) {
                    if(res.status && res.data) {
                        // First uncheck all checkboxes
                        $('.perm-checkbox[data-item-checkbox="true"]').prop('checked', false);

                        // Loop through the permissions and check the relevant checkboxes
                        res.data.forEach(perm => {
                            if (perm.canView) {
                                $(`.perm-checkbox[data-submenu-id="${perm.subMenuId}"][data-perm-type="view"]`).prop('checked', true);
                            }
                            if (perm.canEdit) {
                                $(`.perm-checkbox[data-submenu-id="${perm.subMenuId}"][data-perm-type="edit"]`).prop('checked', true);
                            }
                            if (perm.canDelete) {
                                $(`.perm-checkbox[data-submenu-id="${perm.subMenuId}"][data-perm-type="delete"]`).prop('checked', true);
                            }
                        });

                        // Ensure "Select All" checkboxes are updated based on current selection
                        updateSelectAllCheckboxes();
                    }
                },
                error: function(xhr) {
                    console.error('Could not load permissions', xhr);
                }
            });
        }


        // Helper function to update "Select All" checkboxes
        function updateSelectAllCheckboxes() {
            for(let i = 0; i <= 9; i++) {
                const totalInCategory = $(`.perm-checkbox[data-item-checkbox="true"][data-category-index="${i}"]`).length;
                const checkedInCategory = $(`.perm-checkbox[data-item-checkbox="true"][data-category-index="${i}"]:checked`).length;
                const selectAllCheckbox = $(`[data-category-select-all="true"][data-category-index="${i}"]`);
                selectAllCheckbox.prop('checked', totalInCategory === checkedInCategory);
            }
        }

        // Function to collect all permissions from the form
        function collectPermissions() {
            const permissions = [];

            // Loop through all permission checkboxes
            $('.perm-checkbox[data-item-checkbox="true"]').each(function() {
                const checkbox = $(this);
                const subMenuId = parseInt(checkbox.data('submenu-id'));
                const canView = checkbox.is(':checked');

                permissions.push({
                    SubMenuId: subMenuId,
                    CanView: canView,
                    CanEdit: false,  // Set to true if you have edit checkboxes
                    CanDelete: false // Set to true if you have delete checkboxes
                });
            });

            return permissions;
        }

        // Event listener for "Select All" checkboxes
        $(document).on('change', '[data-category-select-all="true"]', function() {
            const categoryIndex = $(this).data('category-index');
            const isChecked = $(this).is(':checked');

            // Update all checkboxes in this category
            $(`.perm-checkbox[data-category-index="${categoryIndex}"]`).prop('checked', isChecked);
        });

        // Update "Select All" checkbox when individual items change
        $(document).on('change', '.perm-checkbox[data-item-checkbox="true"]', function() {
            const categoryIndex = $(this).data('category-index');
            const totalInCategory = $(`.perm-checkbox[data-item-checkbox="true"][data-category-index="${categoryIndex}"]`).length;
            const checkedInCategory = $(`.perm-checkbox[data-item-checkbox="true"][data-category-index="${categoryIndex}"]:checked`).length;

            // Update the "Select All" checkbox state
            const selectAllCheckbox = $(`[data-category-select-all="true"][data-category-index="${categoryIndex}"]`);
            selectAllCheckbox.prop('checked', totalInCategory === checkedInCategory);
        });
        function loadEmployeeDropdown(selectedId = null) {
          $.getJSON('@Url.Action("GetAllEmployees", "Inventory")', function (employees) {
                const $employeeSelect = $('#empName');
                $employeeSelect.empty().append('<option value="">Select Employee</option>');

                employees.forEach(emp => {
                    // Convert both to string for safe comparison (to avoid type mismatch)
                    const selected = selectedId && String(emp.id) === String(selectedId) ? 'selected' : '';
                    $employeeSelect.append(`
                        <option value="${emp.id}" data-code="${emp.code}" data-name="${emp.name}" ${selected}>
                            ${emp.name}
                        </option>
                    `);
                });
            });
        }

        function loadRolesDropdown() {
            $.ajax({
                url: '@Url.Action("GetRoles", "Account")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const select = $('#role');
                        select.empty(); // clear existing options
                        select.append('<option value="">-- Select Role --</option>');

                        res.data.forEach(role => {
                            select.append(`<option value="${role.id}">${role.name}</option>`);
                        });
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        }


        $(document).ready(function () {
               loadUsers("all");

               $("#statusFilter").change(function () {
            const state = $(this).val();
            loadUsers(state);
        });

               loadEmployeeDropdown();
               loadRolesDropdown();

               $('#roleForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const idVal = $('#roleId').val();
            const isEdit = idVal && parseInt(idVal) > 0;

            const roleData = {
                Id: isEdit ? parseInt(idVal) : 0,
                Name: $('#roleName').val().trim()
            };

            $.ajax({
                url: '@Url.Action("SaveRole", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(roleData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? 'Role updated successfully' : 'Role added successfully');
                        $('#newRoleModal').modal('hide');

                        // Optional: refresh role list after saving
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

              $(document).on('click', '#newUserModal .btn-primary', function(e) {
            e.preventDefault();

              const modal = $('#newUserModal');

        const userData = {
            Id: modal.find('#userId').val() ? parseInt(modal.find('#userId').val()) : 0,
            Username: modal.find('#userName').val().trim(),
            Password: modal.find('#password').val().trim(),
            ConfirmPassword: modal.find('#confirmPassword').val().trim(),
            FirstName: modal.find('#firstName').val().trim(),
            LastName: modal.find('#lastName').val().trim(),
            RoleId: modal.find('#role').val() ? parseInt(modal.find('#role').val()) : 0,
            EmployeeId: modal.find('#empName').val() ? parseInt(modal.find('#empName').val()) : -1,
            IsActive: modal.find('#activeCheck').is(':checked')
        };

            console.log(userData);
            // Simple client-side validation
             if(!userData.FirstName) {
                toastr.warning("Enter First Name");
                return;
            }
            if(!userData.Username) {
                toastr.warning("Enter at least User Name");
                return;
            }
            if(userData.RoleId <= 0) {
                toastr.warning("Choose Role First");
                return;
            }
           if(userData.EmployeeId <= 0) {
                toastr.warning("Choose Employee First");
                return;
            }
            if(userData.Id === 0) { // new user
                if(!userData.Password) {
                    toastr.warning("Enter your new password");
                    return;
                }
                if(userData.Password !== userData.ConfirmPassword) {
                    toastr.warning("Confirm password mismatch");
                    return;
                }
            }

            $.ajax({
                url: '@Url.Action("SaveUser", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function(res) {
                    if(res.status) {
                        toastr.success(res.message);
                        $('#newUserModal').modal('hide');
                                // Optional: refresh role list after saving
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

        $('#savePermissionsBtn').on('click', function (e) {
            e.preventDefault();

            // Get the target user ID
            const targetUserId = $('#targetUserId').val();
            console.log(targetUserId);
            if (!targetUserId || parseInt(targetUserId) <= 0) {
                toastr.error('Please select a user from the list first');
                return;
            }

            // Collect all permissions from the form
            const permissions = collectPermissions();

            if (permissions.length === 0) {
                toastr.warning('No permissions to save');
                return;
            }

            // Show loading state
            const $btn = $(this);
            const originalText = $btn.html();
            $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Saving...');

            // Save permissions
            $.ajax({
                url: `@Url.Action("BulkUpdatePermissions", "Account")?targetUserId=${targetUserId}`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Permissions: permissions
                }),
                success: function (res) {
                    if (res.status) {
                        toastr.success('Permissions updated successfully');
                    } else {
                        toastr.error('Permissions update failed: ' + res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error('Permissions update failed: ' + (xhr.responseJSON?.message || xhr.statusText));
                },
                complete: function() {
                    // Restore button state
                    $btn.prop('disabled', false).html(originalText);
                }
            });
        });


        });



    </script>
}