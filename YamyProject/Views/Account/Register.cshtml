@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register - YAMY Enterprise</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Favicon -->
    <link rel="icon" href="~/favicon.png" type="image/png" />
</head>
<body class="h-screen w-screen bg-[#0b1d36] flex items-center justify-center text-white">

    <div class="flex w-[1000px] h-[600px] bg-[#0e2545]/90 rounded-2xl shadow-2xl overflow-hidden">

        <!-- Left Side -->
        <div class="w-1/2 flex flex-col justify-center items-center bg-transparent px-10">
       @*      <img src="/images/yamy-logo.png" alt="YAMY Logo" class="h-12 mb-6"> *@
            <h1 class="text-3xl font-bold mb-4">Create New Company</h1>
            <p class="text-gray-300 mb-6 text-center">
                Get started by registering your company account.
            </p>
            <button class="bg-white text-black px-6 py-2 rounded-full font-semibold hover:bg-gray-200">
                Learn More
            </button>

            <!-- Footer -->
            <div class="absolute bottom-6 text-xs text-gray-400">
                © YAMY CO. 2026 ALL Rights Reserved.
            </div>
        </div>

        <!-- Right Side (Form) -->
        <div class="w-1/2 bg-gray-200/10 p-10 rounded-l-3xl flex flex-col justify-center">
            <h2 class="text-2xl font-bold text-center mb-6">Sign Up</h2>

            <form id="registerForm" class="space-y-4">
                <input id="CompanyName" type="text" placeholder="Company Name" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="Gmail" type="email" placeholder="Email" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="Phone1" type="tel" placeholder="Phone No" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="Address" type="text" placeholder="Address" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="Name" type="text" placeholder="User Name" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="Password" type="password" placeholder="Password" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                <input id="ConfirmPassword" type="password" placeholder="Re-enter the Password" class="w-full px-4 py-2 rounded-full bg-white text-black focus:ring-2 focus:ring-blue-500 focus:outline-none" />

                <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white py-2 rounded-full font-semibold shadow-md">
                    Sign Up
                </button>
            </form>

       @*      <!-- Switch -->
            <p class="text-sm text-gray-300 text-center mt-6">
                Already have an account?
                <a href="@Url.Action("Login", "Account")" class="text-blue-400 hover:underline">Login</a>
            </p> *@
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <script>


             $('#registerForm').submit(function (e) {
            e.preventDefault();

            var formData = {
                CompanyName: $('#CompanyName').val(),
                Gmail: $('#Gmail').val(),
                Phone1: $('#Phone1').val(),
                Address: $('#Address').val(),
                Name: $('#Name').val(),
                Password: $('#Password').val(),
                ConfirmPassword: $('#ConfirmPassword').val()
            };

            $.ajax({
                url: '@Url.Action("Register", "Account")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(formData),  
                       success: function (response) {
            toastr.success(response.message || 'Company created successfully!');

            setTimeout(function () {
                window.location.href = '@Url.Action("CompanyList", "Account")';
            }, 1500);
        },

                error: function (xhr) {
                    toastr.error('An error occurred: ' + xhr.responseText);
                }
            });
        });


    </script>

</body>
</html>
