            const $debit = $("#accountNameSelect"); // Debit Account
            const $credit = $("#creditAccountNameSelect"); // Credit Account

            $debit.empty().append('<option value="">-- Select --</option>');
            $credit.empty().append('<option value="">-- Select --</option>');

            accounts.forEach(a => {
                const opt = `<option value="${a.id}" data-code="${a.code}">${a.code} - ${a.name}</option>`;
                $debit.append(opt);
                $credit.append(opt);
            });

            // Set selected values
            $debit.val(voucher.debit_account_id || "");
            $credit.val(voucher.credit_account_id || "");

            // Set account codes AFTER select is populated
            const debitCode = $debit.find("option:selected").data("code") || "";
            const creditCode = $credit.find("option:selected").data("code") || "";

            $("#accountCodeInput").val(debitCode);           // Debit code
            $("#creditAccountCodeInput").val(creditCode);    // Credit code
        });



            // =========================
            // LOAD COST CENTERS
            // =========================
            $.get("/Lists/GetCostCenters", function (res) {
                const data = res.data || res;
                if (!data.length) return;

                const $ccDebit = $(".costCenterSelect");       // Debit Cost Center
                const $ccCredit = $(".creditCostCenterSelect"); // Credit Cost Center

                $ccDebit.empty().append('<option value="">-- Select --</option>');
                $ccCredit.empty().append('<option value="">-- Select --</option>');

                data.forEach(cc => {
                    const opt = `<option value="${cc.id}">${cc.code} - ${cc.name}</option>`;
                    $ccDebit.append(opt);
                    $ccCredit.append(opt);
                });

                $ccDebit.val(voucher.debit_cost_center_id || "");
                $ccCredit.val(voucher.credit_cost_center_id || "");
            });

            // =========================
            // CUSTOMER ONLY
            // =========================
            if (voucher.type === "Customer") {
                $.get("/Customer/GetCustomers", function (res) {
                    if (!res.status || !res.data) return;

                    const $cust = $("#vendorNameSelect");
                    $cust.empty().append('<option value="">-- Select --</option>');

                    res.data.forEach(c =>
                        $cust.append(`<option value="${c.id}">${c.code} - ${c.name}</option>`)
                    );

                    // Set selected customer from first invoice (if any)
                    const firstCustomerId = voucher.InvoiceDetails?.[0]?.HumId || null;
                    if (firstCustomerId) $cust.val(firstCustomerId);
                });
            }

            // =========================
            // PAYMENT METHOD
            // =========================
            $("#chequeFields").addClass("d-none");
            $("#transferFields").addClass("d-none");

            if (voucher.method === "Cheque") {
                $("#chequeFields").removeClass("d-none");

                $.get("/Account/GetBankss", function (res) {
                    if (!res.status || !res.data) return;

                    const $bank = $("#bankNameSelect");
                    $bank.empty().append('<option value="">-- Select Bank --</option>');

                    res.data.forEach(b =>
                        $bank.append(`<option value="${b.id}">${b.bankName}</option>`)
                    );

                    $bank.val(voucher.bank_id || "");
                    $("#chequeBookSelect").val(voucher.check_name || "");
                    $("#chequeNoSelect").val(voucher.check_no || "");
                    $("#chequeDate").val(voucher.check_date ? voucher.check_date.split("T")[0] : "");
                    $("#bankAccountSelect").val(voucher.bank_account_id || "");
                    $("#bookNoSelect").val(voucher.book_no || "");
                });
            }

            if (voucher.method === "Transfer") {
                $("#transferFields").removeClass("d-none");
                $("#transferDate").val(voucher.trans_date?.split("T")[0] || "");
                $("#transferName").val(voucher.trans_name || "");
                $("#transferRef").val(voucher.trans_ref || "");
            }

            // =========================
            // INVOICE DETAILS TABLE
            // =========================
            const tbody = $("#paymentInvoiceTable tbody");
            tbody.empty();

            voucher.InvoiceDetails?.forEach((inv, i) => {
                const invDate = inv.InvDate ? inv.InvDate.split("T")[0] : "";
                tbody.append(`
                    <tr data-inv-id="${inv.InvId}" data-hum-id="${inv.HumId}">
                        <td>${i + 1}</td>
                        <td>${invDate}</td>
                        <td data-id="${inv.InvRefId}">${inv.InvCode}</td>
                        <td class="text-end">${(inv.Total ?? 0).toLocaleString()}</td>
                        <td>
                            <input type="number" class="form-control form-control-sm pay-input"
                                   value="${inv.Pay ?? 0}" step="0.01">
                        </td>
                        <td>${inv.Pay ?? 0}</td>
                        <td>
                            <input type="text" class="form-control form-control-sm description-input"
                                   value="${inv.Description || ""}">
                        </td>
                    </tr>
                `);
            });

            // =========================
            // SHOW MODAL
            // =========================
            modal.find(".modal-title").text("Edit Receipt Voucher");
            modal.modal("show");

            setTimeout(() => modal.removeData("editing"), 300);
        });



