            $("#paymentMethodSelect").val(voucher.method || "");

            // =========================
            // SHOW / HIDE TYPE FIELDS
            // =========================
            $("#amountInputDiv").hide();
            $("#vendorNameSelect").closest(".col-md-6").hide();

            if (voucher.type === "Customer") {
                $("#vendorNameSelect").closest(".col-md-6").show();
            }

            if (voucher.type === "General") {
                $("#amountInputDiv").show();
                $("#amountInput").val(voucher.amount || 0);
