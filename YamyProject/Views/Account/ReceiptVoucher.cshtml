           function populateAndSelectCostCenter() {
            $.ajax({
                url: '@Url.Action("GetCostCenters", "Lists")',
                type: 'GET',
                success: function (res) {
                    const data = Array.isArray(res) ? res : (res.data || []);
                    if (!data.length) return;

                    function fillSelect($select) {
                        const selectedId = String($select.data("selected-id") || "");
                        $select.empty().append('<option value="">-- Select --</option>');

                        data.forEach(item => {
                            $select.append(
                                `<option value="${item.id}">${item.code} - ${item.name}</option>`
                            );
                        });

                        if (selectedId) {
                            $select.val(selectedId);
                        }
                    }

                    $(".costCenterSelect").each(function () {
                        fillSelect($(this));
                    });

                    $(".creditCostCenterSelect").each(function () {
                        fillSelect($(this));
                    });
                }
            });
        }

           function loadVendors() {

           let type = $('#subContractor').is(':checked') ? 'Subcontractor' : 'Vendor';

           $.ajax({
                url: '@Url.Action("GetCustomers", "Customer")',
                type: 'GET',
                data: { type: type },
                success: function (res) {
                    if (!res.status || !res.data) return;

                    const $vendorSelect = $('#vendorNameSelect');
                    if (!$vendorSelect.length) return;

                    // Get the selected vendor id (stored via .data)
                    const selectedVendorId = String($vendorSelect.data('selected-id') || "");

                    // Clear existing options and add default
                    $vendorSelect.empty().append('<option value="">-- Select --</option>');

                    // Append new vendor options
                    res.data.forEach(v => {
                        $vendorSelect.append(
                            `<option value="${v.id}" data-code="${v.code}">${v.code} - ${v.name}</option>`
                        );
                    });

                    // Select previously stored vendor
                    if (selectedVendorId) {
                        $vendorSelect.val(selectedVendorId).trigger('change');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error loading vendors:", error);
                }
            });
        }



          $(document).ready(function () {

               $(document).on("click", ".editReceiptVoucherBtn", function () {

            // =========================
            // READ DATA SAFELY
            // =========================
            const raw = $(this).attr("data-customer");
            if (!raw) return;

            const voucher = JSON.parse(raw);

            const modal = $("#salesModal");

            // =========================
            // RESET MODAL
            // =========================
            modal.find("form")[0].reset();
            modal.find("tbody").empty();
            modal.find("select").val("");
            modal.data("editing", true);

            // =========================
            // HEADER
            // =========================
            $("#voucherId").val(voucher.id || 0);
            $("#date").val(voucher.date ? voucher.date.split("T")[0] : "");
