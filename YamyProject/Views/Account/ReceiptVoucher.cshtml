           function loadAccounts(selectId, codeInputId, defaultAccountId, defaultAccountCode) {
            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function(accounts) {
                    const $ddl = $(selectId);
                    const $codeBox = $(codeInputId);

                    $ddl.empty().append('<option value="">-- Select --</option>');

                    accounts.forEach(item => {
                        const isSelected = item.id === defaultAccountId;
                        $ddl.append(
                            $('<option>', {
                                value: item.id,
                                text: item.code + ' - ' + item.name,
                                'data-code': item.code,
                                selected: isSelected
                            })
                        );
                    });

                    $codeBox.val(defaultAccountCode || '');

                    $ddl.off('change').on('change', function() {
                        const selected = $(this).find(':selected');
                        $codeBox.val(selected.data('code') || '');
                    });
                },
                error: function(xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                }
            });
        }

           let chequeBooksData = [];

           function loadChequeBooks() {
            $.ajax({
                url: '@Url.Action("GetChequeBooks", "Account")',
                type: 'GET',
                success: function (res) {
                    chequeBooksData = res.data || [];
