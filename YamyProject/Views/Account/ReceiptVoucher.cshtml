                       class="form-control form-control-sm pay-input"
                       value="0"
                       step="0.01">
            </td>
            <td>
                <input type="text"
                       class="form-control form-control-sm payment-input"
                       value="0">
            </td>
            <td>
                <input type="text"
                       class="form-control form-control-sm description-input"
                       placeholder="Description">
            </td>
                        </tr>
                    `);
                });

            } catch (err) {
                console.error(err);
                toastr.error('Error loading invoices');
            }
        }

        // Trigger when customer changes
        $('#vendorNameSelect').on('change', loadCustomerInvoices);



        });


           function loadAccounts(selectId, codeInputId, defaultAccountId, defaultAccountCode) {
            $.ajax({
                url: '@Url.Action("GetAccruedSalaries", "HR")',
                type: 'GET',
                success: function(accounts) {
                    const $ddl = $(selectId);
                    const $codeBox = $(codeInputId);

                    $ddl.empty().append('<option value="">-- Select --</option>');

                    accounts.forEach(item => {
                        const isSelected = item.id === defaultAccountId;
                        $ddl.append(
                            $('<option>', {
                                value: item.id,
                                text: item.code + ' - ' + item.name,
                                'data-code': item.code,
                                selected: isSelected
                            })
                        );
                    });

                    $codeBox.val(defaultAccountCode || '');

                    $ddl.off('change').on('change', function() {
                        const selected = $(this).find(':selected');
                        $codeBox.val(selected.data('code') || '');
                    });
                },
                error: function(xhr, status, error) {
                    console.error("❌ Error loading accounts:", status, error);
                }
            });
        }

