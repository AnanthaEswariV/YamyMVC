        });

        /* =========================
           ACCOUNT NAME CHANGE - UPDATE CODE
        ========================== */
        $("#accountNameSelect").on("change", function() {
            const code = $(this).find("option:selected").data("code") || "";
            $("#accountCodeInput").val(code);
        });

        $("#creditAccountNameSelect").on("change", function() {
            const code = $(this).find("option:selected").data("code") || "";
            $("#creditAccountCodeInput").val(code);
        });

        /* =========================
           CUSTOMER/VENDOR CHANGE - UPDATE CHEQUE BOOK
        ========================== */
        $("#vendorNameSelect").on("change", function() {
            const selectedText = $(this).find('option:selected').text().trim();
            $('#chequeBookSelect').val(selectedText);
        });


               });

   </script>
