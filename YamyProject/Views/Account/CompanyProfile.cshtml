@{
    ViewData["Title"] = "CompanyProfile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<div class="col-md-12">
    <div class="card">
        <div class="card-header text-center">
            <h4 class="card-title mb-0">Company Profile</h4>
        </div>
        <div class="card-content">
            <div class="card-body">
                <!-- TABS -->
                <ul class="nav nav-pills px-3 pt-2 gap-2" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active btn btn-primary"
                                data-bs-toggle="tab"
                                data-bs-target="#generalTab"
                                type="button">
                            <i class="bi bi-info-circle"></i> General Information
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link btn btn-outline-primary"
                                data-bs-toggle="tab"
                                data-bs-target="#vatTab"
                                type="button">
                            <i class="bi bi-receipt"></i> VAT Configuration
                        </button>
                    </li>
                </ul>


                <div class="tab-content">

                    <div class="tab-pane fade show active" id="generalTab">
                        <div class="p-4">
                            <div class="row">

                                <!-- LEFT FORM -->
                                <div class="col-md-8">
                                    <form>
                                        <div class="mb-3">
                                            <label class="form-label">Company Name</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                                <input type="text" class="form-control" id="companyName">
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Address 1</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                                <input type="text" class="form-control" id="address">
                                            </div>
                                        </div>

                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Phone 1</label>
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                                    <input type="text" class="form-control" id="phone1">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Phone 2</label>
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                                    <input type="text" class="form-control" id="phone2">
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Mobile</label>
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                                    <input type="text" class="form-control" id="mobile">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Gmail</label>
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                                    <input type="email" class="form-control" id="gmail">
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Website</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-globe"></i></span>
                                                <input type="text" class="form-control" id="website">
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">TRN No</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-file-text"></i></span>
                                                <input type="text" class="form-control" id="trnNo">
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Country</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-flag"></i></span>
                                                <select class="form-control" id="countryId">
                                                    <option value="">-- Select Country --</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" id="isDefaultCompany">
                                            <label class="form-check-label">
                                                Make This Company Main Account
                                            </label>
                                        </div>
                                    </form>
                                </div>

                                <!-- RIGHT UPLOAD -->
                                <div class="col-md-4 text-center">
                                    <div class="mb-4">
                                        <img id="logoPreview" class="img-thumbnail mb-2 ">
                                        <div>
                                            <button class="btn btn-primary btn-sm">
                                                <i class="bi bi-upload"></i> Browse
                                            </button>
                                        </div>
                                        <small class="text-muted d-block mt-1">Logo</small>
                                    </div>

                                    <div>
                                        <img id="stampPreview" class="img-thumbnail mb-2">
                                        <div>
                                            <button class="btn btn-primary btn-sm">
                                                <i class="bi bi-upload"></i> Browse
                                            </button>
                                        </div>
                                        <small class="text-muted d-block mt-1">Stamp</small>
                                    </div>
                                </div>

                            </div>


                        </div>
                    </div>


                    <div class="tab-pane fade" id="vatTab">
                        <div class="p-4">
                            <div class="row">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">TAX Registration No</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </span>
                                            <input type="text" class="form-control" id="vatRegistrationNo">
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">TRN Issue Date</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-calendar"></i>
                                            </span>
                                            <input type="date" class="form-control" id="vatTrnIssueDate">
                                        </div>
                                    </div>
                                </div>


                                <!-- QUARTERLY VAT -->
                                <h6 class="fw-bold mb-3">VAT Return (Quarterly)</h6>

                                <div class="row mb-2 fw-semibold text-muted">
                                    <div class="col-md-3">Quarter</div>
                                    <div class="col-md-3">Start Date</div>
                                    <div class="col-md-3">End Date</div>
                                    <div class="col-md-3">Due Date</div>
                                </div>

                                <!-- Q1 -->
                                <div class="row mb-2">
                                    <div class="col-md-3">Quarter No. 1</div>
                                    <div class="col-md-3"><input type="date" id="q1Start" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q1End" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q1Due" class="form-control"></div>
                                </div>

                                <!-- Q2 -->
                                <div class="row mb-2">
                                    <div class="col-md-3">Quarter No. 2</div>
                                    <div class="col-md-3"><input type="date" id="q2Start" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q2End" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q2Due" class="form-control"></div>
                                </div>

                                <!-- Q3 -->
                                <div class="row mb-2">
                                    <div class="col-md-3">Quarter No. 3</div>
                                    <div class="col-md-3"><input type="date" id="q3Start" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q3End" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q3Due" class="form-control"></div>
                                </div>

                                <!-- Q4 -->
                                <div class="row mb-4">
                                    <div class="col-md-3">Quarter No. 4</div>
                                    <div class="col-md-3"><input type="date" id="q4Start" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q4End" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="q4Due" class="form-control"></div>
                                </div>

                                <hr>

                                <!-- CORPORATE TAX -->
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label">Corporate TAX No</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-bank"></i></span>
                                            <input type="text" class="form-control" id="corporateTaxNo">
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">TRN Issue Date</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                                            <input type="date" class="form-control" id="corpTrnIssueDate">
                                        </div>
                                    </div>
                                </div>

                                <!-- YEARLY -->
                                <h6 class="fw-bold mb-3">Corporate Tax (Yearly)</h6>

                                <div class="row mb-2 fw-semibold text-muted">
                                    <div class="col-md-3">Period</div>
                                    <div class="col-md-3">Start Date</div>
                                    <div class="col-md-3">End Date</div>
                                    <div class="col-md-3">Due Date</div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-3">Yearly</div>
                                    <div class="col-md-3"><input type="date" id="corpStart" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="corpEnd" class="form-control"></div>
                                    <div class="col-md-3"><input type="date" id="corpDue" class="form-control"></div>
                                </div>

                            </div>
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="d-flex justify-content-end mt-4">
                    <button class="btn btn-primary me-2" id="btnSaveAll">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <button class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Close
                    </button>
                </div>


            </div>
        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script>

     $(document).ready(function () {
        loadCompanyProfile();
        loadCountries();


    // Bind Save button
    $("#btnSaveAll").click(function(e) {
        e.preventDefault();
        saveCompanyProfile();
    });

        loadCompanyProfile();

    });

     function loadCompanyProfile() {
        $.ajax({
            url: '@Url.Action("GetMasterCompany", "Account")',
            type: "GET",
            success: function (res) {
                console.log(res);
                if (!res.status || !res.data) {
                    toastr.error(res.message || "Failed to load company data");
                    return;
                }
                console.log(res.status);
                console.log(res.data);
                
                let c = res.data.company;
                let v = res.data.vatConfig;
                let ct = res.data.corporateTax; // ✅ IMPORTANT

                /* ================= COMPANY ================= */
                if (c) {
                    $("#companyName").val(c.name);
                    $("#address").val(c.address);
                    $("#phone1").val(c.phone1);
                    $("#phone2").val(c.phone2);
                    $("#mobile").val(c.mobileNumber);
                    $("#gmail").val(c.gmail);
                    $("#website").val(c.website);
                    $("#trnNo").val(c.trnNo);
                    $("#countryId").val(c.countryId);
                    $("#isDefaultCompany").prop("checked", c.isDefault);

                    if (c.logo) {
                        $("#logoPreview").attr("src", "data:image/png;base64," + c.logo);
                    }

                    if (c.stamp) {
                        $("#stampPreview").attr("src", "data:image/png;base64," + c.stamp);
                    }
                }

                /* ================= VAT ================= */
                if (v) {
                    $("#vatRegistrationNo").val(v.registrationNo);
                    $("#vatTrnIssueDate").val(v.trnIssueDate?.substring(0, 10));

                    $("#q1Start").val(v.quarterOneStartDate?.substring(0, 10));
                    $("#q1End").val(v.quarterOneEndDate?.substring(0, 10));
                    $("#q1Due").val(v.quarterOneDueDate?.substring(0, 10));

                    $("#q2Start").val(v.quarterTwoStartDate?.substring(0, 10));
                    $("#q2End").val(v.quarterTwoEndDate?.substring(0, 10));
                    $("#q2Due").val(v.quarterTwoDueDate?.substring(0, 10));

                    $("#q3Start").val(v.quarterThreeStartDate?.substring(0, 10));
                    $("#q3End").val(v.quarterThreeEndDate?.substring(0, 10));
                    $("#q3Due").val(v.quarterThreeDueDate?.substring(0, 10));

                    $("#q4Start").val(v.quarterFourStartDate?.substring(0, 10));
                    $("#q4End").val(v.quarterFourEndDate?.substring(0, 10));
                    $("#q4Due").val(v.quarterFourDueDate?.substring(0, 10));
                }

             if (ct) {
        $("#corporateTaxNo").val(ct.corporateTaxNo);
        $("#corpTrnIssueDate").val(ct.trnIssueDate?.substring(0, 10));
        $("#corpStart").val(ct.startDate?.substring(0, 10));
        $("#corpEnd").val(ct.endDate?.substring(0, 10));
        $("#corpDue").val(ct.dueDate?.substring(0, 10));
    }

            },
            error: function (xhr, status, error) {
                toastr.error("Error loading company profile");
                console.error(error);
            }
        });
    }

     function loadCountries(selectedCountryId) {
        let $country = $("#countryId");
        $country.empty();
        $country.append(`<option value="">-- Select Country --</option>`); // default option

        $.ajax({
            url: '@Url.Action("GetCountry", "Reports")', // returns all countries
            type: 'GET',
            success: function (res) {
                if (res.data && res.data.length > 0) {
                    res.data.forEach(function (c) {
                        // Append each country and select if it matches selectedCountryId
                        $country.append(`<option value="${c.id}" ${c.id == selectedCountryId ? "selected" : ""}>${c.name}</option>`);
                    });
                } else {
                    $country.append(`<option value="">-- No Countries Available --</option>`);
                }
            },
            error: function () {
                console.error("Failed to load countries.");
                $country.append(`<option value="">-- Error Loading Countries --</option>`);
            }
        });
    }

       let companyId = 0; 
       let vatConfigId = 0;
    // Load existing company + VAT data
    function loadCompanyProfile() {
        $.ajax({
            url: '@Url.Action("GetMasterCompany", "Account")',
            type: "GET",
            success: function(res) {
                if (!res.status || !res.data) return;

                let c = res.data.company;
                let v = res.data.vatConfig;
                let ct = res.data.corporateTax;
                companyId = c.id || 0; // save existing company ID for update

                // Company fields
                $("#companyName").val(c.name);
                $("#address").val(c.address);
                $("#phone1").val(c.phone1);
                $("#phone2").val(c.phone2);
                $("#mobile").val(c.mobileNumber);
                $("#gmail").val(c.gmail);
                $("#website").val(c.website);
                $("#trnNo").val(c.trnNo);
                $("#countryId").val(c.countryId);
                $("#isDefaultCompany").prop("checked", c.isDefault);

                if (c.logo) $("#logoPreview").attr("src", "data:image/png;base64," + c.logo);
                if (c.stamp) $("#stampPreview").attr("src", "data:image/png;base64," + c.stamp);

                // VAT fields
                if (v) {
                     vatConfigId = v.id;
                    $("#vatRegistrationNo").val(v.registrationNo);
                    $("#vatTrnIssueDate").val(v.trnIssueDate?.substring(0, 10));

                    $("#q1Start").val(v.quarterOneStartDate?.substring(0, 10));
                    $("#q1End").val(v.quarterOneEndDate?.substring(0, 10));
                    $("#q1Due").val(v.quarterOneDueDate?.substring(0, 10));

                    $("#q2Start").val(v.quarterTwoStartDate?.substring(0, 10));
                    $("#q2End").val(v.quarterTwoEndDate?.substring(0, 10));
                    $("#q2Due").val(v.quarterTwoDueDate?.substring(0, 10));

                    $("#q3Start").val(v.quarterThreeStartDate?.substring(0, 10));
                    $("#q3End").val(v.quarterThreeEndDate?.substring(0, 10));
                    $("#q3Due").val(v.quarterThreeDueDate?.substring(0, 10));

                    $("#q4Start").val(v.quarterFourStartDate?.substring(0, 10));
                    $("#q4End").val(v.quarterFourEndDate?.substring(0, 10));
                    $("#q4Due").val(v.quarterFourDueDate?.substring(0, 10));

                    $("#corporateTaxNo").val(v.corporateTaxNo);
                    $("#corpTrnIssueDate").val(v.trnIssueDate?.substring(0, 10));
                    $("#corpStart").val(v.corporateTaxStartDate?.substring(0, 10));
                    $("#corpEnd").val(v.corporateTaxEndDate?.substring(0, 10));
                    $("#corpDue").val(v.corporateTaxDueDate?.substring(0, 10));
                }

                    if (ct) {
        $("#corporateTaxNo").val(ct.corporateTaxNo);
        $("#corpTrnIssueDate").val(ct.trnIssueDate?.substring(0, 10));
        $("#corpStart").val(ct.startDate?.substring(0, 10));
        $("#corpEnd").val(ct.endDate?.substring(0, 10));
        $("#corpDue").val(ct.dueDate?.substring(0, 10));
    }
            },
            error: function(err) {
                console.error("Failed to load company profile", err);
            }
        });
    }

    // Save Company + VAT sequentially
    function saveCompanyProfile() {
        // Gather Company data
        let companyData = {
            Id: companyId,
            Name: $("#companyName").val().trim(),
            Address: $("#address").val().trim(),
            Description: $("#address").val().trim(),
            Phone1: $("#phone1").val().trim(),
            Phone2: $("#phone2").val().trim(),
            Gmail: $("#gmail").val().trim(),
            MobileNumber: $("#mobile").val().trim(),
            Website: $("#website").val().trim(),
            TrnNo: $("#trnNo").val().trim(),
            CountryId: parseInt($("#countryId").val()) || 0,
            IsDefault: $("#isDefaultCompany").prop("checked"),
            LogoComp: null, // handle separately if needed
            StampComp: null
        };

        // Company validation
        if (!companyData.Name) { toastr.error("Please enter company name"); return; }
        if (!companyData.Description) { toastr.error("Please enter description"); return; }
        if (!companyData.Phone1) { toastr.error("Please enter phone number"); return; }
        if (companyData.CountryId <= 0) { toastr.error("Please select a country"); return; }

        // Save Company first
        $.ajax({
            url: '@Url.Action("SaveCompany", "Account")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(companyData),
            success: function(res) {
                if (!res.status) { toastr.error(res.message); return; }
                toastr.success(res.message);


                // Gather VAT data
                let vatData = {
                    Id: vatConfigId,
                    RegistrationNo: $("#vatRegistrationNo").val().trim(),
                    TRNIssueDate: $("#vatTrnIssueDate").val(),
                    QuarterOneStartDate: $("#q1Start").val(),
                    QuarterOneEndDate: $("#q1End").val(),
                    QuarterOneDueDate: $("#q1Due").val(),
                    QuarterTwoStartDate: $("#q2Start").val(),
                    QuarterTwoEndDate: $("#q2End").val(),
                    QuarterTwoDueDate: $("#q2Due").val(),
                    QuarterThreeStartDate: $("#q3Start").val(),
                    QuarterThreeEndDate: $("#q3End").val(),
                    QuarterThreeDueDate: $("#q3Due").val(),
                    QuarterFourStartDate: $("#q4Start").val(),
                    QuarterFourEndDate: $("#q4End").val(),
                    QuarterFourDueDate: $("#q4Due").val(),
                    CorporateTaxNo: $("#corporateTaxNo").val().trim(),
                    CorporateTaxStartDate: $("#corpStart").val(),
                    CorporateTaxEndDate: $("#corpEnd").val(),
                    CorporateTaxDueDate: $("#corpDue").val(),
                    TRNIssueDateCorp: $("#corpTrnIssueDate").val()
                };
    
                // VAT validation
                if (!vatData.RegistrationNo) { toastr.error("Please enter TAX Registration No"); return; }
                if (!vatData.CorporateTaxNo) { toastr.error("Please enter Corporate Tax No"); return; }

                // Save VAT
                $.ajax({
                    url: '@Url.Action("SaveVatConfig", "Account")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(vatData),
                    success: function(res2) {
                        if (!res2.status) { toastr.error(res2.message); return; }
                        toastr.success(res2.message || "VAT and Corporate Tax saved successfully");
                        setTimeout(() => location.reload(), 1500);
                    },
                    error: function(err) {
                        console.error("VAT save error", err);
                        toastr.error("Error saving VAT/Corporate Tax");
                    }
                });
            },
            error: function(err) {
                console.error("Company save error", err);
                toastr.error("Error saving company data");
            }
        });
    }







</script>

