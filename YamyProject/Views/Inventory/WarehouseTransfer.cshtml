@{
    ViewData["Title"] = "WarehouseTransfer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .warehouse-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
        text-align: center;
    }

    .employee-toolbar {
        background-color: #fff;
        margin: 0 -15px;
        padding: 15px;
        border-bottom: 1px solid #ccc;
        font-size: 14px;
        height: 400px;
    }

        .employee-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .transfer-container {
        display: flex;
        gap: 15px;
        padding: 15px;
    }

    .transfer-panel {
        flex: 1;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 15px;
        max-height: 500px;
        overflow-y: auto;
    }

        /* Add spacing between label, dropdown, search, and table */
        .transfer-panel label {
            display: block;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .transfer-panel select,
        .transfer-panel input[type="text"] {
            width: 100%;
            padding: 7px;
            margin-bottom: 15px; /* increased spacing */
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .transfer-panel table {
            width: 100%;
            border-collapse: collapse;
        }

            .transfer-panel table th,
            .transfer-panel table td {
                border-bottom: 1px solid #ccc;
                padding: 8px;
                text-align: left;
            }

    .transfer-buttons {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 10px;
        align-items: center;
    }

        .transfer-buttons input {
            width: 80px;
            padding: 5px;
        }

        .transfer-buttons button {
            width: 80px;
            padding: 5px;
        }

    .bottom-buttons {
        text-align: right;
        margin-top: 20px; /* increased spacing */
    }

        .bottom-buttons button {
            margin-left: 10px;
            padding: 7px 20px;
        }
</style>


<div class="warehouse-header">Warehouse - Transfer Items Through Warehouse</div>

<div class="employee-toolbar">
    <div class="transfer-container">
        <!-- From Warehouse -->
        <div class="transfer-panel">
            <label>From Warehouse</label>
            <select id="warehouseDropdown" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
            <input type="text" placeholder="Search By Item Name, Code" />
            <div class="table-responsive">
                <table class="table table-striped" id="transactionsBody">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>QTY</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- rows -->
                    </tbody>
                </table>
            </div>

        </div>

        <div class="transfer-buttons">
            <input type="number" id="transferQty" placeholder="QTY" min="0" step="1" />
            <button id="btnTransferTo">&raquo;</button>
            <button id="btnTransferFrom">&laquo;</button>
        </div>

        <!-- To Warehouse -->
        <div class="transfer-panel">
            <label>To Warehouse</label>
            <select id="warehouseDropdowns" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
            <input type="text" placeholder="Search By Item Name, Code" />
            <div class="table-responsive">
                <table class="table table-striped" id="transactionsBodyTO">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>QTY</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- rows -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="bottom-buttons">
        <button>Transfer History</button>
        <button>CLOSE</button>
    </div>
</div>


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script>
        $(document).ready(function () {

            // Load warehouses into both dropdowns
            function loadWarehouses() {
                $.ajax({
                    url: '/Inventory/GetWarehouses', // ✅ your API route
                    type: 'GET',
                    success: function (result) {
                        const dropdownFrom = $('#warehouseDropdown');
                        const dropdownTo = $('#warehouseDropdowns');

                        dropdownFrom.empty().append('<option value="">Select Warehouse</option>');
                        dropdownTo.empty().append('<option value="">Select Warehouse</option>');

                        if (result.status && result.data.length) {
                            result.data.forEach(w => {
                                // use 'display' field from API
                                dropdownFrom.append(`<option value="${w.id}">${w.display}</option>`);
                                dropdownTo.append(`<option value="${w.id}">${w.display}</option>`);
                            });
                        } else {
                            alert(result.message || "No warehouses found");
                        }
                    },
                    error: function (err) {
                        console.error('Error loading warehouses:', err);
                    }
                });
            }

            // Load items for "From Warehouse"
            function loadWarehouseItemsFrom(warehouseId) {
                var tbody = $('#transactionsBody tbody');
                tbody.empty();

                if (!warehouseId) return;

                $.ajax({
                    url: '/Inventory/GetWarehouseItemsFrom',
                    type: 'GET',
                    data: { warehouseId: warehouseId },
                    success: function (result) {
                        if (result.status && result.data.length) {
                            $.each(result.data, function (i, item) {
                                tbody.append(`
                                    <tr>
                                        <td>${item.itemName}</td>
                                        <td class="text-end">${parseFloat(item.qty).toFixed(2)}</td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append('<tr><td colspan="2" class="text-center">No items found</td></tr>');
                        }
                    },
                    error: function (err) {
                        console.error('Error loading warehouse items (From):', err);
                    }
                });
            }

            // Load items for "To Warehouse"
            function loadWarehouseItemsTo(warehouseId) {
                var tbody = $('#transactionsBodyTO tbody');
                tbody.empty();

                if (!warehouseId) return;

                $.ajax({
                    url: '/Inventory/GetWarehouseItemsTo',
                    type: 'GET',
                    data: { warehouseId: warehouseId },
                    success: function (result) {
                        if (result.status && result.data.length) {
                            $.each(result.data, function (i, item) {
                                tbody.append(`
                                    <tr>
                                        <td>${item.itemName}</td>
                                        <td class="text-end">${parseFloat(item.qty).toFixed(2)}</td>
                                    </tr>
                                `);
                            });
                        } else {
                            tbody.append('<tr><td colspan="2" class="text-center">No items found</td></tr>');
                        }
                    },
                    error: function (err) {
                        console.error('Error loading warehouse items (To):', err);
                    }
                });
            }

            // On change events
            $('#warehouseDropdown').on('change', function () {
                var warehouseId = $(this).val();
                loadWarehouseItemsFrom(warehouseId);
            });

            $('#warehouseDropdowns').on('change', function () {
                var warehouseId = $(this).val();
                loadWarehouseItemsTo(warehouseId);
            });

            // Init
            loadWarehouses();
                    function transferItem(sourceTable, reverse = false) {
            const selectedRow = $(sourceTable + ' tbody tr.selected');
            const qtyInput = $('#transferQty').val().trim();
            const qty = parseInt(qtyInput, 10);

            if (!selectedRow.length) {
                alert('Please select an item.');
                return;
            }

            if (isNaN(qty) || qty <= 0) {
                alert('Enter a valid quantity (1 or more).');
                return;
            }

            const availableQty = parseInt(selectedRow.data('qty'), 10);
            if (qty > availableQty) {
                alert('Entered quantity is greater than available stock.');
                return;
            }

            const itemId = selectedRow.data('item-id');
            const sourceWarehouseId = reverse ? $('#warehouseDropdowns').val() : $('#warehouseDropdown').val();
            const targetWarehouseId = reverse ? $('#warehouseDropdown').val() : $('#warehouseDropdowns').val();

            if (!sourceWarehouseId || !targetWarehouseId || sourceWarehouseId === targetWarehouseId) {
                alert('Select valid source and target warehouses.');
                return;
            }

            $.ajax({
                url: '/Inventory/TransferItem',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    SourceWarehouseId: parseInt(sourceWarehouseId),
                    TargetWarehouseId: parseInt(targetWarehouseId),
                    ItemId: parseInt(itemId),
                    Qty: qty,
                    UserId: 1 // replace with logged-in user
                }),
                success: function (result) {
                    if (result.status) {
                        toastr.success('✅ Transfer completed');
                        // Refresh tables
                        loadWarehouseItemsFrom($('#warehouseDropdown').val());
                        loadWarehouseItemsTo($('#warehouseDropdowns').val());
                        $('#transferQty').val('');
                    } else {
                        toastr.error(result.message || 'Transfer failed');
                    }
                },
                error: function (err) {
                    console.error('Transfer error:', err);
                    toastr.error('Transfer failed');
                }
            });
        }

                $('#btnTransferTo').click(() => transferItem('#transactionsBodyFrom', false));
        $('#btnTransferFrom').click(() => transferItem('#transactionsBodyTO', true));

                // Row selection
        $(document).on('click', '#transactionsBodyFrom tbody tr, #transactionsBodyTO tbody tr', function () {
            $(this).siblings().removeClass('selected');
            $(this).addClass('selected'); // only one selected at a time
        });



        });
    </script>



}
