@{
    ViewData["Title"] = "WarehouseTransfer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .warehouse-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
        text-align: center;
    }

    .employee-toolbar {
        background: #fff;
        margin: 0 -15px;
        padding: 15px;
        border-bottom: 1px solid #ccc;
        font-size: 14px;
        height: 400px;
    }

    .transfer-container {
        display: flex;
        gap: 15px;
        padding: 15px;
    }

    .transfer-panel {
        flex: 1;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 15px;
        max-height: 500px;
        overflow-y: auto;
    }

        .transfer-panel label {
            display: block;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .transfer-panel select,
        .transfer-panel input[type="text"] {
            width: 100%;
            padding: 7px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .transfer-panel table {
            width: 100%;
            border-collapse: collapse;
        }

            .transfer-panel table th,
            .transfer-panel table td {
                border-bottom: 1px solid #ccc;
                padding: 8px;
                text-align: left;
            }

    .transfer-buttons {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 10px;
        align-items: center;
    }

        .transfer-buttons input,
        .transfer-buttons button {
            width: 80px;
            padding: 5px;
        }

    .bottom-buttons {
        text-align: right;
        margin-top: 20px;
    }

        .bottom-buttons button {
            margin-left: 10px;
            padding: 7px 20px;
        }

    tr.selected {
        background-color: #d0ebff !important;
    }

    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }

    .toast-success { background-color: #51A351 !important; color: #fff !important; }
    .toast-error { background-color: #BD362F !important; color: #fff !important; }
    .toast-info { background-color: #2F96B4 !important; color: #fff !important; }
    .toast-warning { background-color: #F89406 !important; color: #fff !important; }

</style>

<div class="warehouse-header">Warehouse - Transfer Items Through Warehouse</div>

<div class="employee-toolbar">
    <div class="transfer-container">
        <!-- From Warehouse -->
        <div class="transfer-panel">
            <label>From Warehouse</label>
            <select id="warehouseDropdown" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
            <input type="text" placeholder="Search By Item Name, Code" />
            <div class="table-responsive">
                <table class="table table-striped" id="transactionsBody">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>QTY</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <div class="transfer-buttons">
            <input type="number" id="transferQty" placeholder="QTY" min="1" step="1" />
            <button id="btnTransferTo">&raquo;</button>
            <button id="btnTransferFrom">&laquo;</button>
        </div>

        <!-- To Warehouse -->
        <div class="transfer-panel">
            <label>To Warehouse</label>
            <select id="warehouseDropdowns" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
            <input type="text" placeholder="Search By Item Name, Code" />
            <div class="table-responsive">
                <table class="table table-striped" id="transactionsBodyTO">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>QTY</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="bottom-buttons">
        <button id="transferHistory">Transfer History</button>
    </div>

    <div class="modal fade" id="transferHistoryModal" tabindex="-1" aria-labelledby="transferHistoryLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="transferHistoryLabel">Transfer History</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <table id="transferHistoryTable" class="display" style="width:100%">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Warehouse From</th>
                                <th>Warehouse To</th>
                                <th>Item Name</th>
                                <th>QTY</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>



@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <!-- Buttons extension -->
    <link href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <!-- Export dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script>
        $(document).ready(function () {



          toastr.options = {
                 "closeButton": true,
                 "debug": false,
                 "newestOnTop": false,
                 "progressBar": true,
                 "positionClass": "toast-top-right",
                 "preventDuplicates": false,
                 "onclick": null,
                 "showDuration": "300",
                 "hideDuration": "1000",
                 "timeOut": "5000",
                 "extendedTimeOut": "1000",
                 "showEasing": "swing",
                 "hideEasing": "linear",
                 "showMethod": "fadeIn",
                 "hideMethod": "fadeOut"
             };
            // Load warehouses into both dropdowns
            function loadWarehouses() {
                $.get('/Inventory/GetWarehouses', function (result) {
                    const dropdownFrom = $('#warehouseDropdown');
                    const dropdownTo = $('#warehouseDropdowns');

                    dropdownFrom.empty().append('<option value="">Select Warehouse</option>');
                    dropdownTo.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status && result.data.length) {
                        result.data.forEach(w => {
                            dropdownFrom.append(`<option value="${w.id}">${w.display}</option>`);
                            dropdownTo.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        toastr.warning(result.message || "No warehouses found");
                    }
                });
            }

            // Load items into table
            function loadItems(tableSelector, warehouseId) {
                const tbody = $(`${tableSelector} tbody`);
                tbody.empty();
                if (!warehouseId) return;

                let url = tableSelector === '#transactionsBody'
                    ? '/Inventory/GetWarehouseItemsFrom'
                    : '/Inventory/GetWarehouseItemsTo';

                $.get(url, { warehouseId }, function(result) {
                    if (result.status && result.data.length) {
                        result.data.forEach(item => {
                            tbody.append(`
                                <tr data-item-id="${item.item_id}" data-qty="${item.qty}">
                                    <td>${item.itemName}</td>
                                    <td class="text-end">${parseFloat(item.qty).toFixed(2)}</td>
                                </tr>
                            `);
                        });
                        // Auto-select first row
                        tbody.find('tr:first').addClass('selected');
                    } else {
                        tbody.append('<tr><td colspan="2" class="text-center">No items found</td></tr>');
                    }
                });
            }

            // Warehouse dropdown change events
            $('#warehouseDropdown').on('change', function() {
                loadItems('#transactionsBody', $(this).val());
            });

            $('#warehouseDropdowns').on('change', function() {
                loadItems('#transactionsBodyTO', $(this).val());
            });

            // Row click selection (delegated to tbody only)
            $(document).on("click", "#transactionsBody tbody tr, #transactionsBodyTO tbody tr", function () {
                $(this).siblings().removeClass("selected");
                $(this).addClass("selected");
            });

            // Transfer function
            function transferItem(reverse) {
                let sourceTable = reverse ? '#transactionsBodyTO' : '#transactionsBody';
                let targetTable = reverse ? '#transactionsBody' : '#transactionsBodyTO';

                let $row = $(`${sourceTable} tbody tr.selected`);

                if ($row.length === 0) {
                    toastr.error("Please select an item.");
                    return;
                }

                let qty = parseFloat($("#transferQty").val());
                if (!qty || qty <= 0) {
                    toastr.error("Enter a valid quantity.");
                    return;
                }

                let availableQty = parseFloat($row.find("td:last").text());
                if (qty > availableQty) {
                    toastr.error("Not enough stock in source warehouse.");
                    return;
                }

                let itemId = $row.data("item-id");

                let sourceWarehouseId = reverse ? $('#warehouseDropdowns').val() : $('#warehouseDropdown').val();
                let targetWarehouseId = reverse ? $('#warehouseDropdown').val() : $('#warehouseDropdowns').val();

                if (!sourceWarehouseId || !targetWarehouseId) {
                    toastr.error("Please select both source and target warehouses.");
                    return;
                }

                $.ajax({
                    url: '/Inventory/TransferItem',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        SourceWarehouseId: parseInt(sourceWarehouseId),
                        TargetWarehouseId: parseInt(targetWarehouseId),
                        ItemId: parseInt(itemId),
                        Qty: qty,
                        UserId: 1
                    }),
                    success: function(result) {
                        if (result.status) {
                            toastr.success('✅ Transfer completed');
                            // reload both tables
                            loadItems('#transactionsBody', $('#warehouseDropdown').val());
                            loadItems('#transactionsBodyTO', $('#warehouseDropdowns').val());
                            $('#transferQty').val('');
                        } else {
                            toastr.error(result.message || 'Transfer failed');
                        }
                    },
                    error: function(err) {
                        toastr.error(err.responseJSON?.message || 'Transfer failed');
                    }
                });
            }

            // Button click events
            $("#btnTransferTo").click(() => transferItem(false));
            $("#btnTransferFrom").click(() => transferItem(true));

            // Initial load
            loadWarehouses();

                    $("#transferHistory").click(function() {
            var modal = new bootstrap.Modal(document.getElementById('transferHistoryModal'));
            modal.show();

            if ($.fn.DataTable.isDataTable('#transferHistoryTable')) {
                $('#transferHistoryTable').DataTable().destroy();
                $('#transferHistoryTable tbody').empty();
            }

            $('#transferHistoryTable').DataTable({
                ajax: {
                    url: '/Inventory/GetWarehouseTransfers',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'date' },
                    { data: 'warehouseFrom' },
                    { data: 'warehouseTo' },
                    { data: 'itemName' },
                    { data: 'qty' },
                    { data: 'description' }
                ],
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'excelHtml5',   text: '<i class="fas fa-file-excel me-1"></i> Excel',  className: 'btn btn-primary btn-sm'},
                    { extend: 'pdfHtml5',  text: '<i class="fas fa-file-pdf me-1"></i> PDF',  className: 'btn btn-primary btn-sm'}
                ]
            });
        });
            // Close modal
            $("#closeHistory").click(function(){
                $("#transferHistoryModal").hide();
            });

        });
    </script>
}

                  @*   // ✅ Initialize DataTable with export buttons
                    $('#transactionsTable').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                className: 'btn btn-primary btn-sm'
                            },
                            {
                                extend: 'pdfHtml5',
                                text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                className: 'btn btn-primary btn-sm',
                                orientation: 'landscape',
                                pageSize: 'A4'
                            }
                        ],
                        order: [[0, 'asc']],
                        pageLength: 5
                    }); *@