@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(function () {
            // Open Manager modal from Warehouse modal
            $('.openManagerNew').on('click', function (e) {
                e.preventDefault();
                // hide warehouse modal then show manager modal
                $('#newWarehouseModal').modal('hide');
                $('#newManagerModal').modal('show');
            });

            // When manager modal hides, show warehouse modal back (if needed)
            $('#newManagerModal').on('hidden.bs.modal', function () {
                // only show warehouse if it was open before; simple approach: always show
                $('#newWarehouseModal').modal('show');
            });
                // Tab switching functionality
            document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();

                // Remove active class from all tabs and content
                document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
                document.querySelectorAll('.tab-pane').forEach(pane => {
                    pane.classList.remove('show', 'active');
                });

                // Add active class to clicked tab
                this.classList.add('active');

                // Show corresponding content
                const target = document.querySelector(this.getAttribute('data-bs-target'));
                if (target) {
                    target.classList.add('show', 'active');
                }
            });
        });

            // Handle Save Manager form submit (adds manager to select and closes)
            $('#newManagerForm').submit(function (e) {
                e.preventDefault();
                const name = $('#managerName').val().trim();
                if (!name) {
                    alert('Please enter manager name.');
                    return;
                }
                // create a temporary id for the new manager (replace with server id if you persist)
                const newId = 'm' + Date.now();
                $('#manager').append($('<option>', {
                    value: newId,
                    text: name,
                    selected: true
                }));
                // reset manager form
                $('#newManagerForm')[0].reset();
                // close manager modal (will re-open warehouse modal because of hidden handler)
                $('#newManagerModal').modal('hide');
            });

             $("#newWarehouseForm").submit(function (e) {
            e.preventDefault();

            let model = {
                Id: 0,
                Name: $("#warehouseName").val(),
                City: $("#city").val(),
                BuildingName: $("#buildingName").val(),
                EmpId: parseInt($("#manager").val()) || null,
                AccountId: parseInt($("#mainAccount").val()) || null,  
            };

            $.ajax({
                url: "/Inventory/SaveWarehouse",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                success: function (res) {
                    if (res && res.status) {
                        alert(res.message);
                        $("#warehouseCode").val(res.code);
                        $("#newWarehouseModal").modal("hide");
                        $("#newWarehouseForm")[0].reset();
                    } else {
                        alert(res?.message || "Save failed");
                    }
                },
                error: function (xhr) {
                    alert("Error: " + (xhr.responseJSON?.message || xhr.statusText));
                }
            });
        });



        // Load warehouses into dropdown
        function loadWarehouses() {
            $.ajax({
                url: '/Inventory/GetWarehouses', // your API route
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        result.data.forEach(w => {
                            // use 'display' field from API
                            dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        alert(result.message);
                    }
                },
                error: function(err) {
                    console.error(err);
                }
            });
        }


        // Call on page load
        loadWarehouses();

        });
    </script>
}
