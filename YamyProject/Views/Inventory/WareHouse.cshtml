@{
    ViewData["Title"] = "WareHouse";
}

<style>
    .warehouse-header {
        background: #4472c4;
        color: white;
        margin: -15px -15px 0 -15px;
        padding: 8px 15px;
        font-weight: bold;
    }

    .employee-toolbar {
        background: #e7e6e6;
        margin: 0 -15px;
        padding: 5px 15px;
        border-bottom: 1px solid #ccc;
        font-size: 12px;
    }

        .employee-toolbar .nav-link {
            color: #333;
            padding: 2px 8px;
            font-size: 12px;
        }

    .dataTables_wrapper {
        padding: 50px;
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<div class="warehouse-header">
    <center> WareHouse Center</center>
</div>
<div class="employee-toolbar">
    <div class="container">

        <!-- Top Controls -->
        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <ul class="nav nav-pills">
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                            <i class="bi bi-gear-fill me-1"></i> Warehouse Operations
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newWarehouseModal">
                                    <i class="bi bi-plus-circle me-2"></i> New Warehouse
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item me-2">
                        <a class="nav-link" href="/Inventory/WarehouseTransfer" id="btnTransfer">
                            <i class="bi bi-arrow-left-right me-1"></i> Transfer Items
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" id="btnHistory">
                            <i class="bi bi-clock-history me-1"></i> Transfer History
                        </a>
                    </li>
                </ul>
            </div>
            <div class="col-md-4">
                <select id="warehouseDropdown" class="form-select">
                    <option value="">Select Warehouse</option>
                </select>
            </div>
        </div>

        <div class="row">
            <!-- Warehouse Table -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="warehouseTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Warehouse</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- rows -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Items Table -->
            <div class="col-md-8">
                <div class="card shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-striped custom-table mb-0" id="itemsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Barcode</th>
                                        <th>Cost Price</th>
                                        <th>Sales Price</th>
                                        <th>Quantity</th>
                                        <th>Type</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- rows -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</div>


<div class="modal fade" id="newWarehouseModal" tabindex="-1" aria-labelledby="newWarehouseLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="newWarehouseLabel">New Warehouse</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="newWarehouseForm">
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Code</label>
                            <input type="text" class="form-control" id="warehouseCode" disabled placeholder="Auto">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Name</label>
                            <input type="text" class="form-control" id="warehouseName" placeholder="Enter warehouse name" required>
                        </div>
                    </div>
                    <input type="hidden" id="warehouseId" value="0" />


                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Manager</label>
                            <select class="form-select" id="manager">
                                <option value="">Select Manager</option>
                                <!-- Employees will be appended here -->
                            </select>
                            <a href="#" class="openEmployeeNew text-primary text-decoration-underline">New</a>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <select class="form-select" id="city">
                                <option value="">Select City</option>
                                <option value="Dubai">Dubai</option>
                                <option value="Abu Dhabi">Abu Dhabi</option>
                                <option value="Sharjah">Sharjah</option>
                                <option value="Ajman">Ajman</option>
                                <option value="Umm Al-Quwain">Umm Al-Quwain</option>
                                <option value="Ras Al Khaima">Ras Al Khaima</option>
                                <option value="Fujairah">Fujairah</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Building Name</label>
                            <input type="text" class="form-control" id="buildingName" placeholder="Enter building name">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Main Account</label>
                            <select id="accruedSalaries" class="form-select form-select-sm">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Warehouse Modal -->
<div class="modal fade" id="editWarehouseModal" tabindex="-1" aria-labelledby="editWarehouseLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title" id="editWarehouseLabel">Edit Warehouse</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="editWarehouseForm">
                <div class="modal-body">
                    <input type="hidden" id="editWarehouseId" value="0" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Code</label>
                            <input type="text" class="form-control" id="editWarehouseCode" disabled placeholder="Auto">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Name</label>
                            <input type="text" class="form-control" id="editWarehouseName" placeholder="Enter warehouse name" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Manager</label>
                            <select class="form-select" id="editManager">
                                <option value="">Select Manager</option>
                                <!-- Employees will be appended here -->
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <select class="form-select" id="editCity">
                                <option value="">Select City</option>
                                <option value="Dubai">Dubai</option>
                                <option value="Abu Dhabi">Abu Dhabi</option>
                                <option value="Sharjah">Sharjah</option>
                                <option value="Ajman">Ajman</option>
                                <option value="Umm Al-Quwain">Umm Al-Quwain</option>
                                <option value="Ras Al Khaima">Ras Al Khaima</option>
                                <option value="Fujairah">Fujairah</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Building Name</label>
                            <input type="text" class="form-control" id="editBuildingName" placeholder="Enter building name">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Main Account</label>
                            <select id="editaccruedSalaries" class="form-select form-select-sm">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-warning">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

