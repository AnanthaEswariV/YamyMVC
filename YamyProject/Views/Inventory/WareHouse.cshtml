@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

    <script>

          toastr.options = {
                 "closeButton": true,
                 "debug": false,
                 "newestOnTop": false,
                 "progressBar": true,
                 "positionClass": "toast-top-right",
                 "preventDuplicates": false,
                 "onclick": null,
                 "showDuration": "300",
                 "hideDuration": "1000",
                 "timeOut": "5000",
                 "extendedTimeOut": "1000",
                 "showEasing": "swing",
                 "hideEasing": "linear",
                 "showMethod": "fadeIn",
                 "hideMethod": "fadeOut"
             };

        $(function () {

         $("#newWarehouseForm").submit(function (e) {
            e.preventDefault();

            let model = {
                Id: parseInt($("#warehouseId").val()) || 0, // 0 = add, >0 = edit
                Name: $("#warehouseName").val(),
                City: $("#city").val(),
                BuildingName: $("#buildingName").val(),
                EmpId: parseInt($("#manager").val()) || null,
                AccountId: parseInt($("#accruedSalaries").val()) || null,
            };

            $.ajax({
                url: "/Inventory/SaveWarehouse",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                success: function (res) {
                    if (res && res.status) {
                        // Show success notification
                        toastr.success(res.message || "Warehouse saved successfully!");

                        // Update form fields if needed
                        $("#warehouseCode").val(res.code || "");
                        $("#newWarehouseModal").modal("hide");
                        $("#newWarehouseForm")[0].reset();
                        $("#warehouseId").val(0);

                        // Optional: reload page or table
                        setTimeout(function () {
                            location.reload(); 
                        }, 1500);
                    } else {
                        // Show error notification
                        toastr.error(res?.message || "Failed to save warehouse");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Server error");
                }
            });
        });


        var table = $('#itemsTable').DataTable({
            columns: [
                { data: 'itemName' },
                { data: 'barcode' },
                { data: 'costPrice' },
                { data: 'salesPrice' },
                { data: 'qty' },
                { data: 'type' }
            ]
        });

        // Load warehouses into dropdown
        function loadWarehouses() {
            $.ajax({
                url: '/Inventory/GetWarehouses', // your API route
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        result.data.forEach(w => {
                            // use 'display' field from API
                            dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        alert(result.message);
                    }
                },
                error: function(err) {
                    console.error(err);
                }
            });
        }

        // Call on page load
        loadWarehouses();
        loadWarehouse();

            // Load items when warehouse is selected
        $('#warehouseDropdown').change(function () {
            let warehouseId = $(this).val();
            if (!warehouseId) {
                table.clear().draw();
                return;
            }

            $.ajax({
                url: '/Inventory/GetWarehouseItems?warehouseId=' + warehouseId,
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        table.clear().rows.add(res.data).draw();
                    } else {
                        table.clear().draw();
                        toastr.warning("No items found");
                    }
                },
                error: function () {
                    toastr.error("Failed to load items");
                }
            });
        });

         // Open Employee modal from Warehouse modal
        $('.openEmployeeNew').on('click', function (e) {
            e.preventDefault();

            // Hide Warehouse modal first
            $('#newWarehouseModal').modal('hide');

            // Then show Employee modal
            $('#newEmployeeModal').modal('show');
        });

        // When Employee modal closes, bring Warehouse modal back
        $('#newEmployeeModal').on('hidden.bs.modal', function () {
            $('#newWarehouseModal').modal('show');
        });

        function loadWarehouse() {
            $.ajax({
                url: '/Inventory/GetWarehouses',
                type: 'GET',
                success: function (res) {
                    console.log("✅ Warehouse API Response:", res); // log full response

                    let tbody = $("#warehouseTable tbody");
                    tbody.empty();

                    if (res.status && res.data.length > 0) {
                        res.data.forEach((w, index) => {
                            tbody.append(`
                                <tr>
                                    <td>${w.display}</td>
                                    <td class="text-center">
                                              <button class="btn btn-sm btn-outline-primary edit-warehouse"
                data-id="${w.id}"
                data-code="${w.code}"
                data-name="${w.name}"
                data-empid="${w.empId}"
                data-city="${w.city}"
                data-building="${w.buildingName}"
                data-accountid="${w.accountId}">
            <i class="bi bi-pencil-square"></i>
        </button>

                                        <button class="btn btn-sm btn-outline-danger delete-warehouse" data-id="${w.id}">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `);
                        });
                    } else {
                        tbody.append(`
                            <tr>
                                <td colspan="2" class="text-center text-muted">No warehouses found</td>
                            </tr>
                        `);
                    }
                },
                error: function () {
                    toastr.error("❌ Failed to load warehouses");
                }
            });
        }


        $(document).on("click", ".edit-warehouse", function() {
            const btn = $(this);


            $("#editWarehouseId").val(btn.data("id"));
            $("#editWarehouseCode").val(btn.data("code"));
            $("#editWarehouseName").val(btn.data("name"));
            $("#editManager").val(btn.data("empid"));
            $("#editCity").val(btn.data("city"));
            $("#editBuildingName").val(btn.data("building"));
            $("#editaccruedSalaries").val(btn.data("accountid"));

            $("#editWarehouseModal").modal("show");
        });

        $("#editWarehouseForm").submit(function(e) {
            e.preventDefault();

            let model = {
                Id: parseInt($("#editWarehouseId").val()),
                Name: $("#editWarehouseName").val(),
                City: $("#editCity").val(),
                BuildingName: $("#editBuildingName").val(),
                EmpId: parseInt($("#editManager").val()) || null,
                AccountId: parseInt($("#editaccruedSalaries").val()) || null
            };

            $.ajax({
                url: "/Inventory/EditWarehouse",
                type: "PUT",
                contentType: "application/json",
                data: JSON.stringify(model),
                success: function(res) {
                    if(res.status) {
                        toastr.success(res.message);
                        $("#editWarehouseModal").modal("hide");
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function(xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });

        // Delete warehouse
        $(document).on("click", ".delete-warehouse", function() {
            const id = $(this).data("id");

            if(confirm("Are you sure you want to delete this warehouse?")) {
                        $.ajax({
        url: `/Inventory/DeleteWarehouse/${id}`,
                    type: "DELETE",
                    success: function(res) {
                        if(res && res.status) {
                            toastr.success(res.message || "Warehouse deleted successfully");
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            toastr.error(res.message || "Failed to delete warehouse");
                        }
                    },
                    error: function(xhr) {
                        toastr.error(xhr.responseJSON?.message || xhr.statusText);
                    }
                });
            }
        });


        });

        function loadManagersDropdown(selectedId = null) {
            $.getJSON('/Inventory/GetAllEmployees', function(employees) {
                const $manager = $('#manager');
                $manager.empty().append('<option value="">Select Manager</option>');

                employees.forEach(emp => {
                    const selected = selectedId && emp.id === selectedId ? 'selected' : '';
                    $manager.append(`<option value="${emp.id}" ${selected}>${emp.name}</option>`);
                });
            });
        }


           function loadeditManagersDropdown(selectedId = null) {
            $.getJSON('/Inventory/GetAllEmployees', function(employees) {
                const $manager = $('#editManager');
                $manager.empty().append('<option value="">Select Manager</option>');

                employees.forEach(emp => {
                    const selected = selectedId && emp.id === selectedId ? 'selected' : '';
                    $manager.append(`<option value="${emp.id}" ${selected}>${emp.name}</option>`);
                });
            });
        }

        // Call this on page load
        $(document).ready(function() {
            loadManagersDropdown();
            loadeditManagersDropdown();
        });

         $(document).on('click', '.openEmployeeNew', function(e) {
            e.preventDefault();

            // Reset form for adding new employee
            $('#newEmployeeForm')[0].reset();
            $('#EmployeeId').val(''); // clear ID for Add mode
            $('#cityDropdown').html('<option value="">-- Select --</option>'); // reset city dropdown
            $('#saveOrUpdateBtn').data('action', 'save').text('Save'); // set save mode

            // Show the modal
            $('#newEmployeeModal').modal('show');
        });

          // Form submit handler
        $('#newEmployeeForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;                      // <<--- fix for "form is not defined"
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            // Decide create vs update by EmployeeId presence (robust)
            const idVal = $('#EmployeeId').val();
            const isEdit = idVal && parseInt(idVal) > 0;
            const url = isEdit ? '/HR/EditEmployee' : '/HR/SaveEmployee';

            // Build payload - prefer explicit IDs. Keep this list in sync with your modal IDs.
            const employeeData = {
                Id: isEdit ? parseInt(idVal) : 0,
                Name: $('input[name="EmployeeName"]').val() || '',
                BirthDay: $('#BirthDay').val() || null,
                SocialStatus: $('#SocialStatus').val() || '',
                CountryId: $('#countryDropdown').val() ? parseInt($('#countryDropdown').val()) : null,
                CityId: $('#cityDropdown').val() ? parseInt($('#cityDropdown').val()) : null,
                Address: $('#Address').val() || '',
                Phone: $('#Phone').val() || '',
                Email: $('#Email').val() || '',
                SocialInsuranceNumber: $('#SocialInsuranceNumber').val() || '',
                EmergencyName: $('#EmergencyName').val() || '',
                EmergencyAddress: $('#EmergencyAddress').val() || '',
                EmergencyPhone: $('#EmergencyPhone').val() || '',
                Relation: $('#Relation').val() || '',
                PassportNumber: $('#PassportNumber').val() || '',
                PassportIssueDate: $('#PassportIssueDate').val() || null,
                PassportExpiryDate: $('#PassportExpiryDate').val() || null,
                WorkContractNumber: $('#ContractNumber').val() || '',
                PositionId: $('#PositionId').val() ? parseInt($('#PositionId').val()) : null,
                DepartmentId: $('#DepartmentId').val() ? parseInt($('#DepartmentId').val()) : null,
                WorkContractType: $('#ContractType').val() || '',
                WorkDays: $('input[name="WorkDays"]').val() || '',
                WorkingHours: $('input[name="WorkingHours"]').val() || '',
                ContractIssueDate: $('#ContractIssueDate').val() || null,
                ContractExpiryDate: $('#ContractExpiryDate').val() || null,
                ResidencyFileNumber: $('#ResidencyFileNumber').val() || '',
                ResidencyIssuingAuthority: $('#ResidencyIssuingAuthority').val() || '',
                ResidencyIssueDate: $('#ResidencyIssueDate').val() || null,
                ResidencyExpiryDate: $('#ResidencyExpiryDate').val() || null,
                EmiratesIdfileNumber: $('#EmiratesIdFileNumber').val() || '',
                EmiratesIdissuingAuthority: $('#EmiratesIdIssuingAuthority').val() || '',
                EmiratesIdissueDate: $('#EmiratesIdIssueDate').val() || null,
                EmiratesIdexpiryDate: $('#EmiratesIdExpiryDate').val() || null,
                BasicSalary: parseFloat($('#basicSalary').val()) || 0,
                HousingAllowance: parseFloat($('#houseAllowance').val()) || 0,
                TransportationAllowance: parseFloat($('#transportAllowance').val()) || 0,
                Other: parseFloat($('#otherAllowance').val()) || 0,
                AccountId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                BankId: $('#BankId').val() ? parseInt($('#BankId').val()) : null,
                IbanNumber: $('#IbanNumber').val() || '',
                BankAccountNumber: $('#BankAccountNumber').val() || '',
                EmployeeRecivableId: $('#code2').val() ? parseInt($('#code2').val()) : null,
                AccruedSalariesId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                AcroalLeaveSalaryId: $('#code3').val() ? parseInt($('#code3').val()) : null,
                GratuitId: $('#code4').val() ? parseInt($('#code4').val()) : null,
                PettyCashId: 0,
                Active: $('#employeeActive').is(':checked') ? 1 : 0
            };

            console.log((isEdit ? 'Updating' : 'Saving') + ' employee:', employeeData);

            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(employeeData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? 'Employee updated successfully' : 'Employee saved successfully');
                            $('#newEmployeeModal').modal('hide'); // Optional: reload page or table
                            setTimeout(function () {
                                location.reload(); // or call a function to reload table/dropdown
                            }, 1500);
                    } else {
                        toastr.error(res.message || 'Operation failed');
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Something went wrong');
                }
            });
        });



              $(document).ready(function () {
                $.ajax({
                    url: '/HR/GetAccruedSalaries',
                    type: 'GET',
                    success: function (data) {
                        console.log("✅ API Response:", data);

                        // List of dropdowns with their matching code textbox
                        const dropdowns = [
                            { ddl: '#accruedSalaries' }
                        ];

                        dropdowns.forEach(set => {
                            let $ddl = $(set.ddl);
                            console.log("Found dropdown?", set.ddl, $ddl.length);

                            $ddl.empty().append('<option value="">-- Select --</option>');

                            $.each(data, function (i, item) {
                                $ddl.append(
                                    $('<option>', {
                                        value: item.id,
                                        text: item.code + ' - ' + item.name,
                                        'data-code': item.code
                                    })
                                );
                            });

                            console.log("Total options now for", set.ddl, ":", $ddl.find('option').length);

                            // On change, update the code textbox
                            $ddl.on('change', function () {
                                let selected = $(this).find(':selected');
                                let code = selected.data('code');
                                console.log("Selected in", set.ddl, ":", selected.text(), "Code:", code);
                                $(set.codeBox).val(code || "");
                            });
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("❌ Error loading accounts:", status, error);
                    }
                });
            });


              $(document).ready(function () {
                $.ajax({
                    url: '/HR/GetAccruedSalaries',
                    type: 'GET',
                    success: function (data) {
                        console.log("✅ API Response:", data);

                        // List of dropdowns with their matching code textbox
                        const dropdowns = [
                            { ddl: '#editaccruedSalaries' }
                        ];

                        dropdowns.forEach(set => {
                            let $ddl = $(set.ddl);
                            console.log("Found dropdown?", set.ddl, $ddl.length);

                            $ddl.empty().append('<option value="">-- Select --</option>');

                            $.each(data, function (i, item) {
                                $ddl.append(
                                    $('<option>', {
                                        value: item.id,
                                        text: item.code + ' - ' + item.name,
                                        'data-code': item.code
                                    })
                                );
                            });

                            console.log("Total options now for", set.ddl, ":", $ddl.find('option').length);

                            // On change, update the code textbox
                            $ddl.on('change', function () {
                                let selected = $(this).find(':selected');
                                let code = selected.data('code');
                                console.log("Selected in", set.ddl, ":", selected.text(), "Code:", code);
                                $(set.codeBox).val(code || "");
                            });
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("❌ Error loading accounts:", status, error);
                    }
                });
            });


    </script>
}
