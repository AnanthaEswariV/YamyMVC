@{
    ViewData["Title"] = "WareHouse";
}

<div class="container">

    <!-- Top Controls -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <ul class="nav nav-pills">
                <li class="nav-item dropdown me-2">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                        <i class="bi bi-gear-fill me-1"></i> Warehouse Operations
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newWarehouseModal">
                                <i class="bi bi-plus-circle me-2"></i> New Warehouse
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#" id="btnEdit">
                                <i class="bi bi-pencil-square me-2"></i> Edit Warehouse
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#" id="btnDelete">
                                <i class="bi bi-trash-fill me-2"></i> Delete Warehouse
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="nav-item me-2">
                    <a class="nav-link" href="#" id="btnTransfer">
                        <i class="bi bi-arrow-left-right me-1"></i> Transfer Items
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" id="btnHistory">
                        <i class="bi bi-clock-history me-1"></i> Transfer History
                    </a>
                </li>
            </ul>
        </div>
        <div class="col-md-4">
            <select id="warehouseDropdown" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
        </div>
    </div>

    <!-- Items Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>Barcode</th>
                            <th>Cost Price</th>
                            <th>Sales Price</th>
                            <th>Quantity</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- rows -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="newWarehouseModal" tabindex="-1" aria-labelledby="newWarehouseLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="newWarehouseLabel">New Warehouse</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="newWarehouseForm">
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Code</label>
                            <input type="text" class="form-control" id="warehouseCode" disabled placeholder="Auto">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Name</label>
                            <input type="text" class="form-control" id="warehouseName" placeholder="Enter warehouse name" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Manager</label>
                            <select class="form-select" id="manager">
                                <option value="">Select Manager</option>
                                <option value="1">John Smith</option>
                                <option value="2">Sarah Johnson</option>
                                <option value="3">Mike Wilson</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <select class="form-select" id="city">
                                <option value="">Select City</option>
                                <option value="Dubai" selected>Dubai</option>
                                <option value="Abu Dhabi">Abu Dhabi</option>
                                <option value="Sharjah">Sharjah</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Building Name</label>
                            <input type="text" class="form-control" id="buildingName" placeholder="Enter building name">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Main Account</label>
                            <select class="form-select" id="mainAccount">
                                <option value="">Select Account</option>
                                <option value="110001" selected>110001 - Bank Account</option>
                                <option value="110002">110002 - Cash Account</option>
                                <option value="110003">110003 - Petty Cash</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>


