@{
    ViewData["Title"] = "WareHouse";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="container">

    <!-- Top Controls -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <ul class="nav nav-pills">
                <li class="nav-item dropdown me-2">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                        <i class="bi bi-gear-fill me-1"></i> Warehouse Operations
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="#" id="btnNew" data-bs-toggle="modal" data-bs-target="#newWarehouseModal">
                                <i class="bi bi-plus-circle me-2"></i> New Warehouse
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#" id="btnEdit">
                                <i class="bi bi-pencil-square me-2"></i> Edit Warehouse
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#" id="btnDelete">
                                <i class="bi bi-trash-fill me-2"></i> Delete Warehouse
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="nav-item me-2">
                    <a class="nav-link" href="#" id="btnTransfer">
                        <i class="bi bi-arrow-left-right me-1"></i> Transfer Items
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" id="btnHistory">
                        <i class="bi bi-clock-history me-1"></i> Transfer History
                    </a>
                </li>
            </ul>
        </div>
        <div class="col-md-4">
            <select id="warehouseDropdown" class="form-select">
                <option value="">Select Warehouse</option>
            </select>
        </div>
    </div>

    <!-- Items Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th>Barcode</th>
                            <th>Cost Price</th>
                            <th>Sales Price</th>
                            <th>Quantity</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- rows -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="newWarehouseModal" tabindex="-1" aria-labelledby="newWarehouseLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="newWarehouseLabel">New Warehouse</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="newWarehouseForm">
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Code</label>
                            <input type="text" class="form-control" id="warehouseCode" disabled placeholder="Auto">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Warehouse Name</label>
                            <input type="text" class="form-control" id="warehouseName" placeholder="Enter warehouse name" required>
                        </div>
                    </div>
                    <input type="hidden" id="warehouseId" value="0" />


                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Manager</label>
                            <select class="form-select" id="manager">
                                <option value="">Select Manager</option>
                                <!-- Employees will be appended here -->
                            </select>
                            <a href="#" class="openEmployeeNew text-primary text-decoration-underline">New</a>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <select class="form-select" id="city">
                                <option value="">Select City</option>
                                <option value="Dubai" selected>Dubai</option>
                                <option value="Abu Dhabi">Abu Dhabi</option>
                                <option value="Sharjah">Sharjah</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Building Name</label>
                            <input type="text" class="form-control" id="buildingName" placeholder="Enter building name">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Main Account</label>
                            <select class="form-select" id="mainAccount">
                                <option value="">Select Account</option>
                                <option value="110001" selected>110001 - Bank Account</option>
                                <option value="110002">110002 - Cash Account</option>
                                <option value="110003">110003 - Petty Cash</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- 🔽 Employee Modal Partial -->
@Html.Partial("~/Views/HR/_Employee.cshtml")


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>

          toastr.options = {
                 "closeButton": true,
                 "debug": false,
                 "newestOnTop": false,
                 "progressBar": true,
                 "positionClass": "toast-top-right",
                 "preventDuplicates": false,
                 "onclick": null,
                 "showDuration": "300",
                 "hideDuration": "1000",
                 "timeOut": "5000", 
                 "extendedTimeOut": "1000",
                 "showEasing": "swing",
                 "hideEasing": "linear",
                 "showMethod": "fadeIn",
                 "hideMethod": "fadeOut"
             };


        $(function () {

         $("#newWarehouseForm").submit(function (e) {
            e.preventDefault();

            let model = {
                Id: parseInt($("#warehouseId").val()) || 0, // 0 = add, >0 = edit
                Name: $("#warehouseName").val(),
                City: $("#city").val(),
                BuildingName: $("#buildingName").val(),
                EmpId: parseInt($("#manager").val()) || null,
                AccountId: parseInt($("#mainAccount").val()) || null,
            };

            $.ajax({
                url: "/Inventory/SaveWarehouse",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(model),
                success: function (res) {
                    if (res && res.status) {
                        // Show success notification
                        toastr.success(res.message || "Warehouse saved successfully!");

                        // Update form fields if needed
                        $("#warehouseCode").val(res.code || "");
                        $("#newWarehouseModal").modal("hide");
                        $("#newWarehouseForm")[0].reset();
                        $("#warehouseId").val(0); // reset Id for next insert

                        // Optional: reload page or table
                        setTimeout(function () {
                            location.reload(); // or call a function to reload table/dropdown
                        }, 1500);
                    } else {
                        // Show error notification
                        toastr.error(res?.message || "Failed to save warehouse");
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || "Server error");
                }
            });
        });

        // Load warehouses into dropdown
        function loadWarehouses() {
            $.ajax({
                url: '/Inventory/GetWarehouses', // your API route
                type: 'GET',
                success: function(result) {
                    const dropdown = $('#warehouseDropdown');
                    dropdown.empty().append('<option value="">Select Warehouse</option>');

                    if (result.status) {
                        result.data.forEach(w => {
                            // use 'display' field from API
                            dropdown.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        alert(result.message);
                    }
                },
                error: function(err) {
                    console.error(err);
                }
            });
        }

        // Call on page load
        loadWarehouses();


         // Open Employee modal from Warehouse modal
        $('.openEmployeeNew').on('click', function (e) {
            e.preventDefault();

            // Hide Warehouse modal first
            $('#newWarehouseModal').modal('hide');

            // Then show Employee modal
            $('#newEmployeeModal').modal('show');
        });

        // When Employee modal closes, bring Warehouse modal back
        $('#newEmployeeModal').on('hidden.bs.modal', function () {
            $('#newWarehouseModal').modal('show');
        });

        });


                function loadManagersDropdown(selectedId = null) {
            $.getJSON('/Inventory/GetAllEmployees', function(employees) {
                const $manager = $('#manager');
                $manager.empty().append('<option value="">Select Manager</option>');

                employees.forEach(emp => {
                    const selected = selectedId && emp.id === selectedId ? 'selected' : '';
                    $manager.append(`<option value="${emp.id}" ${selected}>${emp.name}</option>`);
                });
            });
        }

        // Call this on page load
        $(document).ready(function() {
            loadManagersDropdown();
        });


                $(document).on('click', '.openEmployeeNew', function(e) {
            e.preventDefault();

            // Reset form for adding new employee
            $('#newEmployeeForm')[0].reset();
            $('#EmployeeId').val(''); // clear ID for Add mode
            $('#cityDropdown').html('<option value="">-- Select --</option>'); // reset city dropdown
            $('#saveOrUpdateBtn').data('action', 'save').text('Save'); // set save mode

            // Show the modal
            $('#newEmployeeModal').modal('show');
        });

          // Form submit handler
        $('#newEmployeeForm').on('submit', function (e) {
            e.preventDefault();

            const form = this;                      // <<--- fix for "form is not defined"
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            // Decide create vs update by EmployeeId presence (robust)
            const idVal = $('#EmployeeId').val();
            const isEdit = idVal && parseInt(idVal) > 0;
            const url = isEdit ? '/HR/EditEmployee' : '/HR/SaveEmployee';

            // Build payload - prefer explicit IDs. Keep this list in sync with your modal IDs.
            const employeeData = {
                Id: isEdit ? parseInt(idVal) : 0,
                Name: $('input[name="EmployeeName"]').val() || '',
                BirthDay: $('#BirthDay').val() || null,
                SocialStatus: $('#SocialStatus').val() || '',
                CountryId: $('#countryDropdown').val() ? parseInt($('#countryDropdown').val()) : null,
                CityId: $('#cityDropdown').val() ? parseInt($('#cityDropdown').val()) : null,
                Address: $('#Address').val() || '',
                Phone: $('#Phone').val() || '',
                Email: $('#Email').val() || '',
                SocialInsuranceNumber: $('#SocialInsuranceNumber').val() || '',
                EmergencyName: $('#EmergencyName').val() || '',
                EmergencyAddress: $('#EmergencyAddress').val() || '',
                EmergencyPhone: $('#EmergencyPhone').val() || '',
                Relation: $('#Relation').val() || '',
                PassportNumber: $('#PassportNumber').val() || '',
                PassportIssueDate: $('#PassportIssueDate').val() || null,
                PassportExpiryDate: $('#PassportExpiryDate').val() || null,
                WorkContractNumber: $('#ContractNumber').val() || '',
                PositionId: $('#PositionId').val() ? parseInt($('#PositionId').val()) : null,
                DepartmentId: $('#DepartmentId').val() ? parseInt($('#DepartmentId').val()) : null,
                WorkContractType: $('#ContractType').val() || '',
                WorkDays: $('input[name="WorkDays"]').val() || '',
                WorkingHours: $('input[name="WorkingHours"]').val() || '',
                ContractIssueDate: $('#ContractIssueDate').val() || null,
                ContractExpiryDate: $('#ContractExpiryDate').val() || null,
                ResidencyFileNumber: $('#ResidencyFileNumber').val() || '',
                ResidencyIssuingAuthority: $('#ResidencyIssuingAuthority').val() || '',
                ResidencyIssueDate: $('#ResidencyIssueDate').val() || null,
                ResidencyExpiryDate: $('#ResidencyExpiryDate').val() || null,
                EmiratesIdfileNumber: $('#EmiratesIdFileNumber').val() || '',
                EmiratesIdissuingAuthority: $('#EmiratesIdIssuingAuthority').val() || '',
                EmiratesIdissueDate: $('#EmiratesIdIssueDate').val() || null,
                EmiratesIdexpiryDate: $('#EmiratesIdExpiryDate').val() || null,
                BasicSalary: parseFloat($('#basicSalary').val()) || 0,
                HousingAllowance: parseFloat($('#houseAllowance').val()) || 0,
                TransportationAllowance: parseFloat($('#transportAllowance').val()) || 0,
                Other: parseFloat($('#otherAllowance').val()) || 0,
                AccountId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                BankId: $('#BankId').val() ? parseInt($('#BankId').val()) : null,
                IbanNumber: $('#IbanNumber').val() || '',
                BankAccountNumber: $('#BankAccountNumber').val() || '',
                EmployeeRecivableId: $('#code2').val() ? parseInt($('#code2').val()) : null,
                AccruedSalariesId: $('#code1').val() ? parseInt($('#code1').val()) : null,
                AcroalLeaveSalaryId: $('#code3').val() ? parseInt($('#code3').val()) : null,
                GratuitId: $('#code4').val() ? parseInt($('#code4').val()) : null,
                PettyCashId: 0,
                Active: $('#employeeActive').is(':checked') ? 1 : 0
            };

            console.log((isEdit ? 'Updating' : 'Saving') + ' employee:', employeeData);

            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(employeeData),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit ? 'Employee updated successfully' : 'Employee saved successfully');
                            $('#newEmployeeModal').modal('hide'); // Optional: reload page or table
                            setTimeout(function () {
                                location.reload(); // or call a function to reload table/dropdown
                            }, 1500);
                    } else {
                        toastr.error(res.message || 'Operation failed');
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText || 'Something went wrong');
                }
            });
        });

    </script>
}
