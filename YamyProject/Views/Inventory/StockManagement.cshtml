
@{
    ViewData["Title"] = "StockManagement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dt-buttons .btn-primary {
        background-color: #435EBE !important;
        color: #fff !important;
        border: none !important;
    }

        .dt-buttons .btn-primary:hover {
            background-color: #3b51a0 !important;
            color: #fff !important;
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="card">
    <div class="card-header position-relative text-center">
        <strong>Stock Management</strong>

        <button class="btn btn-primary btn-sm position-absolute end-0 top-50 translate-middle-y me-3"
                id="btnAddStock" data-bs-toggle="modal"
                data-bs-target="#stockSettlementModal">
            <i class="fas fa-plus me-1"></i> Add Stock
        </button>
    </div>


    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-center align-items-end gap-4 mb-4">

            <!-- Reported By -->
            <div style="min-width: 250px;">
                <select class="form-select" id="type">
                    <option value="">-- Select Type --</option>
                    @* <option value="Default" selected>Default</option> *@
                    <option value="Item Wise">Item Wise</option>
                </select>

            </div>
            <!-- Checkbox -->
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="chkAllData" class="form-check-input" checked>
                <label for="chkAllData" class="fw-bold mb-0">Show All Data</label>
            </div>

            <!-- Start Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">Start Date</h6>
                <input type="date" class="form-control" id="startDate" disabled>
            </div>

            <!-- End Date -->
            <div style="min-width: 200px;">
                <h6 class="fw-bold mb-1">End Date</h6>
                <input type="date" class="form-control" id="endDate" disabled>
            </div>

            <!-- Filter Button -->
            <div style="min-width: 150px;">
                <button class="btn btn-primary" id="filterBtn">Filter</button>
            </div>
        </div>
        <!-- Table -->
        <table class="table table-striped" id="table2">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Date</th>
                    <th>INV No</th>
                    <th>JV No</th>
                    <th>Item Name</th>
                    <th>QTY</th>
                    <th>Cost Price</th>
                    <th>New On Hand</th>
                    <th>MinusAmount</th>
                    <th>PlusAmount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="stockSettlementModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header bg-primary text-white justify-content-center position-relative">
                <h5 class="modal-title fw-bold">Stock Settlement - New</h5>

                <button type="button"
                        class="btn-close btn-close-white position-absolute end-0 me-3"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <input type="hidden" id="settlementId" value="0">

                <!-- Top Controls -->
                <div class="row g-3 mb-3 align-items-end">

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Date</label>
                        <input type="date" class="form-control" id="date">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Warehouse</label>
                        <select class="form-select" id="warehouseDropdown"></select>
                    </div>


                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Item Code</th>
                                <th>Item Name</th>
                                <th>SYS QTY</th>
                                <th>Price</th>
                                <th>SYS Amount</th>
                                <th>New QTY</th>
                                <th>QTY DIF</th>
                                <th>Amount(-)</th>
                                <th>Amount(+)</th>
                            </tr>
                        </thead>
                        <tbody id="stockManagementTable">
                            <tr>
                                <td>1</td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><select class="form-select form-select-sm itemNameSelect"></select></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="number" class="form-control form-control-sm" step="0.01"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                                <td><input type="text" class="form-control form-control-sm"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Totals -->
                <div class="row mt-3">
                    <div class="col-md-8"></div>
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Amount (-)</span>
                            <span>0.00</span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Amount (+)</span>
                            <span>0.00</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer justify-content-end gap-2">
                <button class="btn btn-primary">Save</button>
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>


  @section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

 <script>
        $(document).ready(function () {

            loadStockSettlements();
            loadWarehouses();
            loadItem();

            $('#chkAllData').change(function () {
                const isChecked = $(this).is(':checked');
                $('#startDate, #endDate').prop('disabled', isChecked);
            });

            $('#filterBtn').click(function () {
                loadStockSettlements();
            });

            $('#type').change(function () {
                loadStockSettlements();
            });

            function loadStockSettlements() {

                const selectionMethod = $('#type').val();
                const ignoreDate = $('#chkAllData').is(':checked');
                const dateFrom = $('#startDate').val();
                const dateTo = $('#endDate').val();

                if (!ignoreDate && (!dateFrom || !dateTo)) {
                    toastr.warning('Please select both start and end dates.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetStockSettlements", "Inventory")',
                    type: 'GET',
                    data: {
                        selectionMethod: selectionMethod,
                        ignoreDate: ignoreDate,
                        dateFrom: dateFrom || null,
                        dateTo: dateTo || null
                    },
                    beforeSend: function () {
                        $('#table2 tbody').html(`
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    <div class="spinner-border text-primary me-2"></div>Loading...
                                </td>
                            </tr>
                        `);
                    },
                    success: function (res) {
                        if (!res.status) {
                            toastr.error(res.message || 'Failed to load stock data');
                            return;
                        }

                        if ($.fn.DataTable.isDataTable('#table2')) {
                            $('#table2').DataTable().clear().destroy();
                        }

                        const tbody = $('#table2 tbody');
                        tbody.empty();

                        if (res.data && res.data.length > 0) {

                            $.each(res.data, function (i, row) {

                                const tr = `
                                    <tr data-id="${row.id}">
                                        <td>${i + 1}</td>
                                        <td>${formatDate(row.date)}</td>
                                        <td>${row.invoiceNo ?? ''}</td>
                                        <td>${row.jvNo ?? ''}</td>
                                        <td>${row.itemName ?? ''}</td>
                                        <td class="text-end">${row.qty ?? ''}</td>
                                        <td class="text-end">${row.costPrice ?? ''}</td>
                                        <td class="text-end">${row.newOnHand ?? ''}</td>
                                        <td class="text-end">${row.minusAmount ?? ''}</td>
                                        <td class="text-end">${row.plusAmount ?? ''}</td>
                                    </tr>`;
                                tbody.append(tr);
                            });

                            $('#table2').DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        className: 'btn btn-primary btn-sm'
                                    },
                                    {
                                        extend: 'pdfHtml5',
                                        text: '<i class="fas fa-file-pdf me-1"></i> PDF',
                                        className: 'btn btn-primary btn-sm',
                                        orientation: 'landscape',
                                        pageSize: 'A4'
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15
                            });

                        } else {
                            tbody.append(`
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        No records found
                                    </td>
                                </tr>
                            `);
                        }
                    },
                    error: function () {
                        toastr.error('Error loading stock settlement data');
                    }
                });
            }

            function formatDate(dateString) {
                if (!dateString) return '';
                const date = new Date(dateString);
                return date.toLocaleDateString();
            }

             function getTodayDate() {
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }
        
            document.getElementById('stockSettlementModal').addEventListener('shown.bs.modal', function () {
            const todayDate = getTodayDate();

            // Fill all date fields
            const dateFields = [
                'date'
            ];

            dateFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !field.value) {
                    field.value = todayDate;
                }
            });
        });

        });

          function loadWarehouses(selector = "#warehouse, #warehouseDropdown") {
            $.ajax({
              url: '@Url.Action("GetWarehouses", "Inventory")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        const dropdowns = $(selector);
                        dropdowns.empty().append('<option value="">Select Warehouse</option>');
                        res.data.forEach(w => {
                            dropdowns.append(`<option value="${w.id}">${w.display}</option>`);
                        });
                    } else {
                        alert(res.message);
                    }
                },
                error: function (err) {
                    console.error("Error fetching warehouses:", err);
                }
            });
        }

          let itemsList = [];

          function loadItem(selector = ".itemNameSelect") {
            $.ajax({
                url: '@Url.Action("GetItems", "Lists")',
                type: 'GET',
                success: function (res) {
                    if (res.status) {
                        itemsList = res.data; // store items

                        const dropdowns = $(selector);
                        dropdowns.empty().append('<option value="">Select Item</option>');

                        res.data.forEach(item => {
                            dropdowns.append(
                                `<option value="${item.id}">${item.itemName}</option>`
                            );
                        });
                    }
                },
                error: function (err) {
                    console.error("Error fetching Item:", err);
                }
            });
        }

          $('#stockManagementTable').on('change', '.itemNameSelect', function () {
            var row = $(this).closest('tr');
            var itemName = $(this).val();
            var warehouseId = $('#warehouseDropdown').val();

                 if (!warehouseId) {
            alert('Please select a warehouse first.');
            $(this).val('');
            return;
        }

        if (!itemName) return;

            $.ajax({
                url: '@Url.Action("GetItemByCodeOrName", "Inventory")',
                type: 'GET',
                data: {
                    type: 'name',       
                    inputText: itemName,
                    warehouseId: warehouseId
                },
                success: function (res) {
                    if (res.status) {
                        var item = res.data;
                        console.log(res);
                        row.find('td:eq(1) input').val(item.code);
                        row.find('td:eq(3) input').val(item.qty); 
                        row.find('td:eq(4) input').val(item.costPrice.toFixed(2));
                        row.find('td:eq(5) input').val(item.total.toFixed(2));
                        row.find('td:eq(6) input').val(item.newQty.toFixed(2)); 
                        row.find('td:eq(7) input').val(item.qtyDif); 
                        row.find('td:eq(8) input').val(item.minusAmount); 
                        row.find('td:eq(9) input').val(item.plusAmount); 

                        if (!row.find('.itemId').length) {
                            row.append('<input type="hidden" class="itemId" value="' + item.itemId + '"/>');
                        } else {
                            row.find('.itemId').val(item.itemId);
                        }
                    } else {
                        alert(res.message);
                        row.find('td input').val('');
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                    alert('Error fetching item data.');
                }
            });
        });

                    $('#stockManagementTable').on('input', 'td:eq(6) input', function () {
            var row = $(this).closest('tr');

            var sysQty = parseFloat(row.find('td:eq(3) input').val()) || 0;
            var price  = parseFloat(row.find('td:eq(4) input').val()) || 0;
            var newQty = parseFloat($(this).val()) || 0;

            // ✅ QTY DIF = NEW - SYS
            var qtyDif = newQty - sysQty;
            row.find('td:eq(7) input').val(qtyDif.toFixed(2));

            // Reset amounts
            row.find('td:eq(8) input').val('0.00'); // Amount (-)
            row.find('td:eq(9) input').val('0.00'); // Amount (+)

            if (qtyDif > 0) {
                // PLUS amount
                var plusAmount = price * qtyDif;
                row.find('td:eq(9) input').val(plusAmount.toFixed(2));
            }
            else if (qtyDif < 0) {
                // MINUS amount
                var minusAmount = price * Math.abs(qtyDif);
                row.find('td:eq(8) input').val(minusAmount.toFixed(2));
            }
        });

                // ===== Submit Stock Settlement =====
        $('#stockSettlementModal .btn-primary').on('click', function (e) {
            e.preventDefault();

            const warehouseId = $('#warehouseDropdown').val();
            const date = $('#date').val();
            const idVal = $('#settlementId').val();
            const isEdit = idVal && parseInt(idVal) > 0;

            if (!date) {
                toastr.error('Please select date');
                return;
            }

            if (!warehouseId) {
                toastr.error('Please select warehouse');
                return;
            }

            let items = [];
            let totalPlus = 0;
            let totalMinus = 0;

            $('#stockManagementTable tr').each(function () {
                const row = $(this);

                const itemId = row.find('.itemId').val();
                if (!itemId) return; // skip empty rows

                const sysQty = parseFloat(row.find('td:eq(3) input').val()) || 0;
                const price = parseFloat(row.find('td:eq(4) input').val()) || 0;
                const newQty = parseFloat(row.find('td:eq(6) input').val()) || 0;
                const qtyDiff = parseFloat(row.find('td:eq(7) input').val()) || 0;
                const minusAmt = parseFloat(row.find('td:eq(8) input').val()) || 0;
                const plusAmt = parseFloat(row.find('td:eq(9) input').val()) || 0;

                if (minusAmt === 0 && plusAmt === 0) {
                    toastr.error(`Row ${row.index() + 1}: Amount cannot be zero`);
                    items = [];
                    return false;
                }

                totalMinus += minusAmt;
                totalPlus += plusAmt;

                items.push({
                    ItemId: parseInt(itemId),
                    OnHand: sysQty,
                    Price: price,
                    NewOnHand: newQty,
                    QtyDiff: qtyDiff,
                    MinusAmount: minusAmt,
                    PlusAmount: plusAmt,
                    Method: row.data('method') || 'fifo'
                });
            });

            if (items.length === 0) {
                toastr.error('Insert items first');
                return;
            }

            if (totalMinus === 0 && totalPlus === 0) {
                toastr.error('Amount must be greater than zero');
                return;
            }

            const payload = {
                Id: isEdit ? parseInt(idVal) : 0,
                Date: date,
                WarehouseId: parseInt(warehouseId),
                TotalPlus: totalPlus,
                TotalMinus: totalMinus,
                Items: items
            };

            $.ajax({
                url: '@Url.Action("SaveStockSettlement", "Inventory")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (res) {
                    if (res.status) {
                        toastr.success(isEdit
                            ? 'Stock settlement updated successfully'
                            : 'Stock settlement saved successfully');

                        $('#stockSettlementModal').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) {
                    toastr.error(xhr.responseJSON?.message || xhr.statusText);
                }
            });
        });


    </script>

 }
