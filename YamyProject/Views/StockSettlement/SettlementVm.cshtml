@model CreateUpdateSettlementViewmodel

@{
    var isEdit = Model?.Id > 0;
    ViewData["Title"] = $"Stock Settlement - {(isEdit ? "Edit" : "Create")}";
}

<div class="container-fluid">
    
    <div class="card shadow">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5>@ViewData["Title"]</h5>
        </div>
        <div class="card-body">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="row mb-3">
            <div class="col-md-3">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" type="date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="WarehouseId">Warehouse</label>
                <select class="form-select form-select-solid js-select2"
                        data-placeholder="Select an author"
                        asp-for="WarehouseId"
                        asp-items="@(new SelectList(Model.WarehousesVm, "Id", "Name"))">
                    <option value="">Select an Warehouse</option>
                </select>
                <span asp-validation-for="WarehouseId" class="text-danger"></span>
            </div>
            <div class="col-md-4 text-center ">
                <div class="row mb-2">
                    <label >Code</label>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-primary">&lt;&lt;</button>
                        <input type="text" class="form-control d-inline-block" style="max-width:300px;" value="@Model.Code" readonly />
                        <button type="button" class="btn btn-outline-primary">&gt;&gt;</button>
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-bordered table-sm" id="itemsTable">
            <thead>
                <tr>
                    <th style="display:none;">id</th>
                    <th>#</th>
                    <th>Item Code</th>
                    <th>Item Name</th>
                    <th>SYS QTY</th>
                    <th>Price</th>
                    <th>SYS Amount</th>
                    <th>New QTY</th>
                    <th>QTY DIF</th>
                    <th>Amount (-)</th>
                    <th>Amount (+)</th>
                    <th style="display:none;">method</th>
                    <th style="display:none;">type</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items != null && Model.Items.Any())
                {
                    int idx = 0;
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td style="display:none;"><input type="hidden" name="Items[@idx].id" value="@item.Id" class="form-control item-id hidden" /></td>

                            <td>@(idx + 1)</td>
                            <td><input type="text" name="Items[@idx].ItemCode" value="@item.ItemCode" class="form-control item-code" /></td>
                            <td><input type="text" name="Items[@idx].ItemName" value="@item.ItemName" class="form-control item-name" /></td>
                            <td><input type="text" name="Items[@idx].on-hand" value="@item.qty" class="form-control on-hand" readonly /></td>
                            <td><input type="text" name="Items[@idx].CostPrice" value="@item.CostPrice" class="form-control price" readonly /></td>
                            <td><input type="text" class="form-control sys-amount" readonly /></td>
                            <td><input type="text" name="Items[@idx].OnHand" value="@item.OnHand" class="form-control on-hand" /></td>
                            <td><input type="text" class="form-control qty-diff" readonly /></td>
                            <td><input type="text" name="Items[@idx].MinusAmount" value="@item.MinusAmount" class="form-control minus-amt" readonly /></td>
                            <td><input type="text" name="Items[@idx].PlusAmount" value="@item.PlusAmount" class="form-control plus-amt" readonly /></td>
                            <td style="display:none;"><input type="text" name="Items[@idx].method" value="@item." class="form-control method"  /></td>
                            <td style="display:none;"><input type="text" name="Items[@idx].type" value="@item.PlusAmount" class="form-control type"  /></td>
                            <td><button type="button" class="btn btn-danger remove-row">Remove</button></td>
                        </tr>
                        idx++;
                    }
                }
                else
                {
                    <tr>
                        <td style="display:none;"><input type="hidden" name="Items[0].id" class="form-control item-id hidden" readonly /></td>

                        <td>1</td>
                        <td><input type="text" name="Items[0].ItemCode" class="form-control item-code" /></td>
                        <td><input type="text" name="Items[0].ItemName" class="form-control item-name" /></td>
                        <td><input type="text" name="Items[0].qty" class="form-control sys-qty" readonly /></td>
                        <td><input type="text" name="Items[0].Price" class="form-control price" readonly /></td>
                        <td><input type="text" name="Items[0].SysAmount" class=" form-control sys-amount" readonly /></td>
                        <td><input type="text" name="Items[0].NewOnHand" class="form-control new-qty" /></td>
                        <td><input type="text" name="Items[0].Qtydiff" class="form-control qty-diff" readonly /></td>
                        <td><input type="text" name="Items[0].MinusAmount" class="form-control minus-amt" readonly /></td>
                        <td><input type="text" name="Items[0].PlusAmount" class="form-control plus-amt" readonly /></td>
                        <td style="display:none;"><input type="text" name="Items[0].method" class="form-control item-method" readonly /></td>
                        <td style="display:none;"><input type="text" name="Items[0].type" class="form-control item-type" readonly /></td>
                        <td><button type="button" class="btn btn-danger remove-row">Remove</button></td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="button" id="addRowBtn" class="btn btn-primary mb-3">Add Item</button>

        <div class="row justify-content-end mb-3">
            <div class="col-md-3">
                <input type="text" class="form-control" value="@Model.Items.Sum(x => x.MinusAmount)" readonly placeholder="Amount (-)" />
            </div>
            <div class="col-md-3">
                <input type="text" class="form-control" value="@Model.Items.Sum(x => x.PlusAmount)" readonly placeholder="Amount (+)" />
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Close</a>
        </div>
    </form>
    </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script>
        function recalcRow($row) {
            var onHand = parseFloat($row.find('.on-hand').val()) || 0;
            var price = parseFloat($row.find('.price').val()) || 0;
            var newQty = parseFloat($row.find('.new-qty').val()) || 0;

            $row.find('.sys-amount').val((onHand * price).toFixed(2));
            $row.find('.qty-diff').val((newQty - onHand).toFixed(2));
            $row.find('.minus-amt').val(Math.max(0, (onHand - newQty) * price).toFixed(2));
            $row.find('.plus-amt').val(Math.max(0, (newQty - onHand) * price).toFixed(2));
        }

        function setupAutocomplete($row) {
           $row.find('.item-code, .item-name').autocomplete({
            source: function (request, response) {
            
               $.getJSON('@Url.Action("GetItems")',
                  {
                      term: request.term,
                      warehouseId:  document.querySelector('.js-select2').value
                  },
                  function (data) {
                                            
                    if (!data) {
                        console.error("No data returned from server!");
                        return;
                    }

                    // 2️⃣ Make sure it's an array (or access the array if wrapped)
                    const itemsArray = Array.isArray(data) ? data : data.items;


                    if (!Array.isArray(itemsArray)) {
                        console.error("Data is not an array!");
                        return;
                    }

                    // 3️⃣ Map each item and check properties
                    response($.map(itemsArray, function(item) {
                         return {
                            label: (item.Code || item.code) + " - " + (item.Name || item.name), // fallback for casing
                            value: item.Code || item.code,
                            itemData: item
                        };
                    }));
                });
            },

            select: function (event, ui) {
                $row.find('.item-id').val(ui.item.itemData.Id || ui.item.itemData.id);
                $row.find('.item-id').val(ui.item.itemData.Id || ui.item.itemData.id); 
                $row.find('.item-code').val(ui.item.itemData.Code || ui.item.itemData.code);
                $row.find('.item-method').val(ui.item.itemData.Method || ui.item.itemData.method);
                $row.find('.item-type').val(ui.item.itemData.Type || ui.item.itemData.type);
                $row.find('.item-name').val(ui.item.itemData.Name || ui.item.itemData.name);
                $row.find('.on-hand').val(ui.item.itemData.OnHand || ui.item.itemData.onHand);
                $row.find('.price').val(ui.item.itemData.CostPrice || ui.item.itemData.costPrice);
                $row.find('.WarehouseId').val(ui.item.itemData.WarehouseId || ui.item.itemData.warehouseId);
                recalcRow($row);
                return false;
            },
            minLength: 1
        });
         
        }
        function NewRow(){
                var index = $('#itemsTable tbody tr').length;
                var newRow = $(`
                    <tr>
                        <td style="display:none;"><input type="hidden" name="Items[${index}].id" class="form-control item-id" readonly/></td>

                        <td>${index + 1}</td>
                        <td><input name="Items[${index}].ItemCode" class="form-control item-code" /></td>
                        <td><input name="Items[${index}].ItemName" class="form-control item-name" /></td>
                        <td><input name="Items[${index}].OnHand" class="form-control on-hand" readonly /></td>
                        <td><input name="Items[${index}].Price" class="form-control price" readonly/></td>
                        <td><input name="Items[${index}].NewOnHand"class="form-control sys-amount" readonly /></td>
                        <td><input name="Items[${index}].NewOnHand" class="form-control new-qty" /></td>
                        <td><input class="form-control qty-diff" readonly /></td>
                        <td><input name="Items[${index}].MinusAmount" class="form-control minus-amt" readonly /></td>
                        <td><input name="Items[${index}].PlusAmount" class="form-control plus-amt" readonly></td>
                        <td style="display:none;"><input name="Items[${index}].method" class="form-control method" readonly></td>
                        <td style="display:none;"><input name="Items[${index}].type" class="form-control type" readonly></td>
                        <td><button type="button" class="btn btn-danger remove-row">Remove</button></td>
                    </tr>
                `);
                $('#itemsTable tbody').append(newRow);
                setupAutocomplete(newRow);

        }

        $(document).ready(function () {
            // Event delegation for dynamic elements
            $('#itemsTable').on('click', '.remove-row', function () {
                $(this).closest('tr').remove();
                updateRowIndexes();
            });

            $('#itemsTable').on('input', '.price, .new-qty', function () {
                recalcRow($(this).closest('tr'));
            });

            // Initialize existing rows
            $('#itemsTable tbody tr').each(function () {
                var $row = $(this);
                setupAutocomplete($row);
                recalcRow($row);
            });

            $('#addRowBtn').click(function () {
                NewRow();
                });
     
            function updateRowIndexes() {
                $('#itemsTable tbody tr').each(function (i) {
                    $(this).find('td:first').text(i + 1);
                    $(this).find('input, select').each(function () {
                        var name = $(this).attr('name');
                        if (name) {
                            var newName = name.replace(/\d+/, i);
                            $(this).attr('name', newName);
                        }
                    });
                });
            }
        });
    </script>

}
