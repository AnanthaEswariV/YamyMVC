@model VendorSubContactViewModel
@{
    ViewData["Title"] = "New Vendor";
    }

<div class="modal fade" id="VendorModal" tabindex="-1"
     aria-labelledby="VendorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content shadow-lg border-0">

            <!-- IMPORTANT: added id="VendorForm" so JS can find the form -->
            <form id="VendorForm" asp-controller="Vendors">
                <!-- HEADER -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="VendorModalLabel">
                        New
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Hidden fields: Id is enough; the others are already bound via selects -->
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Type" readonly />

                <!-- BODY -->
                <div class="modal-body">
                    <!-- BASIC DATA -->
                    <section class="border rounded-3 p-3 mb-3">
                        <div class="fw-semibold mb-3 small text-uppercase">Basic Data</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label">Vendor Name</label>
                                <input asp-for="Name" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Code" class="form-label">Vendor Code</label>
                                <input asp-for="Code" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label">Category</label>
                                <div class="input-group">
                                    <select asp-for="CategoryId"
                                            class="form-select"
                                            asp-items="@(new SelectList(Model.Categoriess, "Id", "Name"))">
                                    </select>
                                    <button type="button" class="btn btn-outline-secondary">
                                        <i class="fas fa-plus-circle fs-6"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label d-block">Opening Balance</label>
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <div class="btn-group" role="group">
                                        <!-- NOTE: no asp-for here – just plain radios posting OpeningType -->
                                        <input  type="radio"
                                               class="btn-check"
                                               asp-for="OpeningType"
                                               id="obDebit"
                                               value="Debit"
                                               checked />
                                        <label class="btn btn-outline-primary" for="obDebit">
                                            Debit
                                        </label>

                                        <input type="radio"
                                               class="btn-check"
                                               asp-for="OpeningType"
                                               id="obCredit"
                                               value="Credit" />
                                        <label class="btn btn-outline-primary" for="obCredit">
                                            Credit
                                        </label>
                                    </div>

                                    <input asp-for="OpeningAmount"
                                           class="form-control text-end"
                                           style="max-width: 140px;"
                                           placeholder="Amount" />

                                    <input asp-for="Date"
                                           type="date"
                                           class="form-control"
                                           style="max-width: 200px;" />

                                    <!-- Preview text for opening balance -->
                                    <small id="openingPreview" class="text-muted ms-2"></small>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- CONTACT & ADDRESS DATA -->
                    <section class="border rounded-3 p-3 mb-3">
                        <div class="fw-semibold mb-3 small text-uppercase">
                            Contact &amp; Address Data
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="MainPhone" class="form-label">Main Phone</label>
                                <input asp-for="MainPhone" class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="WorkPhone" class="form-label">Work Phone</label>
                                <input asp-for="WorkPhone" class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Mobile / Fax</label>
                                <input asp-for="Fax" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="EmailCC" class="form-label">CC Email</label>
                                <input asp-for="EmailCC" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Website" class="form-label">Website</label>
                                <input asp-for="Website" class="form-control" />
                            </div>

                            <div class="col-md-3">
                                <label asp-for="CountryId" class="form-label">Country</label>
                                <select asp-for="CountryId"
                                        class="form-select"
                                        asp-items="@(new SelectList(Model.Country, "Id", "Name"))">
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="CityId" class="form-label">City</label>
                                <!-- IMPORTANT: asp-for="CityId", not CountryId -->
                                <select asp-for="CityId"
                                        class="form-select"
                                        asp-items="@(new SelectList(Model.City, "Id", "Name"))">
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Region" class="form-label">Region</label>
                                <input asp-for="Region" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BulidingNumber" class="form-label">Building Name</label>
                                <input asp-for="BulidingNumber" class="form-control" />
                            </div>
                        </div>
                    </section>

                    <!-- ACCOUNT SETTINGS & OTHER -->
                    <section class="border rounded-3 p-3">
                        <div class="fw-semibold mb-3 small text-uppercase">
                            Account Settings &amp; Other
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="AccountId" class="form-label">Account</label>
                                <select asp-for="AccountId"
                                        class="form-select"
                                        asp-items="@(new SelectList(Model.Account, "Id", "Name"))">
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TRN" class="form-label">TRN</label>
                                <input asp-for="TRN" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FaciltyName" class="form-label">Facility Name</label>
                                <input asp-for="FaciltyName" class="form-control" />
                            </div>

                            <div class="col-md-6 d-flex align-items-center">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" asp-for="IsActive">
                                        Active
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Project</label>
                                <div class="border rounded-3 p-2"
                                     style="max-height: 150px; overflow-y: auto;">
                                    <!-- TODO: bind these from your model instead of hard-coded -->
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="proj135"
                                               name="Projects"
                                               value="135" />
                                        <label class="form-check-label" for="proj135">
                                            135 - p1-135
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="proj136"
                                               name="Projects"
                                               value="136" />
                                        <label class="form-check-label" for="proj136">
                                            136 - fxc-136
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="proj137"
                                               name="Projects"
                                               value="137" />
                                        <label class="form-check-label" for="proj137">
                                            137 - tjhgn
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="proj153"
                                               name="Projects"
                                               value="153" />
                                        <label class="form-check-label" for="proj153">
                                            153 - Eissa Mohammed Ali Ahmed K…
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="submit" name="saveAndNew" value="true"
                            class="btn btn-outline-primary">
                        Save &amp; New
                    </button>
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
    @section Scripts {
    <script>
        function updateOpeningPreview() {
            const typeRadio = document.querySelector('input[name="OpeningType"]:checked');
            const type = typeRadio ? typeRadio.value : 'Debit';

            const amtInput = document.getElementById('OpeningAmount');
            const amt = amtInput ? parseFloat(amtInput.value || '0') || 0 : 0;

            const sign = type === 'Credit' ? -Math.abs(amt) : Math.abs(amt);
            const preview = document.getElementById('openingPreview');

            if (preview) {
                preview.textContent = sign.toFixed(2);
            }
        }

        // When modal content is inserted and opened
        $(document).on('shown.bs.modal', '#VendorModal', function () {
            updateOpeningPreview();
        });

        // When user changes Debit/Credit or amount
        $(document).on('change', 'input[name="OpeningType"]', function () {
            updateOpeningPreview();
        });

        $(document).on('input', '#OpeningAmount', function () {
            updateOpeningPreview();
        });

        // Optional: dynamic action (Create vs Edit) before submit
        $(document).on('submit', '#VendorForm', function (e) {
            const form = this;
            const idField = form.querySelector('input[name="Id"]');
            const idVal = parseInt(idField?.value || '0', 10);

            // Just in case you still want separate actions:
            if (idVal && idVal > 0) {
                form.action = '@Url.Action("Edit", "Vendors")';
            } else {
                form.action = '@Url.Action("Create", "Vendors")';
            }
        });
    </script>
    }
