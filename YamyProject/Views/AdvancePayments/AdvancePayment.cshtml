                                </tr>`
                    );
                  $('#grid-check tbody').append(newRow);
                    const $row = newRow;
                   }
    </script>
     <script>
        $(function () {

          // helper: is last row?
          function isLastRow($row) { return $row.is(':last-child'); }

          // current PaymentType (select with id="PaymentType")
          function PaymentType() {
            const el = document.getElementById('PaymentType') ;
            const v = el ? parseInt(el.value, 10) : NaN;
            return Number.isFinite(v) ? v : 0;
          }

          // current PaymentMethod (select with id="paymentMethod")
          function PaymentMethod() {
            const el = document.getElementById('paymentMethod') ||
                       document.getElementById('PaymentMethod');
            const v = el ? parseInt(el.value, 10) : NaN;
            return Number.isFinite(v) ? v : 0;
          }

          // get the <datalist> an input is wired to (row-scoped first, then global)
          function getDatalist($input, $scope = $(document)) {
            const el = $input[0];
            if (!el) return $();
            if (el.list) return $(el.list);        // native reference
            const id = $input.attr('list');
            if (!id) return $();
            const $scoped = $scope.find('#' + id);
            return $scoped.length ? $scoped : $('#' + id);
          }

          // normalize server objects with either PascalCase or camelCase keys
          function norm(o) {
            return {
              id:   o.Id   ?? o.id   ?? o.Value ?? o.value,
              code: o.Code ?? o.code ?? '',
              name: o.Name ?? o.name ?? o.Text  ?? o.text ?? ''
            };
          }

          function populateDatalist($dl, arr, makeLabel) {
            if (!$dl || !$dl.length) return;
            $dl.empty();
            arr.slice(0, 50).forEach(item => {
              const n = norm(item);
              const label = makeLabel(n);
              $('<option/>', { value: label, text: label, 'data-id': n.id }).appendTo($dl);
            });
          }

          // ---- AJAX fetchers (NO semicolons inside the data object) ----
          function fetchPartners(term, cb) {
            $.getJSON('@Url.Action("GetPartners")',
              { term: term, paymentType: PaymentType() },
              function (data) {
                cb(Array.isArray(data) ? data : (data?.items ?? []));
              }
            );
          }

          function fetchBanks(term, cb) {
            $.getJSON('@Url.Action("GetBanks")',
              { term: term, paymentMethod: PaymentMethod() },
              function (data) {
                cb(Array.isArray(data) ? data : (data?.items ?? []));
              }
            );
          }

          // ---- Fill helpers for your row ----
          function fillPartner($row, item) {
            const p = norm(item);
            $row.find('.RowsName').val(p.name); // visible
            const $hid = $row.find('.Rows-PartnerId'); // only if you actually have this hidden input
            if ($hid.length) $hid.val(p.id);
          }

          function fillBank($row, item) {
            const b = norm(item);
            const label = b.code ? (b.code + ' - ' + b.name) : b.name;
            $row.find('.BankId').val(label); // visible
            const $hid = $row.find('.Rows-BankIdValue'); // only if present
            if ($hid.length) $hid.val(b.id);
          }

          // ---- Main per-row setup ----
          function setupAutocompleteRow($row) {
            const $nameInput = $row.find('.RowsName');
            const $bankInput = $row.find('.BankId');

            const $nameDL = getDatalist($nameInput, $row);
            const $bankDL = getDatalist($bankInput, $row);

            let cachePartners = [];
            let cacheBanks = [];

            // PARTNER (RowsName)
            if ($nameDL.length) {
              $nameInput.off('.ac')
                .on('input.ac', function () {
                  const term = (this.value || '').trim();
                  if (term.length < 1) { $nameDL.empty(); return; }
                  fetchPartners(term, function (arr) {
                    cachePartners = arr;
                    populateDatalist($nameDL, arr, p => p.code ? `${p.code} - ${p.name}` : p.name);
                  });
                })
                .on('change.ac blur.ac', function () {
                  const typed = ($(this).val() || '').trim();
                  if (!typed || !cachePartners.length) return;
                  const chosen = cachePartners.map(norm).find(p =>
                    typed === p.name || typed === (p.code ? `${p.code} - ${p.name}` : p.name)
                  );
                  if (chosen) {
                    fillPartner($row, chosen);
                    if (isLastRow($row) && typeof NewRow === 'function') NewRow();
                         const sel = document.getElementById('paymentMethodd');
                      const raw = sel ? sel.value : '';
                      const mode =
                        ({ '1': 'cash', '2': 'check', '3': 'transfer' }[raw]) ??
                        (String(raw || '').toLowerCase() || 'all');

                      if (typeof window.setTableView === 'function') {
                        window.setTableView(mode);
                      }
                  }
                });
            }

            // BANK (BankId)
            if ($bankDL.length) {
              $bankInput.off('.ac')
                .on('input.ac', function () {
                  const term = (this.value || '').trim();
                  if (term.length < 1) { $bankDL.empty(); return; }
                  fetchBanks(term, function (arr) {
                    cacheBanks = arr;
                    populateDatalist($bankDL, arr, b => b.code ? `${b.code} - ${b.name}` : b.name);
                  });
                })
                .on('change.ac blur.ac', function () {
                  const typed = ($(this).val() || '').trim();
                  if (!typed || !cacheBanks.length) return;
                  const chosen = cacheBanks.map(norm).find(b =>
                    typed === b.name || typed === (b.code ? `${b.code} - ${b.name}` : b.name)
                  );
                  if (chosen) fillBank($row, chosen);
                });
            }
          }

          // ---- Wire existing rows on load (your tbody is #grid-body) ----
          $('#grid-body tr').each(function () {
            setupAutocompleteRow($(this));
          });

          // Optional: if user changes PT/PM, rewire (fetch calls will use new values)
          $('#PaymentType, #paymentMethod').on('change', function () {
            $('#grid-body tr').each(function () { setupAutocompleteRow($(this)); });
          });

        });
    </script>
    <script>
        (function () {
          const $form = $('#apForm'); // your form id
          const token = $form.find('input[name="__RequestVerificationToken"]').val();

          // prevent Enter from native-submit
          $form.on('keydown', 'input,select,textarea', function (e) {
            if (e.key === 'Enter') e.preventDefault();
          });

          // Create vs Edit endpoint for AdvancePayments controller
          function getUrlFromId() {
            const idVal = Number($form.find('input[name="Id"]').val() || 0);
            return idVal > 0
              ? '@Url.Action("Edit", "AdvancePayments")'
              : '@Url.Action("Create", "AdvancePayments")';
          }

          // Only validate: at least one non-template row with Name and Amount>0
          function toNum(v) {
            const n = parseFloat((v ?? '').toString().replace(/,/g, ''));
            return Number.isFinite(n) ? n : NaN;
          }
          function clearInvalid($el) {
            $el.removeClass('is-invalid').siblings('.invalid-feedback').remove();
          }
          function setInvalid($el, message) {
            $el.addClass('is-invalid');
            let $fb = $el.siblings('.invalid-feedback');
            if ($fb.length === 0) {
              $fb = $('<div class="invalid-feedback"></div>');
              $el.after($fb);
            }
            $fb.text(message);
          }
          function isTemplateRow($tr) {
            return $tr.hasClass('template') || $tr.is('[data-template="true"]');
          }

          function validateRows() {
            const $rows = $('#grid-body tr').filter((_, tr) => !isTemplateRow($(tr)));
            let ok = false;
            let firstInvalid = null;

            // require at least one row
            if ($rows.length === 0) {
              alert('At least one row is required.');
              return false;
            }

            $rows.each(function (i) {
              const $tr = $(this);
              const rowNo = i + 1;

              const $name   = $tr.find('.RowsName');
              const $amount = $tr.find('.Rows-Amount');

              // clear any previous state
              $tr.removeClass('table-danger');
              if ($name.length)   clearInvalid($name);
              if ($amount.length) clearInvalid($amount);

              // Name required
              if ($name.length && !($name.val() || '').trim()) {
                setInvalid($name, `Name is required (row ${rowNo}).`);
                $tr.addClass('table-danger');
                firstInvalid = firstInvalid || $name.get(0);
                ok = false;
                return false; // break .each on first error
              }

              // Amount > 0 required
              const amt = toNum($amount.val());
              if (!Number.isFinite(amt) || amt <= 0) {
                setInvalid($amount, `Amount must be greater than 0 (row ${rowNo}).`);
                $tr.addClass('table-danger');
                firstInvalid = firstInvalid || $amount.get(0);
                ok = false;
                return false;
              }

              ok = true; // so far so good
            });

            if (!ok && firstInvalid) {
              firstInvalid.focus?.();
              firstInvalid.scrollIntoView?.({ behavior: 'smooth', block: 'center' });
            }
            return ok;
          }

          function postAjax(saveAndClose) {
            const payload = $form.serialize();
            const url = getUrlFromId();

            $.ajax({
              url,
              type: 'POST',
              data: payload,
              headers: { 'RequestVerificationToken': token },
              success: function (res) {
                if (saveAndClose) {
                  // if server returns redirectUrl, use it; else go back to index
                  window.location.href = (res && res.redirectUrl) || '@Url.Action("Index", "AdvancePayments")';
                } else {
                  alert((res && res.message) || 'Saved.');
                }
              },
              error: function (xhr) {
                try {
                  const r = JSON.parse(xhr.responseText);
                  alert(r.message || 'Error while saving.');
                  console.error(r.errors || r);
                } catch {
                  alert('Error while saving.');
                }
              }
            });
          }

          // Hook buttons (prevent native submit)
          $('#btnAjaxSave').on('click', function (e) {
            e.preventDefault();
            if (!validateRows()) return;
            postAjax(false);
          });
          $('#btnAjaxSaveClose').on('click', function (e) {
            e.preventDefault();
            if (!validateRows()) return;
            postAjax(true);
          });
        })();
    </script>

}