@model UserEditViewModel

@{
    var title = Model.IsNew ? "Users - New User" : "Users - Update User";
    }

<div class="card shadow-sm border-0" style="min-width: 650px;">
    <!-- Header bar -->
    <div class="card-header d-flex justify-content-between align-items-center py-2"
         style="background-color:#003b73;color:#fff;">
        <h6 class="mb-0 fw-semibold">@title</h6>
       @*  <div class="d-flex gap-1">
            <button type="button" class="btn btn-sm btn-outline-light border-0" data-bs-dismiss="modal">
                <i class="bi bi-x-lg"></i>
            </button>
        </div> *@
    </div>

    <form asp-action="Save"
          asp-controller="UserAccounts"
          method="post"
          class="card-body">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- First / Last name -->
        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label small">First Name</label>
                <input asp-for="FirstName" class="form-control form-control-sm" placeholder="First Name" />
                <span asp-validation-for="FirstName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label small">Last Name</label>
                <input asp-for="LastName" class="form-control form-control-sm" placeholder="Last Name" />
                <span asp-validation-for="LastName" class="text-danger small"></span>
            </div>
        </div>

        <!-- Role / Employee -->
        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="RoleId" class="form-label small">Role</label>
                <div class="input-group input-group-sm">
                    <select asp-for="RoleId" asp-items="Model.Roles" class="form-select"></select>
                    <a asp-action="EditRole" class="btn btn-outline-secondary">New</a>
                </div>
                <span asp-validation-for="RoleId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EmployeeId" class="form-label small">Employee</label>
                <div class="input-group input-group-sm">
                    <select asp-for="EmployeeId" asp-items="Model.Employees" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <button type="button" class="btn btn-outline-secondary">New</button>
                </div>
                <span asp-validation-for="EmployeeId" class="text-danger small"></span>
            </div>
        </div>

        <!-- User name + Active -->
        <div class="row mb-3 align-items-end">
            <div class="col-md-8">
                <label asp-for="UserName" class="form-label small">User Name</label>
                <input asp-for="UserName" class="form-control form-control-sm" placeholder="User Name" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="form-check mt-3">
                    <input asp-for="Active" class="form-check-input" />
                    <label asp-for="Active" class="form-check-label small">Active</label>
                </div>
            </div>
        </div>

        <!-- Passwords (only for new user) -->
        @if (Model.IsNew)
            {
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label small">Password</label>
                    <div class="input-group input-group-sm">
                        <input asp-for="Password" class="form-control" placeholder="Enter Password" />
                        <button type="button"
                                class="btn btn-outline-secondary toggle-password"
                                data-target="#Password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label small">Confirm Password</label>
                    <div class="input-group input-group-sm">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Your Password" />
                        <button type="button"
                                class="btn btn-outline-secondary toggle-password"
                                data-target="#ConfirmPassword">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
            }

        <!-- Footer -->
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="submit" class="btn btn-primary px-4">Save</button>
            <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Close</button>
        </div>
    </form>
</div>
