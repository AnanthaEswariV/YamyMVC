@model RoleEditViewModel

@{
    Layout = null;
    var isNew = Model == null || Model.Id == 0;
    var title = isNew ? "Roles - New Role" : "Roles - Edit Role";
    }

<div class="card shadow-sm border-0" style="min-width: 420px;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center px-3 py-2"
         style="background-color:#003b73;color:#fff;">
        <h6 class="mb-0 fw-semibold">@title</h6>

        <div class="d-flex align-items-center gap-1">
            <button type="button" class="btn btn-sm btn-link p-0 text-white opacity-75">
                <i class="bi bi-dash"></i>
            </button>
            <button type="button" class="btn btn-sm btn-link p-0 text-white opacity-75">
                <i class="bi bi-square"></i>
            </button>
            <button type="button" class="btn btn-sm btn-link p-0 text-white opacity-75"
                    data-bs-dismiss="modal">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>

    <form id="roleForm"
          asp-action="SaveRole"
          asp-controller="UserAccounts"
          method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Body -->
        <div class="card-body pb-3 pt-4">
            <div class="mb-2">
                <label asp-for="Name" class="form-label small mb-1">Role Name</label>
                <input asp-for="Name"
                       class="form-control"
                       placeholder="Role Name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
        </div>

        <!-- Footer -->
        <div class="d-flex justify-content-end align-items-center px-3 py-2"
             style="background-color:#e0e0e0;">
            <button type="submit"
                    class="btn btn-sm px-4 me-2 text-white"
                    style="background-color:#003b73;">
                Save
            </button>
            <button type="button"
                    class="btn btn-sm btn-outline-secondary px-4"
                    data-bs-dismiss="modal">
                Close
            </button>
        </div>
    </form>
</div>
<script>
    $(document).on('submit', '#roleForm', function (e) {
        e.preventDefault();

        var $form = $(this);
        $.ajax({
            url: $form.attr('action'),
            type: $form.attr('method'),
            data: $form.serialize(),
            success: function (res) {
                if (res.success) {
                    // close modal
                    $('#roleModal').modal('hide');

                    // TODO: reload roles list if needed
                    // loadRoles();
                } else {
                    // if server returns HTML (validation errors), replace modal content
                    $('#roleModal .modal-content').html(res);
                }
            }
        });
    });
</script>
