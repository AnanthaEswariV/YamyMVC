<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YamyProject | @ViewData["Title"] </title>
    <!-- Fonts & Bootstrap -->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/css/bootstrap.css" />
    <!-- Bootstrap Icons (latest version for piggy-bank icon) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- Vendors -->
    <link rel="stylesheet" href="~/assets/vendors/iconly/bold.css" />
    <link rel="stylesheet" href="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.css" />

    <!-- Main CSS -->
    <link rel="stylesheet" href="~/assets/css/app.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" href="~/assets/images/logo/yamy.png" type="image/png" />

    <link rel="stylesheet" href="~/css/MainLayout.css" />


  </head>
<body>
    <div id="app">
        <!-- ✅ Top Navbar -->
        <partial name="_Header" />
        <!-- ✅ Sidebar -->
        <partial name="_Aside" />

        <!-- ✅ Main -->
         <div id="main">
            <div class="d-flex flex-column flex-column-fluid container-fluid">
                <div class="content flex-column-fluid" id="kt_content">
                    @RenderBody()
                </div>
            </div>
            @*  <div class="page-content">
                <section class="row">
                    <div class="col-12">
                        @RenderBody()
                    </div>
                </section>
            </div> *@

            <!-- ✅ Footer -->
            <footer>
                <partial name="_footer" />

            </footer>
        </div>
    </div>

    <!-- ✅ Scripts -->
    <script src="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.min.js"></script>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script> <!-- fixed ApexCharts -->
    <script src="~/assets/js/pages/dashboard.js"></script>
    <script src="~/assets/js/main.js"></script>
    <script src="~/assets/vendors/simple-datatables/simple-datatables.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/js/MainJs.js"></script>

  </body>
</html>



