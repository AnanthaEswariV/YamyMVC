@using System.Globalization
@{
    var cookieLang = Context.Request.Cookies["siteLang"];
    var isAr = string.Equals(cookieLang, "ar", StringComparison.OrdinalIgnoreCase)
               || CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
}

<!DOCTYPE html>
<html lang="en" dir="ltr" id="htmlRoot" style="visibility:hidden;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YamyProject | @ViewData["Title"]</title>

    <style>
        /* White overlay — covers page while GT is translating.
                   visibility:visible !important overrides the parent html visibility:hidden */
        #gt-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #ffffff;
            z-index: 2147483647;
            display: none;
            align-items: center;
            justify-content: center;
            visibility: visible !important;

        }

            #gt-overlay .gt-spinner {
                width: 64px;
                height: 64px;
                border: 7px solid #e5e7eb;
                border-top-color: #4f46e5;
                border-radius: 50%;
                animation: gt-spin 0.9s linear infinite;
                margin-bottom: 14px;
            }

            #gt-overlay .gt-msg {
                font-family: Nunito, system-ui, sans-serif;
                font-size: 14px;
                font-weight: 600;
                color: #374151;
                text-align: center;
            }

        @@keyframes gt-spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Hide Google Translate toolbar completely */
        .goog-te-banner-frame,
        .goog-te-gadget,
        .skiptranslate {
            display: none !important;
        }

        body {
            top: 0 !important;
        }
    </style>

    <script>
        (function () {

            /* ── cookie helpers ─────────────────────────────────────── */
            function getCookie(n) {
                var m = document.cookie.match('(?:^|; )' + n.replace(/([.$?*|{}()\[\]\/+^])/g, '\\$1') + '=([^;]*)');
                return m ? decodeURIComponent(m[1]) : null;
            }
            function setGT(v) {
                ['; path=/', '; path=/; domain=' + location.hostname, '; path=/; domain=.' + location.hostname]
                    .forEach(function (d) { document.cookie = 'googtrans=' + v + d; });
            }
            function clearGT() {
                var e = '; expires=Thu,01 Jan 1970 00:00:00 UTC; path=/';
                document.cookie = 'googtrans=' + e;
                document.cookie = 'googtrans=' + e + '; domain=' + location.hostname;
                document.cookie = 'googtrans=' + e + '; domain=.' + location.hostname;
            }

            /* ── read language preference ───────────────────────────── */
            var lang = getCookie('siteLang') ||
                (function () { try { return localStorage.getItem('siteLang'); } catch (e) { return null; } })() ||
                'en';

            /* ── build overlay immediately (before body exists) ─────── */
            var overlay = document.createElement('div');
            overlay.id = 'gt-overlay';
            overlay.innerHTML =
                '<div style="text-align:center">' +
                '<div class="gt-spinner"></div>' +
                 '<div class="gt-msg">Applying language\u2026</div>' +
                '</div>';
            document.documentElement.appendChild(overlay);

            /* ── ENGLISH path: show page right away ─────────────────── */
            if (lang !== 'ar') {
                clearGT();
                document.documentElement.style.visibility = 'visible';
                overlay.parentNode && overlay.parentNode.removeChild(overlay);
                return;
            }

            /* ══════════════════════════════════════════════════════════
               ARABIC PATH
               ══════════════════════════════════════════════════════════ */
            document.documentElement.setAttribute('dir', 'rtl');
            document.documentElement.setAttribute('lang', 'ar');
            setGT('/en/ar');

            // Show the white overlay (html stays visibility:hidden underneath)
            overlay.style.display = 'flex';
            void overlay.offsetHeight; // force paint immediately

            var done = false;
            var settleTimer = null;
            var classObs, bodyObs;

            /* Reveal page — called only once mutations have settled */
            function reveal() {
                if (done) return;
                done = true;
                clearTimeout(settleTimer);
                clearTimeout(fallback);
                try { classObs && classObs.disconnect(); } catch (e) {}
                try { bodyObs  && bodyObs.disconnect();  } catch (e) {}

                // Make page visible first, then remove overlay
                document.documentElement.style.visibility = 'visible';
                setTimeout(function () {
                    overlay.style.display = 'none';
                    overlay.parentNode && overlay.parentNode.removeChild(overlay);
                }, 80);
            }

            /*
             * THE REAL FIX — debounced mutation settle
             * ─────────────────────────────────────────
             * Google Translate adds `translated-rtl` to <html> when it
             * STARTS translating — NOT when it finishes.  Text nodes
             * continue to be swapped for hundreds of milliseconds after.
             *
             * Solution:
             *  1. Detect `translated-rtl` on <html>.
             *  2. Watch body for any further DOM mutations.
             *  3. Each mutation resets a 500ms settle timer.
             *  4. Reveal only after 500ms of NO mutations
             *     (GT has truly finished replacing all text nodes).
             */
            function resetSettle() {
                clearTimeout(settleTimer);
                settleTimer = setTimeout(reveal, 500);
            }

            function isArabicReady() {
                return document.documentElement.classList.contains('translated-rtl');
            }

            /* Watch <html> class attribute for translated-rtl */
            classObs = new MutationObserver(function () {
                if (isArabicReady()) resetSettle();
            });
            classObs.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ['class']
            });

            /* Watch body text/child mutations — each one resets the timer */
            function startBodyWatch() {
                if (!document.body) { setTimeout(startBodyWatch, 20); return; }
                bodyObs = new MutationObserver(function () {
                    if (isArabicReady()) resetSettle();
                });
                bodyObs.observe(document.body, {
                    childList: true,
                    subtree: true,
                    characterData: true
                });
            }
            startBodyWatch();

            /* Safety fallback: reveal after 20s even if GT never finishes */
            var fallback = setTimeout(function () {
                if (!done) reveal();
            }, 20000);

            /* Already translated? (cached page) */
            if (isArabicReady()) resetSettle();

        })();
    </script>

    <script>
        /* ── Navigation guard ──────────────────────────────────────────
           On every internal link click, immediately hide the page and
           show a fresh overlay so the outgoing page never flashes.       */
        (function () {
            function setCookie(name, value, days) {
                document.cookie = name + '=' + encodeURIComponent(value) +
                    '; path=/; max-age=' + (days * 86400);
            }

            function isInternal(a) {
                if (!a || !a.getAttribute) return false;
                var h = a.getAttribute('href');
                if (!h || /^(#|mailto:|tel:|javascript:)/i.test(h)) return false;
                try { return new URL(h, location.href).origin === location.origin; }
                catch (e) { return false; }
            }

            function hideForNav() {
                try {
                    var m = document.cookie.match('(?:^|; )siteLang=([^;]*)');
                    var l = m ? decodeURIComponent(m[1]) : null;
                    if (!l) { try { l = localStorage.getItem('siteLang'); } catch (e) {} }
                    if (l !== 'ar') return;

                    // Hide the outgoing page immediately
                    document.documentElement.style.visibility = 'hidden';

                    var ov = document.getElementById('gt-overlay');
                    if (ov) {
                        ov.style.display = 'flex';
                    } else {
                        // Overlay was already removed — recreate for transition
                        var fresh = document.createElement('div');
                        fresh.style.cssText =
                            'position:fixed;top:0;left:0;right:0;bottom:0;background:#fff;' +
                            'z-index:2147483647;display:flex;align-items:center;' +
                            'justify-content:center;visibility:visible!important;';
                        fresh.innerHTML =
                            '<div style="text-align:center">' +
                            '<div style="width:56px;height:56px;border:6px solid #e5e7eb;' +
                            'border-top-color:#4f46e5;border-radius:50%;' +
                            'animation:gt-spin .9s linear infinite;margin-bottom:12px"></div>' +
                            '<div style="font:600 13px/1 Nunito,sans-serif;color:#374151">' +
                            'Applying language\u2026</div></div>';
                        document.documentElement.appendChild(fresh);
                    }
                } catch (e) {}
            }

            document.addEventListener('click', function (ev) {
                var a = ev.target.closest('a');
                if (!a) return;
                if (a.target && a.target.toLowerCase() !== '_self') return;
                if (a.hasAttribute('download') || a.hasAttribute('data-no-pjax')) return;
                if (!isInternal(a)) return;
                hideForNav();
            }, true);

            document.addEventListener('submit', hideForNav, true);
            window.__setSiteLangCookie = setCookie;
        })();
    </script>

    <!-- Google Translate -->
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement(
                { pageLanguage: 'en', includedLanguages: 'ar,en' },
                'google_translate_element'
            );
        }
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <style>
        #btn-en, #btn-ar {
            background: #667eea;
            color: #fff;
            border: none;
            padding: 4px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            opacity: .6;
        }

            #btn-en.active, #btn-ar.active {
                opacity: 1;
                outline: 2px solid #fff;
            }

        .navbar-links .submenu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            z-index: 9999;
            background: #fff;
            min-width: 200px;
        }

        .navbar-links .dropdown:hover > .submenu {
            display: block;
        }

        .navbar-links .has-submenu > .submenu {
            top: 0;
            left: 100%;
        }
    </style>

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap">
    <link rel="stylesheet" href="~/assets/css/bootstrap.css" />
    <link rel="stylesheet" href="~/assets/vendors/iconly/bold.css" />
    <link rel="stylesheet" href="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.css" />
    <link rel="stylesheet" href="~/assets/css/app.css" asp-append-version="true" />
    <link rel="icon" href="~/assets/images/logo/yamy.png" type="image/png" />
    <link rel="stylesheet" href="~/css/MainLayout.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @RenderSection("Styles", required: false)
</head>

<body>
    <div id="app">
        <partial name="_Header" />

        <div id="sidebar" class="active">
            <div class="sidebar-wrapper active">
                <div class="sidebar-header">
                    <div class="d-flex justify-content-between">
                        <div class="toggler">
                            <a href="#" class="sidebar-hide d-xl-none d-block">
                                <i class="bi bi-x bi-middle"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="sidebar-menu">
                    <ul class="menu">
                        <li class="sidebar-item active">
                            <a href="/" class="sidebar-link">
                                <i class="bi bi-grid-fill"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("ChartOfAccount", "Lists")" class="sidebar-link">
                                <i class="bi bi-calculator-fill"></i>
                                <span>Chart Of Account</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("Customer", "Customer")" class="sidebar-link">
                                <i class="bi bi-people-fill"></i>
                                <span>Customers</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("Vendor", "Vendor")" class="sidebar-link">
                                <i class="bi bi-person-lines-fill"></i>
                                <span>Vendors</span>
                            </a>
                        </li>
                        <li class="sidebar-item has-sub">
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-person-badge-fill"></i>
                                <span>HR</span>
                            </a>
                            <ul class="submenu">
                                <li class="submenu-item">
                                    <a href="@Url.Action("HRMS", "HR")">Human Resource</a>
                                </li>
                            </ul>
                        </li>
                        <li class="sidebar-item has-sub">
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-box-seam-fill"></i>
                                <span>Inventory</span>
                            </a>
                            <ul class="submenu">
                                <li class="submenu-item">
                                    <a href="@Url.Action("ItemList", "Lists")">Item List</a>
                                </li>
                                <li class="submenu-item">
                                    <a href="@Url.Action("WareHouse", "Inventory")">Warehouse</a>
                                </li>
                                <li class="submenu-item">
                                    <a href="@Url.Action("WarehouseTransfer", "Inventory")">Item Warehouse Transfer</a>
                                </li>
                            </ul>
                        </li>
                        <li class="sidebar-item has-sub">
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-bank"></i>
                                <span>Banking</span>
                            </a>
                            <ul class="submenu">
                                <li class="submenu-item">
                                    <a href="@Url.Action("BankCenter", "Account")">Bank Center</a>
                                </li>
                                <li class="submenu-item">
                                    <a href="@Url.Action("BankCardCenter", "Account")">Bank Card Center</a>
                                </li>
                                <li class="submenu-item">
                                    <a href="@Url.Action("BankCheque", "Account")">Bank Cheque</a>
                                </li>
                                <li class="submenu-item">
                                    <a href="@Url.Action("PDC", "Account")">PDC</a>
                                </li>
                            </ul>
                        </li>
                        <li class="sidebar-item has-sub">
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-gear-fill"></i>
                                <span>Settings</span>
                            </a>
                            <ul class="submenu">
                                <li class="submenu-item">
                                    <a href="@Url.Action("ChangePassword", "Settings")">Change Password</a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <button class="sidebar-toggler btn x"><i class="bi bi-x"></i></button>
            </div>
        </div>

        <div id="main">
            <div>
                <div class="content" id="kt_content">
                    @RenderBody()
                </div>
            </div>

            <div class="modal fade" id="companyProfileModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content" id="companyProfileModalContent"></div>
                </div>
            </div>

            <footer>
                <partial name="_footer" />
            </footer>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/lib/jquery-ajax-unobtrusive/jquery.unobtrusive-ajax.min.js"></script>
    <script src="~/assets/vendors/simple-datatables/simple-datatables.js"></script>
    <script src="~/assets/js/pages/dashboard.js"></script>
    <script src="~/assets/js/main.js"></script>

    <script>
        function translateTo(lang) {
            var prev = null;
            try { prev = localStorage.getItem('siteLang') || null; } catch (e) {}
            if (lang === prev) return;
            try { localStorage.setItem('siteLang', lang); } catch (e) {}
            try { window.__setSiteLangCookie && window.__setSiteLangCookie('siteLang', lang, 365); } catch (e) {}
            if (lang === 'ar') {
                document.cookie = 'googtrans=/en/ar; path=/';
                document.cookie = 'googtrans=/en/ar; path=/; domain=' + location.hostname;
                document.cookie = 'googtrans=/en/ar; path=/; domain=.' + location.hostname;
            } else {
                var exp = '; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/';
                document.cookie = 'googtrans=' + exp;
                document.cookie = 'googtrans=' + exp + '; domain=' + location.hostname;
                document.cookie = 'googtrans=' + exp + '; domain=.' + location.hostname;
            }
            location.reload();
        }

        $(document).ready(function () {
            $('.sidebar-item.has-sub > .sidebar-link').on('click', function (e) {
                e.preventDefault();
                var $p = $(this).parent('.sidebar-item.has-sub');
                $p.toggleClass('active');
                $p.find('.submenu').first().slideToggle(300);
                $('.sidebar-item.has-sub').not($p).removeClass('active').find('.submenu').slideUp(300);
            });

            var cp = window.location.pathname;
            $('.submenu-item a').each(function () {
                var lp = $(this).attr('href');
                if (lp && cp.indexOf(lp) !== -1 && lp !== '/') {
                    $(this).parent('.submenu-item').addClass('active');
                    $(this).closest('.sidebar-item.has-sub').addClass('active');
                    $(this).closest('.submenu').show();
                }
            });

            $('.sidebar-hide, .sidebar-toggler').on('click', function (e) {
                e.preventDefault();
                $('#sidebar').toggleClass('active');
            });
            $('.burger-btn').on('click', function (e) {
                e.preventDefault();
                $('#sidebar').addClass('active');
            });

            $("#dynamicMenu li[data-item], #dynamicMenu li[data-sub], #dynamicMenu li[data-main]").hide();
            $.get("/Account/GetUserMenu", function (res) {
                if (!res.status) return;
                res.data.forEach(function (main) {
                    main.subMenus.forEach(function (sub) {
                        var item = $('[data-item="' + sub.name.trim() + '"]');
                        item.show();
                        item.closest("li[data-sub]").show();
                        item.closest("li[data-main]").show();
                    });
                });
                $("#dynamicMenu li[data-main]").each(function () {
                    if ($(this).find("li:visible").length === 0) $(this).hide();
                });
            });
        });

        function openCompanyProfileModal() {
            $("#companyProfileModalContent").load("/CompanyCenter/Edit", function () {
                new bootstrap.Modal(document.getElementById("companyProfileModal")).show();
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/site.js"></script>
</body>
</html>
