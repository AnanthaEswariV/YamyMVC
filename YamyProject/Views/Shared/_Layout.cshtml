    <!-- Body scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/lib/jquery-ajax-unobtrusive/jquery.unobtrusive-ajax.min.js"></script>
    <script src="~/assets/vendors/simple-datatables/simple-datatables.js"></script>
    <script src="~/assets/js/pages/dashboard.js"></script>
    <script src="~/assets/js/main.js"></script>

    <script>
        // Save preference → set cookie + localStorage → set googtrans cookie → reload.
        function translateTo(lang) {
            var previous = null;
            try { previous = localStorage.getItem('siteLang') || null; } catch (e) { previous = null; }
            if (lang === previous) return;

            try { localStorage.setItem('siteLang', lang); } catch (e) {}
            try { window.__setSiteLangCookie && window.__setSiteLangCookie('siteLang', lang, 365); } catch (e) {}

            if (lang === 'ar') {
                document.cookie = 'googtrans=/en/ar; path=/';
                document.cookie = 'googtrans=/en/ar; path=/; domain=' + location.hostname;
                document.cookie = 'googtrans=/en/ar; path=/; domain=.' + location.hostname;
            } else {
                var exp = '; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/';
                document.cookie = 'googtrans=' + exp;
                document.cookie = 'googtrans=' + exp + '; domain=' + location.hostname;
                document.cookie = 'googtrans=' + exp + '; domain=.' + location.hostname;
            }

            // reload so server reads cookie and can render initial hidden state when needed
            location.reload();
        }

        // ─── Sidebar Logic ───────────────────────────────────────────────────────
        $(document).ready(function () {
            $('.sidebar-item.has-sub > .sidebar-link').on('click', function (e) {
                e.preventDefault();
                var $parent = $(this).parent('.sidebar-item.has-sub');
                $parent.toggleClass('active');
                $parent.find('.submenu').first().slideToggle(300);
                $('.sidebar-item.has-sub').not($parent).removeClass('active');
                $('.sidebar-item.has-sub').not($parent).find('.submenu').slideUp(300);
            });

            var currentPath = window.location.pathname;
            $('.submenu-item a').each(function () {
                var linkPath = $(this).attr('href');
                if (linkPath && currentPath.indexOf(linkPath) !== -1 && linkPath !== '/') {
                    $(this).parent('.submenu-item').addClass('active');
                    $(this).closest('.sidebar-item.has-sub').addClass('active');
                    $(this).closest('.submenu').show();
                }
            });

            $('.sidebar-hide, .sidebar-toggler').on('click', function (e) {
                e.preventDefault();
                $('#sidebar').toggleClass('active');
            });

            $('.burger-btn').on('click', function (e) {
                e.preventDefault();
                $('#sidebar').addClass('active');
            });

            $("#dynamicMenu li[data-item]").hide();
            $("#dynamicMenu li[data-sub]").hide();
            $("#dynamicMenu li[data-main]").hide();

            $.get("/Account/GetUserMenu", function (res) {
                if (!res.status) return;
                res.data.forEach(main => {
                    main.subMenus.forEach(sub => {
                        const itemName = sub.name.trim();
                        const item = $(`[data-item="${itemName}"]`);
                        item.show();
                        item.closest("li[data-sub]").show();
                        item.closest("li[data-main]").show();
                    });
                });
                $("#dynamicMenu li[data-main]").each(function () {
                    if ($(this).find("li:visible").length === 0) $(this).hide();
                });
            });
        });

        // ─── Company Modal ───────────────────────────────────────────────────────
        function openCompanyProfileModal() {
            $("#companyProfileModalContent").load("/CompanyCenter/Edit", function () {
                const modal = new bootstrap.Modal(document.getElementById("companyProfileModal"));
                modal.show();
            });
        }

    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/site.js"></script>
</body>
</html> 