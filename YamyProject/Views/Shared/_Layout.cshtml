@using System.Globalization
@{
    // Prefer cookie (set by client) so server can render initial HTML correctly on next navigation.
    var cookieLang = Context.Request.Cookies["siteLang"];
    var isAr = string.Equals(cookieLang, "ar", StringComparison.OrdinalIgnoreCase)
               || CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
}

<!DOCTYPE html>
<!-- set lang/dir and initial visibility on server to avoid first-paint flash -->
<html lang="@(isAr ? "ar" : "en")" dir="@(isAr ? "rtl" : "ltr")" id="htmlRoot" style="@(isAr ? "visibility:hidden;" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YamyProject | @ViewData["Title"]</title>

    <!-- Loader styles (early) -->
    <style>
        /* Full-screen translate loader */
        #gt-loader {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.92);
            z-index: 99999;
            -webkit-backdrop-filter: blur(4px);
            backdrop-filter: blur(4px);
        }

        #gt-loader .spinner {
            width: 70px;
            height: 70px;
            border: 8px solid #e6e9ef;
            border-top-color: #4f46e5;
            border-radius: 50%;
            animation: gt-spin 1s linear infinite;
            margin-bottom: 12px;
        }

        #gt-loader .msg {
            font-family: Nunito, system-ui, -apple-system, "Segoe UI", Roboto, Arial;
            color: #374151;
            font-weight: 600;
            text-align: center;
            font-size: 14px;
        }

        keyframes gt-spin {
            to { transform: rotate(360deg); }
        }
    </style>


    <!--
        Translation guard:
        - Read cookie or localStorage for preferred language.
        - Set googtrans cookie before GT script loads.
        - Show loader until translation ready (or until fallback).
    -->
    <script>
        (function () {
            function getCookie(name) {
                var m = document.cookie.match('(?:^|; )' + name.replace(/([.$?*|{}()[]\/+^])/g, '\\$1') + '=([^;]*)');
                return m ? decodeURIComponent(m[1]) : null;
            }
            var lang = getCookie('siteLang') || (function () {
                try { return localStorage.getItem('siteLang'); } catch (e) { return null; }
            })() || 'en';

            function setTranslateCookie(value) {
                var domains = [
                    '; path=/',
                    '; path=/; domain=' + location.hostname,
                    '; path=/; domain=.' + location.hostname
                ];
                domains.forEach(function (d) {
                    document.cookie = 'googtrans=' + value + d;
                });
            }

            // create loader element immediately and attach to document.body
            var loader = document.createElement('div');
            loader.id = 'gt-loader';
            loader.innerHTML = '<div style="text-align:center"><div class="spinner"></div><div class="msg">Applying language…</div></div>';
            try {
                if (document.body) document.body.appendChild(loader);
                else document.documentElement.appendChild(loader);
            } catch (e) { /* ignore */ }

            var loaderShownAt = 0;
            var minVisibleMs = 800; // ensure loader is visible at least this long

            function showLoader() {
                try {
                    loader.style.display = 'flex';
                    // force reflow so browser paints loader immediately
                    // eslint-disable-next-line no-unused-expressions
                    loader.offsetHeight;
                    loaderShownAt = Date.now();
                } catch (e) {}
            }
            function hideLoaderDelayed() {
                try {
                    var elapsed = Date.now() - (loaderShownAt || 0);
                    var remain = minVisibleMs - elapsed;
                    if (remain > 0) {
                        setTimeout(hideLoaderImmediate, remain);
                    } else {
                        hideLoaderImmediate();
                    }
                } catch (e) { hideLoaderImmediate(); }
            }
            function hideLoaderImmediate() {
                try {
                    loader.style.display = 'none';
                    if (loader.parentNode) loader.parentNode.removeChild(loader);
                } catch (e) {}
            }

            if (lang === 'ar') {
                try {
                    document.documentElement.setAttribute('dir', 'rtl');
                    document.documentElement.setAttribute('lang', 'ar');
                } catch (e) { /* ignore */ }

                // set googtrans cookie before GT script loads
                setTranslateCookie('/en/ar');

                // ensure page visible (server may have hidden it), show loader
                try { document.documentElement.style.visibility = 'visible'; } catch (e) {}
                showLoader();

                var shown = false;
                function showPage() {
                    if (shown) return;
                    shown = true;
                    hideLoaderDelayed();
                }

                // Increase fallback to 30s to avoid early hide on slow networks
                var fallbackTimer = setTimeout(showPage, 30000);

                function checkTranslated() {
                    var cls = document.documentElement.className || '';
                    if (cls.indexOf('translated') !== -1) return true;
                    if (document.querySelector('.goog-te-combo')) return true;
                    if (document.querySelector('iframe.goog-te-banner-frame')) return true;
                    return false;
                }

                if (checkTranslated()) {
                    clearTimeout(fallbackTimer);
                    setTimeout(showPage, 300); // small buffer before hiding
                } else {
                    var obs = new MutationObserver(function () {
                        if (checkTranslated()) {
                            clearTimeout(fallbackTimer);
                            setTimeout(showPage, 300);
                            obs.disconnect();
                        }
                    });
                    obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'dir', 'lang'] });

                    var bodyObs = new MutationObserver(function () {
                        if (checkTranslated()) {
                            clearTimeout(fallbackTimer);
                            setTimeout(showPage, 300);
                            bodyObs.disconnect();
                            obs.disconnect();
                        }
                    });
                    bodyObs.observe(document.documentElement, { childList: true, subtree: true });
                }
            } else {
                try {
                    var expiry = '; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/';
                    document.cookie = 'googtrans=' + expiry;
                    document.cookie = 'googtrans=' + expiry + '; domain=' + location.hostname;
                    document.cookie = 'googtrans=' + expiry + '; domain=.' + location.hostname;
                } catch (e) { /* ignore */ }
                try { document.documentElement.style.visibility = 'visible'; } catch (e) {}
                try { hideLoaderImmediate(); } catch (e) {}
            }
        })();
    </script>


    <script>
        (function () {
          // helper cookie writer for translateTo
          function setCookie(name, value, days) {
            var expires = '';
            if (typeof days === 'number') {
              expires = '; max-age=' + (days * 24 * 60 * 60);
            }
            document.cookie = name + '=' + encodeURIComponent(value) + '; path=/' + expires;
          }

          // Intercept internal navigations and show loader immediately if Arabic selected.
          function isInternalLink(a) {
            if (!a || !a.getAttribute) return false;
            var href = a.getAttribute('href');
            if (!href) return false;
            if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('javascript:')) return false;
            try {
              var url = new URL(href, location.href);
              return url.origin === location.origin;
            } catch (e) {
              return false;
            }
          }

          // small helper to show loader (element should already be present from head)
          function showLoaderIfArabic() {
            try {
              var cookieLang = (function () {
                var m = document.cookie.match('(?:^|; )' + 'siteLang'.replace(/([.$?*|{}()[]\/+^])/g, '\\$1') + '=([^;]*)');
                return m ? decodeURIComponent(m[1]) : null;
              })();
              var ls = null;
              try { ls = localStorage.getItem('siteLang'); } catch (e) { ls = null; }
              var lang = cookieLang || ls;
              if (lang === 'ar') {
                  var loader = document.getElementById('gt-loader');
                  if (loader) loader.style.display = 'flex';
              }
            } catch (e) { /* ignore */ }
          }

          document.addEventListener('click', function (ev) {
            var a = ev.target.closest('a');
            if (!a) return;
            if (a.target && a.target.toLowerCase() !== '_self') return;
            if (a.hasAttribute('download') || a.hasAttribute('data-no-pjax')) return;
            if (!isInternalLink(a)) return;

            showLoaderIfArabic();
            // allow the navigation to proceed normally
          }, true);

          // Show loader on form submit as well when Arabic chosen
          document.addEventListener('submit', function (ev) {
            showLoaderIfArabic();
          }, true);

          // Expose cookie helper to translateTo below
          window.__setSiteLangCookie = setCookie;
        })();
    </script>

    <!-- Google Translate initialiser — must load BEFORE the page renders -->
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'ar,en'
            }, 'google_translate_element');
        }
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <script>
    (function () {
        function getCookie(name) {
            var m = document.cookie.match('(?:^|; )' + name.replace(/([.$?*|{}()[]\/+^])/g, '\\$1') + '=([^;]*)');
            return m ? decodeURIComponent(m[1]) : null;
        }

        // If siteLang cookie requests Arabic, ensure googtrans is set and re-init GT when ready.
        var desired = getCookie('siteLang') || (function () { try { return localStorage.getItem('siteLang'); } catch (e) { return null; } })();
        if (desired === 'ar') {
            try {
                document.cookie = 'googtrans=/en/ar; path=/';
                document.cookie = 'googtrans=/en/ar; path=/; domain=' + location.hostname;
                document.cookie = 'googtrans=/en/ar; path=/; domain=.' + location.hostname;
            } catch (e) { console.warn('Unable to set googtrans cookie', e); }
        }

        // Retry init: some environments load GT slower — re-create TranslateElement if needed.
        var tries = 0;
        var maxTries = 60; // 60 * 200ms = 12s max
        var retry = setInterval(function () {
            tries++;
            if (window.google && google.translate && google.translate.TranslateElement) {
                clearInterval(retry);
                try {
                    // If GT was not initialized or cookie changed, re-create widget to pick up cookie
                    new google.translate.TranslateElement({ pageLanguage: 'en', includedLanguages: 'ar,en' }, 'google_translate_element');
                    console.debug('Google Translate re-initialized');
                } catch (e) {
                    console.warn('GT init error', e);
                }
                return;
            }
            if (tries >= maxTries) {
                clearInterval(retry);
                console.warn('Google Translate not available after retries');
            }
        }, 200);
    })();
    </script>

    <style>
        /* Language toggle buttons */
        #btn-en, #btn-ar {
            background: #667eea;
            color: white;
            border: none;
            padding: 4px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            opacity: 0.6;
        }

            #btn-en.active, #btn-ar.active {
                opacity: 1;
                outline: 2px solid white;
            }

        /* Hide Google Translate toolbar / gadget */
        .goog-te-banner-frame {
            display: none !important;
        }

        body {
            top: 0 !important;
        }

        .goog-te-gadget {
            display: none !important;
        }

        .skiptranslate {
            display: none !important;
        }

        /* Sidebar submenu positioning */
        .navbar-links .submenu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            z-index: 9999;
            background: white;
            min-width: 200px;
        }

        .navbar-links .dropdown:hover > .submenu {
            display: block;
        }

        .navbar-links .has-submenu > .submenu {
            top: 0;
            left: 100%;
        }
    </style>

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap">
    <link rel="stylesheet" href="~/assets/css/bootstrap.css" />
    <link rel="stylesheet" href="~/assets/vendors/iconly/bold.css" />
    <link rel="stylesheet" href="~/assets/vendors/perfect-scrollbar/perfect-scrollbar.css" />
    <link rel="stylesheet" href="~/assets/css/app.css" asp-append-version="true" />
    <link rel="icon" href="~/assets/images/logo/yamy.png" type="image/png" />
    <link rel="stylesheet" href="~/css/MainLayout.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @RenderSection("Styles", required: false)
</head>

<body>

    <div id="app">
        <partial name="_Header" />

