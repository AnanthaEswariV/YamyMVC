    <style>
        #gt-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #ffffff;
            z-index: 2147483647;
            display: none;
            align-items: center;
            justify-content: center;
            visibility: visible !important;
        }

            #gt-overlay .gt-spinner {
                width: 64px;
                height: 64px;
                border: 7px solid #e5e7eb;
                border-top-color: #4f46e5;
                border-radius: 50%;
                animation: gt-spin 0.9s linear infinite;
                margin-bottom: 14px;
            }

            #gt-overlay .gt-msg {
                font-family: Nunito, system-ui, sans-serif;
                font-size: 14px;
                font-weight: 600;
                color: #374151;
                text-align: center;
            }

        @@keyframes gt-spin {
            to {
                transform: rotate(360deg);
            }
        }

        .goog-te-banner-frame, .goog-te-gadget, .skiptranslate {
            display: none !important;
        }

        body {
            top: 0 !important;
        }
    </style>

    <script>
        /* ============================================================
           STEP 1 — GLOBAL GT PROTECTION (runs before GT loads)
           ============================================================
           A) Marks modal-content, modal-body, table tbody as notranslate
              so GT never corrupts form labels or table data
           B) Backs up every data-* attribute that contains JSON / long text
              then restores after GT finishes
        ============================================================ */
        (function () {
        // ✅ REPLACE WITH — only shields hidden inputs so JS values stay safe
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('input[type="hidden"]').forEach(function(el) {
                el.setAttribute('translate', 'no');
            });
        });

        new MutationObserver(function (muts) {
            muts.forEach(function (m) {
                m.addedNodes.forEach(function(node) {
                    if (node.nodeType !== 1) return;
                    if (node.matches && node.matches('input[type="hidden"]')) {
                        node.setAttribute('translate', 'no');
                    }
                    if (node.querySelectorAll) {
                        node.querySelectorAll('input[type="hidden"]').forEach(function(el) {
                            el.setAttribute('translate', 'no');
                        });
                    }
                });
            });
        }).observe(document.documentElement, { childList: true, subtree: true });
            /* ── B: data-attribute guardian ────────────────────────── */
            var _attrStore = [];   // [{el, name, value}]

            function guardEl(el) {
                if (!el || el.nodeType !== 1 || el._gtGuarded) return;
                el._gtGuarded = true;
                for (var i = 0; i < el.attributes.length; i++) {
                    var a = el.attributes[i];
                    if (a.name.indexOf('data-') === 0 && a.value.length > 5) {
                        _attrStore.push({ el: el, name: a.name, value: a.value });
                    }
                }
            }

            function guardSubtree(root) {
                guardEl(root);
                if (root.querySelectorAll) {
                    root.querySelectorAll('[data-id],[data-project],[data-item],[data-vendor],[data-customer],[data-account],[data-record],[data-row]')
                        .forEach(guardEl);
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                guardSubtree(document.body);
            });

            new MutationObserver(function (muts) {
                muts.forEach(function (m) {
                    m.addedNodes.forEach(function (n) {
                        if (n.nodeType === 1) guardSubtree(n);
                    });
                });
            }).observe(document.documentElement, { childList: true, subtree: true });

            /* expose restore so gtReady handler (bottom of body) can call it */
            window.__restoreDataAttrs = function () {
                _attrStore.forEach(function (item) {
                    try { item.el.setAttribute(item.name, item.value); } catch (e) {}
                });
            };

        })();
    </script>

    <script>
        /* ============================================================
           STEP 2 — GT OVERLAY / REVEAL LOGIC
        ============================================================ */
        (function () {
            function getCookie(n) {
                var m = document.cookie.match('(?:^|; )' + n.replace(/([.$?*|{}()\[\]\/+^])/g, '\\$1') + '=([^;]*)');
                return m ? decodeURIComponent(m[1]) : null;
            }
            function setGT(v) {
                ['; path=/', '; path=/; domain=' + location.hostname, '; path=/; domain=.' + location.hostname]
                    .forEach(function (d) { document.cookie = 'googtrans=' + v + d; });
            }
            function clearGT() {
                var e = '; expires=Thu,01 Jan 1970 00:00:00 UTC; path=/';
                document.cookie = 'googtrans=' + e;
                document.cookie = 'googtrans=' + e + '; domain=' + location.hostname;
                document.cookie = 'googtrans=' + e + '; domain=.' + location.hostname;
            }

            var lang = getCookie('siteLang') ||
                (function () { try { return localStorage.getItem('siteLang'); } catch (e) { return null; } })() || 'en';

            var overlay = document.createElement('div');
            overlay.id = 'gt-overlay';
            overlay.innerHTML = '<div style="text-align:center"><div class="gt-spinner"></div><div class="gt-msg">Applying language\u2026</div></div>';
            document.documentElement.appendChild(overlay);

            if (lang !== 'ar') {
                clearGT();
                document.documentElement.style.visibility = 'visible';
                overlay.parentNode && overlay.parentNode.removeChild(overlay);
                return;
            }

            document.documentElement.setAttribute('dir', 'rtl');
            document.documentElement.setAttribute('lang', 'ar');
            setGT('/en/ar');
            overlay.style.display = 'flex';
            void overlay.offsetHeight;

            var done = false;
            var settleTimer = null;
            var classObs, bodyObs;

            function reveal() {
                if (done) return;
                done = true;
                clearTimeout(settleTimer);
                clearTimeout(fallback);
                try { classObs && classObs.disconnect(); } catch (e) {}
                try { bodyObs  && bodyObs.disconnect();  } catch (e) {}
                document.documentElement.style.visibility = 'visible';
                setTimeout(function () {
                    overlay.style.display = 'none';
                    overlay.parentNode && overlay.parentNode.removeChild(overlay);
                    /* restore any data-* attrs GT may have touched */
                    try { window.__restoreDataAttrs && window.__restoreDataAttrs(); } catch (e) {}
                    /* signal pages that GT is done */
                    try { window.dispatchEvent(new CustomEvent('gtReady')); } catch (e) {}
                }, 80);
            }

            /* GT sometimes adds translated-ltr instead of translated-rtl */
            function isTranslated() {
                return (document.documentElement.className || '').indexOf('translated-') !== -1;
            }

            function resetSettle() {
                clearTimeout(settleTimer);
                settleTimer = setTimeout(reveal, 300);
            }

            classObs = new MutationObserver(function () {
                if (isTranslated()) resetSettle();
            });
            classObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

            function startBodyWatch() {
                if (!document.body) { setTimeout(startBodyWatch, 20); return; }
                bodyObs = new MutationObserver(function () {
                    if (isTranslated()) resetSettle();
                });
                bodyObs.observe(document.body, { childList: true, subtree: true, characterData: true });
            }
            startBodyWatch();

            /* Force reveal after 4s if GT class appeared but settle never triggered */
            setTimeout(function () { if (isTranslated() && !done) reveal(); }, 4000);

            /* Safety fallback */
            var fallback = setTimeout(function () { if (!done) reveal(); }, 20000);

            if (isTranslated()) resetSettle();
        })();
    </script>

    <script>
        /* ============================================================
           STEP 3 — NAVIGATION GUARD
        ============================================================ */
        (function () {
            function setCookie(name, value, days) {
                document.cookie = name + '=' + encodeURIComponent(value) +
                    '; path=/; max-age=' + (days * 86400);
            }
            function isInternal(a) {
                if (!a || !a.getAttribute) return false;
                var h = a.getAttribute('href');
                if (!h || /^(#|mailto:|tel:|javascript:)/i.test(h)) return false;
                try { return new URL(h, location.href).origin === location.origin; }
                catch (e) { return false; }
            }
            function hideForNav() {
                try {
                    var m = document.cookie.match('(?:^|; )siteLang=([^;]*)');
                    var l = m ? decodeURIComponent(m[1]) : null;
                    if (!l) { try { l = localStorage.getItem('siteLang'); } catch (e) {} }
                    if (l !== 'ar') return;
                    document.documentElement.style.visibility = 'hidden';
                    var ov = document.getElementById('gt-overlay');
                    if (ov) {
                        ov.style.display = 'flex';
                    } else {
                        var fresh = document.createElement('div');
                        fresh.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:#fff;z-index:2147483647;display:flex;align-items:center;justify-content:center;visibility:visible!important;';
                        fresh.innerHTML = '<div style="text-align:center"><div style="width:56px;height:56px;border:6px solid #e5e7eb;border-top-color:#4f46e5;border-radius:50%;animation:gt-spin .9s linear infinite;margin-bottom:12px"></div><div style="font:600 13px/1 Nunito,sans-serif;color:#374151">Applying language\u2026</div></div>';
                        document.documentElement.appendChild(fresh);
                    }
                } catch (e) {}
            }
            document.addEventListener('click', function (ev) {
                var a = ev.target.closest('a');
                if (!a) return;
                if (a.target && a.target.toLowerCase() !== '_self') return;
                if (a.hasAttribute('download') || a.hasAttribute('data-no-pjax')) return;
                if (!isInternal(a)) return;
                hideForNav();
            }, true);
        document.addEventListener('submit', function (ev) {
            var form = ev.target;
            if (!form) return;
            if (form.getAttribute('data-ajax') === 'true') return;
            if (form.hasAttribute('data-ajax')) return;
            var action = form.getAttribute('action') || '';
            if (!action || action === '#' || action === '') return;
            hideForNav();
        }, true);
            window.__setSiteLangCookie = setCookie;
        })();
    </script>

    <!-- Google Translate -->
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement(
