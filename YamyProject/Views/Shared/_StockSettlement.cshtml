@model StockSettlementIndexViewModel

<div class="container-fluid bg-light p-3 rounded shadow-sm">

    <!-- Invoice Header -->
    <div class="row mb-3">
        <div class="col-md-3">
            <label for="Date" class="form-label">Date</label>
            <input type="date" id="Date" name="Date" class="form-control" />
        </div>

        <div class="col-md-4">
            <label for="Warehouse" class="form-label">Warehouse</label>
            <select id="Warehouse" name="Warehouse" class="form-select">
                @* Example for binding:
                @foreach (var wh in Model.Warehouses)
                {
                    <option value="@wh.Value" @(wh.Value == Model.Warehouse ? "selected" : "")>@wh.Text</option>
                } *@
            </select>
        </div>

        <div class="col-md-5 d-flex align-items-end justify-content-end gap-2">
            <button type="button" class="btn btn-outline-secondary">&laquo; Previous</button>
            <button type="button" class="btn btn-outline-secondary">Next &raquo;</button>
        </div>
    </div>

    <!-- Items Table -->
    <div class="table-responsive">
        <table class="table table-bordered table-hover text-center align-middle">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Item Code</th>
                    <th>Item Name</th>
                    <th>SYS QTY</th>
                    <th>Price</th>
                    <th>SYS Amount</th>
                    <th>New QTY</th>
                    <th>QTY DIF</th>
                    <th>Amount (-)</th>
                    <th>Amount (+)</th>
                    <th>DEL</th>
                </tr>
            </thead>
            <tbody>
                 @if (Model.Items != null && Model.Items.Any())
                {
                    int sn = 1;
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@sn</td>
                            <td>@item.Code</td>
                          @*   <td>@item.n</td>
                            <td>@item.SysQty</td>
                            <td>@item.Price</td>
                            <td>@item.SysAmount</td>
                            <td><input type="number" name="Items[@(sn - 1)].NewQty" value="@item.NewQty" class="form-control" /></td>
                            <td>@item.QtyDiff</td>
                            <td>@item.AmountMinus</td>
                            <td>@item.AmountPlus</td> *@
                            <td><button type="button" class="btn btn-sm btn-danger">X</button></td>
                        </tr>
                        sn++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="text-muted">No items added.</td>
                    </tr>
                } 
            </tbody>
        </table>
    </div>

    <!-- Invoice Footer -->
    <div class="d-flex justify-content-end gap-3 mt-3">
        <div>
            <label class="form-label">Amount (-)</label>
            @* <input type="text" class="form-control" value="@Model.TotalAmountMinus" readonly /> *@
        </div>
        <div>
            <label class="form-label">Amount (+)</label>
            @* <input type="text" class="form-control" value="@Model.TotalAmountPlus" readonly /> *@
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Close</a>
    </div>
</div>
