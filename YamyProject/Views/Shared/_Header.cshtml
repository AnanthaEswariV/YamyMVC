<script>
    // ── Mark the active language button immediately from localStorage ────────
    (function () {
        var lang = localStorage.getItem('siteLang') || 'en';
        var btn = document.getElementById('btn-' + lang);
        if (btn) btn.classList.add('active');
    })();

    // ── Permission-based menu filtering ─────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        var permissions = JSON.parse(localStorage.getItem('userPermissions') || '[]');

        var mainMenuMap = {};
        var subMenuMap  = {};

        permissions.forEach(function (p) {
            if (p.mainMenuName && p.canView === true) {
                mainMenuMap[p.mainMenuName.trim().toLowerCase()] = true;
            }
            if (p.subMenuName && p.canView === true) {
                subMenuMap[p.subMenuName.trim().toLowerCase()] = true;
            }
        });

        // Hide sub-menu items the user cannot see
        document.querySelectorAll('[data-submenu]').forEach(function (el) {
            var key = el.getAttribute('data-submenu').trim().toLowerCase();
            if (!subMenuMap[key]) {
                var li = el.closest('li');
                if (li) li.style.display = 'none';
            }
        });

        // Hide sub-dropdowns that are now completely empty
        document.querySelectorAll('.has-submenu').forEach(function (menu) {
            var visible = menu.querySelectorAll('li:not([style*="display: none"])');
            if (visible.length === 0) menu.style.display = 'none';
        });

        // Hide top-level menu items the user cannot see
        document.querySelectorAll('.navbar-links > li.dropdown').forEach(function (menu) {
            var key = menu.getAttribute('data-mainmenu');
            if (!key) key = menu.firstChild.textContent;
            if (!key) return;
            key = key.trim().toLowerCase();
            if (!mainMenuMap[key]) menu.style.display = 'none';
        });
    });
</script>
