<style>
    /* ── RTL Submenu Fix ─────────────────────────────────────────────── */
    [dir="rtl"] .navbar-links .submenu {
        left: auto !important;
        right: 0 !important;
    }

    [dir="rtl"] .navbar-links .dropdown:hover > .submenu {
        left: auto !important;
        right: 0 !important;
    }

    /* Nested submenus open to the LEFT in RTL */
    [dir="rtl"] .navbar-links .has-submenu > .submenu {
        left: auto !important;
        right: 100% !important;
        top: 0 !important;
    }

    [dir="rtl"] .navbar-links {
        direction: rtl;
    }

    [dir="rtl"] .top-navbar .d-flex {
        flex-direction: row-reverse;
    }

    /* Nested submenus open to the RIGHT in LTR */
    [dir="ltr"] .navbar-links .has-submenu > .submenu {
        left: 100% !important;
        right: auto !important;
        top: 0 !important;
    }
</style>

