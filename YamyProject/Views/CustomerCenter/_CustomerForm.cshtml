@model CustomerViewModel

<form asp-action="Create" asp-controller="CustomerCenter" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Customer.Id" />

    <!-- Tabs -->
@*     <ul class="nav nav-tabs nav-tabs-sm mb-3" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active small" id="tab-basic" data-bs-toggle="tab" data-bs-target="#panel-basic" type="button" role="tab">
                <i class="bi bi-card-text me-1"></i> Basic
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link small" id="tab-contact" data-bs-toggle="tab" data-bs-target="#panel-contact" type="button" role="tab">
                <i class="bi bi-telephone me-1"></i> Contact
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link small" id="tab-address" data-bs-toggle="tab" data-bs-target="#panel-address" type="button" role="tab">
                <i class="bi bi-geo-alt me-1"></i> Address
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link small" id="tab-account" data-bs-toggle="tab" data-bs-target="#panel-account" type="button" role="tab">
                <i class="bi bi-gear me-1"></i> Account
            </button>
        </li>
    </ul> *@

    <div @* class="tab-content" *@ class="modal fade" id="CustomerModal" tabindex="-1"
         aria-labelledby="CustomerModalLabel" aria-hidden="true">
        <!-- BASIC -->
        @* <div class="tab-pane fade show active" @*  id="panel-basic" role="tabpanel"  > *@
            <div class="row g-2">
                <div class="col-md-6 col-12">
                    <label class="form-label small mb-1">Customer Name</label>
                    <input asp-for="Customer.Name" class="form-control form-control-sm" placeholder="Name" required />
                </div>
                <div class="col-md-3 col-6">
                    <label class="form-label small mb-1">Code</label>
                    <input asp-for="Customer.Code" class="form-control form-control-sm" placeholder="Code" disabled />
                </div>
                <div class="col-md-3 col-6 d-flex align-items-end">
                    <div class="w-100">
                        <label class="form-label small mb-1">Date</label>
                        <input asp-for="Customer.CreatedDate" type="date" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="col-6">
                    <label class="form-label small mb-1">Category</label>
                    <div class="input-group input-group-sm">
                        <select asp-for="Customer.CatId" class="form-select form-select-sm" asp-items="Model.Categoriess">
                            <option value="">Select</option>
                        </select>
                        <button type="button" id="addCategoryLink" class="btn btn-outline-secondary btn-sm" title="Add category">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">Opening Balance — Debit</label>
                    <input asp-for="Transactions.Debit" id="Debit" class="form-control form-control-sm" placeholder="0.00" />
                </div>
                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">Opening Balance — Credit</label>
                    <input asp-for="Transactions.Credit" id="Credit" class="form-control form-control-sm" placeholder="0.00" />
                </div>
            </div>
        @* </div> *@

        <!-- CONTACT -->
        @* <div class="tab-pane fade" @* id="panel-contact"  role="tabpanel"  > *@
            <div class="row g-2">
                <div class="col-md-4 col-12">
                    <label class="form-label small mb-1">Main Phone</label>
                    <input asp-for="Customer.MainPhone" class="form-control form-control-sm" placeholder="Main Phone" />
                </div>
                <div class="col-md-4 col-12">
                    <label class="form-label small mb-1">Work Phone</label>
                    <input asp-for="Customer.WorkPhone" class="form-control form-control-sm" placeholder="Work Phone" />
                </div>
                <div class="col-md-4 col-12">
                    <label class="form-label small mb-1">Mobile / Fax</label>
                    <input asp-for="Customer.Mobile" class="form-control form-control-sm" placeholder="Mobile or Fax" />
                </div>

                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">Email</label>
                    <input asp-for="Customer.Email" class="form-control form-control-sm" placeholder="Email" />
                </div>
                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">CC Email</label>
                    <input asp-for="Customer.Ccemail" class="form-control form-control-sm" placeholder="CC Email" />
                </div>

                <div class="col-6 mt-2">
                    <label class="form-label small mb-1">Website</label>
                    <input asp-for="Customer.Website" class="form-control form-control-sm" placeholder="Website" />
                </div>
            </div>
        @* </div> *@

        <!-- ADDRESS -->
        @* <div class="tab-pane fade"@*  id="panel-address" role="tabpanel" > *@
            <div class="row g-2">
                <div class="col-md-6 col-12">
                    <label class="form-label small mb-1">Country</label>
                    <select asp-for="Customer.Country" class="form-select form-select-sm" asp-items="Model.Countriess">
                        <option value="">Select Country</option>
                    </select>
                </div>
                <div class="col-md-6 col-12">
                    <label class="form-label small mb-1">City</label>
                    <select asp-for="Customer.City" class="form-select form-select-sm" asp-items="Model.Citys">
                        <option value="">Select City</option>
                    </select>
                </div>

                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">Region</label>
                    <input asp-for="Customer.Region" class="form-control form-control-sm" placeholder="Region" />
                </div>
                <div class="col-md-6 col-12 mt-2">
                    <label class="form-label small mb-1">Building</label>
                    <input asp-for="Customer.BuildingName" class="form-control form-control-sm" placeholder="Building Name" />
                </div>
            </div>
        @* </div> *@

        <!-- ACCOUNT & PROJECTS -->
        @* <div class="tab-pane fade" @* id="panel-account" role="tabpanel" > *@
            <div class="row g-2">
                <div class="col-md-6 col-12">
                    <label class="form-label small mb-1">Account</label>
                    <select asp-for="Customer.AccountId" class="form-select form-select-sm" asp-items="Model.Account">
                        <option value="">Select Account</option>
                    </select>
                </div>

                <div class="col-md-3 col-6 mt-2">
                    <label class="form-label small mb-1">TRN</label>
                    <input asp-for="Customer.Trn" class="form-control form-control-sm" placeholder="TRN" />
                </div>

                <div class="col-md-3 col-6 mt-2">
                    <label class="form-label small mb-1">Facility</label>
                    <input asp-for="Customer.FaciltyName" class="form-control form-control-sm" placeholder="Facility Name" />
                </div>

                @* Projects block is commented; leave as-is if you plan to use it later *@
            </div>
        @* </div> *@
    </div>

    <!-- Buttons -->
    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-sm btn-primary">Save</button>
    </div>
</form>

<style>
    /* compact tab styling */
    .nav-tabs-sm .nav-link {
        padding: .35rem .6rem;
        font-size: .85rem;
    }

    .form-label {
        font-weight: 500;
    }

    .form-control-sm, .form-select-sm {
        height: auto;
        padding: .35rem .5rem;
        font-size: .88rem;
    }

    .form-check-sm .form-check-input {
        width: 1rem;
        height: 1rem;
    }

    .input-group .btn {
        padding: .18rem .5rem;
    }
</style>
