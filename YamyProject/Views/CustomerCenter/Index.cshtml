    </script>
<script>

    $(function () {

            $(document).on('click', '#btnEditCustomer', function (e) {
            e.preventDefault();

            var id = $(this).data('id');
            if (!id) return;

                $.get('@Url.Action("Edit", "CustomerCenter")', { id: id }, function (html) {
                    $('#CustomerModalHost').html(html);

                        var modalEl = document.getElementById('CustomerModal');
                if (modalEl) {
                    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
