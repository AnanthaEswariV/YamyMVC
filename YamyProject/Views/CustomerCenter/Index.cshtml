@model CustomerCenterViewModel
@{
    ViewData["Title"] = "Customer Center";
    }
<div class="container-fluid mt-2">
    <!-- Top Menu -->
    <div class="d-flex align-items-center bg-light p-2 border rounded mb-2">
        <div class="btn-group">
            <button type="button"
                    class="btn btn-sm btn-outline-primary"
                    id="btnNewSubcontractor">
                Customer Operations
            </button>

            <!-- Modal content injected here -->
            <div id="CustomerModalHost"></div>
        </div>
    </div>

    <div class="row">
        <!-- Left Panel -->
        <div class="col-md-3 border-end">
            <form method="get" asp-action="Index" class="mb-2">
                <select name="state"
                        class="form-select form-select-sm"
                        onchange="this.form.submit()">
                    <option value="All" selected="@(Model.State == "All")">All Customers</option>
                    <option value="Active" selected="@(Model.State == "Active")">Active Customer</option>
                    <option value="Inactive" selected="@(Model.State == "Inactive")">Inactive Customer</option>
                </select>
            </form>

            <form method="get" asp-action="Index" class="mb-2">
                <input type="text"
                       name="searchText"
                       value="@Model.SearchText"
                       class="form-control form-control-sm"
                       placeholder="Search by Name, Code" />
            </form>

            <div class="list-group small">
                @foreach (var customer in Model.Customers)
                    {
                    var isActive = Model.SelectedCustomer?.Id == customer.Id ? "active" : "";
                    <a asp-action="Index"
                       asp-route-selectedId="@customer.Id"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @isActive">
                        @customer.Code - @customer.Name
                      @*   <span class="badge @(customer.Balance > 0 ? "bg-success" : "bg-light text-dark") rounded-pill">
                            @(customer.Balance.GetValueOrDefault().ToString("N2"))
                        </span> *@
                        <span class="badge @(customer.Amount > 0 ? "bg-success" : "bg-light text-dark") rounded-pill amount">@customer.Amount.ToString("N3")</span>
                    </a>
                    }
            </div>
        </div>

        <!-- Right Panel -->
        <div class="col-md-9">
            @if (Model.SelectedCustomer != null)
                {
                <div class="card mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2 pb-1 border-bottom px-3 pt-2">
                        <h5 class="mb-0 fw-semibold">Customer Information</h5>

                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                id="btnEditCustomer"
                                data-id="@Model.SelectedCustomer.Id"
                                title="Edit Customer">
                            <i class="bi bi-pencil"></i>
                        </button>
                    </div>

                    <!-- Details -->
                    <div class="row small px-3 pb-2">
                        <!-- Left column -->
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted pe-3">Customer Code</td>
                                        <td class="fw-semibold">@Model.SelectedCustomer.Code</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Customer Name</td>
                                        <td class="fw-semibold">@Model.SelectedCustomer.Name</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">TRN</td>
                                        <td>@Model.SelectedCustomer.Trn</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Email</td>
                                        <td>@Model.SelectedCustomer.Email</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Right column -->
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted pe-3">Work Phone</td>
                                        <td>@Model.SelectedCustomer.WorkPhone</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Main Phone</td>
                                        <td>@Model.SelectedCustomer.MainPhone</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Customer Category</td>
                                        <td>@Model.SelectedCustomer.City</td> @* change to CategoryName if you have *@
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-3">Address</td>
                                        <td class="text-truncate">@Model.SelectedCustomer.City</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <a class="nav-link active"
                           data-bs-toggle="tab"
                           href="#transactions">Transactions</a>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 p-2">
                    <!-- Transactions -->
                    <div class="tab-pane fade show active" id="transactions">
                        <table class="table table-sm table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>SN#</th>
                                    <th>Date</th>
                                    <th>Voucher No</th>
                                    <th>Voucher Type</th>
                                    <th>Description</th>
                                    <th>Debit</th>
                                    <th>Credit</th>
                                    <th>Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Transactions.Any())
                                    {
                                    int sn = 1;
                                    decimal runningBalance = 0;

                                    foreach (var t in Model.Transactions)
                                        {
                                        var debit = t.Debit;
                                        var credit = t.Credit;
                                        runningBalance += (debit - credit);
                                        var date = t.Date.HasValue
                                        ? t.Date.Value.ToString("yyyy-MM-dd")
                                        : "-";

                                        <tr class="txn-row"
                                            data-type="@t.VoucherType"
                                            data-form="@t.VoucherType"
                                            data-invoice-id="@t.invoiceId"
                                            data-vendor-id="@t.Id"
                                            data-date="@t.Date?.ToString("yyyy-MM-dd")">
                                            <td>@sn</td>
                                            <td>@date</td>
                                            <td>@t.VoucherNo</td>
                                            <td>@t.VoucherType</td>
                                            <td>@t.Description</td>
                                            <td>@debit.ToString("N2")</td>
                                            <td>@credit.ToString("N2")</td>
                                            <td>@runningBalance.ToString("N2")</td>
                                        </tr>

                                        sn++;
                                        }
                                    }
                                else
                                    {
                                    <tr>
                                        <td colspan="8" class="text-center">No transactions found.</td>
                                    </tr>
                                    }

                            </tbody>
                        </table>
                    </div>
                </div>
                }
            else
                {
                <div class="alert alert-info">
                    Select a customer from the left panel to view details.
                </div>
                }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            // NEW CUSTOMER
            $('#btnNewSubcontractor').on('click', function (e) {
                e.preventDefault();

                $.get('@Url.Action("Create", "CustomerCenter")', function (html) {
                    $('#CustomerModalHost').html(html);

                    var modalEl = document.getElementById('CustomerModal'); // id inside partial
                    if (modalEl) {
                        var modal = new bootstrap.Modal(modalEl); // use the element directly
                        modal.show();
                    }
                });
            });

            // EDIT CUSTOMER
            $(document).on('click', '#btnEditCustomer', function (e) {
                e.preventDefault();

                var id = $(this).data('id');
                if (!id) return;

                $.get('@Url.Action("Edit", "CustomerCenter")', { id: id }, function (html) {
                    $('#CustomerModalHost').html(html);

                    var modalEl = document.getElementById('CustomerModal'); // same id
                    if (modalEl) {
                        var modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                });
            });

        });
       
        $(document).on('dblclick', '#transactionsTable .txn-row', function () {
            const formNameRaw = $(this).data('form');
            const type        = $(this).data('type');
            const invoiceId   = $(this).data('invoiceId');
            const vendorId    = $(this).data('vendorId');
            const date        = $(this).data('date');   // <-- FIXED

            const formName = (formNameRaw || '').toString().toLowerCase();

            debugger;

            if (!formName || !invoiceId) return;

            if (formName.includes('sales invoice')) {
                window.location.href =
                    '@Url.Action("Edit", "PurchasesCenter")' + '?id=' + invoiceId;
            }
            else if (formName.includes('sales return')) {
                window.location.href =
                    '@Url.Action("Edit", "PurchasesReturn")' + '?id=' + invoiceId;
            }
            else if (formName.includes('customer Receipt')) {
                window.location.href =
                    '@Url.Action("GetVendorInvoiceRowsAsync", "ReceiptVouchers")'
                    + '?vendorId=' + vendorId;
            }
            else if (formName.includes('advance payment')) {
                window.location.href =
                    '@Url.Action("Details", "AdvancePayments")'
                    + '?id=' + invoiceId + '&vendorId=' + vendorId;
            }
            else if (formName.includes('customer opening balance')) {
                const params = new URLSearchParams({
                    refId: invoiceId,
                    vType: formNameRaw,
                    date:  date || ''
                });
                window.location.href = '@Url.Action("GeneralJournal", "Lists")' + '?' + params.toString();
            }
            else if (formName.includes('Credit Note')) {
                window.location.href =
                    '@Url.Action("Edite", "DebitNotes")'
                    + '?id=' + invoiceId;
            }
            else if (formName.includes('customer Advance')) {
                window.location.href =
                    '@Url.Action("Edite", "DebitNotes")'
                    + '?id=' + invoiceId;
            }
        });
  
    </script>
    }