<!-- Modal -->
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Add / Edit Customer</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="customerModalContent" class="p-0">
                    <!-- partial will be injected here via AJAX -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // helper to fetch partial and show modal
            async function loadPartial(url) {
                const resp = await fetch(url, { credentials: 'same-origin' });
                if (!resp.ok) {
                    console.error('Failed to load partial', resp.status);
                    return;
                }
                const html = await resp.text();
                document.getElementById('customerModalContent').innerHTML = html;

                // show the Bootstrap modal
                var modalEl = document.getElementById('customerModal');
                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            }

            // Add new customer (if you have a "New customer" button)
            document.addEventListener('click', function (e) {
                var addBtn = e.target.closest('#btnAddCustomer');
                if (addBtn) {
                    loadPartial('@Url.Action("Create", "CustomerCenter")');
                    return;
                }

                // Edit buttons (delegated)
                var el = e.target.closest('.btnEdit');
                if (!el) return;

                var id = el.getAttribute('data-id');
                if (!id) return;

                loadPartial('@Url.Action("Edit", "CustomerCenter")?id=' + encodeURIComponent(id));
            });

            // Delegate form submit inside modal: handle AJAX post
            document.addEventListener('submit', async function (e) {
                var form = e.target;
                if (!form.closest('#customerModal')) return; // only handle forms inside modal
                e.preventDefault();

                var fd = new FormData(form);
                var action = form.getAttribute('action') || '@Url.Action("Save", "Customer")';

                const resp = await fetch(action, {
                    method: 'POST',
                    body: fd,
                    credentials: 'same-origin'
                });

                const contentType = resp.headers.get('content-type') || '';
                if (contentType.indexOf('application/json') !== -1) {
                    const json = await resp.json();
                    if (json.success) {
                        // close modal
                        var modalEl = document.getElementById('customerModal');
                        var bsModal = bootstrap.Modal.getInstance(modalEl);
                        if (bsModal) bsModal.hide();

                        // call your refresh function (table reload, toast, etc.)
                        if (window.refreshCustomerTable) window.refreshCustomerTable();
                        return;
                    }
                }

                // Otherwise server likely returned the PartialView (with validation errors).
                const html = await resp.text();
                document.getElementById('customerModalContent').innerHTML = html;
            });

            // ===== Logic moved from partial (delegated so it works after injection) =====

            // Debit / Credit mutual disable
            $(document).on("input", "#Debit", function () {
                $("#Credit").prop("disabled", $(this).val().length > 0);
            });

            $(document).on("input", "#Credit", function () {
                $("#Debit").prop("disabled", $(this).val().length > 0);
            });

            // Projects check/uncheck (if you enable that block later)
            $(document).on("click", "#checkAllProjects", function () {
                $(".project-checkbox").prop("checked", true);
            });

            $(document).on("click", "#uncheckAllProjects", function () {
                $(".project-checkbox").prop("checked", false);
            });

        })();
    </script>
    }
