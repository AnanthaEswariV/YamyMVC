@model IEnumerable<YamyProject.Core.ViewModel.SalesCenterViewModel>

@{
    ViewData["Title"] = "Sales Center";
}

<div class="container-fluid bg-light p-3 rounded shadow-sm">
    <h3 class="text-center mb-3">Sales Center</h3>

    <!-- Filters -->
    <form method="get" asp-action="Index" class="row g-3 align-items-end mb-3">
        <!-- Customer Dropdown -->
        <div class="col-md-6 col-12">
            <label class="form-label small mb-1">Customer</label>
            <select asp-for="FirstOrDefault().Id" asp-items="@(new SelectList(Model.FirstOrDefault()?.Customers, "Value", "Text"))" class="form-select form-select-sm">
                <option value="">-- Select Customer --</option>
            </select>
        </div>

        <!-- Date Filters -->
        <div class="col-md-3">
            <label class="form-label">From</label>
            <input type="date" name="fromDate" class="form-control form-control-sm" />
        </div>
        <div class="col-md-3">
            <label class="form-label">To</label>
            <input type="date" name="toDate" class="form-control form-control-sm" />
        </div>

        <!-- Checkboxes -->
        <div class="col-md-2 d-flex align-items-center">
            <div class="form-check mt-4">
                <input type="checkbox" name="allDates" class="form-check-input" />
                <label class="form-check-label">All Dates</label>
            </div>
        </div>
        <div class="col-md-2 d-flex align-items-center">
            <div class="form-check mt-4">
                <input type="checkbox" name="allRecords" class="form-check-input" />
                <label class="form-check-label">All Records</label>
            </div>
        </div>

        <div class="col-12 text-end">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    <!-- Grid -->
    <div class="table-responsive mb-3">
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>SN</th>
                    <th>Date</th>
                    <th>JV No</th>
                    <th>INV No</th>
                    <th>Amount</th>
                    <th>VAT</th>
                    <th>Customer</th>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Item VAT</th>
                    <th>Item Total</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int sn = 1;
                    foreach (var sale in Model)
                    {
                        <tr>
                            <td class="text-center">@sn</td>
                            <td>@sale.Date.ToShortDateString()</td>
                            <td>@sale.JvNo</td>
                            <td>@sale.InvoiceId</td>
                            <td>@sale.Total.ToString("C")</td>
                            <td>@sale.Vat.ToString("C")</td>
                            <td>@sale.CustomerName</td>
                            <td>@sale.ItemName</td>
                            <td>@sale.Qty</td>
                            <td>@sale.Price</td>
                            <td>@sale.ItemVat?.ToString("C")</td>
                            <td>@sale.ItemTotal?.ToString("C")</td>
                        </tr>
                        sn++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="12" class="text-center">No records found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer Buttons -->
    <div class="d-flex justify-content-between">
        <div>
            <a asp-action="Create" class="btn btn-primary">New</a>
            <a asp-action="Edit" class="btn btn-secondary">Edit</a>
        </div>
        <div>
            <a asp-action="Delete" class="btn btn-danger">Delete</a>
            <a asp-action="Recycle" class="btn btn-outline-primary">Recycle</a>
        </div>
    </div>
</div>
