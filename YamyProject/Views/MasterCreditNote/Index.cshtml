@model SalesCenterPageViewModel

@{
    var selectedMode = Context.Request.Query["defaultMode"].FirstOrDefault() ?? "";
}
<div class="container-fluid bg-light p-3 rounded shadow-sm">
    <h3 class="text-center mb-3">Sales Center</h3>
        <!-- Filters -->
    <div class="card shadow-sm">
        <div class="card-header align-items-center py-5 gap-2 gap-md-5">
              <div class="card-toolbar text-end">
                <a asp-controller="MasterCreditNote" asp-action="Create" class="btn btn-primary btn-sm">New</a>
            </div>

              <form method="get" asp-action="Index" class="row g-3 align-items-end mb-3">
                  <!-- Customer Dropdown -->
                  <div class="col-md-4 col-4">
                      <label class="form-label small mb-1">Customer</label>
                          <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select form-select-sm">
                              <option value="All">-- Select Customer --</option>
                          </select>
                  </div>
                  <!-- Date Filters -->
                  <div class="col-md-3">
                     <label class="form-label">From</label>
                    <input type="date" value="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" name="fromDate" class="form-control form-control-sm" />
                  </div>
                  <div class="col-md-3">
                      <label class="form-label">To</label>
                    <input type="date" value="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" name="toDate" class="form-control form-control-sm" />
                  </div>
                  <!-- Checkboxes -->
                  <div class="col-md-2 d-flex align-items-center">
                      <div class="form-check mt-4">
                          <input type="checkbox" name="allDates" class="form-check-input" />
                          <label class="form-check-label">All Dates</label>
                      </div>
                  </div>
                  <div class="col-md-3">
                        <label class="form-label"> Selection Method</label>
                    <select id="defaultMode" name="defaultMode" class="form-select">
                        <option value="Default" selected="@(selectedMode == "Default" ? "selected" : null)">Default</option>
                        <option value="ItemWise" selected="@(selectedMode == "ItemWise" ? "selected" : null)">Item Wise</option>
                    </select>
                  </div>
                  <div class="col-md-3">
                        <label class="form-label"> Invoice Type</label>
                        <select class="form-select" aria-label="Select Payment Method">
                            <option value="Cash">Cash</option>
                            <option value="Credit">Credit</option>
                        </select>
                  </div>
                  <div class="col-md-2 d-flex align-items-center">
                      <div class="form-check mt-4">
                          <input type="checkbox" name="allRecords" class="form-check-input" />
                          <label class="form-check-label">All Records</label>
                      </div>
                  </div>

              </form>
        </div>
        <!-- Grid -->
        <div class="card-body pt-0">
            <div class="table-responsive mb-3">
                <table class="table table-bordered table-striped align-middle">
                    <thead class="table-secondary text-center">
                        <tr>
                            <th>SN</th>
                            <th>Date</th>
                              @if (selectedMode != "ItemWise")
                              { 
                            <th>JV No</th>
                              }
                            <th>INV No</th>
                            <th>Amount</th>
                            <th>VAT</th>
                            <th>Customer</th>
                            @if (selectedMode == "ItemWise")
                              { 
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Item VAT</th>
                            <th>Item Total</th>
                              }
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Sales.Any())
                        {
                            int sn = 1;
                            foreach (var sale in Model.Sales)
                            {
                                <tr>
                                    <td class="text-center">@sn</td>
                                    <td>@sale.Date.ToShortDateString()</td>
                                     @if (selectedMode != "ItemWise")
                                     {
                                        <td>@sale.JvNo</td>
                                     }
                                    <td>@sale.InvoiceId</td>
                                    <td>@sale.Total.ToString("C")</td>
                                    <td>@sale.Vat.ToString("C")</td>
                                    <td>@sale.CustomerName</td>
                                     @if (selectedMode == "ItemWise")
                                     {
                                        <td>@sale.ItemName</td>
                                        <td>@sale.Qty</td>
                                        <td>@sale.Price</td>
                                        <td>@sale.ItemVat?.ToString("C")</td>
                                        <td>@sale.ItemTotal?.ToString("C")</td>
                                     }
                                     <td>
                                    <a class="menu-link px-3 js-render-modal" asp-controller="MasterCreditNote" asp-action="Edit" asp-route-id="@sale.Id">Edit</a>
                                     </td>
                                </tr>
                                sn++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="12" class="text-center">No records found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>        
    </div>
</div>