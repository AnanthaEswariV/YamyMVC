@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

<style>
    :root {
        --pos-bg: #eef2f6;
        --pos-panel: #ffffff;
        --pos-ink: #1f2a37;
        --pos-muted: #6b7280;
        --pos-line: #e6e9ee;
        --pos-accent: #e8761a;
        --pos-accent-dark: #c75f0f;
        --pos-go: #1c8a4e;
    }

    .pos-wrap {
        background: var(--pos-bg);
        border-radius: 16px;
        padding: 14px;
    }

    .pos-panel {
        background: var(--pos-panel);
        border: 1px solid var(--pos-line);
        border-radius: 14px;
    }

    .pos-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px;
        border-bottom: 1px solid var(--pos-line);
        font-weight: 700;
        color: var(--pos-ink);
    }

    .pos-search {
        position: relative;
    }

        .pos-search input {
            padding-left: 38px;
            border-radius: 10px;
            border: 1px solid var(--pos-line);
            height: 44px;
        }

        .pos-search .fa-search {
            position: absolute;
            left: 14px;
            top: 14px;
            color: var(--pos-muted);
        }

    #menuContainer {
        max-height: 74vh;
        overflow-y: auto;
    }

    .pos-product {
        cursor: pointer;
        background: #fff;
        border: 1px solid var(--pos-line);
        border-radius: 12px;
        overflow: hidden;
        height: 100%;
        transition: transform .12s, box-shadow .12s, border-color .12s;
    }

        .pos-product:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 24px rgba(2,6,23,.12);
            border-color: var(--pos-accent);
        }

        .pos-product img {
            width: 100%;
            height: 110px;
            object-fit: cover;
            display: block;
        }

        .pos-product .p-body {
            padding: 9px 11px;
        }

        .pos-product .p-name {
            font-weight: 600;
            color: var(--pos-ink);
            font-size: .9rem;
            line-height: 1.2;
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 2.1em;
        }

        .pos-product .p-price {
            color: var(--pos-accent-dark);
            font-weight: 800;
            font-size: .9rem;
        }

    .pos-ticket {
        position: sticky;
        top: 12px;
    }

    .pos-type .btn {
        font-weight: 600;
    }

    #cartBody {
        max-height: 30vh;
        overflow-y: auto;
        padding: 6px 4px;
    }

    .pos-empty {
        text-align: center;
        color: var(--pos-muted);
        padding: 24px 12px;
        font-size: .92rem;
    }

    .pos-line {
        display: grid;
        grid-template-columns: 1fr auto auto auto;
        align-items: center;
        gap: 10px;
        padding: 10px 8px;
        border-bottom: 1px dashed var(--pos-line);
        cursor: pointer;
        border-radius: 8px;
    }

        .pos-line:last-child {
            border-bottom: 0;
        }

        .pos-line.selected {
            background: #fff5ec;
            box-shadow: inset 0 0 0 2px var(--pos-accent);
        }

    .pos-line-name {
        font-weight: 600;
        color: var(--pos-ink);
    }

    .pos-line-price {
        font-size: .78rem;
        color: var(--pos-muted);
    }

    .pos-line-total {
        font-weight: 700;
        color: var(--pos-ink);
        min-width: 80px;
        text-align: right;
    }

    .pos-line-remove {
        border: 0;
        background: transparent;
        color: #c0392b;
        width: 28px;
        height: 28px;
        border-radius: 8px;
    }

        .pos-line-remove:hover {
            background: #fdecea;
        }

    .qty-stepper {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--pos-line);
        border-radius: 10px;
    }

        .qty-stepper button {
            width: 28px;
            height: 28px;
            border: 0;
            background: #f5f7fa;
            color: var(--pos-ink);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .qty-stepper button:first-child {
                border-radius: 10px 0 0 10px;
            }

            .qty-stepper button:last-child {
                border-radius: 0 10px 10px 0;
            }

            .qty-stepper button:hover {
                background: #e9edf3;
            }

        .qty-stepper span {
            min-width: 30px;
            text-align: center;
            font-weight: 700;
        }

    #ticketMeta {
        padding: 0 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .pos-chip {
        background: #eef2f6;
        color: var(--pos-ink);
        border-radius: 999px;
        padding: 3px 10px;
        font-size: .76rem;
        font-weight: 600;
    }

    .pos-totals {
        padding: 12px 16px;
        border-top: 1px solid var(--pos-line);
    }

        .pos-totals .t-row {
            display: flex;
            justify-content: space-between;
            font-size: .9rem;
            color: var(--pos-muted);
            margin-bottom: 6px;
        }

    .pos-grand {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--pos-accent-dark);
    }

    /* ---------- Action button grid ---------- */
    .pos-actions {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 8px;
        padding: 10px 12px;
        border-top: 1px solid var(--pos-line);
    }

    .pos-act {
        border: 1px solid var(--pos-line);
        background: #fff;
        border-radius: 10px;
        padding: 9px 4px;
        font-size: .78rem;
        font-weight: 600;
        color: var(--pos-ink);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        cursor: pointer;
    }

        .pos-act i {
            font-size: 1rem;
            color: var(--pos-muted);
        }

        .pos-act:hover {
            border-color: var(--pos-accent);
        }

        .pos-act.soon {
            opacity: .55;
        }

    /* ---------- Numpad ---------- */
    .pos-numpad {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 8px;
        padding: 4px 12px 12px;
    }

    .pos-key {
        border: 1px solid var(--pos-line);
        background: #fff;
        border-radius: 10px;
        padding: 12px 0;
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--pos-ink);
        cursor: pointer;
    }

        .pos-key:hover {
            background: #f5f7fa;
        }

        .pos-key.mode {
            background: #f1f5f9;
            color: var(--pos-muted);
            font-size: .82rem;
        }

            .pos-key.mode.active {
                background: var(--pos-accent);
                color: #fff;
                border-color: var(--pos-accent);
            }

    .pos-save {
        background: var(--pos-go);
        border: 0;
        color: #fff;
        font-weight: 700;
        height: 50px;
        border-radius: 12px;
        width: 100%;
    }

        .pos-save:hover {
            filter: brightness(1.05);
        }

    @@media (max-width: 991.98px) {
        .pos-ticket {
            position: static;
        }

        #menuContainer {
            max-height: none;
        }
    }
</style>

<div class="container-fluid mt-3">
    <div class="pos-wrap">
        <div class="row g-3">

            <!-- ================= PRODUCT AREA ================= -->
            <div class="col-lg-8">
                <div class="pos-panel">
                    <div class="pos-panel-head">
                        <span><i class="fas fa-utensils me-2" style="color:var(--pos-accent)"></i> Menu</span>
                        <div class="pos-search" style="width:260px; max-width:50%;">
                            <i class="fas fa-search"></i>
                            <input type="text" class="form-control" id="productSearch" placeholder="Search items…">
                        </div>
                    </div>
                    <div class="p-3">
                        <div class="row g-3" id="menuContainer"></div>
                    </div>
                </div>
            </div>

            <!-- ================= ORDER TICKET ================= -->
            <div class="col-lg-4">
                <div class="pos-panel pos-ticket">
                    <div class="pos-panel-head">
                        <span>
                            <i class="fas fa-receipt me-2" style="color:var(--pos-accent)"></i> Current Order
                            <span class="badge rounded-pill bg-secondary ms-1" id="ticketCount">0</span>
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" id="clearCartBtn" title="Clear order">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>

                    <div class="p-3 pb-2">
                        <div class="btn-group w-100 pos-type mb-3" role="group">
                            <input type="radio" class="btn-check" name="orderType" id="orderTypeDineIn" value="DineIn" checked>
                            <label class="btn btn-outline-primary w-50" for="orderTypeDineIn"><i class="fas fa-utensils"></i> Dine In</label>
                            <input type="radio" class="btn-check" name="orderType" id="orderTypeTakeaway" value="TakeAway">
                            <label class="btn btn-outline-warning w-50" for="orderTypeTakeaway"><i class="fas fa-box"></i> Takeaway</label>
                        </div>

                        <div class="mb-3" id="tableSection">
                            <label class="form-label fw-semibold">Table</label>
                            <select class="form-select" id="tableId"></select>
                        </div>

                        <div class="mb-1">
                            <label class="form-label fw-semibold">Customer</label>
                            <select class="form-select mb-2" id="customerId"><option value="">Walk-In Customer</option></select>
                            <input type="text" class="form-control mb-2" id="customerName" placeholder="Customer name">
                            <input type="text" class="form-control" id="customerMobile" placeholder="Mobile number">
                        </div>
                    </div>

                    <div id="cartBody"></div>
                    <div id="ticketMeta"></div>

                    <!-- Totals -->
                    <div class="pos-totals">
                        <div class="t-row"><span>Subtotal</span><span>AED <span id="subtotalView">0.00</span></span></div>
                        <div class="t-row" id="discountRow" style="display:none;">
                            <span>Discount (<span id="discountPctView">0</span>%)</span>
                            <span>- AED <span id="discountView">0.00</span></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-semibold">Grand Total</span>
                            <span class="pos-grand">AED <span id="grandTotal">0.00</span></span>
                        </div>
                    </div>

                    <!-- Action buttons (Odoo-style) -->
                    <div class="pos-actions">
                        <div class="pos-act" onclick="setNumMode('disc')"><i class="fas fa-percent"></i> Discount</div>
                        <div class="pos-act" onclick="printBill()"><i class="fas fa-file-invoice"></i> Bill</div>
                        <div class="pos-act soon" onclick="featureSoon('Refund')"><i class="fas fa-undo"></i> Refund</div>
                        <div class="pos-act soon" onclick="featureSoon('Split')"><i class="fas fa-columns"></i> Split</div>
                        <div class="pos-act soon" onclick="featureSoon('Transfer')"><i class="fas fa-exchange-alt"></i> Transfer</div>
                    </div>

                    <!-- Numpad -->
                    <div class="pos-numpad">
                        <div class="pos-key" onclick="numKey('1')">1</div>
                        <div class="pos-key" onclick="numKey('2')">2</div>
                        <div class="pos-key" onclick="numKey('3')">3</div>
                        <div class="pos-key mode active" data-mode="qty" onclick="setNumMode('qty')">Qty</div>

                        <div class="pos-key" onclick="numKey('4')">4</div>
                        <div class="pos-key" onclick="numKey('5')">5</div>
                        <div class="pos-key" onclick="numKey('6')">6</div>
                        <div class="pos-key mode" data-mode="disc" onclick="setNumMode('disc')">% Disc</div>

                        <div class="pos-key" onclick="numKey('7')">7</div>
                        <div class="pos-key" onclick="numKey('8')">8</div>
                        <div class="pos-key" onclick="numKey('9')">9</div>
                        <div class="pos-key mode" data-mode="price" onclick="setNumMode('price')">Price</div>

                        <div class="pos-key" onclick="numKey('sign')">+/-</div>
                        <div class="pos-key" onclick="numKey('0')">0</div>
                        <div class="pos-key" onclick="numKey('.')">.</div>
                        <div class="pos-key" onclick="numKey('back')"><i class="fas fa-backspace"></i></div>
                    </div>

                    <div class="px-3 pb-3">
                        <button class="pos-save" id="saveOrderBtn"><i class="fas fa-check-circle me-1"></i> Order</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= ORDER MANAGEMENT ================= -->
    <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Order Management</strong>
            <button class="btn btn-sm btn-info" id="refreshOrdersBtn"><i class="fas fa-sync"></i> Refresh</button>
        </div>
        <div class="card-body">
            <table class="table table-striped align-middle" id="ordersTable">
                <thead>
                    <tr>
                        <th>Order No</th>
                        <th>Type</th>
                        <th>Customer</th>
                        <th>Table</th>
                       @*  <th>Items</th> *@
                        <th>Amount</th>
                        <th>Order Status</th>
                        <th width="120">Payment Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="ordersTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ORDER DETAILS MODAL -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Order Details - <span id="modalOrderNo"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Order Number</strong></label>
                        <input type="text" class="form-control" id="editOrderNo" readonly>
                        <input type="hidden" id="editOrderId">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Order Type</strong></label>
                        <input type="text" class="form-control" id="editOrderType" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Customer Name</strong></label>
                        <input type="text" class="form-control" id="editCustomerName">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Customer Mobile</strong></label>
                        <input type="text" class="form-control" id="editCustomerMobile">
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Table</strong></label>
                        <input type="text" class="form-control" id="editTableName" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Order Status</strong></label>
                        <select class="form-select" id="editOrderStatus">
                            <option value="Running">Running</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Payment Status</strong></label>
                        <select class="form-select" id="editPaymentStatus">
                            <option value="Pending">Pending</option>
                            <option value="Paid">Paid</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Total Amount</strong></label>
                        <input type="text" class="form-control" id="editTotalAmount" readonly>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Order Items</strong></label>
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr><th>Item</th><th width="80">Price</th><th width="80">Qty</th><th width="100">Total</th></tr>
                        </thead>
                        <tbody id="editOrderItems"></tbody>
                    </table>
                </div>
                <div class="row">
                    <div class="col-md-6 offset-md-6">
                        <div class="card">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between mb-2"><span>Subtotal:</span><strong id="editSubtotal">0.00</strong></div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Discount (AED):</span>
                                    <input type="number" class="form-control form-control-sm" id="editDiscount" value="0" step="0.01" style="width:120px;">
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Tax (AED):</span>
                                    <input type="number" class="form-control form-control-sm" id="editTax" value="0" step="0.01" style="width:120px;">
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between">
                                    <strong>Grand Total:</strong>
                                    <h5 class="mb-0"><strong id="editGrandTotal" class="text-primary">0.00</strong></h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger" onclick="deleteOrderFromModal()"><i class="fas fa-trash"></i> Delete Order</button>
                <button type="button" class="btn btn-primary" onclick="saveOrderChanges()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- TRANSFER TABLE MODAL -->
<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Transfer Table</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="transferOrderId">
                <label class="form-label fw-semibold">Move order to</label>
                <select class="form-select" id="transferTableId"></select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="confirmTransfer()">Transfer</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        let cart = [];
        let selectedLine = null;
        let numBuffer = '';
        let numMode = 'qty';        // 'qty' | 'price' | 'disc'
        let orderDiscountPct = 0;
        let orderNote = '';
        let kitchenNote = '';
        let guestCount = 0;

        window.GET_ORDER_DETAILS_URL = '@Url.Action("GetOrderDetails", "Home")';

        // ==================== LOAD DATA ====================
        function loadTables() {
            $.get('@Url.Action("GetAvailableTables", "Home")', function (res) {
                if (res.status) {
                    let html = `<option value="">Select Table</option>`;
                    $.each(res.data, function (i, item) { html += `<option value="${item.id}">${item.tableName}</option>`; });
                    $("#tableId").html(html);
                } else { toastr.error("Failed to load tables"); }
            }).fail(function () { toastr.error("Error loading tables"); });
        }

        function loadMenuItems() {
            $.get('@Url.Action("GetOrderMenuItems", "Home")', function (res) {
                if (!res.status) { toastr.error("Failed to load menu items"); return; }
                let html = "";
                $.each(res.data, function (i, item) {
                    let imageUrl = item.image ? `/uploads/menu/${item.image}` : `/images/no-image.png`;
                    let safeName = (item.name || '').replace(/"/g, '&quot;');
                    html += `
                    <div class="col-6 col-md-4 col-xl-3 pos-product-col" data-name="${safeName}">
                        <div class="pos-product menu-card" data-id="${item.id}" data-name="${safeName}" data-price="${item.price}">
                            <img src="${imageUrl}" alt="${safeName}">
                            <div class="p-body">
                                <div class="p-name">${item.name}</div>
                                <div class="p-price">AED ${parseFloat(item.price).toFixed(2)}</div>
                            </div>
                        </div>
                    </div>`;
                });
                $("#menuContainer").html(html);
            }).fail(function () { toastr.error("Error loading menu items"); });
        }

        function loadCustomers() {
            return $.ajax({
                url: '@Url.Action("GetOrderCustomers", "Home")', type: 'GET',
                success: function (res) {
                    if (!res.status) { toastr.error(res.message); return; }
                    let html = `<option value="">Walk-In Customer</option>`;
                    $.each(res.data, function (i, item) {
                        html += `<option value="${item.id}" data-name="${item.name || ''}" data-mobile="${item.mobile || ''}">${item.name || ''} ${item.mobile ? '(' + item.mobile + ')' : ''}</option>`;
                    });
                    $("#customerId").html(html);
                },
                error: function () { toastr.error("Failed to load customers"); }
            });
        }

        function loadOrders() {
            $.get('@Url.Action("GetOrders", "Home")', function (res) {
                if (!res.status) { toastr.error("Failed to load orders"); return; }
                let html = "";
                $.each(res.data, function (i, order) {
                    let itemCount = order.items ? order.items.length : 0;
                    let statusBadge = `<span class="badge bg-${getStatusColor(order.orderStatus)}">${order.orderStatus}</span>`;
                    let paymentBadge = `<span class="badge bg-${getPaymentColor(order.paymentStatus)}">${order.paymentStatus}</span>`;
                    let typeBadge = order.orderType === 'DineIn'
                        ? `<span class="badge bg-primary"><i class="fas fa-utensils"></i> Dine In</span>`
                        : `<span class="badge bg-warning text-dark"><i class="fas fa-box"></i> Takeaway</span>`;
                    html += `
                    <tr>
                        <td><strong>${order.orderNo}</strong></td>
                        <td>${typeBadge}</td>
                        <td>${order.customerName || 'Walk-In'}</td>
                        <td>${order.tableName || 'N/A'}</td>
                        <td>AED ${parseFloat(order.grandTotal).toFixed(2)}</td>
                        <td>${statusBadge}</td>
                        <td>${paymentBadge}</td>
                        <td>
                            <button class="btn btn-sm btn-success" onclick="printInvoice(${order.id})" title="Print Invoice"><i class="fas fa-print"></i></button>
                            <button class="btn btn-sm btn-info" onclick="viewOrder(${order.id})" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-sm btn-danger" onclick="deleteOrderFromTable(${order.id})" title="Delete Order"><i class="fas fa-trash"></i></button>
                                    <button class="btn btn-sm btn-secondary" onclick="openTransfer(${order.id}, '${order.orderType}', '${order.orderStatus}')" title="Transfer Table">
            <i class="fas fa-exchange-alt"></i>
        </button>
                        </td>
                    </tr>`;
                });
                $("#ordersTableBody").html(html);
            }).fail(function () { toastr.error("Error loading orders"); });
        }

        function getStatusColor(s) { switch (s) { case 'Running': return 'warning'; case 'Completed': return 'success'; case 'Cancelled': return 'danger'; default: return 'secondary'; } }
        function getPaymentColor(s) { switch (s) { case 'Paid': return 'success'; case 'Pending': return 'warning'; default: return 'secondary'; } }

        // ==================== PRODUCT SEARCH ====================
        $(document).on('input', '#productSearch', function () {
            let q = $(this).val().toLowerCase().trim();
            $('#menuContainer .pos-product-col').each(function () {
                let name = ($(this).data('name') || '').toString().toLowerCase();
                $(this).toggle(name.indexOf(q) !== -1);
            });
        });

        // ==================== CART ====================
        $(document).on("click", ".menu-card", function () {
            addToCart({ id: $(this).data("id"), name: $(this).data("name"), price: parseFloat($(this).data("price")) });
        });

        function addToCart(item) {
            let idx = cart.findIndex(x => x.menuItemId == item.id);
            if (idx >= 0) {
                cart[idx].qty += 1;
                cart[idx].amount = cart[idx].qty * cart[idx].price;
                selectedLine = idx;
            } else {
                cart.push({ menuItemId: item.id, itemName: item.name, price: parseFloat(item.price), qty: 1, amount: parseFloat(item.price) });
                selectedLine = cart.length - 1;
            }
            numBuffer = ''; numMode = 'qty'; updateNumModeUI();
            renderCart();
        }

        function selectLine(i) {
            selectedLine = i; numBuffer = ''; numMode = 'qty'; updateNumModeUI();
            renderCart();
        }

        function renderCart() {
            let subtotal = 0;
            if (cart.length === 0) {
                $("#cartBody").html(`<div class="pos-empty">No items yet — tap a product to start the order.</div>`);
                selectedLine = null;
            } else {
                let html = "";
                $.each(cart, function (i, item) {
                    subtotal += item.amount;
                    let sel = (i === selectedLine) ? ' selected' : '';
                    html += `
                    <div class="pos-line${sel}" data-index="${i}" onclick="selectLine(${i})">
                        <div>
                            <div class="pos-line-name">${item.itemName}</div>
                            <div class="pos-line-price">AED ${item.price.toFixed(2)} each</div>
                        </div>
                        <div class="qty-stepper">
                            <button type="button" onclick="event.stopPropagation(); updateQty(${i}, ${item.qty - 1})"><i class="fas fa-minus"></i></button>
                            <span>${item.qty}</span>
                            <button type="button" onclick="event.stopPropagation(); updateQty(${i}, ${item.qty + 1})"><i class="fas fa-plus"></i></button>
                        </div>
                        <div class="pos-line-total">AED ${item.amount.toFixed(2)}</div>
                        <button type="button" class="pos-line-remove" onclick="event.stopPropagation(); removeFromCart(${i})"><i class="fas fa-times"></i></button>
                    </div>`;
                });
                $("#cartBody").html(html);
            }

            let discount = subtotal * (orderDiscountPct / 100);
            let grand = subtotal - discount;

            $("#ticketCount").text(cart.length);
            $("#subtotalView").text(subtotal.toFixed(2));
            if (orderDiscountPct > 0) {
                $("#discountRow").show();
                $("#discountPctView").text(orderDiscountPct);
                $("#discountView").text(discount.toFixed(2));
            } else {
                $("#discountRow").hide();
            }
            $("#grandTotal").text(grand.toFixed(2));
        }

        function updateQty(index, qty) {
            qty = parseInt(qty);
            if (isNaN(qty) || qty <= 0) { removeFromCart(index); return; }
            cart[index].qty = qty;
            cart[index].amount = qty * cart[index].price;
            renderCart();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            if (selectedLine === index) selectedLine = null;
            else if (selectedLine !== null && index < selectedLine) selectedLine--;
            renderCart();
        }

        $("#clearCartBtn").click(function () {
            if (cart.length === 0 && orderDiscountPct === 0 && !orderNote && !kitchenNote && !guestCount) return;
            resetTicket();
        });

        function resetTicket() {
            cart = []; selectedLine = null; numBuffer = ''; numMode = 'qty';
            orderDiscountPct = 0; orderNote = ''; kitchenNote = ''; guestCount = 0;
            updateNumModeUI(); renderNotes(); renderCart();
        }

        // ==================== NUMPAD ====================
        function setNumMode(mode) {
            numMode = mode; numBuffer = ''; updateNumModeUI();
            if (mode !== 'disc' && selectedLine === null) {
                toastr.info('Select an item first, then type the ' + (mode === 'price' ? 'price' : 'quantity'));
            }
        }
        function updateNumModeUI() {
            $('.pos-key.mode').removeClass('active');
            $('.pos-key.mode[data-mode="' + numMode + '"]').addClass('active');
        }
        function numKey(ch) {
            if (ch === 'back') { numBuffer = numBuffer.slice(0, -1); }
            else if (ch === 'sign') { numBuffer = ''; }
            else if (ch === '.') { if (numBuffer.indexOf('.') === -1) numBuffer = (numBuffer || '0') + '.'; }
            else { numBuffer += ch; }
            applyNumpad();
        }
        function applyNumpad() {
            if (numMode === 'disc') {
                let pct = parseFloat(numBuffer) || 0;
                if (pct > 100) pct = 100;
                orderDiscountPct = pct;
                renderCart();
                return;
            }
            if (selectedLine === null || !cart[selectedLine]) return;
            let val = parseFloat(numBuffer);
            if (numMode === 'qty') {
                let q = parseInt(numBuffer);
                if (!isNaN(q) && q > 0) { cart[selectedLine].qty = q; cart[selectedLine].amount = q * cart[selectedLine].price; }
            } else if (numMode === 'price') {
                if (!isNaN(val)) { cart[selectedLine].price = val; cart[selectedLine].amount = cart[selectedLine].qty * val; }
            }
            renderCart();
        }

        // ==================== ACTION BUTTONS ====================
    

        function renderNotes() {
            let html = "";
            if (guestCount > 0) html += `<span class="pos-chip"><i class="fas fa-user-friends"></i> ${guestCount} guests</span>`;
            if (orderNote) html += `<span class="pos-chip"><i class="fas fa-comment-dots"></i> ${orderNote}</span>`;
            if (kitchenNote) html += `<span class="pos-chip"><i class="fas fa-tag"></i> ${kitchenNote}</span>`;
            $("#ticketMeta").html(html);
        }

        function printBill() {
            if (cart.length === 0) { toastr.error("Cart is empty"); return; }
            let subtotal = cart.reduce((s, x) => s + x.amount, 0);
            let discount = subtotal * (orderDiscountPct / 100);
            let grand = subtotal - discount;
            let data = {
                orderType: $("input[name='orderType']:checked").val(),
                tableName: $("#tableId option:selected").text() || 'N/A',
                customerName: $("#customerName").val() || 'Walk-In',
                customerMobile: $("#customerMobile").val() || '',
                guests: guestCount, note: orderNote, kitchenNote: kitchenNote,
                items: cart, subtotal: subtotal, discount: discount, grandTotal: grand
            };
            if (typeof window.printBillData === 'function') window.printBillData(data);
            else toastr.error("Bill printer not loaded");
        }

        // ==================== ORDER TYPE / CUSTOMER ====================
        $("input[name='orderType']").change(function () {
            if ($(this).val() === "DineIn") { $("#tableSection").show(); }
            else { $("#tableSection").hide(); $("#tableId").val(""); }
        });

        $("#customerId").change(function () {
            let s = $(this).find(":selected");
            $("#customerName").val(s.data("name") || "");
            $("#customerMobile").val(s.data("mobile") || "");
        });

        // ==================== SAVE ORDER ====================
        $("#saveOrderBtn").click(async function () {
            try {
                let orderType = $("input[name='orderType']:checked").val();
                if (orderType === "DineIn" && $("#tableId").val() == "") { toastr.error("Please select a table"); return; }
                if (cart.length == 0) { toastr.error("Cart is empty"); return; }

                let customerId = await createCustomerIfNeeded();

                let subtotal = cart.reduce((s, x) => s + x.amount, 0);
                let discount = subtotal * (orderDiscountPct / 100);
                let grand = subtotal - discount;

                let model = {
                    orderType: orderType,
                    tableId: orderType === "DineIn" ? parseInt($("#tableId").val()) : null,
                    customerId: customerId,
                    customerName: $("#customerName").val(),
                    customerMobile: $("#customerMobile").val(),
                    totalAmount: subtotal,
                    discountAmount: discount,
                    taxAmount: 0,
                    grandTotal: grand,
                    items: cart
                };

                $.ajax({
                    url: '@Url.Action("SaveOrder", "Home")', type: 'POST',
                    contentType: 'application/json', data: JSON.stringify(model),
                    success: function (res) {
                        if (res.status) {
                            toastr.success(res.message);
                            resetTicket();
                            $("#customerId").val("");
                            $("#customerName").val("");
                            $("#customerMobile").val("");
                            $("#tableId").val("");
                            $("#orderTypeDineIn").prop("checked", true);
                            $("#tableSection").show();
                            $("#productSearch").val("");
                            $('#menuContainer .pos-product-col').show();
                            loadOrders();
                            loadTables();
                        } else { toastr.error(res.message); }
                    },
                    error: function (xhr) { toastr.error(xhr.responseJSON?.message || "Order save failed"); }
                });
            } catch (e) { toastr.error("Unexpected error: " + e.message); }
        });

        // ==================== CREATE CUSTOMER ====================
        async function createCustomerIfNeeded() {
            let customerId = $("#customerId").val();
            if (customerId && customerId !== "") return parseInt(customerId);
            let customerName = $("#customerName").val().trim();
            let mobile = $("#customerMobile").val().trim();
            if (customerName === "") return 0;
            let customerModel = { Id: 0, Name: customerName, Mobile: mobile, CategoryId: 1, CountryId: 1, Active: true };
            try {
                let response = await $.ajax({ url: '@Url.Action("SaveCustomer", "Home")', type: 'POST', contentType: 'application/json', data: JSON.stringify(customerModel) });
                if (response.status) {
                    toastr.success("Customer added");
                    await loadCustomers();
                    if (response.customerId) { $("#customerId").val(response.customerId); return response.customerId; }
                    return 0;
                } else { toastr.error(response.message); return 0; }
            } catch (xhr) { toastr.error(xhr.responseJSON?.message || "Customer save failed"); return 0; }
        }

        // ==================== ORDER MANAGEMENT MODAL ====================
        let currentOrderId = null;

        function viewOrder(orderId) {
            currentOrderId = orderId;
            $.get('@Url.Action("GetOrderDetails", "Home")?id=' + orderId, function (res) {
                if (res.status) {
                    let order = res.data.order;
                    let items = res.data.items || [];
                    $("#editOrderId").val(order.id);
                    $("#editOrderNo").val(order.orderNo);
                    $("#modalOrderNo").text(order.orderNo);
                    $("#editOrderType").val(order.orderType === 'DineIn' ? 'Dine In' : 'Takeaway');
                    $("#editCustomerName").val(order.customerName || '');
                    $("#editCustomerMobile").val(order.customerMobile || '');
                    $("#editTableName").val(order.tableName || 'N/A');
                    $("#editOrderStatus").val(order.orderStatus);
                    $("#editPaymentStatus").val(order.paymentStatus);
                    togglePaymentBasedStatus();
                    $("#editTotalAmount").val('AED ' + parseFloat(order.grandTotal).toFixed(2));
                    let itemsHtml = ''; let subtotal = 0;
                    $.each(items, function (i, item) {
                        subtotal += parseFloat(item.amount);
                        itemsHtml += `<tr><td>${item.itemName}</td><td>AED ${parseFloat(item.price).toFixed(2)}</td><td>${item.qty}</td><td>AED ${parseFloat(item.amount).toFixed(2)}</td></tr>`;
                    });
                    $("#editOrderItems").html(itemsHtml);
                    $("#editSubtotal").text(subtotal.toFixed(2));
                    $("#editDiscount").val(order.discountAmount || 0);
                    $("#editTax").val(order.taxAmount || 0);
                    updateGrandTotal();
                    new bootstrap.Modal(document.getElementById('orderDetailsModal')).show();
                } else { toastr.error(res.message); }
            }).fail(function () { toastr.error("Failed to load order details"); });
        }

        function togglePaymentBasedStatus() {
            let paymentStatus = $("#editPaymentStatus").val();
            let completedOption = $("#editOrderStatus option[value='Completed']");
            if (paymentStatus === "Paid") { completedOption.prop("disabled", false); }
            else {
                completedOption.prop("disabled", true);
                if ($("#editOrderStatus").val() === "Completed") $("#editOrderStatus").val("Running");
            }
        }
        $("#editPaymentStatus").change(function () { togglePaymentBasedStatus(); });

        function updateGrandTotal() {
            let subtotal = parseFloat($("#editSubtotal").text());
            let discount = parseFloat($("#editDiscount").val()) || 0;
            let tax = parseFloat($("#editTax").val()) || 0;
            $("#editGrandTotal").text((subtotal - discount + tax).toFixed(2));
        }
        $("#editDiscount, #editTax").change(function () { updateGrandTotal(); });

        function deleteOrderFromTable(orderId) {
            if (confirm("Are you sure you want to delete this order?")) {
                $.ajax({
                    url: '@Url.Action("DeleteOrder", "Home")', type: 'POST', contentType: 'application/json',
                    data: JSON.stringify({ orderId: orderId }),
                    success: function (res) { if (res.status) { toastr.success("Order deleted successfully"); loadOrders(); loadTables(); } else { toastr.error(res.message); } },
                    error: function () { toastr.error("Failed to delete order"); }
                });
            }
        }

        function editOrderStatus(orderId, currentStatus) {
            let newStatus = prompt("Update Status (Running/Completed/Cancelled):", currentStatus);
            if (newStatus && newStatus !== currentStatus) {
                $.ajax({
                    url: '@Url.Action("UpdateOrderStatus", "Home")', type: 'POST', contentType: 'application/json',
                    data: JSON.stringify({ orderId: orderId, status: newStatus }),
                    success: function (res) { if (res.status) { toastr.success("Order status updated"); loadOrders(); } else { toastr.error(res.message); } },
                    error: function () { toastr.error("Failed to update status"); }
                });
            }
        }

        function saveOrderChanges() {
            let orderId = $("#editOrderId").val();
            let customerName = $("#editCustomerName").val();
            let customerMobile = $("#editCustomerMobile").val();
            let orderStatus = $("#editOrderStatus").val();
            let paymentStatus = $("#editPaymentStatus").val();
            let discountAmount = parseFloat($("#editDiscount").val()) || 0;
            let taxAmount = parseFloat($("#editTax").val()) || 0;
            let grandTotal = parseFloat($("#editGrandTotal").text()) || 0;

            if (!customerName.trim()) { toastr.error("Please enter customer name"); return; }
            if (orderStatus === "Completed" && paymentStatus !== "Paid") { toastr.error("Order can only be completed after payment is marked as Paid"); return; }

            $.ajax({
                url: '@Url.Action("UpdateOrder", "Home")', type: 'POST', contentType: 'application/json',
                data: JSON.stringify({ orderId, customerName, customerMobile, orderStatus, paymentStatus, discountAmount, taxAmount, grandTotal }),
                success: function (res) {
                    if (res.status) {
                        toastr.success("Order updated successfully");
                        bootstrap.Modal.getInstance(document.getElementById('orderDetailsModal')).hide();
                        loadOrders(); loadTables();
                    } else { toastr.error(res.message); }
                },
                error: function (xhr) { toastr.error(xhr.responseJSON?.message || "Failed to update order"); }
            });
        }

        function deleteOrderFromModal() {
            let orderId = $("#editOrderId").val();
            if (confirm("Are you sure you want to delete this order? This action cannot be undone.")) {
                $.ajax({
                    url: '@Url.Action("DeleteOrder", "Home")', type: 'POST', contentType: 'application/json',
                    data: JSON.stringify({ orderId: orderId }),
                    success: function (res) {
                        if (res.status) {
                            toastr.success("Order deleted successfully");
                            bootstrap.Modal.getInstance(document.getElementById('orderDetailsModal')).hide();
                            loadOrders(); loadTables();
                        } else { toastr.error(res.message); }
                    },
                    error: function () { toastr.error("Failed to delete order"); }
                });
            }
        }

        // ==================== INIT ====================
        $(document).ready(function () {
            loadCustomers();
            loadTables();
            loadMenuItems();
            loadOrders();
            renderCart();
            renderNotes();
            updateNumModeUI();
            setInterval(loadOrders, 30000);
            $("#refreshOrdersBtn").click(function () { loadOrders(); toastr.info("Orders refreshed"); });
        });


                function openTransfer(orderId, orderType, orderStatus) {
            if (orderType !== 'DineIn') { toastr.info("Only dine-in orders can be transferred."); return; }
            if (orderStatus !== 'Running') { toastr.info("Only running orders can be transferred."); return; }

            $("#transferOrderId").val(orderId);

            // load free tables into the picker
            $.get('@Url.Action("GetAvailableTables", "Home")', function (res) {
                if (!res.status) { toastr.error("Failed to load tables"); return; }
                if (!res.data || res.data.length === 0) {
                    toastr.info("No free tables available right now.");
                    return;
                }
                let html = "";
                $.each(res.data, function (i, t) { html += `<option value="${t.id}">${t.tableName}</option>`; });
                $("#transferTableId").html(html);
                new bootstrap.Modal(document.getElementById('transferModal')).show();
            }).fail(function () { toastr.error("Error loading tables"); });
        }

        function confirmTransfer() {
            let orderId = $("#transferOrderId").val();
            let newTableId = $("#transferTableId").val();
            if (!newTableId) { toastr.error("Please pick a table"); return; }

            $.ajax({
                url: '@Url.Action("TransferTable", "Home")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ orderId: parseInt(orderId), newTableId: parseInt(newTableId) }),
                success: function (res) {
                    if (res.status) {
                        toastr.success(res.message);
                        bootstrap.Modal.getInstance(document.getElementById('transferModal')).hide();
                        loadOrders();
                        loadTables();   // refresh the cart dropdown too
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr) { toastr.error(xhr.responseJSON?.message || "Transfer failed"); }
            });
        }
    </script>

    <!-- Invoice + bill logic lives in a static file so Razor never parses the full-HTML templates -->
    <script src="~/js/restoran-invoice.js"></script>
