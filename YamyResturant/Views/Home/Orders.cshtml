
@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>

    .menuItem:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

<div class="container-fluid mt-3">
    <div class="row">
        <!-- LEFT -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    Menu Items
                </div>
                <div class="card-body">
                    <div class="row"
                         id="menuContainer">
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    Order Cart
                </div>
                <div class="card-body">
                    <!-- TABLE -->
                    <div class="mb-3">
                        <label>Select Table</label>

                        <select class="form-select"
                                id="tableId">
                        </select>
                    </div>

                    <!-- CUSTOMER -->
                    <div class="mb-3">

                        <label>Customer Name</label>

                        <input type="text"
                               class="form-control"
                               id="customerName">

                    </div>

                    <!-- CART -->
                    <table class="table table-bordered">

                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qty</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody id="cartBody"></tbody>

                    </table>

                    <!-- TOTAL -->
                    <div class="mt-3">

                        <h5>
                            Grand Total:
                            <span id="grandTotal">
                                0
                            </span>
                        </h5>

                    </div>

                    <button class="btn btn-success w-100 mt-3"
                            id="saveOrderBtn">
                        Save Order
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>


        // LOAD TABLES
        function loadTables() {

            $.get('/Home/GetAvailableTables', function (res) {

                let html =
                    `<option value="">Select Table</option>`;

                $.each(res.data, function (i, item) {

                    html += `
                    <option value="${item.id}">
                        ${item.tableName}
                    </option>`;
                });

                $("#tableId").html(html);
            });
        }


            function loadMenuItems() {

            $.get('/Home/GetOrderMenuItems', function (res) {

                let html = "";

                $.each(res.data, function (i, item) {

                    let imageUrl = item.image
                        ? `/uploads/menu/${item.image}`
                        : `/images/no-image.png`;

                    html += `

                    <div class="col-md-3 mb-4">

                        <div class="card shadow-sm border-0 h-100 menuItem"
                             style="
                                cursor:pointer;
                                border-radius:12px;
                                overflow:hidden;
                                transition:0.3s;
                             "
                             onclick='addToCart(${JSON.stringify(item)})'>

                            <img src="${imageUrl}"
                                 style="
                                    width:100%;
                                    height:180px;
                                    object-fit:cover;
                                 ">

                            <div class="card-body text-center">

                                <h6 class="fw-bold mb-2">
                                    ${item.name}
                                </h6>

                                <h5 class="text-primary fw-bold">
                                    AED ${parseFloat(item.price).toFixed(2)}
                                </h5>

                            </div>

                        </div>

                    </div>`;
                });

                $("#menuContainer").html(html);
            });
        }


        // ADD CART
        function addToCart(item) {

            let existing =
                cart.find(x => x.menuItemId == item.id);

            if (existing) {

                existing.qty += 1;

                existing.amount =
                    existing.qty * existing.price;
            }
            else {

                cart.push({

                    menuItemId: item.id,
                    itemName: item.name,
                    price: parseFloat(item.price),
                    qty: 1,
                    amount: parseFloat(item.price)
                });
            }

            renderCart();
        }


        // RENDER CART
        function renderCart() {

            let html = "";

            let total = 0;

            $.each(cart, function (i, item) {

                total += item.amount;

                html += `
                <tr>

                    <td>${item.itemName}</td>

                    <td>
                        <input type="number"
                               value="${item.qty}"
                               min="1"
                               onchange="updateQty(${i}, this.value)"
                               class="form-control">
                    </td>

                    <td>${item.amount.toFixed(2)}</td>

                </tr>`;
            });

            $("#cartBody").html(html);

            $("#grandTotal").text(total.toFixed(2));
        }


        // UPDATE QTY
        function updateQty(index, qty) {

            qty = parseFloat(qty);

            cart[index].qty = qty;

            cart[index].amount =
                qty * cart[index].price;

            renderCart();
        }


        // SAVE ORDER
        $("#saveOrderBtn").click(function () {

            if (cart.length == 0) {

                toastr.error("Cart is empty");
                return;
            }

            let model = {

                tableId: $("#tableId").val(),

                customerName:
                    $("#customerName").val(),

                totalAmount:
                    parseFloat($("#grandTotal").text()),

                discountAmount: 0,

                taxAmount: 0,

                grandTotal:
                    parseFloat($("#grandTotal").text()),

                items: cart
            };

            $.ajax({

                url: '/Home/SaveOrder',

                type: 'POST',

                contentType: 'application/json',

                data: JSON.stringify(model),

                success: function (res) {

                    if (res.status) {

                        toastr.success(res.message);

                        cart = [];

                        renderCart();
                    }
                    else {
                        toastr.error(res.message);
                    }
                }
            });
        });


        // INIT
        $(document).ready(function () {

            loadTables();

            loadMenuItems();
        });

   </script>
   }
