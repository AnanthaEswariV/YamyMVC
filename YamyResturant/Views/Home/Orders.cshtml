
@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>

    .menuItem:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

<div class="container-fluid mt-3">
    <div class="row">
        <!-- LEFT -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    Menu Items
                </div>
                <div class="card-body">
                    <div class="row"
                         id="menuContainer">
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    Order Cart
                </div>
                <div class="card-body">
                    <!-- TABLE -->
                    <div class="mb-3">
                        <label>Select Table</label>

                        <select class="form-select"
                                id="tableId">
                        </select>
                    </div>
                    <!-- CUSTOMER -->
                    <div class="card mb-3">

                        <div class="card-body">

                            <!-- SELECT CUSTOMER -->
                            <div class="mb-3">

                                <label class="form-label">
                                    Select Customer
                                </label>

                                <select class="form-select"
                                        id="customerId">

                                    <option value="">
                                        Walk-In Customer
                                    </option>

                                </select>

                            </div>

                            <!-- CUSTOMER NAME -->
                            <div class="mb-3">

                                <label class="form-label">
                                    Customer Name
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="customerName"
                                       placeholder="Enter customer name">

                            </div>

                            <!-- MOBILE -->
                            <div class="mb-3">

                                <label class="form-label">
                                    Mobile Number
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="customerMobile"
                                       placeholder="Enter mobile number">

                            </div>

                        </div>

                    </div>
                    <!-- CART -->
                    <table class="table table-bordered">

                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qty</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody id="cartBody"></tbody>

                    </table>

                    <!-- TOTAL -->
                    <div class="mt-3">

                        <h5>
                            Grand Total:
                            <span id="grandTotal">
                                0
                            </span>
                        </h5>

                    </div>

                    <button class="btn btn-success w-100 mt-3"
                            id="saveOrderBtn">
                        Save Order
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>

        let cart = [];

        function loadTables() {
            $.get('@Url.Action("GetAvailableTables", "Home")', function (res) {

                let html =
                    `<option value="">Select Table</option>`;

                $.each(res.data, function (i, item) {

                    html += `
                    <option value="${item.id}">
                        ${item.tableName}
                    </option>`;
                });

                $("#tableId").html(html);
            });
        }

        function loadMenuItems() {

            
            $.get('@Url.Action("GetOrderMenuItems", "Home")', function (res) {

                let html = "";

                $.each(res.data, function (i, item) {

                    let imageUrl = item.image
                        ? `/uploads/menu/${item.image}`
                        : `/images/no-image.png`;

                    html += `

                    <div class="col-md-3 mb-4">

                        <div class="card shadow-sm border-0 h-100 menuItem menu-card"
                             data-id="${item.id}"
                             data-name="${item.name}"
                             data-price="${item.price}"
                             style="
                                cursor:pointer;
                                border-radius:12px;
                                overflow:hidden;
                                transition:0.3s;
                             ">

                            <img src="${imageUrl}"
                                 style="
                                    width:100%;
                                    height:180px;
                                    object-fit:cover;
                                 ">

                            <div class="card-body text-center">

                                <h6 class="fw-bold mb-2">
                                    ${item.name}
                                </h6>

                                <h5 class="text-primary fw-bold">
                                    AED ${parseFloat(item.price).toFixed(2)}
                                </h5>

                            </div>

                        </div>

                    </div>`;
                });

                $("#menuContainer").html(html);
            });
        }

        $(document).on("click", ".menu-card", function () {

            let item = {

                id: $(this).data("id"),

                name: $(this).data("name"),

                price: parseFloat($(this).data("price"))
            };

            addToCart(item);
        });

        function addToCart(item) {

            let existing =
                cart.find(x => x.menuItemId == item.id);

            if (existing) {

                existing.qty += 1;

                existing.amount =
                    existing.qty * existing.price;
            }
            else {

                cart.push({

                    menuItemId: item.id,

                    itemName: item.name,

                    price: parseFloat(item.price),

                    qty: 1,

                    amount: parseFloat(item.price)
                });
            }

            renderCart();
        }

        function renderCart() {

            let html = "";

            let total = 0;

            if (cart.length == 0) {

                html = `
                <tr>
                    <td colspan="3"
                        class="text-center text-muted">
                        No items added
                    </td>
                </tr>`;
            }

            $.each(cart, function (i, item) {

                total += item.amount;

                html += `
                <tr>

                    <td>
                        ${item.itemName}
                    </td>

                    <td width="100">

                        <input type="number"
                               value="${item.qty}"
                               min="1"
                               class="form-control form-control-sm"
                               onchange="updateQty(${i}, this.value)">
                    </td>

                    <td>

                        AED ${item.amount.toFixed(2)}

                    </td>

                </tr>`;
            });

            $("#cartBody").html(html);

            $("#grandTotal").text(
                total.toFixed(2)
            );
        }

        function updateQty(index, qty) {

            qty = parseFloat(qty);

            if (qty <= 0 || isNaN(qty)) {

                qty = 1;
            }

            cart[index].qty = qty;

            cart[index].amount =
                qty * cart[index].price;

            renderCart();
        }

        $("#saveOrderBtn").click(async function () {

            try {

                if ($("#tableId").val() == "") {

                    toastr.error("Please select table");

                    return;
                }

                if (cart.length == 0) {

                    toastr.error("Cart is empty");

                    return;
                }

                // CREATE CUSTOMER
                let customerId =
                    await createCustomerIfNeeded();

                let model = {

                    tableId:
                        parseInt($("#tableId").val()),

                    customerId:
                        customerId,

                    customerName:
                        $("#customerName").val(),

                    customerMobile:
                        $("#customerMobile").val(),

                    totalAmount:
                        parseFloat($("#grandTotal").text()),

                    discountAmount: 0,

                    taxAmount: 0,

                    grandTotal:
                        parseFloat($("#grandTotal").text()),

                    items: cart
                };

                $.ajax({
                   url:  '@Url.Action("SaveOrder", "Home")',

                    type: 'POST',

                    contentType: 'application/json',

                    data: JSON.stringify(model),

                    success: function (res) {

                        if (res.status) {

                            toastr.success(res.message);

                            // RESET
                            cart = [];

                            renderCart();

                            $("#customerId").val("");

                            $("#customerName").val("");

                            $("#customerMobile").val("");

                            $("#tableId").val("");
                        }
                        else {

                            toastr.error(res.message);
                        }
                    },

                    error: function () {

                        toastr.error("Order save failed");
                    }
                });

            }
            catch (e) {

                toastr.error("Unexpected error");
            }
        });

        function loadCustomers() {

            return $.ajax({
                url:  '@Url.Action("GetOrderCustomers", "Home")',

                type: 'GET',

                success: function (res) {

                    if (!res.status) {

                        toastr.error(res.message);

                        return;
                    }

                    let html = `
                    <option value="">
                        Walk-In Customer
                    </option>`;

                    $.each(res.data, function (i, item) {

                        html += `
                        <option
                            value="${item.id}"
                            data-name="${item.name || ''}"
                            data-mobile="${item.mobile || ''}">

                            ${item.name || ''}
                            ${item.mobile ? '(' + item.mobile + ')' : ''}

                        </option>`;
                    });

                    $("#customerId").html(html);
                },

                error: function () {

                    toastr.error("Failed to load customers");
                }
            });
        }

        $("#customerId").change(function () {

            let selected =
                $(this).find(":selected");

            $("#customerName").val(
                selected.data("name") || ""
            );

            $("#customerMobile").val(
                selected.data("mobile") || ""
            );
        });

        async function createCustomerIfNeeded() {

            let customerId = $("#customerId").val();

            // Existing customer selected
            if (customerId && customerId !== "") {

                return parseInt(customerId);
            }

            let customerName =
                $("#customerName").val().trim();

            let mobile =
                $("#customerMobile").val().trim();

            // Walk-in customer only
            if (customerName === "") {

                return 0;
            }

            let customerModel = {

                Id: 0,

                Name: customerName,

                Mobile: mobile,

                CategoryId: 1, // MUST EXIST

                CountryId: 1, // MUST EXIST

                Active: true
            };

            try {

                let response = await $.ajax({
                      url:  '@Url.Action("SaveCustomer", "Customer")',

                    type: 'POST',

                    contentType: 'application/json',

                    data: JSON.stringify(customerModel)
                });

                console.log(response);

                if (response.status) {

                    toastr.success("Customer added");

                    await loadCustomers();

                    // auto select customer
                    if (response.customerId) {

                        $("#customerId")
                            .val(response.customerId);

                        return response.customerId;
                    }

                    return 0;
                }
                else {

                    toastr.error(response.message);

                    return 0;
                }
            }
            catch (xhr) {

                console.log(xhr);

                toastr.error(
                    xhr.responseJSON?.message ||
                    xhr.responseText ||
                    "Customer save failed"
                );

                return 0;
            }
        }

        $(document).ready(function () {

            loadCustomers();

            loadTables();

            loadMenuItems();

            renderCart();
        });

   </script>
   }
