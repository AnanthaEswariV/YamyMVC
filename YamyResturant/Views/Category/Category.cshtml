
@{
    ViewData["Title"] = "Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<!-- ✅ Added container + vertical spacing to match hero section margins -->
<div class="container my-3">
    <div class="card">
        <div class="card-header text-center">
            <strong>Category Management</strong>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <!-- Left side - Filter -->
                <div style="min-width: 300px;">
                </div>

                <!-- Right side - Add Bank Button -->
                <div>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#categoryModal">
                        <i class="bi bi-plus-circle me-2"></i>Add Category
                    </button>
                </div>
            </div>

            <!-- Table -->
            <table class="table table-striped" id="table1">
                <thead>
                    <tr>
                        <th>S.No</th>
                        <th>Code</th>
                        <th>Category</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Rows will be loaded dynamically -->
                </tbody>
            </table>
        </div>
    </div>
</div>
<!-- Add/Edit Category Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <form id="categoryForm" class="needs-validation" novalidate>

            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title w-100 text-center" id="categoryModalLabel">
                        Category Management
                    </h5>

                    <button type="button"
                            class="btn btn-sm btn-outline-light"
                            data-bs-dismiss="modal">
                        ✕
                    </button>
                </div>

                <!-- Body -->
                <div class="modal-body p-4">

                    <!-- Hidden Id -->
                    <input type="hidden" id="categoryId" value="0" />

                    <!-- Category Code -->
                    <div class="mb-3">
                        <label for="categoryCode" class="form-label text-muted">
                            Category Code
                        </label>

                        <input type="text"
                               class="form-control"
                               id="categoryCode"
                               placeholder="Category Code"
                               disabled>
                    </div>

                    <!-- Category Name -->
                    <div class="mb-3">
                        <label for="categoryName" class="form-label text-muted">
                            Category Name
                        </label>

                        <input type="text"
                               class="form-control"
                               id="categoryName"
                               name="CategoryName"
                               placeholder="Enter Category Name"
                               required>
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button type="submit" class="btn btn-primary px-4">
                        Save
                    </button>

                    <button type="button"
                            class="btn btn-outline-primary px-4"
                            data-bs-dismiss="modal">
                        Close
                    </button>

                </div>

            </div>

        </form>
    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/assets/vendors/fontawesome/all.min.css">
    <script src="~/assets/vendors/fontawesome/all.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script>
        // ===== Load Item Categories Table =====
        function loadItemCategories() {

            $.ajax({
                url: '@Url.Action("GetItemCategories", "Category")',
                type: "GET",

                success: function (res) {

                    if (res.status) {

                        // Destroy existing DataTable
                        if ($.fn.DataTable.isDataTable("#table1")) {
                            $("#table1").DataTable().destroy();
                        }

                        let tbody = $("#table1 tbody");
                        tbody.empty();

                        if (res.data && res.data.length > 0) {

                            $.each(res.data, function (i, row) {

                                let rowData = JSON.stringify(row);

                                let tr = `
                                    <tr>
                                        <td>${row.sn}</td>
                                        <td>${row.categoryCode ?? ""}</td>
                                        <td>${row.categoryName ?? ""}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary editCategoryBtn"
                                                    data-category='${rowData}'>
                                                <i class="fas fa-pen"></i>
                                            </button>

                                            <button class="btn btn-sm btn-danger deleteCategoryBtn"
                                                    data-id='${row.id}'>
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>`;

                                tbody.append(tr);
                            });

                            // Initialize DataTable
                            $("#table1").DataTable({
                                dom: 'Bfrtip',
                                buttons: [
                                    {
                                        extend: 'excelHtml5',
                                        className: 'btn btn-primary btn-sm',
                                        text: '<i class="fas fa-file-excel me-1"></i> Excel',
                                        exportOptions: {
                                            columns: ':not(:last-child)'
                                        }
                                    },
                                    {
                                        extend: 'print',
                                        text: '<i class="fas fa-print me-1"></i> Print',
                                        className: 'btn btn-primary btn-sm',
                                        exportOptions: {
                                            columns: ':not(:last-child)'
                                        }
                                    }
                                ],
                                order: [[0, 'asc']],
                                pageLength: 15
                            });

                        } else {

                            tbody.append(`
                                <tr>
                                    <td colspan="4"
                                        class="text-center"
                                        style="padding:40px; color:#6c757d; font-style:italic;">
                                        No records found
                                    </td>
                                </tr>`);

                            $('.dt-buttons').hide();
                        }

                    } else {

                        $("#table1 tbody").html(`
                            <tr>
                                <td colspan="4"
                                    class="text-center"
                                    style="color:red; padding:40px;">
                                    Error: ${res.message || 'Failed to load data'}
                                </td>
                            </tr>`);

                        $('.dt-buttons').hide();
                    }
                },

                error: function (xhr, status, error) {

                    if ($.fn.DataTable.isDataTable("#table1")) {
                        $("#table1").DataTable().destroy();
                    }

                    $("#table1 tbody").html(`
                        <tr>
                            <td colspan="4"
                                class="text-center"
                                style="color:red; padding:40px;">
                                Error loading data: ${error}
                            </td>
                        </tr>`);

                    $('.dt-buttons').hide();
                }
            });
        }

        // ===== Edit Category Button Click =====
        $(document).on("click", ".editCategoryBtn", function () {

            const category = $(this).data("category");

            if (!category) return;

            console.log(category);

            // Set values
            $("#categoryId").val(category.id);
            $("#categoryCode").val(category.categoryCode);
            $("#categoryName").val(category.categoryName);

            // Change modal title
            $("#categoryModalLabel").text("Edit Category");

            // Show modal
            $("#categoryModal").modal("show");
        });



        // ===== Add New Category =====
        $("#btnAddCategory").on("click", function () {

            // Reset form
            $("#categoryForm")[0].reset();

            // Reset hidden fields
            $("#categoryId").val(0);
            $("#categoryCode").val("");

            // Remove validation
            $("#categoryForm").removeClass("was-validated");

            // Modal title
            $("#categoryModalLabel").text("Add Category");

            // Show modal
            $("#categoryModal").modal("show");
        });



        // ===== Submit Category Form =====
        $("#categoryForm").on("submit", function (e) {

            e.preventDefault();

            const form = this;

            // Bootstrap validation
            if (!form.checkValidity()) {

                form.classList.add("was-validated");

                return;
            }

            const idVal = $("#categoryId").val();

            const isEdit =
                idVal && parseInt(idVal) > 0;

            // Create object
            const categoryData = {

                Id: isEdit
                    ? parseInt(idVal)
                    : 0,

                CategoryName:
                    $("#categoryName").val().trim()
            };

            $.ajax({

                url: '@Url.Action("SaveCategory", "Category")',

                type: 'POST',

                contentType: 'application/json',

                data: JSON.stringify(categoryData),

                success: function (res) {

                    if (res.status) {

                        toastr.success(
                            isEdit
                                ? 'Category updated successfully'
                                : 'Category added successfully'
                        );

                        // Close modal
                        $("#categoryModal").modal("hide");

                        // Reload table
                        loadItemCategories();

                        // Reset form
                        $("#categoryForm")[0].reset();

                        $("#categoryId").val(0);

                    } else {

                        toastr.error(res.message);
                    }
                },

                error: function (xhr) {

                    toastr.error(
                        xhr.responseJSON?.message
                        || xhr.statusText
                    );
                }
            });
        });


        // ===== Delete Category =====
        $(document).on("click", ".deleteCategoryBtn", function () {

            const id = $(this).data("id");

            if (!id) return;

            // Confirm delete
            if (!confirm("Are you sure you want to delete this category?")) {
                return;
            }

            $.ajax({

                url: '@Url.Action("DeleteCategory", "Category")',

                type: 'POST',

                data: { id: id },

                success: function (res) {

                    if (res.status) {

                        toastr.success(res.message);

                        // Reload table
                        loadItemCategories();

                    } else {

                        toastr.error(res.message);
                    }
                },

                error: function (xhr) {

                    toastr.error(
                        xhr.responseJSON?.message
                        || xhr.statusText
                    );
                }
            });
        });


        // ===== Page Load =====
        $(document).ready(function () {
            loadItemCategories();
        });
    </script>
    }
    

